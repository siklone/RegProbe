{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hardware DB Document",
  "type": "object",
  "required": ["version", "generatedAtUtc", "items"],
  "properties": {
    "version": { "type": "string" },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "brand", "series", "modelName", "generation", "codename", "releaseYear",
          "architecture", "processNode", "tags", "iconKey", "aliases", "normalizedName"
        ],
        "properties": {
          "id": { "type": "string" },
          "brand": { "type": "string" },
          "series": { "type": "string" },
          "modelName": { "type": "string" },
          "generation": { "type": "string" },
          "codename": { "type": "string" },
          "releaseYear": { "type": "integer" },
          "architecture": { "type": "string" },
          "processNode": { "type": "string" },
          "coreCount": { "type": "integer" },
          "units": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "iconKey": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "normalizedName": { "type": "string" }
        }
      }
    }
  }
}
