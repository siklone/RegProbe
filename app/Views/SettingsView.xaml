<UserControl x:Class="RegProbe.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:RegProbe.App.Services"
             xmlns:views="clr-namespace:RegProbe.App.Views"
             mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             Background="#0D0D0D">

    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="ThemePickerPanel">
            <UniformGrid Columns="5"/>
        </ItemsPanelTemplate>

        <Style x:Key="ThemePickerListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemsPanel" Value="{StaticResource ThemePickerPanel}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="ThemePickerItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="#141414"
                                BorderBrush="#232323"
                                BorderThickness="1"
                                Padding="12,12"
                                MinHeight="72">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#343434"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#211412"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <views:UtilityPageChrome HeaderEyebrow="Utility"
                             HeaderTitle="{Binding Title}"
                             HeaderDescription="Only shell-level preferences live here. This page stays intentionally small and quiet.">
        <views:UtilityPageChrome.BodyContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource UtilityPanelBorderStyle}">
                    <Grid Margin="0,14,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="176"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Theme"
                                       Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                            <TextBlock Text="Palette"
                                       Margin="0,5,0,0"
                                       Style="{StaticResource UtilitySectionTitleTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Margin="0,0,0,10"
                                       Style="{StaticResource UtilitySectionBodyTextStyle}"
                                       Text="Choose the accent palette used across the shell and workspace surfaces."/>

                            <ListBox ItemsSource="{Binding AvailableThemes}"
                                     SelectedItem="{Binding CurrentThemePalette, Mode=TwoWay}"
                                     Style="{StaticResource ThemePickerListStyle}"
                                     ItemContainerStyle="{StaticResource ThemePickerItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type services:ThemePalette}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <WrapPanel HorizontalAlignment="Center"
                                                       Margin="0,0,0,10">
                                                <Border Width="10" Height="10" Margin="0,0,6,0" Background="{Binding AccentPrimary}"/>
                                                <Border Width="10" Height="10" Margin="0,0,6,0" Background="{Binding AccentDark}"/>
                                                <Border Width="10" Height="10" Margin="0,0,6,0" Background="{Binding AccentLight}"/>
                                                <Border Width="10" Height="10" Background="{Binding AccentSecondary}"/>
                                            </WrapPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#EAEAEA"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource UtilitySubtleMonoTextStyle}"
                                       Text="{Binding CurrentThemePalette.Name, StringFormat=Selected palette: {0}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Style="{StaticResource UtilitySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="State"
                                   Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                        <TextBlock Text="Save status"
                                   Margin="0,5,0,0"
                                   Style="{StaticResource UtilitySectionTitleTextStyle}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource UtilitySubtleMonoTextStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </views:UtilityPageChrome.BodyContent>
    </views:UtilityPageChrome>
</UserControl>
