<UserControl x:Class="RegProbe.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:RegProbe.App.Services"
             mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             Background="Transparent">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="ThemePickerPanel">
            <WrapPanel/>
        </ItemsPanelTemplate>

        <Style x:Key="ThemePickerListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemsPanel" Value="{StaticResource ThemePickerPanel}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="ThemePickerItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chip"
                                Padding="12,10"
                                MinWidth="132"
                                Background="{DynamicResource ShellPanelRaisedBrush}"
                                BorderBrush="{DynamicResource ShellHairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ShellPanelAltBrush}"/>
                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource ShellTopNavHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ShellTopNavSelectedBrush}"/>
                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <Grid Margin="24,22,24,24">
            <StackPanel>
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Utility"
                               Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                    <TextBlock Text="{Binding Title}"
                               Margin="0,4,0,0"
                               Style="{StaticResource AppHeroTitleTextStyle}"/>
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource AppHeroSubtitleTextStyle}"
                               Text="Only the palette and startup scan preference live here. Changes save immediately."/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource ShellPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Theme"
                                       Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                            <TextBlock Text="Palette"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource AppSectionTitleTextStyle}"/>
                            <TextBlock Margin="0,6,0,14"
                                       Style="{StaticResource AppSectionSubtitleTextStyle}"
                                       Text="Choose the accent palette used across the shell and configuration surfaces."/>

                            <ListBox ItemsSource="{Binding AvailableThemes}"
                                     SelectedItem="{Binding CurrentThemePalette, Mode=TwoWay}"
                                     Style="{StaticResource ThemePickerListStyle}"
                                     ItemContainerStyle="{StaticResource ThemePickerItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type services:ThemePalette}">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource ShellPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Launch"
                                       Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                            <TextBlock Text="Startup scan"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource AppSectionTitleTextStyle}"/>
                            <TextBlock Margin="0,6,0,14"
                                       Style="{StaticResource AppSectionSubtitleTextStyle}"
                                       Text="Keep the inventory pass on if you want fresh state as soon as the app opens."/>

                            <Border Style="{StaticResource ShellSubtlePanelStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Run startup scan on launch"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="Performs a quick detect pass after the shell loads."/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding RunStartupScanOnLaunch, Mode=TwoWay}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Margin="0,18,0,0"
                        Style="{StaticResource ShellSubtlePanelStyle}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
