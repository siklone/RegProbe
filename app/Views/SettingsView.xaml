<UserControl x:Class="RegProbe.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:RegProbe.App.Services"
             mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             Background="#0D0D0D">

    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="ThemePickerPanel">
            <WrapPanel/>
        </ItemsPanelTemplate>

        <Style x:Key="ThemePickerListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemsPanel" Value="{StaticResource ThemePickerPanel}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="ThemePickerItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="#141414"
                                BorderBrush="#232323"
                                BorderThickness="1"
                                Padding="12,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#343434"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#211412"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionEyebrowTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6E6E6E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#707070"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <Grid Margin="20,18,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,18">
                <TextBlock Text="Utility"
                           Style="{StaticResource SectionEyebrowTextStyle}"/>
                <TextBlock Text="{Binding Title}"
                           Margin="0,4,0,0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource SectionBodyTextStyle}"
                           Text="Only theme and startup scan preferences live here. Changes save as soon as you make them."/>
            </StackPanel>

            <Border Grid.Row="1"
                    BorderBrush="#171717"
                    BorderThickness="0,1,0,1"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,14,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Theme"
                                       Style="{StaticResource SectionEyebrowTextStyle}"/>
                            <TextBlock Text="Palette"
                                       Margin="0,5,0,0"
                                       Style="{StaticResource SectionTitleTextStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Margin="0,0,0,10"
                                       Style="{StaticResource SectionBodyTextStyle}"
                                       Text="Choose the accent palette used across the shell and workspace surfaces."/>

                            <ListBox ItemsSource="{Binding AvailableThemes}"
                                     SelectedItem="{Binding CurrentThemePalette, Mode=TwoWay}"
                                     Style="{StaticResource ThemePickerListStyle}"
                                     ItemContainerStyle="{StaticResource ThemePickerItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type services:ThemePalette}">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#EAEAEA"
                                                   HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            BorderBrush="#171717"
                            BorderThickness="0,1,0,0">
                        <Grid Margin="0,14,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Launch"
                                           Style="{StaticResource SectionEyebrowTextStyle}"/>
                                <TextBlock Text="Startup scan"
                                           Margin="0,5,0,0"
                                           Style="{StaticResource SectionTitleTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="0,0,20,0">
                                <TextBlock Text="Run startup scan on launch"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#F0F0F0"/>
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource SectionBodyTextStyle}"
                                           Text="Performs a quick detect pass after the shell loads so the workspace starts with fresher state."/>
                            </StackPanel>

                            <CheckBox Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding RunStartupScanOnLaunch, Mode=TwoWay}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    BorderBrush="#171717"
                    BorderThickness="0,1,0,0"
                    Padding="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="State"
                               Style="{StaticResource SectionEyebrowTextStyle}"/>
                    <TextBlock Text="Save status"
                               Margin="0,5,0,0"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,10,0,0"
                               Foreground="#7B7B7B"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
