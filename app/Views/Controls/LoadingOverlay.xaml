<UserControl x:Class="RegProbe.App.Views.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="300">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    
    <Grid Background="#7F000000" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
        <Border Background="{DynamicResource BackgroundMediumBrush}" 
                BorderBrush="{DynamicResource AccentColorBrush}"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30,20"
                MaxWidth="400">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.4" ShadowDepth="4"/>
            </Border.Effect>
            
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE76D;" 
                           FontFamily="Segoe MDL2 Assets" 
                           FontSize="32" 
                           Foreground="{DynamicResource AccentBrightCyanBrush}"
                           HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1"
                                                     RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                
                <TextBlock Text="{Binding Message}"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,16,0,0"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
