<UserControl x:Class="RegProbe.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <Grid Margin="24,22,24,24">
            <StackPanel>
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                    <TextBlock Text="RegProbe"
                               Margin="0,4,0,0"
                               Style="{StaticResource AppHeroTitleTextStyle}"/>
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource AppHeroSubtitleTextStyle}"
                               Text="Registry research and tweak workspace with rollback, evidence gating, and policy-backed reference links."/>
                </StackPanel>

                <WrapPanel Margin="0,0,0,10">
                    <Border Style="{StaticResource ShellMetricChipStyle}">
                        <StackPanel>
                            <TextBlock Text="Version"
                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding AppVersion}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ShellMetricChipStyle}">
                        <StackPanel>
                            <TextBlock Text="Build"
                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding BuildConfiguration}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ShellMetricChipStyle}">
                        <StackPanel>
                            <TextBlock Text="Framework"
                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding Framework}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ShellMetricChipStyle}">
                        <StackPanel>
                            <TextBlock Text="Architecture"
                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding Architecture}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ShellMetricChipStyle}">
                        <StackPanel>
                            <TextBlock Text="Log size"
                                       Style="{StaticResource AppMetricLabelTextStyle}"/>
                            <TextBlock Text="{Binding LogFileSizeFormatted}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Style="{StaticResource ShellPanelStyle}"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Repository"
                                   Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                        <TextBlock Text="Canonical source"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource AppSectionTitleTextStyle}"/>
                        <TextBlock Margin="0,6,0,10"
                                   Style="{StaticResource AppSectionSubtitleTextStyle}"
                                   Text="Open the project repository for source, issue context, and implementation history."/>
                        <Button Content="{Binding RepositoryUrl}"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="{Binding RepositoryUrl}"
                                Style="{StaticResource ShellInlineLinkButtonStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ShellPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Logs"
                                   Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                        <TextBlock Text="Runtime trace"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource AppSectionTitleTextStyle}"/>
                        <TextBlock Margin="0,6,0,10"
                                   Style="{StaticResource AppSectionSubtitleTextStyle}"
                                   Text="Open the local tweak log if you need to inspect recent commands, detections, or failures."/>
                        <Button Content="Open tweak log"
                                Command="{Binding OpenLogFileCommand}"
                                Style="{StaticResource ShellInlineLinkButtonStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
