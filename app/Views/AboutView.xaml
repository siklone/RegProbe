<UserControl x:Class="RegProbe.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:RegProbe.App.Views"
             mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             Background="#0D0D0D">

    <views:UtilityPageChrome HeaderEyebrow="Utility"
                             HeaderTitle="{Binding Title}"
                             HeaderDescription="A focused Windows configuration shell with reversible changes, clean logging, and a calmer day-to-day workspace.">
        <views:UtilityPageChrome.BodyContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18"
                        Style="{StaticResource UtilitySectionBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="136"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#111111"
                                BorderBrush="#242424"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,18,0">
                            <Image Source="/RegProbe.App;component/Resources/Brand/regprobe-logo-full.png"
                                   Width="112"
                                   Height="112"
                                   Stretch="Uniform"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="RegProbe"
                                       Style="{StaticResource UtilitySectionTitleTextStyle}"/>
                            <TextBlock Margin="0,6,0,0"
                                       MaxWidth="640"
                                       Style="{StaticResource UtilitySectionBodyTextStyle}"
                                       Text="Evidence-backed Windows configuration work, packaged as a calmer desktop shell and a reproducible research repo."/>

                            <WrapPanel Margin="0,14,0,0">
                                <Border Background="#111111"
                                        BorderBrush="#232323"
                                        BorderThickness="1"
                                        Padding="8,4"
                                        Margin="0,0,8,8">
                                    <TextBlock Text="Reversible"
                                               Foreground="#D6D6D6"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#111111"
                                        BorderBrush="#232323"
                                        BorderThickness="1"
                                        Padding="8,4"
                                        Margin="0,0,8,8">
                                    <TextBlock Text="Logged"
                                               Foreground="#D6D6D6"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#111111"
                                        BorderBrush="#232323"
                                        BorderThickness="1"
                                        Padding="8,4"
                                        Margin="0,0,8,8">
                                    <TextBlock Text="Research-backed"
                                               Foreground="#D6D6D6"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource UtilityPanelBorderStyle}">
                    <Grid Grid.IsSharedSizeScope="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="UtilityMetricLabel"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version"
                                       Style="{StaticResource UtilityMetricLabelTextStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AppVersion}"
                                       Margin="16,0,0,0"
                                       Style="{StaticResource UtilityMetricValueTextStyle}"/>
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource UtilityMetricRowBorderStyle}">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="UtilityMetricLabel"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Build"
                                           Style="{StaticResource UtilityMetricLabelTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BuildConfiguration}"
                                           Margin="16,0,0,0"
                                           Style="{StaticResource UtilityMetricValueTextStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource UtilityMetricRowBorderStyle}">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="UtilityMetricLabel"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Framework"
                                           Style="{StaticResource UtilityMetricLabelTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Framework}"
                                           Margin="16,0,0,0"
                                           Style="{StaticResource UtilityMetricValueTextStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Style="{StaticResource UtilityMetricRowBorderStyle}">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="UtilityMetricLabel"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Architecture"
                                           Style="{StaticResource UtilityMetricLabelTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Architecture}"
                                           Margin="16,0,0,0"
                                           Style="{StaticResource UtilityMetricValueTextStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                Style="{StaticResource UtilityMetricRowBorderStyle}">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="UtilityMetricLabel"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Log size"
                                           Style="{StaticResource UtilityMetricLabelTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LogFileSizeFormatted}"
                                           Margin="16,0,0,0"
                                           Style="{StaticResource UtilityMetricValueTextStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        HorizontalAlignment="Left"
                        MaxWidth="760"
                        Style="{StaticResource UtilitySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Repository"
                                   Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                        <TextBlock Text="Canonical source"
                                   Margin="0,5,0,0"
                                   Style="{StaticResource UtilitySectionTitleTextStyle}"/>
                        <TextBlock Margin="0,6,0,10"
                                   Style="{StaticResource UtilitySectionBodyTextStyle}"
                                   Text="Open the canonical repository for source, release history, and implementation context."/>
                        <TextBlock Text="{Binding RepositoryUrl}"
                                   Margin="0,0,0,10"
                                   Style="{StaticResource UtilitySubtleMonoTextStyle}"/>
                        <Button Content="Open repository"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="{Binding RepositoryUrl}"
                                Style="{StaticResource UtilityInlineLinkButtonStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,18,0,0"
                        HorizontalAlignment="Left"
                        MaxWidth="760"
                        Style="{StaticResource UtilitySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Logs"
                                   Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                        <TextBlock Text="Runtime trace"
                                   Margin="0,5,0,0"
                                   Style="{StaticResource UtilitySectionTitleTextStyle}"/>
                        <TextBlock Margin="0,6,0,10"
                                   Style="{StaticResource UtilitySectionBodyTextStyle}"
                                   Text="Open the local tweak log when you need recent commands, detections, or failure details."/>
                        <TextBlock Text="{Binding LogFileSizeFormatted, StringFormat=Current file size: {0}}"
                                   Margin="0,0,0,10"
                                   Style="{StaticResource UtilitySubtleMonoTextStyle}"/>
                        <Button Content="Open tweak log"
                                Command="{Binding OpenLogFileCommand}"
                                Style="{StaticResource UtilityInlineLinkButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </views:UtilityPageChrome.BodyContent>
    </views:UtilityPageChrome>
</UserControl>
