<UserControl x:Class="RegProbe.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:RegProbe.App.Views"
             mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             Background="#0D0D0D">

    <views:UtilityPageChrome HeaderEyebrow="{Binding Title}"
                             HeaderTitle="RegProbe"
                             HeaderDescription="A focused Windows configuration shell with reversible changes, clean logging, and a calmer day-to-day workspace.">
        <views:UtilityPageChrome.BodyContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="#171717"
                        BorderThickness="0,1,0,1"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version"
                                       Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AppVersion}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#F0F0F0"
                                       FontFamily="{DynamicResource FontFamilyMono}"/>
                        </Grid>

                        <Border Grid.Row="1"
                                BorderBrush="#171717"
                                BorderThickness="0,1,0,0">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Build"
                                           Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BuildConfiguration}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#F0F0F0"
                                           FontFamily="{DynamicResource FontFamilyMono}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                BorderBrush="#171717"
                                BorderThickness="0,1,0,0">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Framework"
                                           Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Framework}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#F0F0F0"
                                           FontFamily="{DynamicResource FontFamilyMono}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                BorderBrush="#171717"
                                BorderThickness="0,1,0,0">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Architecture"
                                           Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Architecture}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#F0F0F0"
                                           FontFamily="{DynamicResource FontFamilyMono}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                BorderBrush="#171717"
                                BorderThickness="0,1,0,0">
                            <Grid Margin="0,12,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Log size"
                                           Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LogFileSizeFormatted}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#F0F0F0"
                                           FontFamily="{DynamicResource FontFamilyMono}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Style="{StaticResource UtilitySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Repository"
                                   Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                        <TextBlock Text="Canonical source"
                                   Margin="0,5,0,0"
                                   Style="{StaticResource UtilitySectionTitleTextStyle}"/>
                        <TextBlock Margin="0,6,0,10"
                                   Style="{StaticResource UtilitySectionBodyTextStyle}"
                                   Text="Open the canonical repository for source, release history, and implementation context."/>
                        <Button Content="{Binding RepositoryUrl}"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="{Binding RepositoryUrl}"
                                Style="{StaticResource UtilityInlineLinkButtonStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Style="{StaticResource UtilitySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Logs"
                                   Style="{StaticResource UtilitySectionEyebrowTextStyle}"/>
                        <TextBlock Text="Runtime trace"
                                   Margin="0,5,0,0"
                                   Style="{StaticResource UtilitySectionTitleTextStyle}"/>
                        <TextBlock Margin="0,6,0,10"
                                   Style="{StaticResource UtilitySectionBodyTextStyle}"
                                   Text="Open the local tweak log when you need recent commands, detections, or failure details."/>
                        <Button Content="Open tweak log"
                                Command="{Binding OpenLogFileCommand}"
                                Style="{StaticResource UtilityInlineLinkButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </views:UtilityPageChrome.BodyContent>
    </views:UtilityPageChrome>
</UserControl>
