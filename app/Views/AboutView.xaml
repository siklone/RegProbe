<UserControl x:Class="RegProbe.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12">
    <UserControl.Resources>
        <Style x:Key="AboutCardStyle" TargetType="Border" BasedOn="{StaticResource AppSurfaceCardStyle}">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalContentAlignment="Stretch"
                  Background="{DynamicResource BackgroundDarkestBrush}">
        <Grid Margin="16,8,16,12"
              HorizontalAlignment="Stretch">
            <StackPanel Margin="0,6,0,8">
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Utility"
                               Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                    <TextBlock Text="RegProbe"
                               Margin="0,3,0,0"
                               Style="{StaticResource AppHeroTitleTextStyle}"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="Registry research and tweak workspace with evidence trails, rollback, and policy mapping."
                               Style="{StaticResource AppHeroSubtitleTextStyle}"/>
                </StackPanel>

                <Border Style="{StaticResource AboutCardStyle}">
                    <UniformGrid Columns="4">
                        <StackPanel>
                            <TextBlock Text="Version" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="SemiBold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Build" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding BuildConfiguration}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="SemiBold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Framework" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding Framework}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="SemiBold" FontSize="16"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Log Size" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding LogFileSizeFormatted}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="SemiBold" FontSize="16"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <Border Style="{StaticResource AboutCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Repository"
                                   Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                        <Button Content="{Binding RepositoryUrl}"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="{Binding RepositoryUrl}"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource AccentBrightCyanBrush}"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AboutCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Logs"
                                   Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                        <Button Content="Open tweak log"
                                Command="{Binding OpenLogFileCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource AccentBrightCyanBrush}"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
