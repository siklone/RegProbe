<UserControl x:Class="RegProbe.App.Views.WorkspaceContentChrome"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#0D0D0D"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RegProbe.App;component/Resources/TweaksWorkspaceResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#171717" BorderThickness="0,0,0,1" Padding="28,24,32,18">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentWorkspaceLabel}" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                    <TextBlock Text="{Binding CurrentWorkspaceDescription}" Margin="0,6,0,0" FontSize="11" Foreground="#787878" TextWrapping="Wrap" MaxWidth="780"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderBrush="#171717" BorderThickness="0,0,0,1" Padding="28,14,32,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         Tag="{Binding SearchPlaceholder}"
                         ToolTip="{Binding SearchPlaceholder}"/>

                <ScrollViewer Grid.Column="2"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              Focusable="False"
                              VerticalAlignment="Center">
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsWorkspaceSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Tag="Favorites" IsChecked="{Binding ShowFavoritesOnly}" Style="{StaticResource ChipStyle}">
                                    <TextBlock>
                                        <Run Text="Favorites"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding FavoritesCount, Mode=OneWay}"/>
                                    </TextBlock>
                                </CheckBox>
                                <CheckBox Tag="Safe" IsChecked="{Binding ShowSafe}" Style="{StaticResource ChipStyle}"><TextBlock Text="Safe"/></CheckBox>
                                <CheckBox Tag="Advanced" IsChecked="{Binding ShowAdvanced}" Style="{StaticResource ChipStyle}"><TextBlock Text="Advanced"/></CheckBox>
                                <CheckBox Tag="Risky" IsChecked="{Binding ShowRisky}" Style="{StaticResource ChipStyle}"><TextBlock Text="Risky"/></CheckBox>
                                <CheckBox Tag="ClassA" IsChecked="{Binding ShowClassA}" Style="{StaticResource ChipStyle}" Visibility="{Binding ShowContributorEvidenceUi, Converter={StaticResource BoolToVisibility}}"><TextBlock Text="Class A"/></CheckBox>
                                <CheckBox Tag="ClassB" IsChecked="{Binding ShowClassB}" Style="{StaticResource ChipStyle}" Visibility="{Binding ShowContributorEvidenceUi, Converter={StaticResource BoolToVisibility}}"><TextBlock Text="Class B"/></CheckBox>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMaintenanceWorkspaceSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Tag="Safe" IsChecked="{Binding ShowSafe}" Style="{StaticResource ChipStyle}"><TextBlock Text="Safe"/></CheckBox>
                                <CheckBox Tag="Advanced" IsChecked="{Binding ShowAdvanced}" Style="{StaticResource ChipStyle}"><TextBlock Text="Advanced"/></CheckBox>
                                <CheckBox Tag="Risky" IsChecked="{Binding ShowRisky}" Style="{StaticResource ChipStyle}"><TextBlock Text="Risky"/></CheckBox>
                                <TextBlock Text="One-off actions"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#525252"
                                           FontSize="10"
                                           FontFamily="{DynamicResource FontFamilyMono}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2" BorderBrush="#171717" BorderThickness="0,0,0,1" Padding="28,12,32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding FilterSummaryLabel}" Style="{StaticResource ToolbarLabelStyle}"/>
                    <TextBlock Text="{Binding FilterSummary}" Margin="0,4,0,0" FontSize="11" Foreground="#707070" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding InventorySummaryLabel}" Style="{StaticResource ToolbarLabelStyle}"/>
                    <TextBlock Text="{Binding InventoryStatusMessage}" Margin="0,4,0,0" FontSize="11" Foreground="#707070" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <ListBox ItemsSource="{Binding ElementName=Root, Path=ItemsSource}"
                     ItemTemplate="{Binding ElementName=Root, Path=ItemTemplate}"
                     ItemContainerStyle="{StaticResource TweakListItemStyle}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasVisibleTweaks}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
            </ListBox>

            <Border Padding="24">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasVisibleTweaks}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding EmptyStateTitle}" FontSize="14" FontWeight="SemiBold" Foreground="#ECECEC" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding EmptyStateDescription}" Margin="0,8,0,0" FontSize="11" Foreground="#666666" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
                    <WrapPanel HorizontalAlignment="Center" Margin="0,14,0,0">
                        <Button Content="{Binding EmptyStateActionText}" Command="{Binding ResetFiltersCommand}" Style="{StaticResource FlatButtonStyle}" MinWidth="128" Margin="0,0,8,0" HorizontalAlignment="Center"/>
                        <Button Content="{Binding ClearCategorySelectionText}" Command="{Binding ClearCategorySelectionCommand}" Style="{StaticResource FlatButtonStyle}" MinWidth="164" Visibility="{Binding CanClearCategorySelection, Converter={StaticResource BoolToVisibility}}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
