<UserControl x:Class="RegProbe.App.Views.WorkspaceShellChrome"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#0D0D0D"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RegProbe.App;component/Resources/TweaksWorkspaceResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#0D0D0D">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#101010" BorderBrush="#171717" BorderThickness="0,0,1,0">
            <Grid Margin="0,26,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,0,20,16">
                    <TextBlock Text="{Binding WorkspaceCategoryHeader}" Style="{StaticResource SectionEyebrowStyle}" FontSize="12"/>
                    <TextBlock Text="{Binding WorkspaceCategoryHint}" Margin="0,6,0,0" FontSize="12" Foreground="#666666" TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Row="1"
                        Margin="0,0,0,2"
                        Command="{Binding ClearCategorySelectionCommand}"
                        Tag="{Binding IsAllCategoriesSelected}"
                        Style="{StaticResource SidebarButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding AllItemsLabel}" FontSize="13" Foreground="#B9B9B9"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentWorkspaceItemCount}"
                                   FontSize="12"
                                   Foreground="#5F5F5F"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Button>

                <ListBox Grid.Row="2"
                         Margin="0,6,0,0"
                         ItemsSource="{Binding CategoryGroups}"
                         SelectedValuePath="CategoryName"
                         SelectedValue="{Binding SelectedCategoryName, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource SidebarItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="42"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding CategoryName}" FontSize="13"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CountBadge}"
                                           FontSize="12"
                                           Foreground="#5F5F5F"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <ContentPresenter Grid.Column="1"
                          Content="{Binding ElementName=Root, Path=ShellContent}"/>
    </Grid>
</UserControl>
