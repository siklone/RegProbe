<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:viewModels="clr-namespace:RegProbe.App.ViewModels">
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <Style x:Key="SectionEyebrowStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}"/>
        <Setter Property="Foreground" Value="#6F6F6F"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#7C7C7C"/>
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#D6D6D6"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,8,12,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0"
                            CornerRadius="0">
                        <Grid>
                            <Border x:Name="Accent"
                                    Width="2"
                                    HorizontalAlignment="Left"
                                    Background="#3B82F6"
                                    Opacity="0"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#131B27"/>
                            <Setter Property="Foreground" Value="#E6EEF9"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#162437"/>
                            <Setter Property="Foreground" Value="#E6EEF9"/>
                            <Setter TargetName="Accent" Property="Opacity" Value="1"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="#B6B6B6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="14,4,12,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root" Background="{TemplateBinding Background}">
                        <Grid>
                            <Border x:Name="Accent"
                                    Width="2"
                                    HorizontalAlignment="Left"
                                    Background="#3B82F6"
                                    Opacity="0"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#131B27"/>
                            <Setter Property="Foreground" Value="#E6EEF9"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#162437"/>
                            <Setter Property="Foreground" Value="#E6EEF9"/>
                            <Setter TargetName="Accent" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Padding" Value="14,0,14,0"/>
        <Setter Property="Foreground" Value="#ECECEC"/>
        <Setter Property="CaretBrush" Value="#F3F4F6"/>
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#353535"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                            <TextBlock x:Name="Placeholder"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       Foreground="#6E6E6E"
                                       Text="{TemplateBinding Tag}"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value=""/>
                                <Condition Property="IsKeyboardFocused" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#4A4A4A"/>
                            <Setter TargetName="Root" Property="Background" Value="#232323"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChipStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#A8A8A8"/>
        <Setter Property="Background" Value="#1C1C1C"/>
        <Setter Property="BorderBrush" Value="#373737"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5,10,5"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#232323"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="Favorites">
                            <Setter Property="Foreground" Value="#C8CBD1"/>
                            <Setter Property="BorderBrush" Value="#4A4A4A"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="Safe">
                            <Setter Property="Foreground" Value="#6EE7A3"/>
                            <Setter Property="BorderBrush" Value="#246B44"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="Advanced">
                            <Setter Property="Foreground" Value="#60A5FA"/>
                            <Setter Property="BorderBrush" Value="#285EA8"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="Risky">
                            <Setter Property="Foreground" Value="#F2B24D"/>
                            <Setter Property="BorderBrush" Value="#8A5B18"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="ClassA">
                            <Setter Property="Foreground" Value="#C8A7FF"/>
                            <Setter Property="BorderBrush" Value="#6742B0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="ClassB">
                            <Setter Property="Foreground" Value="#63E0D6"/>
                            <Setter Property="BorderBrush" Value="#1F7C76"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="ClassD">
                            <Setter Property="Foreground" Value="#B5BBC7"/>
                            <Setter Property="BorderBrush" Value="#59606D"/>
                        </DataTrigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#262626"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#3B3B3B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#E2E2E2"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ConfigurationPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
        <Setter Property="Background" Value="#1D4ED8"/>
        <Setter Property="BorderBrush" Value="#2563EB"/>
        <Setter Property="Foreground" Value="#F4F7FF"/>
        <Setter Property="MinWidth" Value="92"/>
    </Style>

    <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource ConfigurationPrimaryActionButtonStyle}"/>

    <Style x:Key="ConfigurationSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="#7F7F7F"/>
        <Setter Property="MinWidth" Value="92"/>
    </Style>

    <Style x:Key="RepairsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ConfigurationPrimaryActionButtonStyle}"/>

    <Style x:Key="TweakListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RowCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="0,2,12,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Root"
                            Width="14"
                            Height="14"
                            Background="Transparent"
                            BorderBrush="#545454"
                            BorderThickness="1"
                            CornerRadius="3">
                        <Path x:Name="Tick"
                              Data="M 2,7 L 5,10 L 11,3"
                              Stroke="#22C55E"
                              StrokeThickness="1.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Visibility="Collapsed"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#22C55E"/>
                            <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusPillBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#414141"/>
    </Style>

    <Style x:Key="EvidencePillBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#29241D"/>
        <Setter Property="BorderBrush" Value="#58482D"/>
    </Style>

    <Style x:Key="TierPillBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="7,2"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#4A4A4A"/>
    </Style>

    <Style x:Key="RiskPillBorderStyle" TargetType="Border" BasedOn="{StaticResource TierPillBorderStyle}"/>

    <DataTemplate x:Key="ConfigurationTweakRowTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
        <Grid>
            <Border x:Name="Card" Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="112"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="Stripe" Grid.Column="0" Background="#434343" CornerRadius="10,0,0,10"/>

                <Grid Grid.Column="1" Margin="16,16,18,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.RowSpan="3"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Style="{StaticResource RowCheckBoxStyle}"/>

                    <StackPanel Grid.Column="1">
                        <WrapPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding Name}" Foreground="#F4F4F4" FontSize="15" FontWeight="SemiBold" Margin="0,0,12,0"/>
                            <Border Margin="0,0,6,6">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource TierPillBorderStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EvidenceClassBadgeText}" Value="A">
                                                <Setter Property="BorderBrush" Value="#6E4EC8"/>
                                                <Setter Property="Background" Value="#261B44"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EvidenceClassBadgeText}" Value="B">
                                                <Setter Property="BorderBrush" Value="#20877D"/>
                                                <Setter Property="Background" Value="#132826"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EvidenceClassBadgeText}" Value="C">
                                                <Setter Property="BorderBrush" Value="#44607A"/>
                                                <Setter Property="Background" Value="#1A222B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EvidenceClassBadgeText}" Value="D">
                                                <Setter Property="BorderBrush" Value="#5E646F"/>
                                                <Setter Property="Background" Value="#24272C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding EvidenceClassBadgeText}" Foreground="#EAEAEA" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource RiskPillBorderStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RiskBadgeText}" Value="SAFE">
                                                <Setter Property="BorderBrush" Value="#246B44"/>
                                                <Setter Property="Background" Value="#12261A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RiskBadgeText}" Value="ADVANCED">
                                                <Setter Property="BorderBrush" Value="#285EA8"/>
                                                <Setter Property="Background" Value="#142338"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RiskBadgeText}" Value="RISKY">
                                                <Setter Property="BorderBrush" Value="#8A5B18"/>
                                                <Setter Property="Background" Value="#2E2111"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding RiskBadgeText}" Foreground="#EAEAEA" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="{Binding ConfigurationFriendlyDescription}"
                                   Foreground="#B8B8B8"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   ToolTip="{Binding FriendlyDescription}"/>

                        <WrapPanel>
                            <Border Margin="0,0,10,0">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EvidencePillBorderStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEvidenceConfirmed}" Value="True">
                                                <Setter Property="Background" Value="#102317"/>
                                                <Setter Property="BorderBrush" Value="#1E7A43"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓"
                                               Margin="0,0,4,0"
                                               FontSize="10"
                                               FontWeight="Medium"
                                               Visibility="{Binding IsEvidenceConfirmed, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="{Binding EvidenceStateText}"
                                               FontSize="10"
                                               FontWeight="Medium"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding ConfigurationImpactAreaText}" Foreground="#8D8D8D" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding ConfigurationCompactInfoLine}" Foreground="#9EA3AA" FontSize="11" FontFamily="{DynamicResource FontFamilyMono}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding ConfigurationInventoryFreshnessText}" Foreground="#757575" FontSize="11"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2" Margin="0,16,12,16" VerticalAlignment="Top" HorizontalAlignment="Right" Width="84">
                    <Border HorizontalAlignment="Right" MinWidth="72">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StatusPillBorderStyle}">
                                <Setter Property="Background" Value="{Binding StatusBadgeBackground}"/>
                                <Setter Property="BorderBrush" Value="{Binding StatusColor}"/>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,16,16,16" VerticalAlignment="Top">
                    <Button Content="{Binding ActionButtonText}" Command="{Binding ApplyCommand}" ToolTip="{Binding PrimaryActionTooltip}" Style="{StaticResource ConfigurationPrimaryActionButtonStyle}"/>
                    <Button Content="Restore" Command="{Binding RollbackCommand}" Style="{StaticResource ConfigurationSecondaryActionButtonStyle}" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsApplied}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="#132118"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="#274233"/>
                <Setter TargetName="Stripe" Property="Background" Value="#22C55E"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding StatusText}" Value="Error">
                <Setter TargetName="Card" Property="Background" Value="#241615"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="#5B2D2B"/>
                <Setter TargetName="Stripe" Property="Background" Value="#D36C5F"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="RepairsTweakRowTemplate" DataType="{x:Type viewModels:RepairsItemViewModel}">
        <Grid>
            <Border x:Name="Card" Background="#171717" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="112"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="Stripe" Grid.Column="0" Background="#434343" CornerRadius="10,0,0,10"/>

                <Grid Grid.Column="1" Margin="16,16,18,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.RowSpan="3" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource RowCheckBoxStyle}"/>

                    <StackPanel Grid.Column="1">
                        <WrapPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding Name}" Foreground="#F4F4F4" FontSize="15" FontWeight="SemiBold" Margin="0,0,12,0"/>
                            <Border Margin="0,0,6,6">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource TierPillBorderStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EvidenceClassBadgeText}" Value="A">
                                                <Setter Property="BorderBrush" Value="#6E4EC8"/>
                                                <Setter Property="Background" Value="#261B44"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EvidenceClassBadgeText}" Value="B">
                                                <Setter Property="BorderBrush" Value="#20877D"/>
                                                <Setter Property="Background" Value="#132826"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EvidenceClassBadgeText}" Value="D">
                                                <Setter Property="BorderBrush" Value="#5E646F"/>
                                                <Setter Property="Background" Value="#24272C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding EvidenceClassBadgeText}" Foreground="#EAEAEA" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource RiskPillBorderStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RiskBadgeText}" Value="SAFE">
                                                <Setter Property="BorderBrush" Value="#246B44"/>
                                                <Setter Property="Background" Value="#12261A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RiskBadgeText}" Value="ADVANCED">
                                                <Setter Property="BorderBrush" Value="#285EA8"/>
                                                <Setter Property="Background" Value="#142338"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RiskBadgeText}" Value="RISKY">
                                                <Setter Property="BorderBrush" Value="#8A5B18"/>
                                                <Setter Property="Background" Value="#2E2111"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding RiskBadgeText}" Foreground="#EAEAEA" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="{Binding FriendlyDescription}" Foreground="#B8B8B8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <WrapPanel>
                            <Border Margin="0,0,10,0">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EvidencePillBorderStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEvidenceConfirmed}" Value="True">
                                                <Setter Property="Background" Value="#102317"/>
                                                <Setter Property="BorderBrush" Value="#1E7A43"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓"
                                               Margin="0,0,4,0"
                                               FontSize="10"
                                               FontWeight="Medium"
                                               Visibility="{Binding IsEvidenceConfirmed, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="{Binding EvidenceStateText}"
                                               FontSize="10"
                                               FontWeight="Medium"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding CompactInfoLine}" Foreground="#9EA3AA" FontSize="11" FontFamily="{DynamicResource FontFamilyMono}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding InventoryFreshnessText}" Foreground="#757575" FontSize="11"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2" Margin="0,16,12,16" VerticalAlignment="Top" HorizontalAlignment="Right" Width="84">
                    <Border HorizontalAlignment="Right" MinWidth="72">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StatusPillBorderStyle}">
                                <Setter Property="Background" Value="{Binding StatusBadgeBackground}"/>
                                <Setter Property="BorderBrush" Value="{Binding StatusColor}"/>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding RepairStatusText}" Foreground="{Binding StatusColor}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,16,16,16" VerticalAlignment="Top">
                    <Button Content="{Binding RunRepairButtonText}" Command="{Binding RunRepairCommand}" ToolTip="{Binding RunRepairTooltip}" Style="{StaticResource RepairsActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsApplied}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="#132118"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="#274233"/>
                <Setter TargetName="Stripe" Property="Background" Value="#22C55E"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RepairStatusText}" Value="Error">
                <Setter TargetName="Card" Property="Background" Value="#241615"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="#5B2D2B"/>
                <Setter TargetName="Stripe" Property="Background" Value="#D36C5F"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>
