<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:viewModels="clr-namespace:RegProbe.App.ViewModels">
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#777777"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,12,16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="2,0,0,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#141414"/>
                            <Setter Property="Foreground" Value="#DADADA"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#141414"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#777777"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,12,16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="2,0,0,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#141414"/>
                            <Setter Property="Foreground" Value="#DADADA"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#141414"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChipStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#686868"/>
        <Setter Property="Background" Value="#151515"/>
        <Setter Property="BorderBrush" Value="#252525"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#1A1A1A"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#353535"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="Advanced"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#20170F"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5A4020"/>
                            <Setter Property="Foreground" Value="#E0AF63"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="Risky"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#261614"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5A2A24"/>
                            <Setter Property="Foreground" Value="#D87A70"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="ClassA"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#241412"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5A241C"/>
                            <Setter Property="Foreground" Value="#E36A59"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="ClassB"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#14202A"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#27445D"/>
                            <Setter Property="Foreground" Value="#6FADE8"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#121212"/>
        <Setter Property="Foreground" Value="#E8E8E8"/>
        <Setter Property="BorderBrush" Value="#232323"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="CaretBrush" Value="#E8E8E8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                            <TextBlock Margin="10,0,10,0"
                                       VerticalAlignment="Center"
                                       Foreground="#575757"
                                       IsHitTestVisible="False"
                                       Text="{TemplateBinding Tag}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource TemplatedParent}}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#343434"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#151515"/>
        <Setter Property="Foreground" Value="#909090"/>
        <Setter Property="BorderBrush" Value="#252525"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="MinWidth" Value="76"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#373737"/>
                            <Setter Property="Foreground" Value="#E8E8E8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#2B1715"/>
                <Setter Property="BorderBrush" Value="#C0392B"/>
                <Setter Property="Foreground" Value="#F0B1A8"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RepairsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ApplyButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding RepairState}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#2B1715"/>
                <Setter Property="BorderBrush" Value="#C0392B"/>
                <Setter Property="Foreground" Value="#F0B1A8"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAdvancedRisk}" Value="True">
                <Setter Property="Background" Value="#20170F"/>
                <Setter Property="BorderBrush" Value="#5A4020"/>
                <Setter Property="Foreground" Value="#E0AF63"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsRisky}" Value="True">
                <Setter Property="Background" Value="#261614"/>
                <Setter Property="BorderBrush" Value="#8E3A31"/>
                <Setter Property="Foreground" Value="#E7A096"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TweakListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionEyebrowStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#696969"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#5E5E5E"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <DataTemplate x:Key="ConfigurationTweakRowTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
        <Border BorderBrush="#191919" BorderThickness="0,0,0,0.5" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" Margin="0,20,20,0" VerticalAlignment="Top" IsChecked="{Binding IsSelected, Mode=TwoWay}">
                    <CheckBox.Template>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="Root" Width="14" Height="14" Background="Transparent" BorderBrush="#343434" BorderThickness="1" CornerRadius="2">
                                <Path x:Name="Check" Data="M 2,7 L 5,10 L 11,3" Stroke="#F4F4F4" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#311714"/>
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </CheckBox.Template>
                </CheckBox>

                <StackPanel Grid.Column="1" Margin="0,16,24,16">
                    <WrapPanel>
                        <TextBlock Text="{Binding Name}" Margin="0,0,12,6" FontSize="15" FontWeight="SemiBold" Foreground="#ECECEC"/>
                        <Border Margin="0,0,6,6" Padding="7,2" CornerRadius="4" Background="#191919" BorderBrush="#2B2B2B" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#191919"/>
                                    <Setter Property="BorderBrush" Value="#2B2B2B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RepairState}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                                            <Setter Property="Background" Value="#17311E"/>
                                            <Setter Property="BorderBrush" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RepairState}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                                            <Setter Property="Background" Value="#261614"/>
                                            <Setter Property="BorderBrush" Value="#5A2A24"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding RepairStatusText}" FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8C8C8C"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RepairState}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                                                <Setter Property="Foreground" Value="#6DC171"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RepairState}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                                                <Setter Property="Foreground" Value="#D98075"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border Margin="0,0,6,6" Padding="7,2" CornerRadius="4" Background="#181818" BorderBrush="#2B2B2B" BorderThickness="1" Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#181818"/>
                                    <Setter Property="BorderBrush" Value="#2B2B2B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EvidenceClassId}" Value="A">
                                            <Setter Property="Background" Value="#241412"/>
                                            <Setter Property="BorderBrush" Value="#5A241C"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EvidenceClassId}" Value="B">
                                            <Setter Property="Background" Value="#14202A"/>
                                            <Setter Property="BorderBrush" Value="#27445D"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding EvidenceClassBadgeText}" FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8D8D8D"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EvidenceClassId}" Value="A">
                                                <Setter Property="Foreground" Value="#E36A59"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EvidenceClassId}" Value="B">
                                                <Setter Property="Foreground" Value="#6FADE8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </WrapPanel>

                    <TextBlock Text="{Binding FriendlyDescription}" Margin="0,2,0,0" FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap" MaxWidth="820"/>
                    <TextBlock Text="{Binding ResearchGateMessage}" Margin="0,7,0,0" FontSize="10" Foreground="#33FFFFFF" TextWrapping="Wrap" Visibility="{Binding HasResearchGateMessage, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding RowMetaText}" Margin="0,10,0,0" FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding BatchSummaryLine}" Margin="0,5,0,0" FontSize="10" Foreground="#5B5B5B" TextWrapping="Wrap" Visibility="{Binding HasBatchSummaryLine, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="Revert"
                            Command="{Binding RollbackCommand}"
                            ToolTip="{Binding RollbackActionTooltip}"
                            Style="{StaticResource FlatButtonStyle}"
                            MinWidth="86"
                            Margin="0,0,6,0"/>
                    <Button Content="{Binding ActionButtonText}"
                            Command="{Binding ApplyCommand}"
                            ToolTip="{Binding PrimaryActionTooltip}"
                            Style="{StaticResource ApplyButtonStyle}"
                            MinWidth="86"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="RepairsTweakRowTemplate" DataType="{x:Type viewModels:RepairsItemViewModel}">
        <Border BorderBrush="#191919" BorderThickness="0,0,0,0.5" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="112"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" Margin="0,20,20,0" VerticalAlignment="Top" IsChecked="{Binding IsSelected, Mode=TwoWay}">
                    <CheckBox.Template>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="Root" Width="14" Height="14" Background="Transparent" BorderBrush="#343434" BorderThickness="1" CornerRadius="2">
                                <Path x:Name="Check" Data="M 2,7 L 5,10 L 11,3" Stroke="#F4F4F4" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#311714"/>
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </CheckBox.Template>
                </CheckBox>

                <StackPanel Grid.Column="1" Margin="0,16,24,16">
                    <WrapPanel>
                        <TextBlock Text="{Binding Name}" Margin="0,0,12,6" FontSize="15" FontWeight="SemiBold" Foreground="#ECECEC"/>
                        <Border Margin="0,0,6,6" Padding="7,2" CornerRadius="4" Background="#191919" BorderBrush="#2B2B2B" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#191919"/>
                                    <Setter Property="BorderBrush" Value="#2B2B2B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                                            <Setter Property="Background" Value="#17311E"/>
                                            <Setter Property="BorderBrush" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                                            <Setter Property="Background" Value="#261614"/>
                                            <Setter Property="BorderBrush" Value="#5A2A24"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8C8C8C"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                                                <Setter Property="Foreground" Value="#6DC171"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                                                <Setter Property="Foreground" Value="#D98075"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border Margin="0,0,6,6" Padding="7,2" CornerRadius="4" Background="#181818" BorderBrush="#2B2B2B" BorderThickness="1" Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#181818"/>
                                    <Setter Property="BorderBrush" Value="#2B2B2B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EvidenceClassId}" Value="A">
                                            <Setter Property="Background" Value="#241412"/>
                                            <Setter Property="BorderBrush" Value="#5A241C"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EvidenceClassId}" Value="B">
                                            <Setter Property="Background" Value="#14202A"/>
                                            <Setter Property="BorderBrush" Value="#27445D"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding EvidenceClassBadgeText}" FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8D8D8D"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EvidenceClassId}" Value="A">
                                                <Setter Property="Foreground" Value="#E36A59"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EvidenceClassId}" Value="B">
                                                <Setter Property="Foreground" Value="#6FADE8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </WrapPanel>

                    <TextBlock Text="{Binding FriendlyDescription}" Margin="0,2,0,0" FontSize="11" Foreground="#8A8A8A" TextWrapping="Wrap" MaxWidth="820"/>
                    <TextBlock Text="{Binding ResearchGateMessage}" Margin="0,7,0,0" FontSize="10" Foreground="#33FFFFFF" TextWrapping="Wrap" Visibility="{Binding HasResearchGateMessage, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding RowMetaText}" Margin="0,10,0,0" FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding RepairsRiskHint}"
                               Margin="0,6,0,0"
                               FontSize="10"
                               Foreground="#B78763"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasRepairsRiskHint, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding BatchSummaryLine}" Margin="0,5,0,0" FontSize="10" Foreground="#5B5B5B" TextWrapping="Wrap" Visibility="{Binding HasBatchSummaryLine, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="{Binding RunRepairButtonText}"
                            Command="{Binding RunRepairCommand}"
                            ToolTip="{Binding RunRepairTooltip}"
                            Style="{StaticResource RepairsActionButtonStyle}"
                            MinWidth="86"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
