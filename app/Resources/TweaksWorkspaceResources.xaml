<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:viewModels="clr-namespace:RegProbe.App.ViewModels">
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#767676"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="22,11,18,11"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="2,0,0,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#141414"/>
                            <Setter Property="Foreground" Value="#DADADA"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#161616"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#767676"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="22,11,18,11"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="2,0,0,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#141414"/>
                            <Setter Property="Foreground" Value="#DADADA"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#161616"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChipStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#686868"/>
        <Setter Property="Background" Value="#151515"/>
        <Setter Property="BorderBrush" Value="#252525"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#1A1A1A"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#353535"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="Advanced"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#20170F"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5A4020"/>
                            <Setter Property="Foreground" Value="#E0AF63"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="Risky"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#261614"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5A2A24"/>
                            <Setter Property="Foreground" Value="#D87A70"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="ClassA"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#241412"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5A241C"/>
                            <Setter Property="Foreground" Value="#E36A59"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="ClassB"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#14202A"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#27445D"/>
                            <Setter Property="Foreground" Value="#6FADE8"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#121212"/>
        <Setter Property="Foreground" Value="#E8E8E8"/>
        <Setter Property="BorderBrush" Value="#232323"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="CaretBrush" Value="#E8E8E8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                            <TextBlock Margin="10,0,10,0"
                                       VerticalAlignment="Center"
                                       Foreground="#575757"
                                       IsHitTestVisible="False"
                                       Text="{TemplateBinding Tag}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource TemplatedParent}}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#343434"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#151515"/>
        <Setter Property="Foreground" Value="#909090"/>
        <Setter Property="BorderBrush" Value="#252525"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinWidth" Value="76"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#373737"/>
                            <Setter Property="Foreground" Value="#E8E8E8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#2B1715"/>
                <Setter Property="BorderBrush" Value="#C0392B"/>
                <Setter Property="Foreground" Value="#F0B1A8"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RepairsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ApplyButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding RepairState}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#2B1715"/>
                <Setter Property="BorderBrush" Value="#C0392B"/>
                <Setter Property="Foreground" Value="#F0B1A8"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAdvancedRisk}" Value="True">
                <Setter Property="Background" Value="#20170F"/>
                <Setter Property="BorderBrush" Value="#5A4020"/>
                <Setter Property="Foreground" Value="#E0AF63"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsRisky}" Value="True">
                <Setter Property="Background" Value="#261614"/>
                <Setter Property="BorderBrush" Value="#8E3A31"/>
                <Setter Property="Foreground" Value="#E7A096"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TweakListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionEyebrowStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#696969"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#5E5E5E"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <Style x:Key="WorkspaceRowBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="#171717"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="WorkspaceSelectionCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Margin" Value="0,18,18,0"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Root" Width="14" Height="14" Background="Transparent" BorderBrush="#343434" BorderThickness="1" CornerRadius="2">
                        <Path x:Name="Check" Data="M 2,7 L 5,10 L 11,3" Stroke="#F4F4F4" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#311714"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WorkspaceRowTitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,12,7"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#ECECEC"/>
    </Style>

    <Style x:Key="WorkspaceDescriptionStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,1,0,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#8A8A8A"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxWidth" Value="760"/>
    </Style>

    <Style x:Key="WorkspaceResearchGateStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#33FFFFFF"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceRowMetaStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#5E5E5E"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceFooterLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#686868"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <Style x:Key="WorkspaceFooterValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyMono}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceFooterHintStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#505050"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceBatchSummaryStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#555555"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyMono}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceStatusBadgeBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,6,6"/>
        <Setter Property="Padding" Value="7,2"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="#191919"/>
        <Setter Property="BorderBrush" Value="#2B2B2B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#17311E"/>
                <Setter Property="BorderBrush" Value="#2E7D32"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                <Setter Property="Background" Value="#261614"/>
                <Setter Property="BorderBrush" Value="#5A2A24"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WorkspaceStatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#8C8C8C"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Foreground" Value="#6DC171"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                <Setter Property="Foreground" Value="#D98075"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WorkspaceEvidenceBadgeBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,6,6"/>
        <Setter Property="Padding" Value="7,2"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="#181818"/>
        <Setter Property="BorderBrush" Value="#2B2B2B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="A">
                <Setter Property="Background" Value="#241412"/>
                <Setter Property="BorderBrush" Value="#5A241C"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="B">
                <Setter Property="Background" Value="#14202A"/>
                <Setter Property="BorderBrush" Value="#27445D"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WorkspaceEvidenceBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#8D8D8D"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="A">
                <Setter Property="Foreground" Value="#E36A59"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="B">
                <Setter Property="Foreground" Value="#6FADE8"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="ConfigurationTweakRowTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
        <Border Style="{StaticResource WorkspaceRowBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="188"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource WorkspaceSelectionCheckBoxStyle}"/>

                <StackPanel Grid.Column="1" Margin="0,16,24,16">
                    <WrapPanel>
                        <TextBlock Text="{Binding Name}" Style="{StaticResource WorkspaceRowTitleStyle}"/>
                        <Border Tag="{Binding RepairState}" Style="{StaticResource WorkspaceStatusBadgeBorderStyle}">
                            <TextBlock Text="{Binding RepairStatusText}" Tag="{Binding RepairState}" Style="{StaticResource WorkspaceStatusBadgeTextStyle}"/>
                        </Border>
                        <Border Tag="{Binding EvidenceClassId}" Style="{StaticResource WorkspaceEvidenceBadgeBorderStyle}" Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding EvidenceClassBadgeText}" Tag="{Binding EvidenceClassId}" Style="{StaticResource WorkspaceEvidenceBadgeTextStyle}"/>
                        </Border>
                    </WrapPanel>

                    <TextBlock Text="{Binding FriendlyDescription}" Style="{StaticResource WorkspaceDescriptionStyle}"/>
                    <TextBlock Text="{Binding ResearchGateMessage}" Style="{StaticResource WorkspaceResearchGateStyle}" Visibility="{Binding HasResearchGateMessage, Converter={StaticResource BoolToVisibility}}"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ImpactAreaLabel}"
                                   Style="{StaticResource WorkspaceFooterLabelStyle}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding CompactInfoLine}"
                                   Style="{StaticResource WorkspaceFooterValueStyle}"
                                   Visibility="{Binding HasCompactInfoLine, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding InventoryFreshnessText}"
                                   Style="{StaticResource WorkspaceFooterHintStyle}"
                                   Margin="16,0,0,0"/>
                    </Grid>
                    <TextBlock Text="{Binding BatchSummaryLine}" Style="{StaticResource WorkspaceBatchSummaryStyle}" Visibility="{Binding HasBatchSummaryLine, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Content="Revert"
                            Command="{Binding RollbackCommand}"
                            ToolTip="{Binding RollbackActionTooltip}"
                            Style="{StaticResource FlatButtonStyle}"
                            MinWidth="82"
                            Margin="0,0,6,0"/>
                    <Button Content="{Binding ActionButtonText}"
                            Command="{Binding ApplyCommand}"
                            ToolTip="{Binding PrimaryActionTooltip}"
                            Style="{StaticResource ApplyButtonStyle}"
                            MinWidth="82"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="RepairsTweakRowTemplate" DataType="{x:Type viewModels:RepairsItemViewModel}">
        <Border Style="{StaticResource WorkspaceRowBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="112"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource WorkspaceSelectionCheckBoxStyle}"/>

                <StackPanel Grid.Column="1" Margin="0,16,24,16">
                    <WrapPanel>
                        <TextBlock Text="{Binding Name}" Style="{StaticResource WorkspaceRowTitleStyle}"/>
                        <Border Tag="{Binding AppliedStatus}" Style="{StaticResource WorkspaceStatusBadgeBorderStyle}">
                            <TextBlock Text="{Binding StatusText}" Tag="{Binding AppliedStatus}" Style="{StaticResource WorkspaceStatusBadgeTextStyle}"/>
                        </Border>
                        <Border Tag="{Binding EvidenceClassId}" Style="{StaticResource WorkspaceEvidenceBadgeBorderStyle}" Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding EvidenceClassBadgeText}" Tag="{Binding EvidenceClassId}" Style="{StaticResource WorkspaceEvidenceBadgeTextStyle}"/>
                        </Border>
                    </WrapPanel>

                    <TextBlock Text="{Binding FriendlyDescription}" Style="{StaticResource WorkspaceDescriptionStyle}"/>
                    <TextBlock Text="{Binding ResearchGateMessage}" Style="{StaticResource WorkspaceResearchGateStyle}" Visibility="{Binding HasResearchGateMessage, Converter={StaticResource BoolToVisibility}}"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ImpactAreaLabel}"
                                   Style="{StaticResource WorkspaceFooterLabelStyle}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding CompactInfoLine}"
                                   Style="{StaticResource WorkspaceFooterValueStyle}"
                                   Visibility="{Binding HasCompactInfoLine, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding InventoryFreshnessText}"
                                   Style="{StaticResource WorkspaceFooterHintStyle}"
                                   Margin="16,0,0,0"/>
                    </Grid>
                    <TextBlock Text="{Binding RepairsRiskHint}"
                               Margin="0,6,0,0"
                               FontSize="10"
                               Foreground="#B78763"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasRepairsRiskHint, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding BatchSummaryLine}" Style="{StaticResource WorkspaceBatchSummaryStyle}" Visibility="{Binding HasBatchSummaryLine, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Content="{Binding RunRepairButtonText}"
                            Command="{Binding RunRepairCommand}"
                            ToolTip="{Binding RunRepairTooltip}"
                            Style="{StaticResource RepairsActionButtonStyle}"
                            MinWidth="82"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
