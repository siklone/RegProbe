<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:viewModels="clr-namespace:RegProbe.App.ViewModels">
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#767676"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="18,8,16,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="2,0,0,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F1F1F"/>
                                <Setter Property="Foreground" Value="#DADADA"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202020"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#767676"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="18,7,16,7"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="2,0,0,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F1F1F"/>
                                <Setter Property="Foreground" Value="#DADADA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202020"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChipStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#8D8D8D"/>
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="BorderBrush" Value="#343434"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="11,6"/>
        <Setter Property="Margin" Value="0,0,10,10"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#242424"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#4A4A4A"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="Advanced"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#29251F"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#5A4A36"/>
                            <Setter Property="Foreground" Value="#CEB285"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="Risky"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#2B201E"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#63423B"/>
                            <Setter Property="Foreground" Value="#CE9C94"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="ClassA"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#272120"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#4B3A37"/>
                            <Setter Property="Foreground" Value="#B89D99"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="ClassB"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="#1D2328"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#37424C"/>
                            <Setter Property="Foreground" Value="#9AAAB8"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#E8E8E8"/>
        <Setter Property="BorderBrush" Value="#343434"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CaretBrush" Value="#E8E8E8"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                      <Border x:Name="Root"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="4">
                          <Grid>
                              <ScrollViewer x:Name="PART_ContentHost"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                                <TextBlock Margin="10,0,10,0"
                                           VerticalAlignment="Center"
                                           Foreground="#626262"
                                           IsHitTestVisible="False"
                                           Text="{TemplateBinding Tag}">
                                  <TextBlock.Style>
                                      <Style TargetType="TextBlock">
                                          <Setter Property="Visibility" Value="Collapsed"/>
                                          <Style.Triggers>
                                              <MultiDataTrigger>
                                                  <MultiDataTrigger.Conditions>
                                                      <Condition Binding="{Binding Text.Length, RelativeSource={RelativeSource TemplatedParent}}" Value="0"/>
                                                      <Condition Binding="{Binding IsKeyboardFocused, RelativeSource={RelativeSource TemplatedParent}}" Value="False"/>
                                                  </MultiDataTrigger.Conditions>
                                                  <Setter Property="Visibility" Value="Visible"/>
                                              </MultiDataTrigger>
                                          </Style.Triggers>
                                      </Style>
                                  </TextBlock.Style>
                              </TextBlock>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#575757"/>
                            <Setter TargetName="Root" Property="Background" Value="#202020"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#D8D8D8"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="MinWidth" Value="76"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#565656"/>
                                <Setter Property="Foreground" Value="#F1F1F1"/>
                            </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#2B1715"/>
                <Setter Property="BorderBrush" Value="#C0392B"/>
                <Setter Property="Foreground" Value="#F0B1A8"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ConfigurationPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ApplyButtonStyle}">
        <Setter Property="MinWidth" Value="104"/>
        <Setter Property="Background" Value="#241A19"/>
        <Setter Property="BorderBrush" Value="#7A4D48"/>
        <Setter Property="Foreground" Value="#F2DFDB"/>
    </Style>

    <Style x:Key="ConfigurationSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
        <Setter Property="MinWidth" Value="104"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#8E8E8E"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="2,2"/>
    </Style>

    <Style x:Key="RepairsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ApplyButtonStyle}">
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="Background" Value="#241A19"/>
        <Setter Property="BorderBrush" Value="#7A4D48"/>
        <Setter Property="Foreground" Value="#F2DFDB"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RepairState}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#2B1715"/>
                <Setter Property="BorderBrush" Value="#C0392B"/>
                <Setter Property="Foreground" Value="#F0B1A8"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAdvancedRisk}" Value="True">
                <Setter Property="Background" Value="#2A241E"/>
                <Setter Property="BorderBrush" Value="#5A4830"/>
                <Setter Property="Foreground" Value="#D4B27E"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsRisky}" Value="True">
                <Setter Property="Background" Value="#2C1E1B"/>
                <Setter Property="BorderBrush" Value="#694037"/>
                <Setter Property="Foreground" Value="#D49A92"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TweakListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionEyebrowStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#696969"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#5E5E5E"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <Style x:Key="WorkspaceRowBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="#2D2D2D"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="WorkspaceSelectionCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Margin" Value="0,16,16,0"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Root" Width="15" Height="15" Background="Transparent" BorderBrush="#343434" BorderThickness="1" CornerRadius="3">
                        <Path x:Name="Check" Data="M 2,6.5 L 4.7,9.2 L 10.6,3.2" Stroke="#F4F4F4" StrokeThickness="1.35" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#311714"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#C0392B"/>
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WorkspaceRowTitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#ECECEC"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="WorkspaceDescriptionStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#ADADAD"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxWidth" Value="660"/>
    </Style>

    <Style x:Key="ConfigurationDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource WorkspaceDescriptionStyle}">
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Foreground" Value="#B0B0B0"/>
        <Setter Property="MaxWidth" Value="680"/>
    </Style>

    <Style x:Key="WorkspaceResearchGateStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#33FFFFFF"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceRowMetaStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,7,0,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#5E5E5E"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceFooterLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#8B8B8B"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <Style x:Key="WorkspaceFooterValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#8A8A8A"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyMono}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ConfigurationFooterValueStyle" TargetType="TextBlock" BasedOn="{StaticResource WorkspaceFooterValueStyle}">
        <Setter Property="Foreground" Value="#717171"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyText}"/>
    </Style>

    <Style x:Key="WorkspaceFooterHintStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#797979"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="WorkspaceBatchSummaryStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,3,0,0"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="Foreground" Value="#626262"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyMono}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ConfigurationBatchSummaryStyle" TargetType="TextBlock" BasedOn="{StaticResource WorkspaceBatchSummaryStyle}">
        <Setter Property="Foreground" Value="#636363"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyText}"/>
    </Style>

    <Style x:Key="WorkspaceStatusBadgeBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="Padding" Value="7,3"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#363636"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Background" Value="#1F2D22"/>
                <Setter Property="BorderBrush" Value="#45634C"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                <Setter Property="Background" Value="#2A1C1A"/>
                <Setter Property="BorderBrush" Value="#71453F"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WorkspaceStatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#A3A3A3"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                <Setter Property="Foreground" Value="#88C08F"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                <Setter Property="Foreground" Value="#D89A91"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WorkspaceInlineMetaSeparatorStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="8,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#4A4A4A"/>
        <Setter Property="Text" Value="•"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="WorkspaceEvidenceBadgeBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="Padding" Value="5,1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#303030"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="A">
                <Setter Property="Background" Value="#24201F"/>
                <Setter Property="BorderBrush" Value="#403531"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="B">
                <Setter Property="Background" Value="#1F2327"/>
                <Setter Property="BorderBrush" Value="#343D45"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WorkspaceEvidenceBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#8B8B8B"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="A">
                <Setter Property="Foreground" Value="#B08D88"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="B">
                <Setter Property="Foreground" Value="#91A4B5"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RepairsRiskBadgeBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Padding" Value="6,1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Background" Value="#191512"/>
        <Setter Property="BorderBrush" Value="#3D2C1D"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="RepairsRiskBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="Foreground" Value="#B78A62"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
    </Style>

    <DataTemplate x:Key="ConfigurationTweakRowTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
        <Border Style="{StaticResource WorkspaceRowBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="116"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource WorkspaceSelectionCheckBoxStyle}"/>

                <StackPanel Grid.Column="1" Margin="0,16,22,16">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource WorkspaceRowTitleStyle}" Margin="0,0,0,0"/>
                    <TextBlock Text="{Binding ConfigurationFriendlyDescription}"
                               ToolTip="{Binding FriendlyDescription}"
                               Style="{StaticResource ConfigurationDescriptionStyle}"/>
                    <TextBlock Text="{Binding ResearchGateMessage}" Style="{StaticResource WorkspaceResearchGateStyle}" Visibility="{Binding HasResearchGateMessage, Converter={StaticResource BoolToVisibility}}"/>
                    <WrapPanel Margin="0,8,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConfigurationImpactAreaText}"
                                   Style="{StaticResource WorkspaceFooterLabelStyle}"/>
                        <TextBlock Text="·" Style="{StaticResource WorkspaceFooterHintStyle}" Margin="6,0"/>
                        <TextBlock
                                   Text="{Binding ConfigurationCompactInfoLine}"
                                   Style="{StaticResource ConfigurationFooterValueStyle}"
                                   Visibility="{Binding HasCompactInfoLine, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="·" Style="{StaticResource WorkspaceFooterHintStyle}" Margin="6,0"/>
                        <TextBlock
                                   Text="{Binding ConfigurationInventoryFreshnessText}"
                                   Style="{StaticResource WorkspaceFooterHintStyle}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding BatchSummaryLine}"
                               Style="{StaticResource ConfigurationBatchSummaryStyle}"
                               Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,16,12,16" VerticalAlignment="Top">
                    <Border Tag="{Binding AppliedStatus}"
                            Style="{StaticResource WorkspaceStatusBadgeBorderStyle}"
                            ToolTip="{Binding StatusTooltip}">
                        <TextBlock Text="{Binding StatusText}" Tag="{Binding AppliedStatus}" Style="{StaticResource WorkspaceStatusBadgeTextStyle}"/>
                    </Border>
                    <Border Tag="{Binding EvidenceClassId}"
                            Margin="0,6,0,0"
                            Style="{StaticResource WorkspaceEvidenceBadgeBorderStyle}"
                            Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding EvidenceClassBadgeText}" Tag="{Binding EvidenceClassId}" Style="{StaticResource WorkspaceEvidenceBadgeTextStyle}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Vertical" Margin="0,14,0,14" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="{Binding ActionButtonText}"
                            Command="{Binding ApplyCommand}"
                            ToolTip="{Binding ConfigurationPrimaryActionTooltip}"
                            Style="{StaticResource ConfigurationPrimaryActionButtonStyle}"
                            Margin="0,0,0,6"/>
                    <Button Content="Restore"
                            Command="{Binding RollbackCommand}"
                            ToolTip="{Binding ConfigurationRollbackActionTooltip}"
                            Style="{StaticResource ConfigurationSecondaryActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="RepairsTweakRowTemplate" DataType="{x:Type viewModels:RepairsItemViewModel}">
        <Border Style="{StaticResource WorkspaceRowBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="104"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource WorkspaceSelectionCheckBoxStyle}"/>

                <StackPanel Grid.Column="1" Margin="0,16,22,16">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource WorkspaceRowTitleStyle}" Margin="0,0,0,0"/>
                    <TextBlock Text="{Binding FriendlyDescription}" Style="{StaticResource WorkspaceDescriptionStyle}"/>
                    <TextBlock Text="{Binding ResearchGateMessage}" Style="{StaticResource WorkspaceResearchGateStyle}" Visibility="{Binding HasResearchGateMessage, Converter={StaticResource BoolToVisibility}}"/>
                    <WrapPanel Margin="0,8,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ImpactAreaLabel}"
                                   Style="{StaticResource WorkspaceFooterLabelStyle}"/>
                        <TextBlock Text="·" Style="{StaticResource WorkspaceFooterHintStyle}" Margin="6,0"/>
                        <TextBlock
                                   Text="{Binding CompactInfoLine}"
                                   Style="{StaticResource WorkspaceFooterValueStyle}"
                                   Visibility="{Binding HasCompactInfoLine, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="·" Style="{StaticResource WorkspaceFooterHintStyle}" Margin="6,0"/>
                        <TextBlock
                                   Text="{Binding InventoryFreshnessText}"
                                   Style="{StaticResource WorkspaceFooterHintStyle}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding BatchSummaryLine}"
                               Style="{StaticResource WorkspaceBatchSummaryStyle}"
                               Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,16,12,16" VerticalAlignment="Top">
                    <Border Tag="{Binding AppliedStatus}" Style="{StaticResource WorkspaceStatusBadgeBorderStyle}">
                        <TextBlock Text="{Binding StatusText}" Tag="{Binding AppliedStatus}" Style="{StaticResource WorkspaceStatusBadgeTextStyle}"/>
                    </Border>
                    <Border Tag="{Binding EvidenceClassId}"
                            Margin="0,6,0,0"
                            Style="{StaticResource WorkspaceEvidenceBadgeBorderStyle}"
                            Visibility="{Binding DataContext.ShowContributorEvidenceUi, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding EvidenceClassBadgeText}" Tag="{Binding EvidenceClassId}" Style="{StaticResource WorkspaceEvidenceBadgeTextStyle}"/>
                    </Border>
                    <Border Margin="0,6,0,0"
                            Style="{StaticResource RepairsRiskBadgeBorderStyle}"
                            Visibility="{Binding HasRepairsRiskHint, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding RepairsRiskHint}"
                                   Style="{StaticResource RepairsRiskBadgeTextStyle}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,14,0,14" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="{Binding RunRepairButtonText}"
                            Command="{Binding RunRepairCommand}"
                            ToolTip="{Binding RunRepairTooltip}"
                            Style="{StaticResource RepairsActionButtonStyle}"
                            MinWidth="82"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
