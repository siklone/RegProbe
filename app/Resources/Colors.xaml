<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================== -->
    <!-- NORD COLOR PALETTE (Primitives)                -->
    <!-- ============================================== -->

    <!-- Polar Night (Dark Backgrounds) -->
    <Color x:Key="Nord0">#1B1F27</Color> <!-- Deepest -->
    <Color x:Key="Nord1">#242A36</Color> <!-- Dark -->
    <Color x:Key="Nord2">#2E3546</Color> <!-- Medium -->
    <Color x:Key="Nord3">#3A4256</Color> <!-- Light -->

    <!-- Snow Storm (Light Foreground) -->
    <Color x:Key="Nord4">#D8DEE9</Color>
    <Color x:Key="Nord5">#E5E9F0</Color>
    <Color x:Key="Nord6">#ECEFF4</Color>

    <!-- Frost (Accents) -->
    <Color x:Key="Nord7">#63D9FF</Color> <!-- Teal -->
    <Color x:Key="Nord8">#38D0FF</Color> <!-- Cyan -->
    <Color x:Key="Nord9">#6EA8FF</Color> <!-- Blue -->
    <Color x:Key="Nord10">#315A88</Color> <!-- Dark Blue -->

    <!-- Aurora (Status) -->
    <Color x:Key="Nord11">#FF4C58</Color> <!-- Red -->
    <Color x:Key="Nord12">#FF9C57</Color> <!-- Orange -->
    <Color x:Key="Nord13">#FFD75A</Color> <!-- Yellow -->
    <Color x:Key="Nord14">#5BE58C</Color> <!-- Green -->
    <Color x:Key="Nord15">#C49CF3</Color> <!-- Purple -->

    <!-- ============================================== -->
    <!-- SEMANTIC LAYER SYSTEM (Modern Phase 1)         -->
    <!-- ============================================== -->

    <!-- Base Layer Colors -->
    <Color x:Key="LayerFillColorDefault">#090B10</Color>
    <Color x:Key="LayerFillColorAlt">#0D1118</Color>
    <Color x:Key="CardFillColorDefault">#141923</Color>
    <Color x:Key="CardFillColorSecondary">#1B212C</Color>
    
    <!-- Glass / Alpha System -->
    <Color x:Key="GlassLowColor">#0AFFFFFF</Color>    <!-- 4% -->
    <Color x:Key="GlassMediumColor">#14FFFFFF</Color> <!-- 8% -->
    <Color x:Key="GlassHighColor">#26FFFFFF</Color>   <!-- 15% -->
    <Color x:Key="GlassBorderColor">#24FFFFFF</Color>

    <!-- Text Colors -->
    <Color x:Key="TextFillColorPrimary">#ECEFF4</Color>   <!-- Nord6 -->
    <Color x:Key="TextFillColorSecondary">#D8DEE9</Color> <!-- Nord4 -->
    <Color x:Key="TextFillColorTertiary">#97A2B3</Color>

    <!-- ============================================== -->
    <!-- BRUSH RESOURCES                                -->
    <!-- ============================================== -->

    <!-- 1. Backgrounds -->
    <SolidColorBrush x:Key="BackgroundDarkestBrush" Color="{StaticResource LayerFillColorDefault}"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource LayerFillColorAlt}"/>
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource CardFillColorDefault}"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource CardFillColorSecondary}"/>

    <!-- 2. Foregrounds -->
    <SolidColorBrush x:Key="ForegroundBrightestBrush" Color="{StaticResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="ForegroundBrightBrush" Color="{StaticResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="ForegroundLightBrush" Color="{StaticResource TextFillColorTertiary}"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="{StaticResource TextFillColorTertiary}"/>

    <!-- 3. Accents (Refined) -->
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource Nord7}"/>       <!-- Teal-ish -->
    <SolidColorBrush x:Key="AccentBrightCyanBrush" Color="{StaticResource Nord8}"/> <!-- Primary Cyan -->
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource Nord9}"/>
    <SolidColorBrush x:Key="AccentDarkBlueBrush" Color="{StaticResource Nord10}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource Nord15}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Nord8}"/>           <!-- Alias -->

    <!-- 4. Status -->
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Nord11}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Nord12}"/>
    <SolidColorBrush x:Key="CautionBrush" Color="{StaticResource Nord13}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Nord14}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Nord15}"/>

    <!-- 5. Specialized Surfaces -->
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#1AA3BE8C"/> <!-- 10% Opacity Success -->
    <SolidColorBrush x:Key="SuccessSurfaceAltBrush" Color="#26A3BE8C"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#8BC08E"/>
    <SolidColorBrush x:Key="CautionSurfaceBrush" Color="#1AEBCB8B"/>
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#1ABF616A"/>
    
    <SolidColorBrush x:Key="ForegroundOnAccentBrush" Color="#1B1F27"/> <!-- Dark text on bright accent -->
    <SolidColorBrush x:Key="ForegroundOnLightAccentBrush" Color="#1B1F27"/>
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#171C24"/>

    <!-- ============================================== -->
    <!-- ADVANCED GRADIENTS & EFFECTS                   -->
    <!-- ============================================== -->

    <!-- Main Background Gradient (Subtle Deep Glow) -->
    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#090B10" Offset="0"/>
        <GradientStop Color="#0B0F15" Offset="0.55"/>
        <GradientStop Color="#11151D" Offset="1"/>
    </LinearGradientBrush>

    <!-- Primary Action Gradient (Cyan to Blue) -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Nord8}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord9}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Nord8}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord10}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Hover Gradient -->
    <LinearGradientBrush x:Key="PrimaryGradientHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Nord7}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord8}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glass Brushes -->
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassLowColor}"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorderColor}"/>
    
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="{StaticResource GlassMediumColor}"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="{StaticResource GlassHighColor}"/>
    <SolidColorBrush x:Key="DisabledOverlayBrush" Color="#60000000"/>
    <SolidColorBrush x:Key="ScrimOverlayBrush" Color="#99000000"/>

    <!-- Shared shell and surface brushes -->
    <SolidColorBrush x:Key="ShellWindowBackgroundBrush" Color="#090B10"/>
    <SolidColorBrush x:Key="ShellTitleBarBackgroundBrush" Color="#CC090B10"/>
    <SolidColorBrush x:Key="ShellTitleBarBorderBrush" Color="#16FFFFFF"/>
    <SolidColorBrush x:Key="ShellTopNavItemBrush" Color="#0D1218"/>
    <SolidColorBrush x:Key="ShellTopNavBorderBrush" Color="#24FFFFFF"/>
    <SolidColorBrush x:Key="ShellTopNavHoverBrush" Color="#131821"/>
    <SolidColorBrush x:Key="ShellTopNavHoverBorderBrush" Color="#33FF4C58"/>
    <SolidColorBrush x:Key="ShellTopNavSelectedBrush" Color="#18FF4C58"/>
    <SolidColorBrush x:Key="ShellTopNavSelectedBorderBrush" Color="#66FF4C58"/>
    <SolidColorBrush x:Key="ShellBrandChipBrush" Color="#121720"/>
    <SolidColorBrush x:Key="ShellBrandChipBorderBrush" Color="#44FF4C58"/>
    <SolidColorBrush x:Key="ShellBrandAccentBrush" Color="#FF4C58"/>
    <SolidColorBrush x:Key="ShellWarmGlowBrush" Color="#14FF4C58"/>
    <SolidColorBrush x:Key="ShellCoolGlowBrush" Color="#1200D5FF"/>

    <LinearGradientBrush x:Key="AppSurfaceGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#171B24" Offset="0"/>
        <GradientStop Color="#10141A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppSurfaceAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A141B" Offset="0"/>
        <GradientStop Color="#101319" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppMetricTileGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#171B24" Offset="0"/>
        <GradientStop Color="#10141B" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppDetailSheetGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#171C24" Offset="0"/>
        <GradientStop Color="#10141A" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AppInsetSurfaceBrush" Color="#0F131A"/>
    <SolidColorBrush x:Key="AppChipSurfaceBrush" Color="#10151E"/>
    <SolidColorBrush x:Key="AppQuietButtonBrush" Color="#10151D"/>
    <SolidColorBrush x:Key="AppQuietButtonHoverBrush" Color="#151922"/>
    <SolidColorBrush x:Key="AppQuietButtonPressedBrush" Color="#1C2028"/>
    <SolidColorBrush x:Key="AppMetricTileHoverBrush" Color="#181D27"/>
    <SolidColorBrush x:Key="AppSearchSurfaceBrush" Color="#10141C"/>
    <SolidColorBrush x:Key="AppWorkspaceSurfaceBrush" Color="#121720"/>
    <SolidColorBrush x:Key="AppWorkspaceHoverBrush" Color="#181D28"/>
    <SolidColorBrush x:Key="AppWorkspaceSelectedBrush" Color="#22FF4C58"/>
    <SolidColorBrush x:Key="AppWorkspaceSelectedBorderBrush" Color="#80FF4C58"/>
    <SolidColorBrush x:Key="AppSelectionBoxBrush" Color="#10151C"/>
    <SolidColorBrush x:Key="AppSelectionBoxHoverBrush" Color="#141B24"/>
    <SolidColorBrush x:Key="AppSelectionBoxCheckedBrush" Color="#255B8D"/>
    <SolidColorBrush x:Key="AppSelectionBoxBorderBrush" Color="#73849A"/>
    <SolidColorBrush x:Key="AppSelectionBoxHoverBorderBrush" Color="#92A3B8"/>
    <SolidColorBrush x:Key="AppSelectionBoxCheckedBorderBrush" Color="#82C7FF"/>
    <SolidColorBrush x:Key="AppSelectionCheckBrush" Color="#F9FBFF"/>
    <SolidColorBrush x:Key="DashboardHeroIconBrush" Color="#132131"/>
    <SolidColorBrush x:Key="DashboardHeroIconBorderBrush" Color="#3352C6FF"/>

    <!-- Shadows Match -->
    <Color x:Key="ShadowColorSmall">#26000000</Color>
    <Color x:Key="ShadowColorMedium">#40000000</Color>
    <Color x:Key="ShadowColorLarge">#66000000</Color>
    
    <!-- ============================================== -->
    <!-- GLOW / NEON EFFECTS                            -->
    <!-- ============================================== -->

    <!-- Cyan glow for active elements (like Ashampoo/DefenceByte style) -->
    <Color x:Key="GlowCyanColor">#88C0D0</Color>
    <SolidColorBrush x:Key="GlowCyanBrush" Color="#4488C0D0"/>           <!-- 27% opacity -->
    <SolidColorBrush x:Key="GlowCyanSubtleBrush" Color="#2288C0D0"/>     <!-- 13% -->
    <SolidColorBrush x:Key="GlowCyanBorderBrush" Color="#5588C0D0"/>     <!-- 33% -->

    <!-- Gauge ring gradients -->
    <LinearGradientBrush x:Key="GaugeRingBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#88C0D0" Offset="0"/>
        <GradientStop Color="#5E81AC" Offset="0.5"/>
        <GradientStop Color="#A3BE8C" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card surface with subtle gradient -->
    <LinearGradientBrush x:Key="CardSurfaceGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#242A36" Offset="0"/>
        <GradientStop Color="#1F2530" Offset="1"/>
    </LinearGradientBrush>

    <!-- Hero section radial glow -->
    <RadialGradientBrush x:Key="HeroGlowBrush" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
        <GradientStop Color="#1588C0D0" Offset="0"/>
        <GradientStop Color="#00171B22" Offset="1"/>
    </RadialGradientBrush>

    <!-- Metric card accents -->
    <SolidColorBrush x:Key="MetricCyanSurfaceBrush" Color="#1A88C0D0"/>
    <SolidColorBrush x:Key="MetricBlueSurfaceBrush" Color="#1A5E81AC"/>
    <SolidColorBrush x:Key="MetricPurpleSurfaceBrush" Color="#1AB48EAD"/>
    <SolidColorBrush x:Key="MetricGreenSurfaceBrush" Color="#1AA3BE8C"/>
    <SolidColorBrush x:Key="MetricOrangeSurfaceBrush" Color="#1AD08770"/>

    <!-- Chart Colors Compatibility -->
    <Color x:Key="AccentBrightCyan40">#4086BBD6</Color>
    <Color x:Key="AccentBrightCyan30">#3086BBD6</Color>
    <Color x:Key="AccentBrightCyan20">#2086BBD6</Color>
    <Color x:Key="AccentBrightCyan10">#1086BBD6</Color>
    <Color x:Key="AccentBrightCyan08">#0886BBD6</Color>
    <Color x:Key="AccentBrightCyan00">#0086BBD6</Color>
    <Color x:Key="Success40">#409BCD9E</Color>
    <Color x:Key="Success30">#309BCD9E</Color>
    <Color x:Key="Success20">#209BCD9E</Color>
    <Color x:Key="Success10">#109BCD9E</Color>
    <Color x:Key="Success08">#089BCD9E</Color>
    <Color x:Key="Success00">#009BCD9E</Color>
    <Color x:Key="Danger40">#40E07A7A</Color>
    <Color x:Key="Danger30">#30E07A7A</Color>
    <Color x:Key="Danger20">#20E07A7A</Color>
    <Color x:Key="Danger08">#08E07A7A</Color>
    <Color x:Key="Danger00">#00E07A7A</Color>

</ResourceDictionary>
