<Window x:Class="RegProbe.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:RegProbe.App.Behaviors"
        xmlns:controls="clr-namespace:RegProbe.App.Views.Controls"
        mc:Ignorable="d"
        Title="RegProbe"
        Width="1080"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Background="#0D0D0D"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{DynamicResource FontFamilyText}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding ShowConfigurationCommand}"/>
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding ShowRepairsCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding ShowSettingsCommand}"/>
        <KeyBinding Key="F1" Command="{Binding ShowAboutCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClearFiltersCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="TrafficDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="ShellWindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8D8D8D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#181818"/>
                                <Setter Property="Foreground" Value="#F3F3F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202020"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellWindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                    <Setter Property="Foreground" Value="#F6F6F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ShellTopTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#676767"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6,12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                            <Border x:Name="Accent"
                                    Width="24"
                                    Height="2"
                                    Background="#C0392B"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D8D8D8"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                                <Setter Property="Foreground" Value="#F3F3F3"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Accent" Property="Opacity" Value="1"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Panel.ZIndex="100"
                Background="#111111"
                BorderBrush="#1E1E1E"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Ellipse Style="{StaticResource TrafficDotStyle}" Fill="#FF5F57"/>
                    <Ellipse Style="{StaticResource TrafficDotStyle}" Fill="#FEBC2E"/>
                    <Ellipse Style="{StaticResource TrafficDotStyle}" Fill="#28C840"/>
                    <TextBlock Text="RegProbe"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#666666"
                               FontFamily="{DynamicResource FontFamilyDisplay}"
                               FontSize="12"/>
                </StackPanel>

                <Grid Grid.Column="1"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                      MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize"
                            Style="{StaticResource ShellWindowControlButtonStyle}">
                        <Path Data="M 0,0 H 10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1"
                              StrokeStartLineCap="Square"
                              StrokeEndLineCap="Square"/>
                    </Button>

                    <Button x:Name="MaximizeButton"
                            Click="MaximizeButton_Click"
                            ToolTip="Maximize"
                            Style="{StaticResource ShellWindowControlButtonStyle}">
                        <Rectangle Width="10"
                                   Height="10"
                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   StrokeThickness="1"
                                   Fill="Transparent"/>
                    </Button>

                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click"
                            ToolTip="Close"
                            Style="{StaticResource CloseWindowButtonStyle}">
                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Panel.ZIndex="90"
                Background="#111111"
                BorderBrush="#1A1A1A"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            Grid.Column="0"
                            VerticalAlignment="Center">
                    <Button Content="Configuration"
                            Command="{Binding ShowConfigurationCommand}"
                            Tag="{Binding IsConfigurationViewActive}"
                            Margin="0,0,6,0"
                            Style="{StaticResource ShellTopTabButtonStyle}"/>
                    <Button Content="Repairs"
                            Command="{Binding ShowRepairsCommand}"
                            Tag="{Binding IsRepairsViewActive}"
                            Margin="0,0,6,0"
                            Style="{StaticResource ShellTopTabButtonStyle}"/>
                    <Button Content="Settings"
                            Command="{Binding ShowSettingsCommand}"
                            Tag="{Binding IsSettingsViewActive}"
                            Margin="0,0,6,0"
                            Style="{StaticResource ShellTopTabButtonStyle}"/>
                    <Button Content="About"
                            Command="{Binding ShowAboutCommand}"
                            Tag="{Binding IsAboutViewActive}"
                            Style="{StaticResource ShellTopTabButtonStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding AppVersionLabel}"
                               Margin="20,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#484848"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Border Background="#5A211B"
                        Padding="16,12"
                        Visibility="{Binding HasPendingRollbacks, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="&#xE7BA;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Foreground="#FFF3F1"
                                   Margin="0,0,12,0"/>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Crash recovery required"
                                       Foreground="#FFF3F1"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding PendingRollbackMessage}"
                                       Foreground="#F4D8D3"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Command="{Binding RecoverPendingRollbacksCommand}"
                                    Style="{StaticResource AppQuietActionButtonStyle}"
                                    Background="#1F5C39"
                                    Foreground="#F0FFF5"
                                    Margin="0,0,8,0"
                                    Content="Recover"/>
                            <Button Command="{Binding DismissPendingRollbacksCommand}"
                                    Style="{StaticResource AppQuietActionButtonStyle}"
                                    Background="Transparent"
                                    BorderBrush="#F0D3CE"
                                    Foreground="#F0D3CE"
                                    Content="Dismiss"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#173245"
                        Padding="16,12"
                        Visibility="{Binding IsRecovering, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Foreground="#EAF6FF"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="Recovering pending rollbacks..."
                                   Foreground="#EAF6FF"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#0D0D0D">
                <ContentControl Content="{Binding CurrentViewModel}">
                    <i:Interaction.Behaviors>
                        <behaviors:NavigationTransitionBehavior Transition="FadeAndSlide"/>
                    </i:Interaction.Behaviors>
                </ContentControl>
            </Border>
        </Grid>

        <controls:NotificationHost x:Name="NotificationHost"
                                   Panel.ZIndex="200"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="True"/>

        <controls:LoadingOverlay DataContext="{Binding BusyService}"
                                 Panel.ZIndex="300"
                                 d:IsHidden="True"/>
    </Grid>
</Window>
