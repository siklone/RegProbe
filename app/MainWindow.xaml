<Window x:Class="RegProbe.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:RegProbe.App.Behaviors"
        xmlns:controls="clr-namespace:RegProbe.App.Views.Controls"
        mc:Ignorable="d"
        Title="RegProbe"
        Width="1080"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Background="{DynamicResource ShellWindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{DynamicResource FontFamilyText}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding ShowWorkspaceCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding ShowSettingsCommand}"/>
        <KeyBinding Key="F1" Command="{Binding ShowAboutCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClearFiltersCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="ShellWindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        </Style>

        <Style x:Key="ShellHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ShellTopNavItemBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShellTopNavBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ShellTopNavHoverBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ShellTopNavHoverBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ShellTopNavSelectedBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ShellWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Panel.ZIndex="100"
                Background="{DynamicResource ShellTitleBarBackgroundBrush}"
                BorderBrush="{DynamicResource ShellTitleBarBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="14,9,0,9"
                        Padding="10,0"
                        Background="{DynamicResource ShellBrandChipBrush}"
                        BorderBrush="{DynamicResource ShellBrandChipBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        VerticalAlignment="Stretch"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="RP"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                               FontFamily="{DynamicResource FontFamilyDisplay}"
                               FontWeight="Bold"
                               FontSize="12"/>
                </Border>

                <Grid Grid.Column="1"
                      Margin="14,0,0,0"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                      MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="RegProbe"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                   FontFamily="{DynamicResource FontFamilyDisplay}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Registry research and reversible configuration workspace"
                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                   FontSize="10"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize"
                            Style="{StaticResource ShellWindowControlButtonStyle}">
                        <Path Data="M 0,0 H 10"
                              Stroke="{DynamicResource ForegroundLightBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Square"
                              StrokeEndLineCap="Square"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,10,0,0"/>
                    </Button>

                    <Button x:Name="MaximizeButton"
                            Click="MaximizeButton_Click"
                            ToolTip="Maximize"
                            Style="{StaticResource ShellWindowControlButtonStyle}">
                        <Grid>
                            <Rectangle Width="10"
                                       Height="10"
                                       Stroke="{DynamicResource ForegroundLightBrush}"
                                       StrokeThickness="1"
                                       Fill="Transparent"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ShellWindowControlButtonStyle}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Root" Background="Transparent">
                                                <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                                                      Stroke="{DynamicResource ForegroundLightBrush}"
                                                      StrokeThickness="1.1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="16,12,16,0"
                Style="{StaticResource ShellSubtlePanelStyle}"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Configuration"
                            Command="{Binding ShowWorkspaceCommand}"
                            Tag="{Binding IsWorkspaceViewActive}"
                            Style="{StaticResource ShellHeaderButtonStyle}"/>
                    <Button Content="Settings"
                            Command="{Binding ShowSettingsCommand}"
                            Tag="{Binding IsSettingsViewActive}"
                            Style="{StaticResource ShellHeaderButtonStyle}"/>
                    <Button Content="About"
                            Command="{Binding ShowAboutCommand}"
                            Tag="{Binding IsAboutViewActive}"
                            Style="{StaticResource ShellHeaderButtonStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Ctrl+1  Ctrl+,  F1"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="10"/>
                    <Border Padding="10,6"
                            Background="{DynamicResource ShellPanelRaisedBrush}"
                            BorderBrush="{DynamicResource ShellHairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="{Binding AppVersionLabel}"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                   FontFamily="{DynamicResource FontFamilyMono}"
                                   FontSize="10"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="16,12,16,16"
                Style="{StaticResource ShellPanelStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0">
                    <Border Background="{DynamicResource DangerBrush}"
                            Padding="16,12"
                            CornerRadius="14,14,0,0"
                            Visibility="{Binding HasPendingRollbacks, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="&#xE7BA;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                       Margin="0,0,12,0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Crash Recovery Required"
                                           Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding PendingRollbackMessage}"
                                           Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Command="{Binding RecoverPendingRollbacksCommand}"
                                        Style="{StaticResource AppQuietActionButtonStyle}"
                                        Background="{DynamicResource SuccessBrush}"
                                        Foreground="{DynamicResource ForegroundOnLightAccentBrush}"
                                        Margin="0,0,8,0"
                                        Content="Recover"/>
                                <Button Command="{Binding DismissPendingRollbacksCommand}"
                                        Style="{StaticResource AppQuietActionButtonStyle}"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource ForegroundOnAccentBrush}"
                                        Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                        Content="Dismiss"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource AccentDarkBlueBrush}"
                            Padding="16,12"
                            Visibility="{Binding IsRecovering, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Recovering pending rollbacks..."
                                       Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="14"
                        Background="{DynamicResource ShellSubtleFillBrush}"
                        CornerRadius="12">
                    <ContentControl Content="{Binding CurrentViewModel}">
                        <i:Interaction.Behaviors>
                            <behaviors:NavigationTransitionBehavior Transition="FadeAndSlide"/>
                        </i:Interaction.Behaviors>
                    </ContentControl>
                </Border>
            </Grid>
        </Border>

        <Grid Panel.ZIndex="100"
              IsHitTestVisible="False"
              Visibility="{Binding IsStartupScanActive, Converter={StaticResource BoolToVisibility}}">
            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="252"
                    Margin="0,0,28,28"
                    Padding="16,14"
                    Background="{DynamicResource ShellPanelAltBrush}"
                    BorderBrush="{DynamicResource ShellHairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Opacity="0.98">
                <StackPanel>
                    <TextBlock Text="Background scan"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <ProgressBar Height="4"
                                 Margin="0,10,0,0"
                                 Style="{StaticResource AnimatedLoadingBarStyle}"
                                 IsIndeterminate="True"/>
                </StackPanel>
            </Border>
        </Grid>

        <controls:NotificationHost x:Name="NotificationHost"
                                   Panel.ZIndex="200"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="True"/>

        <controls:LoadingOverlay DataContext="{Binding BusyService}"
                                 Panel.ZIndex="300"
                                 d:IsHidden="True"/>
    </Grid>
</Window>
