<Window x:Class="RegProbe.App.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:RegProbe.App.Behaviors"
        xmlns:controls="clr-namespace:RegProbe.App.Views.Controls"
        mc:Ignorable="d"
        Title="RegProbe"
        Width="1080"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Background="#151515"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{DynamicResource FontFamilyText}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding ShowConfigurationCommand}"/>
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding ShowRepairsCommand}"/>
        <KeyBinding Key="F1" Command="{Binding ShowAboutCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClearFiltersCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="TrafficCommandButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Width="18"
                                Height="18"
                                Background="Transparent">
                            <Grid>
                                <Ellipse x:Name="Dot"
                                         Width="10"
                                         Height="10"
                                         Fill="{TemplateBinding Foreground}"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"/>
                                <Path x:Name="Glyph"
                                      Width="7"
                                      Height="7"
                                      Stroke="#0D0D0D"
                                      StrokeThickness="1.1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"
                                      Stretch="Fill"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Data="{TemplateBinding Tag}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Glyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Dot" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellTopTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6C6C6C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4,10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                            <Border x:Name="Accent"
                                    Width="24"
                                    Height="2"
                                    Background="#C0392B"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#DDDDDD"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" Value="True">
                                <Setter Property="Foreground" Value="#F3F3F3"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Accent" Property="Opacity" Value="1"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#151515">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Panel.ZIndex="100"
                Background="#1B1B1B">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="22,0,0,0"
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="RegProbe"
                               Margin="0,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#A5A5A5"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <Grid Grid.Column="1">
                    <i:Interaction.Behaviors>
                        <behaviors:WindowTitleBarDragBehavior/>
                    </i:Interaction.Behaviors>
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,18,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Command="{Binding HostController.MinimizeCommand, ElementName=RootWindow}"
                            ToolTip="Minimize"
                            Foreground="#FEBC2E"
                            Tag="M 1,3.5 H 6"
                            Margin="0,0,8,0"
                            Style="{StaticResource TrafficCommandButtonStyle}"/>
                    <Button Command="{Binding HostController.ToggleMaximizeRestoreCommand, ElementName=RootWindow}"
                            ToolTip="Maximize or restore"
                            Foreground="#28C840"
                            Tag="M 1,1.2 H 6 V 5.8 H 1 Z"
                            Margin="0,0,8,0"
                            Style="{StaticResource TrafficCommandButtonStyle}"/>
                    <Button Command="{Binding HostController.CloseCommand, ElementName=RootWindow}"
                            ToolTip="Close"
                            Foreground="#FF5F57"
                            Tag="M 1,1 L 6,6 M 6,1 L 1,6"
                            Style="{StaticResource TrafficCommandButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Panel.ZIndex="90"
                Background="#1B1B1B"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,0,22,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Configuration"
                            Command="{Binding ShowConfigurationCommand}"
                            Tag="{Binding IsConfigurationViewActive}"
                            Margin="0,0,16,0"
                            Style="{StaticResource ShellTopTabButtonStyle}"/>
                    <Button Content="Repairs"
                            Command="{Binding ShowRepairsCommand}"
                            Tag="{Binding IsRepairsViewActive}"
                            Margin="0,0,16,0"
                            Style="{StaticResource ShellTopTabButtonStyle}"/>
                    <Button Content="About"
                            Command="{Binding ShowAboutCommand}"
                            Tag="{Binding IsAboutViewActive}"
                            Style="{StaticResource ShellTopTabButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Border Background="#5A211B"
                        Padding="16,12"
                        Visibility="{Binding HasPendingRollbacks, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="&#xE7BA;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Foreground="#FFF3F1"
                                   Margin="0,0,12,0"/>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Crash recovery required"
                                       Foreground="#FFF3F1"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding PendingRollbackMessage}"
                                       Foreground="#F4D8D3"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Command="{Binding RecoverPendingRollbacksCommand}"
                                    Style="{StaticResource AppQuietActionButtonStyle}"
                                    Background="#1F5C39"
                                    Foreground="#F0FFF5"
                                    Margin="0,0,8,0"
                                    Content="Recover"/>
                            <Button Command="{Binding DismissPendingRollbacksCommand}"
                                    Style="{StaticResource AppQuietActionButtonStyle}"
                                    Background="Transparent"
                                    BorderBrush="#F0D3CE"
                                    Foreground="#F0D3CE"
                                    Content="Dismiss"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#173245"
                        Padding="16,12"
                        Visibility="{Binding IsRecovering, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Foreground="#EAF6FF"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="Recovering pending rollbacks..."
                                   Foreground="#EAF6FF"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#151515">
                <ContentControl Content="{Binding CurrentViewModel}">
                    <i:Interaction.Behaviors>
                        <behaviors:NavigationTransitionBehavior Transition="FadeAndSlide"/>
                    </i:Interaction.Behaviors>
                </ContentControl>
            </Border>
        </Grid>

        <controls:NotificationHost x:Name="NotificationHost"
                                   Panel.ZIndex="200"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="True"/>

        <controls:LoadingOverlay DataContext="{Binding BusyService}"
                                 Panel.ZIndex="300"
                                 d:IsHidden="True"/>
    </Grid>
</Window>
