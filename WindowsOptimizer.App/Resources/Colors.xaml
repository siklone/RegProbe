<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nord Color Palette -->

    <!-- Polar Night (Dark Backgrounds) -->
    <Color x:Key="Nord0">#2E3440</Color>
    <Color x:Key="Nord1">#3B4252</Color>
    <Color x:Key="Nord2">#434C5E</Color>
    <Color x:Key="Nord3">#4C566A</Color>

    <!-- Snow Storm (Light Backgrounds) -->
    <Color x:Key="Nord4">#D8DEE9</Color>
    <Color x:Key="Nord5">#E5E9F0</Color>
    <Color x:Key="Nord6">#ECEFF4</Color>

    <!-- Frost (Accents) -->
    <Color x:Key="Nord7">#8FBCBB</Color>
    <Color x:Key="Nord8">#88C0D0</Color>
    <Color x:Key="Nord9">#81A1C1</Color>
    <Color x:Key="Nord10">#5E81AC</Color>

    <!-- Aurora (Status Colors) -->
    <Color x:Key="Nord11">#BF616A</Color>
    <Color x:Key="Nord12">#D08770</Color>
    <Color x:Key="Nord13">#EBCB8B</Color>
    <Color x:Key="Nord14">#A3BE8C</Color>
    <Color x:Key="Nord15">#B48EAD</Color>

    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="BackgroundDarkestBrush" Color="{StaticResource Nord0}"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource Nord1}"/>
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource Nord2}"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource Nord3}"/>

    <SolidColorBrush x:Key="ForegroundLightBrush" Color="{StaticResource Nord4}"/>
    <SolidColorBrush x:Key="ForegroundBrightBrush" Color="{StaticResource Nord5}"/>
    <SolidColorBrush x:Key="ForegroundBrightestBrush" Color="{StaticResource Nord6}"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#A7B0C2"/>

    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource Nord7}"/>
    <SolidColorBrush x:Key="AccentBrightCyanBrush" Color="{StaticResource Nord8}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource Nord9}"/>
    <SolidColorBrush x:Key="AccentDarkBlueBrush" Color="{StaticResource Nord10}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Nord11}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Nord12}"/>
    <SolidColorBrush x:Key="CautionBrush" Color="{StaticResource Nord13}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Nord14}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Nord15}"/>
    <SolidColorBrush x:Key="ForegroundOnAccentBrush" Color="{StaticResource Nord6}"/>
    <SolidColorBrush x:Key="ForegroundOnLightAccentBrush" Color="{StaticResource Nord0}"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#2E4A3E"/>
    <SolidColorBrush x:Key="SuccessSurfaceAltBrush" Color="#3B5C4A"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#8FAE7B"/>
    <SolidColorBrush x:Key="CautionSurfaceBrush" Color="#4A3E2E"/>
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#4A2E2E"/>
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#1E222A"/>

    <!-- Chart Gradient Colors -->
    <Color x:Key="AccentBrightCyan40">#4088C0D0</Color>
    <Color x:Key="AccentBrightCyan30">#3088C0D0</Color>
    <Color x:Key="AccentBrightCyan20">#2088C0D0</Color>
    <Color x:Key="AccentBrightCyan10">#1088C0D0</Color>
    <Color x:Key="AccentBrightCyan08">#0888C0D0</Color>
    <Color x:Key="AccentBrightCyan00">#0088C0D0</Color>
    <Color x:Key="Success40">#40A3BE8C</Color>
    <Color x:Key="Success30">#30A3BE8C</Color>
    <Color x:Key="Success20">#20A3BE8C</Color>
    <Color x:Key="Success10">#10A3BE8C</Color>
    <Color x:Key="Success08">#08A3BE8C</Color>
    <Color x:Key="Success00">#00A3BE8C</Color>
    <Color x:Key="Danger40">#40BF616A</Color>
    <Color x:Key="Danger30">#30BF616A</Color>
    <Color x:Key="Danger20">#20BF616A</Color>
    <Color x:Key="Danger08">#08BF616A</Color>
    <Color x:Key="Danger00">#00BF616A</Color>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Nord0}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord1}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Nord8}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord10}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glassmorphism Effects -->
    <SolidColorBrush x:Key="GlassBrush" Color="#40FFFFFF" Opacity="0.1"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#30FFFFFF" Opacity="0.15"/>

    <!-- Hover/Pressed States -->
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#FFFFFF" Opacity="0.1"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#000000" Opacity="0.2"/>
    <SolidColorBrush x:Key="DisabledOverlayBrush" Color="#000000" Opacity="0.4"/>
    <SolidColorBrush x:Key="ScrimOverlayBrush" Color="#000000" Opacity="0.6"/>

    <!-- Shadows -->
    <Color x:Key="ShadowColorSmall">#20000000</Color>
    <Color x:Key="ShadowColorMedium">#40000000</Color>
    <Color x:Key="ShadowColorLarge">#60000000</Color>

</ResourceDictionary>
