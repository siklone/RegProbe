<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================== -->
    <!-- NORD COLOR PALETTE (Primitives)                -->
    <!-- ============================================== -->

    <!-- Polar Night (Dark Backgrounds) -->
    <Color x:Key="Nord0">#1B1F27</Color> <!-- Deepest -->
    <Color x:Key="Nord1">#242A36</Color> <!-- Dark -->
    <Color x:Key="Nord2">#2E3546</Color> <!-- Medium -->
    <Color x:Key="Nord3">#3A4256</Color> <!-- Light -->

    <!-- Snow Storm (Light Foreground) -->
    <Color x:Key="Nord4">#D8DEE9</Color>
    <Color x:Key="Nord5">#E5E9F0</Color>
    <Color x:Key="Nord6">#ECEFF4</Color>

    <!-- Frost (Accents) -->
    <Color x:Key="Nord7">#8FBCBB</Color> <!-- Teal -->
    <Color x:Key="Nord8">#88C0D0</Color> <!-- Cyan -->
    <Color x:Key="Nord9">#81A1C1</Color> <!-- Blue -->
    <Color x:Key="Nord10">#5E81AC</Color> <!-- Dark Blue -->

    <!-- Aurora (Status) -->
    <Color x:Key="Nord11">#BF616A</Color> <!-- Red -->
    <Color x:Key="Nord12">#D08770</Color> <!-- Orange -->
    <Color x:Key="Nord13">#EBCB8B</Color> <!-- Yellow -->
    <Color x:Key="Nord14">#A3BE8C</Color> <!-- Green -->
    <Color x:Key="Nord15">#B48EAD</Color> <!-- Purple -->

    <!-- ============================================== -->
    <!-- SEMANTIC LAYER SYSTEM (Modern Phase 1)         -->
    <!-- ============================================== -->

    <!-- Base Layer Colors -->
    <Color x:Key="LayerFillColorDefault">#171B22</Color> <!-- Slightly darker than Nord0 for contrast -->
    <Color x:Key="LayerFillColorAlt">#1B1F27</Color>    <!-- Nord0 -->
    <Color x:Key="CardFillColorDefault">#242A36</Color>  <!-- Nord1 -->
    <Color x:Key="CardFillColorSecondary">#2E3546</Color> <!-- Nord2 -->
    
    <!-- Glass / Alpha System -->
    <Color x:Key="GlassLowColor">#0AFFFFFF</Color>    <!-- 4% -->
    <Color x:Key="GlassMediumColor">#14FFFFFF</Color> <!-- 8% -->
    <Color x:Key="GlassHighColor">#26FFFFFF</Color>   <!-- 15% -->
    <Color x:Key="GlassBorderColor">#1FFFFFFF</Color> <!-- 12% border -->

    <!-- Text Colors -->
    <Color x:Key="TextFillColorPrimary">#ECEFF4</Color>   <!-- Nord6 -->
    <Color x:Key="TextFillColorSecondary">#D8DEE9</Color> <!-- Nord4 -->
    <Color x:Key="TextFillColorTertiary">#9EA8BA</Color>  <!-- Muted -->

    <!-- ============================================== -->
    <!-- BRUSH RESOURCES                                -->
    <!-- ============================================== -->

    <!-- 1. Backgrounds -->
    <SolidColorBrush x:Key="BackgroundDarkestBrush" Color="{StaticResource LayerFillColorDefault}"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource LayerFillColorAlt}"/>
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource CardFillColorDefault}"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource CardFillColorSecondary}"/>

    <!-- 2. Foregrounds -->
    <SolidColorBrush x:Key="ForegroundBrightestBrush" Color="{StaticResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="ForegroundBrightBrush" Color="{StaticResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="ForegroundLightBrush" Color="{StaticResource TextFillColorTertiary}"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="{StaticResource TextFillColorTertiary}"/>

    <!-- 3. Accents (Refined) -->
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource Nord7}"/>       <!-- Teal-ish -->
    <SolidColorBrush x:Key="AccentBrightCyanBrush" Color="{StaticResource Nord8}"/> <!-- Primary Cyan -->
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource Nord9}"/>
    <SolidColorBrush x:Key="AccentDarkBlueBrush" Color="{StaticResource Nord10}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource Nord15}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Nord8}"/>           <!-- Alias -->

    <!-- 4. Status -->
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Nord11}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Nord12}"/>
    <SolidColorBrush x:Key="CautionBrush" Color="{StaticResource Nord13}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Nord14}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Nord15}"/>

    <!-- 5. Specialized Surfaces -->
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#1AA3BE8C"/> <!-- 10% Opacity Success -->
    <SolidColorBrush x:Key="SuccessSurfaceAltBrush" Color="#26A3BE8C"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#8BC08E"/>
    <SolidColorBrush x:Key="CautionSurfaceBrush" Color="#1AEBCB8B"/>
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#1ABF616A"/>
    
    <SolidColorBrush x:Key="ForegroundOnAccentBrush" Color="#1B1F27"/> <!-- Dark text on bright accent -->
    <SolidColorBrush x:Key="ForegroundOnLightAccentBrush" Color="#1B1F27"/>
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#171C24"/>

    <!-- ============================================== -->
    <!-- ADVANCED GRADIENTS & EFFECTS                   -->
    <!-- ============================================== -->

    <!-- Main Background Gradient (Subtle Deep Glow) -->
    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#171B22" Offset="0"/>
        <GradientStop Color="#1C2129" Offset="1"/>
    </LinearGradientBrush>

    <!-- Primary Action Gradient (Cyan to Blue) -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Nord8}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord9}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Nord8}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord10}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Hover Gradient -->
    <LinearGradientBrush x:Key="PrimaryGradientHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Nord7}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord8}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glass Brushes -->
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassLowColor}"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorderColor}"/>
    
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="{StaticResource GlassMediumColor}"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="{StaticResource GlassHighColor}"/>
    <SolidColorBrush x:Key="DisabledOverlayBrush" Color="#60000000"/>
    <SolidColorBrush x:Key="ScrimOverlayBrush" Color="#99000000"/>

    <!-- Shadows Match -->
    <Color x:Key="ShadowColorSmall">#26000000</Color>
    <Color x:Key="ShadowColorMedium">#40000000</Color>
    <Color x:Key="ShadowColorLarge">#66000000</Color>
    
    <!-- Chart Colors Compatibility -->
    <Color x:Key="AccentBrightCyan40">#4086BBD6</Color>
    <Color x:Key="AccentBrightCyan30">#3086BBD6</Color>
    <Color x:Key="AccentBrightCyan20">#2086BBD6</Color>
    <Color x:Key="AccentBrightCyan10">#1086BBD6</Color>
    <Color x:Key="AccentBrightCyan08">#0886BBD6</Color>
    <Color x:Key="AccentBrightCyan00">#0086BBD6</Color>
    <Color x:Key="Success40">#409BCD9E</Color>
    <Color x:Key="Success30">#309BCD9E</Color>
    <Color x:Key="Success20">#209BCD9E</Color>
    <Color x:Key="Success10">#109BCD9E</Color>
    <Color x:Key="Success08">#089BCD9E</Color>
    <Color x:Key="Success00">#009BCD9E</Color>
    <Color x:Key="Danger40">#40E07A7A</Color>
    <Color x:Key="Danger30">#30E07A7A</Color>
    <Color x:Key="Danger20">#20E07A7A</Color>
    <Color x:Key="Danger08">#08E07A7A</Color>
    <Color x:Key="Danger00">#00E07A7A</Color>

</ResourceDictionary>
