<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:WindowsOptimizer.App.Converters">

    <!-- Boolean to Visibility Converter -->
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

    <!-- Inverse Boolean Converter -->
    <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

    <!-- Null to Visibility Converter -->
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

    <!-- Null to Collapsed Converter (null → Collapsed, non-null → Visible) -->
    <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>

    <!-- String Empty to Visibility Converter -->
    <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>

    <!-- Arc Converter for Circular Charts -->
    <converters:ArcConverter x:Key="ArcConverter"/>

    <!-- First Character Converter -->
    <converters:FirstCharConverter x:Key="FirstCharConverter"/>

</ResourceDictionary>
