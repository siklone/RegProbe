<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nord Light Theme - Snow Storm as backgrounds, Polar Night as foregrounds -->

    <!-- Snow Storm (Light Backgrounds - now used as backgrounds) -->
    <Color x:Key="Nord0">#F4F6FA</Color>
    <Color x:Key="Nord1">#EDF1F7</Color>
    <Color x:Key="Nord2">#E5EAF2</Color>
    <Color x:Key="Nord3">#D7DDE8</Color>

    <!-- Polar Night (Dark - now used as foregrounds) -->
    <Color x:Key="Nord4">#4A5263</Color>
    <Color x:Key="Nord5">#3E4658</Color>
    <Color x:Key="Nord6">#2F3545</Color>

    <!-- Frost (Accents - slightly darker for light theme) -->
    <Color x:Key="Nord7">#7FB4AE</Color>
    <Color x:Key="Nord8">#78AFC8</Color>
    <Color x:Key="Nord9">#6F94CA</Color>
    <Color x:Key="Nord10">#5678B5</Color>

    <!-- Aurora (Status Colors - same, good contrast on light) -->
    <Color x:Key="Nord11">#D86A6A</Color>
    <Color x:Key="Nord12">#D8916A</Color>
    <Color x:Key="Nord13">#D9B56D</Color>
    <Color x:Key="Nord14">#8FBC91</Color>
    <Color x:Key="Nord15">#B689C8</Color>

    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="BackgroundDarkestBrush" Color="{StaticResource Nord0}"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource Nord1}"/>
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource Nord2}"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource Nord3}"/>

    <SolidColorBrush x:Key="ForegroundLightBrush" Color="{StaticResource Nord4}"/>
    <SolidColorBrush x:Key="ForegroundBrightBrush" Color="{StaticResource Nord5}"/>
    <SolidColorBrush x:Key="ForegroundBrightestBrush" Color="{StaticResource Nord6}"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#667085"/>

    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource Nord7}"/>
    <SolidColorBrush x:Key="AccentBrightCyanBrush" Color="{StaticResource Nord8}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource Nord9}"/>
    <SolidColorBrush x:Key="AccentDarkBlueBrush" Color="{StaticResource Nord10}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Nord11}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Nord12}"/>
    <SolidColorBrush x:Key="CautionBrush" Color="{StaticResource Nord13}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Nord14}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Nord15}"/>
    <SolidColorBrush x:Key="ForegroundOnAccentBrush" Color="{StaticResource Nord0}"/>
    <SolidColorBrush x:Key="ForegroundOnLightAccentBrush" Color="{StaticResource Nord6}"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#E7F2E8"/>
    <SolidColorBrush x:Key="SuccessSurfaceAltBrush" Color="#DDEBDC"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#6FAF74"/>
    <SolidColorBrush x:Key="CautionSurfaceBrush" Color="#F6EEDB"/>
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#F3DEDE"/>
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#F4F6FA"/>

    <!-- Chart Gradient Colors -->
    <Color x:Key="AccentBrightCyan40">#4078AFC8</Color>
    <Color x:Key="AccentBrightCyan30">#3078AFC8</Color>
    <Color x:Key="AccentBrightCyan20">#2078AFC8</Color>
    <Color x:Key="AccentBrightCyan10">#1078AFC8</Color>
    <Color x:Key="AccentBrightCyan08">#0878AFC8</Color>
    <Color x:Key="AccentBrightCyan00">#0078AFC8</Color>
    <Color x:Key="Success40">#408FBC91</Color>
    <Color x:Key="Success30">#308FBC91</Color>
    <Color x:Key="Success20">#208FBC91</Color>
    <Color x:Key="Success10">#108FBC91</Color>
    <Color x:Key="Success08">#088FBC91</Color>
    <Color x:Key="Success00">#008FBC91</Color>
    <Color x:Key="Danger40">#40D86A6A</Color>
    <Color x:Key="Danger30">#30D86A6A</Color>
    <Color x:Key="Danger20">#20D86A6A</Color>
    <Color x:Key="Danger08">#08D86A6A</Color>
    <Color x:Key="Danger00">#00D86A6A</Color>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Nord0}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord2}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Nord8}" Offset="0"/>
        <GradientStop Color="{StaticResource Nord10}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glassmorphism Effects (inverted for light theme) -->
    <SolidColorBrush x:Key="GlassBrush" Color="#000000" Opacity="0.03"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#000000" Opacity="0.08"/>

    <!-- Hover/Pressed States -->
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#000000" Opacity="0.04"/>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="#000000" Opacity="0.12"/>
    <SolidColorBrush x:Key="DisabledOverlayBrush" Color="#FFFFFF" Opacity="0.45"/>
    <SolidColorBrush x:Key="ScrimOverlayBrush" Color="#000000" Opacity="0.5"/>

    <!-- Shared shell and surface brushes -->
    <SolidColorBrush x:Key="ShellWindowBackgroundBrush" Color="#F4F6FA"/>
    <SolidColorBrush x:Key="ShellTitleBarBackgroundBrush" Color="#EEF2F8"/>
    <SolidColorBrush x:Key="ShellTitleBarBorderBrush" Color="#18000000"/>
    <SolidColorBrush x:Key="ShellTopNavItemBrush" Color="#F7F9FD"/>
    <SolidColorBrush x:Key="ShellTopNavBorderBrush" Color="#16000000"/>
    <SolidColorBrush x:Key="ShellTopNavHoverBrush" Color="#EEF3FA"/>
    <SolidColorBrush x:Key="ShellTopNavHoverBorderBrush" Color="#3396A8C6"/>
    <SolidColorBrush x:Key="ShellTopNavSelectedBrush" Color="#22D86A6A"/>
    <SolidColorBrush x:Key="ShellTopNavSelectedBorderBrush" Color="#66D86A6A"/>
    <SolidColorBrush x:Key="ShellBrandChipBrush" Color="#F8FAFD"/>
    <SolidColorBrush x:Key="ShellBrandChipBorderBrush" Color="#55D86A6A"/>
    <SolidColorBrush x:Key="ShellBrandAccentBrush" Color="#D86A6A"/>
    <SolidColorBrush x:Key="ShellWarmGlowBrush" Color="#08D86A6A"/>
    <SolidColorBrush x:Key="ShellCoolGlowBrush" Color="#086F94CA"/>

    <LinearGradientBrush x:Key="AppSurfaceGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F1F5FA" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppSurfaceAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF8F9" Offset="0"/>
        <GradientStop Color="#F3F6FB" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppMetricTileGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FCFDFE" Offset="0"/>
        <GradientStop Color="#EEF3F9" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AppDetailSheetGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#EEF2F8" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AppInsetSurfaceBrush" Color="#F7F9FD"/>
    <SolidColorBrush x:Key="AppChipSurfaceBrush" Color="#F5F7FC"/>
    <SolidColorBrush x:Key="AppQuietButtonBrush" Color="#F6F8FC"/>
    <SolidColorBrush x:Key="AppQuietButtonHoverBrush" Color="#EEF3FA"/>
    <SolidColorBrush x:Key="AppQuietButtonPressedBrush" Color="#E6ECF5"/>
    <SolidColorBrush x:Key="AppMetricTileHoverBrush" Color="#EEF3FA"/>
    <SolidColorBrush x:Key="AppSearchSurfaceBrush" Color="#F8FAFD"/>
    <SolidColorBrush x:Key="AppWorkspaceSurfaceBrush" Color="#F6F8FC"/>
    <SolidColorBrush x:Key="AppWorkspaceHoverBrush" Color="#EEF3FA"/>
    <SolidColorBrush x:Key="AppWorkspaceSelectedBrush" Color="#22D86A6A"/>
    <SolidColorBrush x:Key="AppWorkspaceSelectedBorderBrush" Color="#66D86A6A"/>
    <SolidColorBrush x:Key="AppSelectionBoxBrush" Color="#F8FAFD"/>
    <SolidColorBrush x:Key="AppSelectionBoxHoverBrush" Color="#EEF2F8"/>
    <SolidColorBrush x:Key="AppSelectionBoxCheckedBrush" Color="#6F94CA"/>
    <SolidColorBrush x:Key="AppSelectionBoxBorderBrush" Color="#A8B4C3"/>
    <SolidColorBrush x:Key="AppSelectionBoxHoverBorderBrush" Color="#8C9DB1"/>
    <SolidColorBrush x:Key="AppSelectionBoxCheckedBorderBrush" Color="#6F94CA"/>
    <SolidColorBrush x:Key="AppSelectionCheckBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DashboardHeroIconBrush" Color="#EAF3FF"/>
    <SolidColorBrush x:Key="DashboardHeroIconBorderBrush" Color="#66A8C9FF"/>
    <SolidColorBrush x:Key="MetricCyanSurfaceBrush" Color="#E9F6FB"/>
    <SolidColorBrush x:Key="MetricBlueSurfaceBrush" Color="#E9EEF9"/>
    <SolidColorBrush x:Key="MetricPurpleSurfaceBrush" Color="#F2ECF7"/>
    <SolidColorBrush x:Key="MetricGreenSurfaceBrush" Color="#E8F4EA"/>
    <SolidColorBrush x:Key="MetricOrangeSurfaceBrush" Color="#F8EEE6"/>

    <!-- Shadows -->
    <Color x:Key="ShadowColorSmall">#12000000</Color>
    <Color x:Key="ShadowColorMedium">#20000000</Color>
    <Color x:Key="ShadowColorLarge">#2E000000</Color>

</ResourceDictionary>
