<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>

    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    
    <!-- Quantum Optimizations -->
    <!-- NOTE: ReadyToRun publish can fail on duplicate simple-name inputs (e.g., Dia2Lib.dll). -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>WindowsOptimizer.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="LibreHardwareMonitorLib" Version="0.9.6" />
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" Version="1.1.135" />
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="1.1.0" />
    <PackageReference Include="System.Drawing.Common" Version="8.0.24" />
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="8.0.1" />
    <PackageReference Include="TaskScheduler" Version="2.12.2" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\tray-icon.ico" Condition="Exists('Resources\tray-icon.ico')" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\\WindowsOptimizer.Core\\WindowsOptimizer.Core.csproj" />
    <ProjectReference Include="..\\WindowsOptimizer.Engine\\WindowsOptimizer.Engine.csproj" />
    <ProjectReference Include="..\\WindowsOptimizer.Infrastructure\\WindowsOptimizer.Infrastructure.csproj" />
    <ProjectReference Include="..\\WindowsOptimizer.ElevatedHost\\WindowsOptimizer.ElevatedHost.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\\WindowsOptimizer.Plugins.DevTools\\WindowsOptimizer.Plugins.DevTools.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <Target Name="CopyElevatedHostAfterBuild" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <ElevatedHostRid Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)</ElevatedHostRid>
      <ElevatedHostRid Condition="'$(ElevatedHostRid)' == ''">win-x64</ElevatedHostRid>

      <ElevatedHostOutputDir>$(MSBuildProjectDirectory)\\..\\WindowsOptimizer.ElevatedHost\\bin\\$(Configuration)\\$(TargetFramework)\\$(ElevatedHostRid)\\</ElevatedHostOutputDir>
      <ElevatedHostDestinationDir>$(TargetDir)ElevatedHost\\</ElevatedHostDestinationDir>
    </PropertyGroup>
    <ItemGroup>
      <ElevatedHostFilesAfterBuild Include="$(ElevatedHostOutputDir)**\\*.*" />
    </ItemGroup>

    <Copy SourceFiles="@(ElevatedHostFilesAfterBuild)" DestinationFiles="@(ElevatedHostFilesAfterBuild->'$(ElevatedHostDestinationDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyElevatedHostAfterPublish" AfterTargets="Publish" Condition="'$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <ElevatedHostRid Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)</ElevatedHostRid>
      <ElevatedHostRid Condition="'$(ElevatedHostRid)' == ''">win-x64</ElevatedHostRid>

      <ElevatedHostOutputDir>$(MSBuildProjectDirectory)\\..\\WindowsOptimizer.ElevatedHost\\bin\\$(Configuration)\\$(TargetFramework)\\$(ElevatedHostRid)\\</ElevatedHostOutputDir>
      <ElevatedHostDestinationDir>$(PublishDir)ElevatedHost\\</ElevatedHostDestinationDir>
    </PropertyGroup>
    <ItemGroup>
      <ElevatedHostFilesAfterPublish Include="$(ElevatedHostOutputDir)**\\*.*" />
    </ItemGroup>

    <Copy SourceFiles="@(ElevatedHostFilesAfterPublish)" DestinationFiles="@(ElevatedHostFilesAfterPublish->'$(ElevatedHostDestinationDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyDocsAfterBuild" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <DocsSourceDir>$(MSBuildProjectDirectory)\\..\\Docs\\</DocsSourceDir>
      <DocsDestinationDir>$(TargetDir)Docs\\</DocsDestinationDir>
    </PropertyGroup>
    <ItemGroup Condition="Exists('$(DocsSourceDir)')">
      <DocsFilesAfterBuild Include="$(DocsSourceDir)**\\*.*" />
    </ItemGroup>
    <Copy Condition="Exists('$(DocsSourceDir)')" SourceFiles="@(DocsFilesAfterBuild)" DestinationFiles="@(DocsFilesAfterBuild->'$(DocsDestinationDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyDocsAfterPublish" AfterTargets="Publish" Condition="'$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <DocsSourceDir>$(MSBuildProjectDirectory)\\..\\Docs\\</DocsSourceDir>
      <DocsDestinationDir>$(PublishDir)Docs\\</DocsDestinationDir>
    </PropertyGroup>
    <ItemGroup Condition="Exists('$(DocsSourceDir)')">
      <DocsFilesAfterPublish Include="$(DocsSourceDir)**\\*.*" />
    </ItemGroup>
    <Copy Condition="Exists('$(DocsSourceDir)')" SourceFiles="@(DocsFilesAfterPublish)" DestinationFiles="@(DocsFilesAfterPublish->'$(DocsDestinationDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyBundledPluginsAfterPublish" AfterTargets="Publish" Condition="'$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <BundledPluginsDestinationDir>$(PublishDir)Plugins\</BundledPluginsDestinationDir>
    </PropertyGroup>

    <ItemGroup>
      <BundledPluginAssemblies Include="$(MSBuildProjectDirectory)\..\WindowsOptimizer.Plugins.DevTools\bin\$(Configuration)\$(TargetFramework)\WindowsOptimizer.Plugins.DevTools.dll" Condition="Exists('$(MSBuildProjectDirectory)\..\WindowsOptimizer.Plugins.DevTools\bin\$(Configuration)\$(TargetFramework)\WindowsOptimizer.Plugins.DevTools.dll')" />
    </ItemGroup>

    <MakeDir Directories="$(BundledPluginsDestinationDir)" />
    <Copy SourceFiles="@(BundledPluginAssemblies)" DestinationFolder="$(BundledPluginsDestinationDir)" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyBundledPluginsAfterBuild" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <BundledPluginsDestinationDir>$(TargetDir)Plugins\</BundledPluginsDestinationDir>
    </PropertyGroup>

    <ItemGroup>
      <BundledPluginAssemblies Include="$(MSBuildProjectDirectory)\..\WindowsOptimizer.Plugins.DevTools\bin\$(Configuration)\$(TargetFramework)\WindowsOptimizer.Plugins.DevTools.dll" Condition="Exists('$(MSBuildProjectDirectory)\..\WindowsOptimizer.Plugins.DevTools\bin\$(Configuration)\$(TargetFramework)\WindowsOptimizer.Plugins.DevTools.dll')" />
    </ItemGroup>

    <MakeDir Directories="$(BundledPluginsDestinationDir)" />
    <Copy SourceFiles="@(BundledPluginAssemblies)" DestinationFolder="$(BundledPluginsDestinationDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
