<Window x:Class="WindowsOptimizer.App.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Optimizer"
        Width="240"
        Height="56"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Storyboard x:Key="VistaBootBarStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="GlowSegment"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-88"
                             To="188"
                             Duration="0:0:1.15"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource VistaBootBarStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid Background="Transparent"
          IsHitTestVisible="False">
        <Border Width="180"
                Height="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="4"
                Background="#14FFFFFF"
                BorderBrush="#28FFFFFF"
                BorderThickness="1">
            <Grid ClipToBounds="True">
                <Border x:Name="GlowSegment"
                        Width="72"
                        Height="8"
                        CornerRadius="4"
                        HorizontalAlignment="Left">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">
                            <GradientStop Color="#0018FF9A" Offset="0"/>
                            <GradientStop Color="#8877FFD1" Offset="0.35"/>
                            <GradientStop Color="#EEB4FFE8" Offset="0.5"/>
                            <GradientStop Color="#8877FFD1" Offset="0.65"/>
                            <GradientStop Color="#0018FF9A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10"
                                          ShadowDepth="0"
                                          Opacity="0.65"
                                          Color="#9BFFE1"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <TranslateTransform X="-88"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
