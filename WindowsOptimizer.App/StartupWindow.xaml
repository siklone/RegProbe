<Window x:Class="WindowsOptimizer.App.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Optimizer"
        Width="1100"
        Height="700"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        ShowActivated="False"
        AllowsTransparency="False"
        Background="#FF080A0F"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="LowQuality"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SineEase x:Key="EaseInOut" EasingMode="EaseInOut"/>
        <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>
        <BackEase x:Key="SnapEase" EasingMode="EaseOut" Amplitude="0.42"/>

        <Storyboard x:Key="StartupSceneStoryboard">
            <DoubleAnimation Storyboard.TargetName="BackgroundMesh"
                             Storyboard.TargetProperty="Opacity"
                             From="0.18"
                             To="1"
                             Duration="0:0:0.55"/>
            <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.05"
                             To="1"
                             Duration="0:0:0.55">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.05"
                             To="1"
                             Duration="0:0:0.55">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="OuterRing"
                             Storyboard.TargetProperty="StrokeDashOffset"
                             BeginTime="0:0:0.4"
                             From="565"
                             To="0"
                             Duration="0:0:1.2">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="InnerRing"
                             Storyboard.TargetProperty="StrokeDashOffset"
                             BeginTime="0:0:0.7"
                             From="440"
                             To="0"
                             Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="InnerRingAppearRotate"
                             Storyboard.TargetProperty="Angle"
                             BeginTime="0:0:0.7"
                             From="-90"
                             To="0"
                             Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="LogoShape"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:0.9"
                             From="0"
                             To="1"
                             Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleX"
                             BeginTime="0:0:0.9"
                             From="0.6"
                             To="1"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="SnapEase"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleY"
                             BeginTime="0:0:0.9"
                             From="0.6"
                             To="1"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="SnapEase"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoRotate"
                             Storyboard.TargetProperty="Angle"
                             BeginTime="0:0:0.9"
                             From="-20"
                             To="0"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="SnapEase"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CenterDot"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:1.1"
                             From="0"
                             To="1"
                             Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="CenterDotScale"
                             Storyboard.TargetProperty="ScaleX"
                             BeginTime="0:0:1.1"
                             From="1"
                             To="1.4"
                             Duration="0:0:0.3"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CenterDotScale"
                             Storyboard.TargetProperty="ScaleY"
                             BeginTime="0:0:1.1"
                             From="1"
                             To="1.4"
                             Duration="0:0:0.3"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CenterDotScale"
                             Storyboard.TargetProperty="ScaleX"
                             BeginTime="0:0:1.8"
                             From="1"
                             To="1.15"
                             Duration="0:0:1.5"
                             AutoReverse="True"
                             RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CenterDotScale"
                             Storyboard.TargetProperty="ScaleY"
                             BeginTime="0:0:1.8"
                             From="1"
                             To="1.15"
                             Duration="0:0:1.5"
                             AutoReverse="True"
                             RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="TitleWrap"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:1.4"
                             From="0"
                             To="1"
                             Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="TitleTranslate"
                             Storyboard.TargetProperty="Y"
                             BeginTime="0:0:1.4"
                             From="16"
                             To="0"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <StaticResource ResourceKey="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="VersionBadge"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:1.7"
                             From="0"
                             To="1"
                             Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="TaglineText"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:1.75"
                             From="0"
                             To="1"
                             Duration="0:0:0.4"/>

            <DoubleAnimation Storyboard.TargetName="LoadSection"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:1.9"
                             From="0"
                             To="1"
                             Duration="0:0:0.3"/>

            <DoubleAnimation Storyboard.TargetName="OuterRingRotate"
                             Storyboard.TargetProperty="Angle"
                             BeginTime="0:0:0"
                             From="0"
                             To="360"
                             Duration="0:0:20"
                             RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="InnerRingRotate"
                             Storyboard.TargetProperty="Angle"
                             BeginTime="0:0:0"
                             From="0"
                             To="-360"
                             Duration="0:0:20"
                             RepeatBehavior="Forever"/>

            <DoubleAnimation Storyboard.TargetName="ScanlineTranslate"
                             Storyboard.TargetProperty="Y"
                             BeginTime="0:0:3.2"
                             From="-20"
                             To="900"
                             Duration="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetName="Scanline"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:3.2"
                             From="0"
                             To="0.78"
                             Duration="0:0:0.08"
                             AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="Scanline"
                             Storyboard.TargetProperty="Opacity"
                             BeginTime="0:0:3.28"
                             From="0.78"
                             To="0.78"
                             Duration="0:0:0.56"/>
        </Storyboard>

        <Storyboard x:Key="ShimmerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                             Storyboard.TargetProperty="X"
                             From="-220"
                             To="360"
                             Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="SceneRoot"
          Background="#FF080A0F"
          SnapsToDevicePixels="True">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="SceneScale"
                            ScaleX="1"
                            ScaleY="1"/>
        </Grid.RenderTransform>

        <Grid x:Name="BackgroundMesh"
              Opacity="0.18"
              IsHitTestVisible="False"
              CacheMode="BitmapCache">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="BackgroundScale"
                                ScaleX="1.05"
                                ScaleY="1.05"/>
            </Grid.RenderTransform>

            <Rectangle Fill="#080A0F"/>

            <Ellipse Width="920"
                     Height="760"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Margin="-140,0,0,-240">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#24FF3B3B" Offset="0"/>
                        <GradientStop Color="#10FF3B3B" Offset="0.52"/>
                        <GradientStop Color="#00FF3B3B" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="760"
                     Height="640"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-180,-90,0">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#1600D4FF" Offset="0"/>
                        <GradientStop Color="#0B00D4FF" Offset="0.5"/>
                        <GradientStop Color="#0000D4FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="420"
                     Height="420"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#12FF8C42" Offset="0"/>
                        <GradientStop Color="#08FF8C42" Offset="0.55"/>
                        <GradientStop Color="#00FF8C42" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Rectangle Opacity="0.18">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,6,6"
                                  ViewportUnits="Absolute"
                                  Viewbox="0,0,6,6"
                                  ViewboxUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#11FFFFFF">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,6,1"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <Canvas x:Name="ParticleCanvas"
                IsHitTestVisible="False"/>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="780"
                Height="520"
                Background="#A00B0E14"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="28"
                CacheMode="BitmapCache">

            <Grid Margin="48,36,48,34">
                <Grid.RowDefinitions>
                    <RowDefinition Height="260"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="240"
                      Height="240">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="OuterRingRotate"
                                         Angle="0"
                                         CenterX="120"
                                         CenterY="120"/>
                    </Grid.RenderTransform>

                    <Canvas Width="240"
                            Height="240">
                        <Ellipse x:Name="OuterRing"
                                 Width="180"
                                 Height="180"
                                 Canvas.Left="30"
                                 Canvas.Top="30"
                                 Stroke="#E6FF4A4A"
                                 StrokeThickness="1.5"
                                 StrokeDashArray="565 565"
                                 StrokeDashOffset="565"/>

                        <Line X1="120" Y1="22" X2="120" Y2="34" Stroke="#AAFF4A4A" StrokeThickness="1.35"/>
                        <Line X1="120" Y1="206" X2="120" Y2="218" Stroke="#AAFF4A4A" StrokeThickness="1.35"/>
                        <Line X1="22" Y1="120" X2="34" Y2="120" Stroke="#AAFF4A4A" StrokeThickness="1.35"/>
                        <Line X1="206" Y1="120" X2="218" Y2="120" Stroke="#AAFF4A4A" StrokeThickness="1.35"/>
                    </Canvas>

                    <Grid Width="240"
                          Height="240">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="InnerRingRotate"
                                             Angle="0"
                                             CenterX="120"
                                             CenterY="120"/>
                        </Grid.RenderTransform>

                        <Canvas Width="240"
                                Height="240">
                            <Ellipse x:Name="InnerRing"
                                     Width="140"
                                     Height="140"
                                     Canvas.Left="50"
                                     Canvas.Top="50"
                                     Stroke="#CC00D4FF"
                                     StrokeThickness="1.25"
                                     StrokeDashArray="440 440"
                                     StrokeDashOffset="440">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="InnerRingAppearRotate"
                                                     Angle="-90"
                                                     CenterX="70"
                                                     CenterY="70"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="140"
                                     Height="140"
                                     Canvas.Left="50"
                                     Canvas.Top="50"
                                     Stroke="#AA00D4FF"
                                     StrokeThickness="1.25"
                                     StrokeDashArray="6 8"/>
                        </Canvas>
                    </Grid>

                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="LogoScale"
                                                ScaleX="0.6"
                                                ScaleY="0.6"/>
                                <RotateTransform x:Name="LogoRotate"
                                                 Angle="-20"/>
                            </TransformGroup>
                        </Grid.RenderTransform>

                        <Border x:Name="LogoShape"
                                Width="50"
                                Height="50"
                                Opacity="0"
                                Background="#1FFF3B3B"
                                BorderBrush="#72FF4A4A"
                                BorderThickness="1.2"
                                CornerRadius="7"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform Angle="45"/>
                            </Border.RenderTransform>
                        </Border>

                        <Ellipse x:Name="CenterDot"
                                 Width="10"
                                 Height="10"
                                 Opacity="0"
                                 Fill="#FFFF3B3B"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="CenterDotScale"
                                                ScaleX="1"
                                                ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                </Grid>

                <StackPanel x:Name="TitleWrap"
                            Grid.Row="1"
                            Opacity="0"
                            HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="TitleTranslate"
                                            Y="16"/>
                    </StackPanel.RenderTransform>

                    <TextBlock x:Name="TitleText"
                               Text="Windows Optimizer Suite"
                               FontSize="26"
                               FontWeight="SemiBold"
                               FontFamily="{DynamicResource FontFamilyDisplay}"
                               Foreground="#FFE8EAF0"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <Border x:Name="VersionBadge"
                            Opacity="0"
                            Margin="0,10,0,0"
                            Padding="10,4"
                            Background="#110F141B"
                            BorderBrush="#28FF3B3B"
                            BorderThickness="1"
                            CornerRadius="8"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="VersionText"
                                   Text="v0.1.0 - Preview Build"
                                   FontSize="10"
                                   FontFamily="{DynamicResource FontFamilyMono}"
                                   Foreground="#FFFF3B3B"
                                   TextAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TaglineText"
                               Opacity="0"
                               Margin="0,10,0,0"
                               Text="System intelligence for serious machines"
                               FontSize="12"
                               Foreground="#CC8892A4"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="LoadSection"
                            Grid.Row="3"
                            Opacity="0"
                            Margin="0,26,0,0"
                            HorizontalAlignment="Center">
                    <Border Width="240"
                            Height="4"
                            Background="#12FFFFFF"
                            BorderBrush="#20FFFFFF"
                            BorderThickness="1"
                            CornerRadius="2"
                            ClipToBounds="True">
                        <Grid>
                            <Border x:Name="LoadFill"
                                    Background="#FFFF3B3B"
                                    HorizontalAlignment="Stretch"
                                    CornerRadius="2"
                                    RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="LoadFillScale"
                                                    ScaleX="0"
                                                    ScaleY="1"/>
                                </Border.RenderTransform>
                            </Border>

                            <Rectangle Width="86"
                                       Height="4"
                                       HorizontalAlignment="Left"
                                       Opacity="0.7"
                                       IsHitTestVisible="False">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="ShimmerTranslate"
                                                        X="-220"/>
                                </Rectangle.RenderTransform>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0.5"
                                                         EndPoint="1,0.5">
                                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                                        <GradientStop Color="#55FFFFFF" Offset="0.45"/>
                                        <GradientStop Color="#CCFFFFFF" Offset="0.55"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="LoadLabel"
                               Margin="0,10,0,0"
                               FontSize="10"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               Foreground="#FF3A4455"
                               Text="Initializing..."
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="4"
                           Margin="0,18,0,0"
                           VerticalAlignment="Bottom"
                           FontSize="9"
                           FontFamily="{DynamicResource FontFamilyMono}"
                           Foreground="#803A4455"
                           Text="(c) 2025 Windows Optimizer Suite"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <Rectangle x:Name="Scanline"
                   Height="2"
                   VerticalAlignment="Top"
                   Opacity="0"
                   IsHitTestVisible="False">
            <Rectangle.RenderTransform>
                <TranslateTransform x:Name="ScanlineTranslate"
                                    Y="-20"/>
            </Rectangle.RenderTransform>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0.5"
                                     EndPoint="1,0.5">
                    <GradientStop Color="#00FF3B3B" Offset="0"/>
                    <GradientStop Color="#00FF3B3B" Offset="0.12"/>
                    <GradientStop Color="#AAFF3B3B" Offset="0.5"/>
                    <GradientStop Color="#00FF3B3B" Offset="0.88"/>
                    <GradientStop Color="#00FF3B3B" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>
