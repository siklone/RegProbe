<Window x:Class="WindowsOptimizer.App.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Optimizer"
        Width="240"
        Height="56"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Grid Background="Transparent"
          IsHitTestVisible="False">
        <Border x:Name="TrackHost"
                Width="196"
                Height="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="5"
                Background="#1727342C"
                BorderBrush="#2E8DE0B8"
                BorderThickness="1">
            <Grid ClipToBounds="True">
                <Border Background="#1337A071"
                        CornerRadius="5"/>
                <Canvas x:Name="SweepCanvas">
                    <Border x:Name="GlowSegment"
                            Width="64"
                            Height="10"
                            Canvas.Left="-88"
                            CornerRadius="5"
                            Opacity="0.98">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#0038F0B1" Offset="0"/>
                                <GradientStop Color="#9A5EF9C7" Offset="0.30"/>
                                <GradientStop Color="#F7D2FFF0" Offset="0.52"/>
                                <GradientStop Color="#9A5EF9C7" Offset="0.72"/>
                                <GradientStop Color="#0038F0B1" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14"
                                              ShadowDepth="0"
                                              Opacity="0.9"
                                              Color="#A5FFE9"/>
                        </Border.Effect>
                    </Border>
                    <Border x:Name="TrailSegment"
                            Width="110"
                            Height="10"
                            Canvas.Left="-128"
                            CornerRadius="5"
                            Opacity="0.34">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#0018FF9A" Offset="0"/>
                                <GradientStop Color="#664AF0B6" Offset="0.48"/>
                                <GradientStop Color="#0018FF9A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</Window>
