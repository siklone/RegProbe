<UserControl x:Class="WindowsOptimizer.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Section Card Style -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- Modern Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="44" Height="24">
                                <Border x:Name="Track"
                                        Background="{DynamicResource BackgroundMediumBrush}"
                                        CornerRadius="12"
                                        BorderBrush="{DynamicResource BackgroundLightBrush}"
                                        BorderThickness="1"/>
                                <Border x:Name="Thumb"
                                        Width="18" Height="18"
                                        CornerRadius="9"
                                        Background="{DynamicResource ForegroundLightBrush}"
                                        HorizontalAlignment="Left"
                                        Margin="3,0,0,0"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundDarkestBrush}">
        <Grid Margin="32">
            <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                <!-- Header -->
                <TextBlock Text="{Binding Title}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                <TextBlock Margin="0,8,0,32"
                           Text="Configure application preferences and integration settings."
                           Foreground="{DynamicResource AccentBrightCyanBrush}"
                           FontSize="14"/>

                <!-- Appearance Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource SuccessBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="🎨" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Appearance"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding IsDarkTheme}"
                                  Content="Dark Theme"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="56,0,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Switch between dark and light color schemes
                        </TextBlock>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding EnableCardShadows}"
                                  Content="Card Shadows"
                                  Margin="0,16,0,8"/>
                        <TextBlock Margin="56,0,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Toggle drop shadows on cards and controls (default off for smoother scrolling).
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Startup & Scans Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="🚀" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Startup &amp; Scans"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding RunStartupScanOnLaunch}"
                                  Content="Run startup scan on launch"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="56,0,0,16"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Performs a quick startup scan before the main window appears.
                        </TextBlock>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding ShowPreviewHint}"
                                  Content="Show Preview mode hint on Dashboard"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="56,0,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Displays the Preview tip badge next to System Status.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Monitoring Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource AccentBrightCyanBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="📈" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Monitoring"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11" Margin="0,0,0,16">
                            Use Customize in Monitor to reorder or hide sections. Reset restores defaults.
                        </TextBlock>

                        <Button Content="Reset Monitor Layout"
                                Command="{Binding ResetMonitorLayoutCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Discord Integration Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#5865F2" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="💬" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Discord Integration"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Webhook URL -->
                        <TextBlock Text="Webhook URL"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Create a webhook in Discord → Server Settings → Integrations → Webhooks
                        </TextBlock>

                        <!-- Toggles -->
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding DiscordNotificationsEnabled}"
                                  Content="Enable Discord Notifications"
                                  Margin="0,0,0,16"/>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding DiscordAutoPatchEnabled}"
                                  Content="Enable Automatic Patch Creation"
                                  Margin="0,0,0,16"/>

                        <!-- Test Button -->
                        <Button Content="🧪 Test Webhook"
                                Command="{Binding TestWebhookCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Application Info Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="ℹ️" FontFamily="Segoe UI Emoji" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Application Information"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Version" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Build" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding BuildConfiguration}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Framework" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding Framework}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="16" Margin="0,20,0,0">
                            <TextBlock Foreground="{DynamicResource ForegroundLightBrush}" FontSize="12" TextWrapping="Wrap">
                                <Run Text="Windows Optimizer Suite" FontWeight="SemiBold"/>
                                <Run Text="- A modern, safe, and reversible Windows optimization tool built with WPF and .NET 8."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <Border Background="{DynamicResource BackgroundDarkBrush}"
                        BorderBrush="{DynamicResource AccentDarkBlueBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource AccentBrightCyanBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <Button Content="💾 Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
