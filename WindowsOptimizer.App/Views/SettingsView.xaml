<UserControl x:Class="WindowsOptimizer.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Section Card Style -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
        
        <!-- Modern Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="44" Height="24">
                                <Border x:Name="Track" 
                                        Background="#434C5E" 
                                        CornerRadius="12"
                                        BorderBrush="#4C566A"
                                        BorderThickness="1"/>
                                <Border x:Name="Thumb" 
                                        Width="18" Height="18" 
                                        CornerRadius="9"
                                        Background="#D8DEE9"
                                        HorizontalAlignment="Left"
                                        Margin="3,0,0,0"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#5E81AC"/>
                                <Setter TargetName="Thumb" Property="Background" Value="#ECEFF4"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#D8DEE9"/>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#434C5E"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5E81AC"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#81A1C1"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#434C5E"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#2E3440">
        <Grid Margin="32">
            <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                <!-- Header -->
                <TextBlock Text="{Binding Title}" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="#ECEFF4"/>
                <TextBlock Margin="0,8,0,32"
                           Text="Configure application preferences and integration settings."
                           Foreground="#88C0D0"
                           FontSize="14"/>

                <!-- Discord Integration Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#5865F2" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="💬" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Discord Integration" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="#ECEFF4"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Webhook URL -->
                        <TextBlock Text="Webhook URL" 
                                   FontWeight="SemiBold" 
                                   Foreground="#D8DEE9"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Foreground="#4C566A"
                                   FontSize="11">
                            Create a webhook in Discord → Server Settings → Integrations → Webhooks
                        </TextBlock>

                        <!-- Toggles -->
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding DiscordNotificationsEnabled}"
                                  Content="Enable Discord Notifications"
                                  Margin="0,0,0,16"/>
                        
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding DiscordAutoPatchEnabled}"
                                  Content="Enable Automatic Patch Creation"
                                  Margin="0,0,0,16"/>

                        <!-- Test Button -->
                        <Button Content="🧪 Test Webhook"
                                Command="{Binding TestWebhookCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Application Info Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#5E81AC" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="ℹ️" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Application Information" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="#ECEFF4"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Version" Foreground="#4C566A" FontSize="11"/>
                                <TextBlock Text="1.0.0" Foreground="#88C0D0" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Build" Foreground="#4C566A" FontSize="11"/>
                                <TextBlock Text="Release" Foreground="#88C0D0" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Framework" Foreground="#4C566A" FontSize="11"/>
                                <TextBlock Text=".NET 8.0" Foreground="#88C0D0" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#434C5E" CornerRadius="8" Padding="16" Margin="0,20,0,0">
                            <TextBlock Foreground="#D8DEE9" FontSize="12" TextWrapping="Wrap">
                                <Run Text="Windows Optimizer Suite" FontWeight="SemiBold"/>
                                <Run Text="- A modern, safe, and reversible Windows optimization tool built with WPF and .NET 8."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <Border Background="#3B4252" 
                        BorderBrush="#5E81AC" 
                        BorderThickness="1"
                        CornerRadius="8" 
                        Padding="16"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#88C0D0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <Button Content="💾 Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
