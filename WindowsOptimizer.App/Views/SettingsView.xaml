<UserControl x:Class="WindowsOptimizer.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Section Card Style -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- Modern Toggle Switch Style -->
        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="Left">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Content="{TemplateBinding Content}" 
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  Margin="{TemplateBinding Padding}" 
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="{DynamicResource ForegroundLightBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource BackgroundDarkBrush}" BorderThickness="1" BorderBrush="{DynamicResource BackgroundLightBrush}" CornerRadius="8" Margin="0,4,0,0">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundDarkestBrush}">
        <Grid Margin="32">
            <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                <!-- Header -->
                <TextBlock Text="{Binding Title}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                <TextBlock Margin="0,8,0,32"
                           Text="Configure application preferences and integration settings."
                           Foreground="{DynamicResource AccentBrightCyanBrush}"
                           FontSize="14"/>

                <!-- Appearance Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource SuccessBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="🎨" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Appearance"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Accent Theme" Margin="0,0,0,8" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="13" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding AvailableThemes}" 
                                  SelectedItem="{Binding CurrentThemePalette}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="0,0,0,24"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Choose the primary accent color.
                        </TextBlock>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding IsDarkTheme}"
                                  Content="Dark Mode Base"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="56,0,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Use dark background colors (currently main supported mode).
                        </TextBlock>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding EnableCardShadows}"
                                  Content="Card Shadows"
                                  Margin="0,16,0,8"/>
                        <TextBlock Margin="56,0,0,16"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Toggle drop shadows on cards and controls (default off for smoother scrolling).
                        </TextBlock>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding IsCompactMode}"
                                  Content="Compact &quot;Pro&quot; Mode"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="56,0,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Reduce density of lists for power users to see more items at once.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Startup & Scans Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="🚀" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Startup &amp; Scans"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding RunStartupScanOnLaunch}"
                                  Content="Run startup scan on launch"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="56,0,0,16"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Performs a quick startup scan before the main window appears.
                        </TextBlock>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding ShowPreviewHint}"
                                  Content="Show Preview mode hint on Dashboard"
                                  Margin="0,0,0,8"/>
                        <TextBlock Margin="56,0,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Displays the Preview tip badge next to System Status.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Monitoring Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource AccentBrightCyanBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="📈" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Monitoring"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11" Margin="0,0,0,16">
                            Use Customize in Monitor to reorder or hide sections. Reset restores defaults.
                        </TextBlock>

                        <Button Content="Reset Monitor Layout"
                                Command="{Binding ResetMonitorLayoutCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Discord Integration Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#5865F2" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="💬" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Discord Integration"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Webhook URL -->
                        <TextBlock Text="Webhook URL"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBox Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11">
                            Create a webhook in Discord → Server Settings → Integrations → Webhooks
                        </TextBlock>

                        <!-- Toggles -->
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding DiscordNotificationsEnabled}"
                                  Content="Enable Discord Notifications"
                                  Margin="0,0,0,16"/>

                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding DiscordAutoPatchEnabled}"
                                  Content="Enable Automatic Patch Creation"
                                  Margin="0,0,0,16"/>

                        <!-- Test Button -->
                        <Button Content="🧪 Test Webhook"
                                Command="{Binding TestWebhookCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Application Info Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="ℹ️" FontFamily="Segoe UI Emoji" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Application Information"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Version" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Build" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding BuildConfiguration}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Framework" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding Framework}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="16" Margin="0,20,0,0">
                            <TextBlock Foreground="{DynamicResource ForegroundLightBrush}" FontSize="12" TextWrapping="Wrap">
                                <Run Text="Windows Optimizer Suite" FontWeight="SemiBold"/>
                                <Run Text="- A modern, safe, and reversible Windows optimization tool built with WPF and .NET 8."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <Border Background="{DynamicResource BackgroundDarkBrush}"
                        BorderBrush="{DynamicResource AccentDarkBlueBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource AccentBrightCyanBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <Button Content="💾 Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
