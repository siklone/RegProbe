<UserControl x:Class="WindowsOptimizer.App.Views.TrayPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             Width="280" Height="180">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Colors.xaml"/>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource BackgroundDarkBrush}" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Stats -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="System Monitor" FontSize="14" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                <TextBlock Text="Live Overview" FontSize="10" 
                           Foreground="{DynamicResource ForegroundLightBrush}"/>
            </StackPanel>

            <!-- Stats -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <!-- CPU -->
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="CPU" FontSize="11" Foreground="{DynamicResource ForegroundBrightBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text=" • " FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}"/>
                        <TextBlock Text="{Binding CpuTemp}" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" Text="{Binding CpuUsage, StringFormat={}{0:F0}%}" 
                               FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>

                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="6" Margin="0,4,0,0" 
                                 Value="{Binding CpuUsage}" Maximum="100" 
                                 Background="{DynamicResource BackgroundLightBrush}"
                                 Foreground="{DynamicResource AccentBrush}"/>
                </Grid>

                <!-- RAM -->
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Memory (RAM)" FontSize="11" Foreground="{DynamicResource ForegroundBrightBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="{Binding RamUsagePercent, StringFormat={}{0:F0}%}" 
                               FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentPurpleBrush}"/>

                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="6" Margin="0,4,0,0" 
                                 Value="{Binding RamUsagePercent}" Maximum="100" 
                                 Background="{DynamicResource BackgroundLightBrush}"
                                 Foreground="{DynamicResource AccentPurpleBrush}"/>
                </Grid>

                <!-- GPU -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="GPU Temp:" FontSize="11" Foreground="{DynamicResource ForegroundBrightBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="{Binding GpuTemp}" FontSize="11" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                </Grid>
            </StackPanel>
            
            <!-- Footer -->
            <Button Grid.Row="2" Content="Open Dashboard" 
                    Command="{Binding ShowWindowCommand}"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Height="30" Margin="0,12,0,0"/>

        </Grid>
    </Border>
</UserControl>
