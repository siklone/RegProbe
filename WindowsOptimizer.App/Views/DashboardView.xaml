<UserControl x:Class="WindowsOptimizer.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="920"
             d:DesignWidth="1200"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="DashboardSurfaceStyle"
               TargetType="Border"
               BasedOn="{StaticResource AppSurfaceCardStyle}"/>

        <Style x:Key="DashboardChipStyle"
               TargetType="Border"
               BasedOn="{StaticResource AppChipStyle}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
        </Style>

        <Style x:Key="DashboardActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AppQuietActionButtonStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="DashboardPrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardActionButtonStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="DashboardQuickActionContentTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="DashboardQuickActionContentHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyMono}"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="DashboardQuickActionSegmentStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AppInsetSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="MinWidth" Value="138"/>
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppWorkspaceHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ShellTopNavHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardScanQuickActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardQuickActionSegmentStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsDashboardScanSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardFastCleanQuickActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardQuickActionSegmentStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsDashboardFastCleanSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardMaintenanceQuickActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardQuickActionSegmentStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsDashboardMaintenanceSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardCardButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AppMetricTileButtonStyle}">
            <Setter Property="Padding" Value="11"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="DashboardSummaryCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardSurfaceStyle}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="138"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
        </Style>

        <Style x:Key="DashboardRecommendationCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardSurfaceStyle}">
            <Setter Property="MinHeight" Value="84"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="DashboardSourceCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardSurfaceStyle}">
            <Setter Property="Width" Value="228"/>
            <Setter Property="MinHeight" Value="150"/>
            <Setter Property="Padding" Value="9"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
        </Style>

        <Style x:Key="DashboardHardwareCardStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardCardButtonStyle}">
            <Setter Property="Height" Value="122"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="DashboardFeaturedHardwareCardStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardHardwareCardStyle}">
            <Setter Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceAccentGradientBrush}"/>
        </Style>

        <Style x:Key="DashboardCardLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="8.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyMono}"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="DashboardCardNameTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDisplay}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="14"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="DashboardCardNameAccentTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DashboardCardNameTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <Style x:Key="DashboardCardMetaTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyMono}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="13"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="{DynamicResource ScrimOverlayBrush}"
                Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <Border Width="220"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource DashboardSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Loading dashboard"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Height="4"
                                 Margin="0,10,0,0"
                                 Style="{StaticResource AnimatedLoadingBarStyle}"
                                 IsIndeterminate="True"/>
                </StackPanel>
            </Border>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch">
            <Grid HorizontalAlignment="Stretch"
                  Margin="16,8,16,12">
            <StackPanel Margin="0,6,0,8">
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Overview"
                               Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                    <TextBlock Text="Dashboard"
                               Margin="0,3,0,0"
                               Style="{StaticResource AppHeroTitleTextStyle}"/>
                    <TextBlock Text="{Binding PlatformIdentity}"
                               Margin="0,4,0,0"
                               Style="{StaticResource AppHeroSubtitleTextStyle}"/>
                </StackPanel>

                <Border Margin="0,0,0,12"
                        Style="{StaticResource DashboardSurfaceStyle}">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="{DynamicResource DashboardHeroIconBrush}"
                                BorderBrush="{DynamicResource DashboardHeroIconBorderBrush}"
                                BorderThickness="1">
                            <Image Source="{Binding OsIconSource}"
                                   Width="24"
                                   Height="24"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OsName}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       FontFamily="{DynamicResource FontFamilyDisplay}"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SystemName}"
                                       Margin="0,4,0,0"
                                       FontSize="11"
                                       FontFamily="{DynamicResource FontFamilyMono}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap"/>
                            <Border Margin="0,6,0,0"
                                    Style="{StaticResource DashboardChipStyle}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding OsCompactSummary}"
                                           FontSize="10"
                                           FontFamily="{DynamicResource FontFamilyMono}"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Column="2"
                              Margin="20,0,0,0"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Margin="0,0,28,0"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="UPTIME"
                                           FontSize="9"
                                           FontFamily="{DynamicResource FontFamilyMono}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Uptime}"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           FontFamily="{DynamicResource FontFamilyDisplay}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="PC NAME"
                                           FontSize="9"
                                           FontFamily="{DynamicResource FontFamilyMono}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding SystemName}"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           FontFamily="{DynamicResource FontFamilyDisplay}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           HorizontalAlignment="Right"
                                           MaxWidth="220"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Margin="0,0,0,12"
                        Style="{StaticResource DashboardSurfaceStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Quick Actions"
                                   FontSize="12"
                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>

                        <WrapPanel Grid.Row="0"
                                   Grid.Column="1"
                                   VerticalAlignment="Center">
                            <Button Style="{StaticResource DashboardScanQuickActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RunDashboardScanCommand}"
                                    ToolTip="Refreshes live tweak states without applying changes.">
                                <StackPanel>
                                    <TextBlock Text="Scan" Style="{StaticResource DashboardQuickActionContentTitleStyle}"/>
                                    <TextBlock Text="Refresh live states" Style="{StaticResource DashboardQuickActionContentHintStyle}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource DashboardFastCleanQuickActionButtonStyle}"
                                    Margin="8,0,0,0"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RunFastCleanCommand}"
                                    ToolTip="Runs the lightweight cleanup bundle for safe cache and temp-file cleanup.">
                                <StackPanel>
                                    <TextBlock Text="Fast Clean" Style="{StaticResource DashboardQuickActionContentTitleStyle}"/>
                                    <TextBlock Text="Clear safe caches" Style="{StaticResource DashboardQuickActionContentHintStyle}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource DashboardMaintenanceQuickActionButtonStyle}"
                                    Margin="8,0,0,0"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.OpenMaintenanceWorkspaceCommand}"
                                    ToolTip="Opens the maintenance workspace with cleanup and repair tasks highlighted.">
                                <StackPanel>
                                    <TextBlock Text="Maintenance" Style="{StaticResource DashboardQuickActionContentTitleStyle}"/>
                                    <TextBlock Text="Open cleanup tasks" Style="{StaticResource DashboardQuickActionContentHintStyle}"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <ProgressBar Grid.Row="0"
                                     Grid.Column="2"
                                     Width="128"
                                     Height="3"
                                     Margin="12,0,0,0"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource AnimatedLoadingBarStyle}"
                                     IsIndeterminate="True"
                                     Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsDashboardQuickActionRunning, Converter={StaticResource BoolToVisibility}}"/>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="0,10,0,0"
                                Padding="10,7"
                                Background="{DynamicResource AppInsetSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DashboardQuickActionStatus}"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10.5"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Hardware"
                               Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                    <Border Grid.Column="1"
                            Height="1"
                            Margin="12,7,0,0"
                            Background="{DynamicResource GlassBorderBrush}"
                            VerticalAlignment="Center"/>
                </Grid>

                <primitives:UniformGrid Columns="5"
                                        Margin="-4,-4,-4,6">
                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="os">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding OsIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="OPERATING SYSTEM"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding OsCardTitle}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding OsCompactSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="motherboard">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding MotherboardIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="MOTHERBOARD"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding BaseboardProduct}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding MotherboardCompactSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardFeaturedHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="cpu">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding CpuIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="PROCESSOR"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding ProcessorCardTitle}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameAccentTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding ProcessorCompactSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardFeaturedHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="gpu">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding GpuIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="GRAPHICS"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding GpuCardTitle}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameAccentTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding GraphicsCardSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="memory">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding MemoryIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="MEMORY"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TotalPhysicalMemory}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding MemoryCardSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="storage">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding StorageIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="STORAGE"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding DiskDrives.Count, StringFormat={}{0} drives}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding StorageCardSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="displays">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding DisplayIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="DISPLAYS"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding Monitors.Count, StringFormat={}{0} displays}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding DisplayCardSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="network">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding NetworkIconSource}"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="NETWORK"
                                               Style="{StaticResource DashboardCardLabelTextStyle}"/>
                                    <TextBlock Text="{Binding NetworkAdapters.Count, StringFormat={}{0} adapters}"
                                               Margin="0,2,0,0"
                                               Style="{StaticResource DashboardCardNameTextStyle}"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding NetworkCardSummary}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource DashboardCardMetaTextStyle}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="usb">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding UsbIconSource}"
                                       Width="24"
                                       Height="24"
