<UserControl x:Class="WindowsOptimizer.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1100"
             FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
             FontSize="12">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="DashboardSurfaceStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#22272F" Offset="0"/>
                        <GradientStop Color="#1A1E25" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="DashboardChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#14000000"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>

        <Style x:Key="DashboardCardButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#20252D" Offset="0"/>
                        <GradientStop Color="#171B22" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#3DFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="IsTabStop" Value="True"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource PressedOverlayBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#C6111418"
                Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <Border Width="260"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource DashboardSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Loading dashboard"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Height="4"
                                 Margin="0,12,0,0"
                                 IsIndeterminate="True"/>
                </StackPanel>
            </Border>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,24">
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Dashboard"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                    <TextBlock Text="{Binding SystemName, StringFormat=Live hardware snapshot for {0}}"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource ForegroundLightBrush}"/>
                </StackPanel>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,16,0"
                            Style="{StaticResource DashboardSurfaceStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="92"
                                    Height="92"
                                    CornerRadius="26"
                                    Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1">
                                <Image Source="{Binding OsIconSource}"
                                       Width="46"
                                       Height="46"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="20,0,0,0">
                                <TextBlock Text="System overview"
                                           FontSize="12"
                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                <TextBlock Text="{Binding OsName}"
                                           Margin="0,6,0,0"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SystemModel}"
                                           Margin="0,8,0,0"
                                           FontSize="14"
                                           Foreground="{DynamicResource ForegroundBrightBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding ProcessorName}"
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding GpuName}"
                                           Margin="0,4,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           TextWrapping="Wrap"/>

                                <WrapPanel Margin="0,18,0,0">
                                    <Border Style="{StaticResource DashboardChipStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Build"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"/>
                                            <TextBlock Text="{Binding OsBuild}"
                                                       Margin="0,2,0,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource DashboardChipStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Architecture"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"/>
                                            <TextBlock Text="{Binding OsArchitecture}"
                                                       Margin="0,2,0,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource DashboardChipStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Memory"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"/>
                                            <TextBlock Text="{Binding TotalPhysicalMemory}"
                                                       Margin="0,2,0,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource DashboardSurfaceStyle}">
                        <StackPanel>
                            <TextBlock Text="Quick facts"
                                       FontSize="12"
                                       Foreground="{DynamicResource ForegroundLightBrush}"/>

                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Motherboard"
                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BaseboardProduct}"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="180"/>

                                <TextBlock Grid.Row="1"
                                           Margin="0,10,0,0"
                                           Text="Storage"
                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding DiskDrives.Count, StringFormat={}{0} drives}"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="2"
                                           Margin="0,10,0,0"
                                           Text="Displays"
                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding Monitors.Count, StringFormat={}{0} active}"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="3"
                                           Margin="0,10,0,0"
                                           Text="Network"
                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding NetworkAdapters.Count, StringFormat={}{0} adapters}"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           FontWeight="SemiBold"/>
                            </Grid>

                            <TextBlock Margin="0,18,0,0"
                                       Text="{Binding Uptime, StringFormat=Uptime: {0}}"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Hardware details"
                           Margin="0,0,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>

                <WrapPanel ItemWidth="216">
                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="os">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding OsIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Operating System"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding OsName}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding OsVersion}"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="motherboard">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding MotherboardIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Motherboard"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding BaseboardProduct}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding BaseboardManufacturer}"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="cpu">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding CpuIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Processor"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding ProcessorName}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding ProcessorCores, StringFormat={}{0} cores}"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="gpu">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding GpuIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Graphics"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding GpuName}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding GpuResolution}"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="memory">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding MemoryIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Memory"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding TotalPhysicalMemory}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding MemorySlots, StringFormat={}{0} slots}"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="storage">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding StorageIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Storage"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding DiskDrives.Count, StringFormat={}{0} drives}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="{Binding BootDevice}"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="displays">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding DisplayIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Displays"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Monitors.Count, StringFormat={}{0} active displays}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="Per-monitor detail view"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="network">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding NetworkIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Network"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkAdapters.Count, StringFormat={}{0} adapters}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="Inspect adapter inventory"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DashboardCardButtonStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="usb">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding UsbIconSource}"
                                       Width="30"
                                       Height="30"
                                       Stretch="Uniform"
                                       Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="USB"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding UsbDevices.Count, StringFormat={}{0} devices}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="Controller and device detail"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
