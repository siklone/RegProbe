<UserControl x:Class="WindowsOptimizer.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             xmlns:converters="clr-namespace:WindowsOptimizer.App.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <viewModels:ScoreToOffsetConverter x:Key="ScoreToOffsetConverter"/>
        <converters:StringEmptyToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        
        <!-- Glassmorphism Stat Card -->
        <Style x:Key="GlassStatCardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3B4252" Offset="0"/>
                        <GradientStop Color="#434C5E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.3" Direction="270"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform" Value="{StaticResource UiScaleTransform}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1.03" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1.03" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1.0" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1.0" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="42"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
        </Style>
        
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#88C0D0"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#2E3440">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header with Health Gauge -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Welcome back! 👋"
                               FontSize="14"
                               Foreground="#88C0D0"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Title}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#ECEFF4"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="Monitor your system optimizations and track applied tweaks."
                               Foreground="#D8DEE9"
                               FontSize="14"/>
                    <!-- Action Buttons Row -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <!-- Scan Now Button -->
                        <Button Command="{Binding ScanAllCommand}"
                                Padding="20,12"
                                Cursor="Hand"
                                Margin="0,0,12,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#5E81AC"/>
                                    <Setter Property="Foreground" Value="#ECEFF4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#81A1C1"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#4C566A"/>
                                            <Setter Property="Foreground" Value="#D8DEE9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Scan Now"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                    <Setter Property="Text" Value="Scanning..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <!-- Create Restore Point Button -->
                        <Button Command="{Binding CreateRestorePointCommand}"
                                Padding="20,12"
                                Cursor="Hand"
                                ToolTip="Create a system restore point before applying tweaks">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#A3BE8C"/>
                                    <Setter Property="Foreground" Value="#2E3440"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#B4C99B"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#4C566A"/>
                                            <Setter Property="Foreground" Value="#D8DEE9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Create Restore Point"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCreatingRestorePoint}" Value="True">
                                                    <Setter Property="Text" Value="Creating..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Restore Point Status Message -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding RestorePointStatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding RestorePointStatusMessage}"
                                   Foreground="#88C0D0"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <!-- Enable VSS Button -->
                        <Button Command="{Binding EnableVssCommand}"
                                Padding="8,4"
                                Margin="12,0,0,0"
                                Cursor="Hand"
                                Visibility="{Binding VssServiceNeedsEnable, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="Click to start the Volume Shadow Copy service. This requires administrator privileges and will prompt for elevation.">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#EBCB8B"/>
                                    <Setter Property="Foreground" Value="#2E3440"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Background" Value="#4C566A"/>
                                                        <Setter Property="Foreground" Value="#D8DEE9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D08770"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Enable VSS" FontSize="11" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

	                <!-- Circular Health Gauge -->
	                <StackPanel Grid.Column="1" Margin="24,0,0,0" HorizontalAlignment="Right">
	                    <Grid Width="140" Height="140" ToolTip="{Binding OptimizationScoreDetails}">
	                        <Ellipse Stroke="#3B4252" StrokeThickness="12" Fill="Transparent"/>
	                        <Ellipse x:Name="ScoreRing" Stroke="#5E81AC" StrokeThickness="12" Fill="Transparent" 
	                                 StrokeDashArray="100, 100"
	                                 StrokeDashOffset="{Binding OptimizationScore, ConverterParameter=314, Converter={StaticResource ScoreToOffsetConverter}}">
	                            <Ellipse.Style>
	                                <Style TargetType="Ellipse">
	                                    <Setter Property="Opacity" Value="1"/>
	                                    <Style.Triggers>
	                                        <DataTrigger Binding="{Binding HasHealthData}" Value="False">
	                                            <Setter Property="Opacity" Value="0.25"/>
	                                        </DataTrigger>
	                                    </Style.Triggers>
	                                </Style>
	                            </Ellipse.Style>
	                        </Ellipse>
                        
	                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
	                            <TextBlock Text="{Binding OptimizationScoreDisplayText}" 
	                                       FontSize="28" FontWeight="Bold" Foreground="#ECEFF4" HorizontalAlignment="Center"/>
	                            <TextBlock Text="Health" FontSize="11" Foreground="#88C0D0" HorizontalAlignment="Center"/>
	                        </StackPanel>
	                    </Grid>

                    <TextBlock Text="{Binding OptimizationScoreDetails}"
                               Foreground="#4C566A"
                               FontSize="11"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Width="180"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Statistics Grid -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,-16,24">
                <!-- Total Tweaks Available (Clickable) -->
                <Button Command="{Binding NavigateToTotalTweaksCommand}" Cursor="Hand" ToolTip="Click to view all tweaks">
                    <Button.Template>
                        <ControlTemplate>
                            <Border x:Name="CardBorder" Style="{StaticResource GlassStatCardStyle}">
                                <StackPanel>
                                    <Border Background="#5E81AC" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                                        <TextBlock Text="📦" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding TotalTweaksAvailable}" Style="{StaticResource StatValueStyle}"/>
                                    <TextBlock Text="Total Tweaks" Style="{StaticResource StatLabelStyle}"/>
                                    <TextBlock Text="Click to view" FontSize="10" Foreground="#4C566A" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Tweaks Applied (Clickable) -->
                <Button Command="{Binding NavigateToAppliedTweaksCommand}" Cursor="Hand" ToolTip="Click to view applied tweaks">
                    <Button.Template>
                        <ControlTemplate>
                            <Border x:Name="CardBorder" Style="{StaticResource GlassStatCardStyle}">
                                <StackPanel>
                                    <Border Background="#A3BE8C" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                                        <TextBlock Text="✅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding TweaksApplied}" Style="{StaticResource StatValueStyle}" Foreground="#A3BE8C"/>
                                    <TextBlock Text="Applied (Health)" Style="{StaticResource StatLabelStyle}"/>
                                    <TextBlock Text="Click to filter" FontSize="10" Foreground="#4C566A" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Tweaks Rolled Back (Clickable) -->
                <Button Command="{Binding NavigateToRolledBackTweaksCommand}" Cursor="Hand" ToolTip="Click to view rolled back tweaks">
                    <Button.Template>
                        <ControlTemplate>
                            <Border x:Name="CardBorder" Style="{StaticResource GlassStatCardStyle}">
                                <StackPanel>
                                    <Border Background="#EBCB8B" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                                        <TextBlock Text="↩️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding TweaksRolledBack}" Style="{StaticResource StatValueStyle}" Foreground="#EBCB8B"/>
                                    <TextBlock Text="Rolled Back" Style="{StaticResource StatLabelStyle}"/>
                                    <TextBlock Text="Click to filter" FontSize="10" Foreground="#4C566A" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Log File Size (Clickable) -->
                <Button Command="{Binding OpenLogFileCommand}" Cursor="Hand" ToolTip="{Binding LogFilePath}">
                    <Button.Template>
                        <ControlTemplate>
                            <Border x:Name="CardBorder" Style="{StaticResource GlassStatCardStyle}">
                                <StackPanel>
                                    <Border Background="#B48EAD" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                                        <TextBlock Text="📄" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding LogFileSizeFormatted}" Style="{StaticResource StatValueStyle}" FontSize="32"/>
                                    <TextBlock Text="Log File Size" Style="{StaticResource StatLabelStyle}"/>
                                    <TextBlock Text="Click to open" FontSize="10" Foreground="#4C566A" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </UniformGrid>

            <!-- System Status -->
            <Border Grid.Row="2" Style="{StaticResource InfoCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🖥️ System Status" FontSize="18" FontWeight="SemiBold" Foreground="#ECEFF4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Border Background="#5E81AC" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding ElevationStatus}" Foreground="#ECEFF4" FontSize="11" FontWeight="Medium"/>
                            </Border>
                            <!-- Boot Time Info -->
                            <Border Background="#88C0D0" CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                                    ToolTip="{Binding LastBootTimeFormatted}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏱️" Margin="0,0,4,0"/>
                                    <TextBlock Text="Last Boot:" Foreground="#2E3440" FontSize="11"/>
                                    <TextBlock Text="{Binding LastBootDurationFormatted}" Foreground="#2E3440" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#A3BE8C" CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                                    ToolTip="Average boot time from history"
                                    Visibility="{Binding HasBootTimeHistory, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" Margin="0,0,4,0"/>
                                    <TextBlock Text="Avg:" Foreground="#2E3440" FontSize="11"/>
                                    <TextBlock Text="{Binding AverageBootDurationFormatted}" Foreground="#2E3440" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="4" Padding="8,4"
                                    ToolTip="Boot time improvement since first measurement"
                                    Visibility="{Binding HasBootTimeImprovement, Converter={StaticResource BoolToVisibility}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#A3BE8C"/>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚀" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding BootTimeImprovementFormatted}" Foreground="#2E3440" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text=" faster" Foreground="#2E3440" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#434C5E" CornerRadius="8" Padding="16,12" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Use Preview mode to test changes safely"
                                       Foreground="#D8DEE9"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Recent Activity Timeline -->
            <Border Grid.Row="3" Style="{StaticResource InfoCardStyle}" Margin="0,0,0,16"
                    Visibility="{Binding HasRecentActivity, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="📋 Recent Activity" FontSize="16" FontWeight="SemiBold" Foreground="#ECEFF4"/>
                        <Button Command="{Binding RefreshActivityCommand}"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                ToolTip="Refresh activity timeline">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="🔄" FontSize="14"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3B4252"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding RecentActivity}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#3B4252" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Action Icon -->
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Margin="0,0,12,0"
                                                Background="{Binding StatusColor}">
                                            <TextBlock Text="{Binding ActionIcon}"
                                                       FontSize="12"
                                                       Foreground="#2E3440"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Tweak Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TweakName}"
                                                       Foreground="#ECEFF4"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Action}"
                                                           Foreground="#88C0D0"
                                                           FontSize="10"/>
                                                <TextBlock Text=" • "
                                                           Foreground="#4C566A"
                                                           FontSize="10"/>
                                                <TextBlock Text="{Binding Message}"
                                                           Foreground="#D8DEE9"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="300"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Time -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TimeAgo}"
                                                   Foreground="#4C566A"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding TimestampFormatted}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Quick Actions Grid -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Quick Categories Card -->
                <Border Grid.Column="0" Style="{StaticResource InfoCardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="🎯 Quick Categories" FontSize="16" FontWeight="SemiBold" Foreground="#ECEFF4" Margin="0,0,0,12"/>

                        <Button Command="{Binding NavigateToPrivacyCommand}" Cursor="Hand" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate>
                                    <Border x:Name="Bd" Background="#434C5E" CornerRadius="6" Padding="10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔒" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Privacy" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="12"/>
                                                <TextBlock Text="Telemetry, tracking" Foreground="#88C0D0" FontSize="10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4C566A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding NavigateToPowerCommand}" Cursor="Hand" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate>
                                    <Border x:Name="Bd" Background="#434C5E" CornerRadius="6" Padding="10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚡" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Performance" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="12"/>
                                                <TextBlock Text="Power, CPU, services" Foreground="#88C0D0" FontSize="10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4C566A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding NavigateToNetworkCommand}" Cursor="Hand" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate>
                                    <Border x:Name="Bd" Background="#434C5E" CornerRadius="6" Padding="10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🌐" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Network" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="12"/>
                                                <TextBlock Text="DNS, TCP/IP, Wi-Fi" Foreground="#88C0D0" FontSize="10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4C566A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding NavigateToSecurityCommand}" Cursor="Hand" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate>
                                    <Border x:Name="Bd" Background="#434C5E" CornerRadius="6" Padding="10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🛡️" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Security" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="12"/>
                                                <TextBlock Text="UAC, Firewall, updates" Foreground="#88C0D0" FontSize="10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4C566A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding NavigateToExplorerCommand}" Cursor="Hand" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate>
                                    <Border x:Name="Bd" Background="#434C5E" CornerRadius="6" Padding="10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Explorer" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="12"/>
                                                <TextBlock Text="File manager, shell" Foreground="#88C0D0" FontSize="10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4C566A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding NavigateToAllTweaksCommand}" Cursor="Hand" Margin="0,4,0,0">
                            <Button.Template>
                                <ControlTemplate>
                                    <Border x:Name="Bd" Background="#5E81AC" CornerRadius="6" Padding="10">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="View All Tweaks →" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#81A1C1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- System Information Card -->
                <Border Grid.Column="1" Style="{StaticResource InfoCardStyle}" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="💻 System Information" FontSize="16" FontWeight="SemiBold" Foreground="#ECEFF4" Margin="0,0,0,12"/>

                        <Border Background="#434C5E" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="OS:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OsVersion}" Foreground="#ECEFF4" FontSize="11" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Build:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OsBuild}" Foreground="#ECEFF4" FontSize="11"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Arch:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SystemArchitecture}" Foreground="#ECEFF4" FontSize="11"/>
                            </Grid>
                        </Border>

                        <Border Background="#434C5E" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU Cores:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProcessorCount}" Foreground="#ECEFF4" FontSize="11"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total RAM:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalMemoryFormatted}" Foreground="#A3BE8C" FontSize="11" FontWeight="Medium"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Free RAM:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AvailableMemoryFormatted}" Foreground="#EBCB8B" FontSize="11"/>
                            </Grid>
                        </Border>

                        <Border Background="#434C5E" CornerRadius="8" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Machine:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MachineName}" Foreground="#ECEFF4" FontSize="11" TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="User:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UserName}" Foreground="#ECEFF4" FontSize="11" TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Uptime:" Foreground="#88C0D0" FontSize="11" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SystemUptime}" Foreground="#B48EAD" FontSize="11"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Safety & Shortcuts Card -->
                <Border Grid.Column="2" Style="{StaticResource InfoCardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🛡️ Safety &amp; Shortcuts" FontSize="16" FontWeight="SemiBold" Foreground="#ECEFF4" Margin="0,0,0,12"/>

                        <!-- Tweak Lifecycle -->
                        <Border Background="#2E4A3E" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Tweak Lifecycle:" Foreground="#A3BE8C" FontWeight="SemiBold" FontSize="11"/>
                                <WrapPanel Margin="0,6,0,0">
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="6,3" Margin="0,0,4,4">
                                        <TextBlock Text="Preview" Foreground="#A3BE8C" FontSize="10"/>
                                    </Border>
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="6,3" Margin="0,0,4,4">
                                        <TextBlock Text="Apply" Foreground="#A3BE8C" FontSize="10"/>
                                    </Border>
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="6,3" Margin="0,0,4,4">
                                        <TextBlock Text="Verify" Foreground="#A3BE8C" FontSize="10"/>
                                    </Border>
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="6,3" Margin="0,0,0,4">
                                        <TextBlock Text="Rollback" Foreground="#A3BE8C" FontSize="10"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Keyboard Shortcuts -->
                        <Border Background="#3B4252" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="⌨️ Keyboard Shortcuts:" Foreground="#88C0D0" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="#4C566A" CornerRadius="3" Padding="4,2" Margin="0,0,8,3">
                                        <TextBlock Text="Ctrl+Z" Foreground="#ECEFF4" FontSize="9" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Undo last action" Foreground="#D8DEE9" FontSize="10" VerticalAlignment="Center"/>

                                    <Border Grid.Row="1" Grid.Column="0" Background="#4C566A" CornerRadius="3" Padding="4,2" Margin="0,0,8,3">
                                        <TextBlock Text="Ctrl+F" Foreground="#ECEFF4" FontSize="9" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Search tweaks" Foreground="#D8DEE9" FontSize="10" VerticalAlignment="Center"/>

                                    <Border Grid.Row="2" Grid.Column="0" Background="#4C566A" CornerRadius="3" Padding="4,2" Margin="0,0,8,3">
                                        <TextBlock Text="Ctrl+A" Foreground="#ECEFF4" FontSize="9" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Select all visible" Foreground="#D8DEE9" FontSize="10" VerticalAlignment="Center"/>

                                    <Border Grid.Row="3" Grid.Column="0" Background="#4C566A" CornerRadius="3" Padding="4,2" Margin="0,0,8,3">
                                        <TextBlock Text="Ctrl+D" Foreground="#ECEFF4" FontSize="9" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Detect selected" Foreground="#D8DEE9" FontSize="10" VerticalAlignment="Center"/>

                                    <Border Grid.Row="4" Grid.Column="0" Background="#4C566A" CornerRadius="3" Padding="4,2" Margin="0,0,8,0">
                                        <TextBlock Text="F5" Foreground="#ECEFF4" FontSize="9" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Refresh view" Foreground="#D8DEE9" FontSize="10" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Safety Points -->
                        <StackPanel>
                            <TextBlock Foreground="#D8DEE9" FontSize="11" TextWrapping="Wrap">
                                <Run Text="✓" Foreground="#A3BE8C"/> Logged &amp; reversible
                            </TextBlock>
                            <TextBlock Foreground="#D8DEE9" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0">
                                <Run Text="✓" Foreground="#A3BE8C"/> Elevated via ElevatedHost
                            </TextBlock>
                            <TextBlock Foreground="#D8DEE9" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0">
                                <Run Text="✓" Foreground="#A3BE8C"/> Command allowlist
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
