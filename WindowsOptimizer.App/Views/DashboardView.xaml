<UserControl x:Class="WindowsOptimizer.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="920"
             d:DesignWidth="1200"
             FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
             FontSize="11"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="DashboardSurfaceStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1F252D" Offset="0"/>
                        <GradientStop Color="#151A20" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#38FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="DashboardChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#13000000"/>
            <Setter Property="BorderBrush" Value="#24FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
        </Style>

        <Style x:Key="DashboardActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#18000000"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#1D0C1118"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardCardButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E242C" Offset="0"/>
                        <GradientStop Color="#161A21" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#34FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="IsTabStop" Value="True"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.01" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.01" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardRoot" Property="Background" Value="{DynamicResource PressedOverlayBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardSummaryCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardSurfaceStyle}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="132"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="DashboardRecommendationCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardSurfaceStyle}">
            <Setter Property="Width" Value="308"/>
            <Setter Property="MinHeight" Value="172"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="DashboardSourceCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardSurfaceStyle}">
            <Setter Property="Width" Value="228"/>
            <Setter Property="MinHeight" Value="150"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="DashboardHardwareCardStyle"
               TargetType="Button"
               BasedOn="{StaticResource DashboardCardButtonStyle}">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="116"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#C6111418"
                Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <Border Width="220"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource DashboardSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="Loading dashboard"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Height="4"
                                 Margin="0,10,0,0"
                                 Style="{StaticResource AnimatedLoadingBarStyle}"
                                 IsIndeterminate="True"/>
                </StackPanel>
            </Border>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="10,8,10,12">
                <DockPanel Margin="0,0,0,8" LastChildFill="False">
                    <Border DockPanel.Dock="Right"
                            MinWidth="136"
                            MaxWidth="172"
                            Padding="8,6"
                            CornerRadius="10"
                            Background="#1D0C1118"
                            BorderBrush="#2FC8F5FF"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Quality"
                                       FontSize="8"
                                       Foreground="{DynamicResource ForegroundLightBrush}"/>
                            <TextBlock Text="{Binding AuditCompactSummary}"
                                       Margin="0,2,0,0"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Dashboard"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        <TextBlock Text="{Binding PlatformIdentity}"
                                   Margin="0,3,0,0"
                                   FontSize="9"
                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </DockPanel>

                <Border Margin="0,0,0,8"
                        Style="{StaticResource DashboardSurfaceStyle}">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="{DynamicResource BackgroundMediumBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1">
                            <Image Source="{Binding OsIconSource}"
                                   Width="24"
                                   Height="24"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OsName}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SystemName}"
                                       Margin="0,2,0,0"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding OsCompactSummary}"
                                       Margin="0,2,0,0"
                                       FontSize="9"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <WrapPanel Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0">
                            <Border Style="{StaticResource DashboardChipStyle}">
                                <StackPanel>
                                    <TextBlock Text="PC"
                                               FontSize="8"
                                               Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    <TextBlock Text="{Binding SystemName}"
                                               Margin="0,2,0,0"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               TextWrapping="Wrap"
                                               MaxWidth="130"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource DashboardChipStyle}">
                                <StackPanel>
                                    <TextBlock Text="Uptime"
                                               FontSize="8"
                                               Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    <TextBlock Text="{Binding Uptime}"
                                               Margin="0,2,0,0"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               TextWrapping="Wrap"
                                               MaxWidth="120"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Margin="0,0,0,8"
                        Style="{StaticResource DashboardSurfaceStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Quick Actions"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DashboardQuickActionStatus}"
                                       Margin="0,4,0,0"
                                       FontSize="9"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       TextWrapping="Wrap"/>
                            <ProgressBar Height="3"
                                         Margin="0,8,0,0"
                                         Style="{StaticResource AnimatedLoadingBarStyle}"
                                         IsIndeterminate="True"
                                         Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsDashboardQuickActionRunning, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>

                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center">
                            <Button Style="{StaticResource DashboardActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RunDashboardScanCommand}"
                                    Content="Scan"/>
                            <Button Style="{StaticResource DashboardActionButtonStyle}"
                                    Margin="6,6,0,0"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RunFastCleanCommand}"
                                    Content="Fast Clean"/>
                            <Button Style="{StaticResource DashboardActionButtonStyle}"
                                    Margin="6,6,0,0"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.OpenMaintenanceWorkspaceCommand}"
                                    Content="Maintenance"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Hardware"
                           Margin="0,0,0,6"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>

                <WrapPanel Margin="0,0,0,10"
                           ItemWidth="190">
                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="os">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding OsIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Operating System"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding OsName}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding OsCompactSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="motherboard">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding MotherboardIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Motherboard"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding BaseboardProduct}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding MotherboardCompactSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="cpu">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding CpuIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Processor"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding ProcessorName}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding ProcessorCompactSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="gpu">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding GpuIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Graphics"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding GpuName}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding GraphicsCardSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="memory">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding MemoryIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Memory"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding TotalPhysicalMemory}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding MemoryCardSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="storage">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding StorageIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Storage"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding DiskDrives.Count, StringFormat={}{0} drives}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding StorageCardSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="displays">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding DisplayIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Displays"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Monitors.Count, StringFormat={}{0} displays}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding DisplayCardSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="network">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding NetworkIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Network"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkAdapters.Count, StringFormat={}{0} adapters}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding NetworkCardSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="usb">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding UsbIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="USB"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding UsbHeadline}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding UsbCardSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource DashboardHardwareCardStyle}"
                            Command="{Binding OpenDetailCommand}"
                            CommandParameter="audio">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="True">
                                <Image Source="{Binding AudioIconSource}"
                                       Width="28"
                                       Height="28"
                                       Stretch="Uniform"
                                       Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Audio"
                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding AudioDeviceCount, StringFormat={}{0} devices}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding AudioCardSummary}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
