<UserControl x:Class="WindowsOptimizer.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             mc:Ignorable="d">
    <UserControl.Resources>
        <viewModels:ScoreToOffsetConverter x:Key="ScoreToOffsetConverter"/>
        
        <!-- Glassmorphism Stat Card -->
        <Style x:Key="GlassStatCardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3B4252" Offset="0"/>
                        <GradientStop Color="#434C5E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.3" Direction="270"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform" Value="{StaticResource UiScaleTransform}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1.03" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1.03" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1.0" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1.0" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="42"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
        </Style>
        
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#88C0D0"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#2E3440">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header with Health Gauge -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Welcome back! 👋" 
                               FontSize="14" 
                               Foreground="#88C0D0"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Title}" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="#ECEFF4"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="Monitor your system optimizations and track applied tweaks."
                               Foreground="#D8DEE9"
                               FontSize="14"/>
                </StackPanel>

	                <!-- Circular Health Gauge -->
	                <StackPanel Grid.Column="1" Margin="24,0,0,0" HorizontalAlignment="Right">
	                    <Grid Width="140" Height="140" ToolTip="{Binding OptimizationScoreDetails}">
	                        <Ellipse Stroke="#3B4252" StrokeThickness="12" Fill="Transparent"/>
	                        <Ellipse x:Name="ScoreRing" Stroke="#5E81AC" StrokeThickness="12" Fill="Transparent" 
	                                 StrokeDashArray="100, 100"
	                                 StrokeDashOffset="{Binding OptimizationScore, ConverterParameter=314, Converter={StaticResource ScoreToOffsetConverter}}">
	                            <Ellipse.Style>
	                                <Style TargetType="Ellipse">
	                                    <Setter Property="Opacity" Value="1"/>
	                                    <Style.Triggers>
	                                        <DataTrigger Binding="{Binding HasHealthData}" Value="False">
	                                            <Setter Property="Opacity" Value="0.25"/>
	                                        </DataTrigger>
	                                    </Style.Triggers>
	                                </Style>
	                            </Ellipse.Style>
	                        </Ellipse>
                        
	                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
	                            <TextBlock Text="{Binding OptimizationScoreDisplayText}" 
	                                       FontSize="28" FontWeight="Bold" Foreground="#ECEFF4" HorizontalAlignment="Center"/>
	                            <TextBlock Text="Health" FontSize="11" Foreground="#88C0D0" HorizontalAlignment="Center"/>
	                        </StackPanel>
	                    </Grid>

                    <TextBlock Text="{Binding OptimizationScoreDetails}"
                               Foreground="#4C566A"
                               FontSize="11"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Width="180"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Statistics Grid -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,-16,24">
                <!-- Total Tweaks Available -->
                <Border Style="{StaticResource GlassStatCardStyle}">
                    <StackPanel>
                        <Border Background="#5E81AC" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="📦" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TotalTweaksAvailable}" Style="{StaticResource StatValueStyle}"/>
                        <TextBlock Text="Total Tweaks" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Tweaks Applied -->
                <Border Style="{StaticResource GlassStatCardStyle}">
                    <StackPanel>
                        <Border Background="#A3BE8C" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="✅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TweaksApplied}" Style="{StaticResource StatValueStyle}" Foreground="#A3BE8C"/>
                        <TextBlock Text="Applied (Health)" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Tweaks Rolled Back -->
                <Border Style="{StaticResource GlassStatCardStyle}">
                    <StackPanel>
                        <Border Background="#EBCB8B" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="↩️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TweaksRolledBack}" Style="{StaticResource StatValueStyle}" Foreground="#EBCB8B"/>
                        <TextBlock Text="Rolled Back" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Log File Size -->
                <Border Style="{StaticResource GlassStatCardStyle}">
                    <StackPanel>
                        <Border Background="#B48EAD" CornerRadius="12" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="📄" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding LogFileSizeFormatted}" Style="{StaticResource StatValueStyle}" FontSize="32"/>
                        <TextBlock Text="Log File Size" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- System Status -->
            <Border Grid.Row="2" Style="{StaticResource InfoCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🖥️ System Status" FontSize="18" FontWeight="SemiBold" Foreground="#ECEFF4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Border Background="#5E81AC" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding ElevationStatus}" Foreground="#ECEFF4" FontSize="11" FontWeight="Medium"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Grid.Column="1" Background="#434C5E" CornerRadius="8" Padding="16,12" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Use Preview mode to test changes safely" 
                                       Foreground="#D8DEE9" 
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Quick Actions Grid -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Features Card -->
                <Border Grid.Column="0" Style="{StaticResource InfoCardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="🎯 Features" FontSize="16" FontWeight="SemiBold" Foreground="#ECEFF4" Margin="0,0,0,16"/>
                        
                        <Border Background="#434C5E" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="16" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Registry Tweaks" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="13"/>
                                    <TextBlock Text="Modify Windows registry safely" Foreground="#88C0D0" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#434C5E" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧" FontSize="16" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Service Management" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="13"/>
                                    <TextBlock Text="Control Windows services" Foreground="#88C0D0" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#434C5E" CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💻" FontSize="16" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Command Execution" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="13"/>
                                    <TextBlock Text="Run system commands securely" Foreground="#88C0D0" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Safety Card -->
                <Border Grid.Column="1" Style="{StaticResource InfoCardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🛡️ Safety" FontSize="16" FontWeight="SemiBold" Foreground="#ECEFF4" Margin="0,0,0,16"/>
                        
                        <Border Background="#2E4A3E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="All tweaks support:" Foreground="#A3BE8C" FontWeight="SemiBold" FontSize="13"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                        <TextBlock Text="Preview" Foreground="#A3BE8C" FontSize="11"/>
                                    </Border>
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                        <TextBlock Text="Apply" Foreground="#A3BE8C" FontSize="11"/>
                                    </Border>
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="8,4" Margin="0,0,6,0">
                                        <TextBlock Text="Verify" Foreground="#A3BE8C" FontSize="11"/>
                                    </Border>
                                    <Border Background="#3B5C4A" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Rollback" Foreground="#A3BE8C" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Foreground="#D8DEE9" FontSize="12" TextWrapping="Wrap">
                            <Run Text="✓" Foreground="#A3BE8C"/> Changes are logged and reversible
                        </TextBlock>
                        <TextBlock Foreground="#D8DEE9" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0">
                            <Run Text="✓" Foreground="#A3BE8C"/> ElevatedHost handles admin operations
                        </TextBlock>
                        <TextBlock Foreground="#D8DEE9" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0">
                            <Run Text="✓" Foreground="#A3BE8C"/> Command allowlist for security
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
