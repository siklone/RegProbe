<UserControl x:Class="WindowsOptimizer.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WindowsOptimizer.App.Views"
             mc:Ignorable="d"
             d:DesignHeight="1200" d:DesignWidth="1100"
             FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
             FontSize="12">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:PercentToWidthConverter x:Key="PercentToWidth"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibility"/>
        
        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        
        <!-- Info Card Style (Using ContentControl to allow Template) -->
        <Style x:Key="InfoCardStyle" TargetType="ContentControl">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Height" Value="280"/> <!-- Fixed Height -->
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer VerticalScrollBarVisibility="Hidden" 
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="8"
                                          PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                                <ContentPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        
        <!-- Value Style -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="WrapWithOverflow"/>
        </Style>
        
        <!-- Row Style -->
        <Style x:Key="InfoRowStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        
        <!-- Link Button Style -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" 
                                   TextDecorations="Underline"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- Loading Overlay -->
        <Border Background="{DynamicResource BackgroundDarkestBrush}"
                Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔄" FontFamily="Segoe UI Emoji" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="Loading System Information..."
                           Foreground="{DynamicResource ForegroundLightBrush}"
                           FontSize="14" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="4,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Columns -->
                    <RowDefinition Height="Auto"/> <!-- Full Width Bottom -->
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="System Information"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                               FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Hardware and software overview"
                               Foreground="{DynamicResource ForegroundLightBrush}"
                               FontSize="10" Margin="0,1,0,0"/>
                </StackPanel>
                
                <!-- Columns -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- LEFT COLUMN (5 Cards) -->
                    <StackPanel Grid.Column="0">
                        <!-- 1. Operating System - REPLACED Border with ContentControl -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="🪟 Operating System" Style="{StaticResource SectionHeaderStyle}"/>
                                
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="OS Name" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding OsName}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Version" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding OsVersion}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <DockPanel>
                                        <TextBlock Text="Build Number" Style="{StaticResource LabelStyle}" DockPanel.Dock="Left"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding OsBuild}" Style="{StaticResource ValueStyle}" VerticalAlignment="Center"/>
                                            <Button Content="🔗" ToolTip="Windows Release Info" 
                                                    Style="{StaticResource LinkButtonStyle}"
                                                    Command="{Binding OpenUrlCommand}" 
                                                    CommandParameter="{Binding WindowsBuildUrl}"
                                                    FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Architecture" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding OsArchitecture}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Install Date" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding OsInstallDate}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Windows Directory" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding WindowsDirectory}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="System Directory" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SystemDirectory}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Boot Device" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding BootDevice}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Time Zone" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding TimeZone}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="User Name" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding UserName}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="System Uptime" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding Uptime}" Style="{StaticResource ValueStyle}" Foreground="{DynamicResource SuccessBrush}"/>
                                </StackPanel>
                                
                                <Border Height="1" Background="{DynamicResource BackgroundLightBrush}" Margin="0,8"/>
                                <TextBlock Text="Boot &amp; Security" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                
                                <WrapPanel Orientation="Horizontal">
                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                                <Setter Property="BorderBrush" Value="#F44336"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SecureBootState}" Value="On">
                                                         <Setter Property="Background" Value="#1A4CAF50"/>
                                                         <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SecureBootState}" Value="True">
                                                         <Setter Property="Background" Value="#1A4CAF50"/>
                                                         <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Secure Boot" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" Margin="0,0,4,0"/>
                                            <Ellipse Width="6" Height="6" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#F44336"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SecureBootState}" Value="On">
                                                                <Setter Property="Fill" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SecureBootState}" Value="True">
                                                                <Setter Property="Fill" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </StackPanel>
                                    </Border>

                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0" Background="#1A4CAF50" BorderBrush="#4CAF50" BorderThickness="1" 
                                            Visibility="{Binding BiosMode, Converter={StaticResource StringToVisibility}}">
                                        <TextBlock Text="UEFI Enabled" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                    </Border>
                                    
                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0" Background="#1A4CAF50" BorderBrush="#4CAF50" BorderThickness="1">
                                        <TextBlock Text="TPM 2.0" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                    </Border>

                                    <Border CornerRadius="4" Padding="6,2" Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1">
                                        <TextBlock Text="HVCI" FontSize="11" FontWeight="SemiBold" Foreground="#AAA"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </ContentControl>
                        
                        <!-- 2. Processor -->
                        <!-- 2. Processor (CPU-Z Style) -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="🖥️ Processor" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                    <Button Content="📋 Specs"
                                            Style="{StaticResource LinkButtonStyle}"
                                            Command="{Binding OpenUrlCommand}"
                                            CommandParameter="{Binding ProcessorSearchUrl}"
                                            Margin="12,0,0,0"
                                            Visibility="{Binding ProcessorSearchUrl, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                                
                                <!-- Top Info -->
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12" Background="#11FFFFFF">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <!-- Generic CPU Icon or Logo placeholder -->
                                        <Border Width="48" Height="48" Background="#22FFFFFF" CornerRadius="4" VerticalAlignment="Top">
                                            <TextBlock Text="CPU" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#55FFFFFF" FontWeight="Bold"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ProcessorName}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CpuDetails.CodeName, StringFormat=Code Name: {0}}" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,2,0,0" Visibility="{Binding CpuDetails.CodeName, Converter={StaticResource StringToVisibility}}"/>
                                            <TextBlock Text="{Binding ProcessorSocket, StringFormat=Package: {0}}" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Technical Details Grid -->
                                <Grid Margin="0,0,0,12">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="12"/>
                                         <ColumnDefinition Width="*"/>
                                     </Grid.ColumnDefinitions>
                                     
                                     <!-- Left Sub-col -->
                                     <StackPanel Grid.Column="0">
                                         <TextBlock Text="Technology" Style="{StaticResource LabelStyle}"/>
                                         <TextBlock Text="{Binding CpuDetails.Technology}" Style="{StaticResource ValueStyle}" Margin="0,0,0,6"/>

                                         <TextBlock Text="Cores" Style="{StaticResource LabelStyle}"/>
                                         <TextBlock Text="{Binding ProcessorCores}" Style="{StaticResource ValueStyle}"/>
                                     </StackPanel>

                                     <!-- Right Sub-col -->
                                     <StackPanel Grid.Column="2">
                                          <TextBlock Text="Stepping" Style="{StaticResource LabelStyle}"/>
                                          <TextBlock Text="{Binding CpuDetails.Stepping}" Style="{StaticResource ValueStyle}" Margin="0,0,0,6"/>
                                          
                                          <TextBlock Text="Threads" Style="{StaticResource LabelStyle}"/>
                                          <TextBlock Text="{Binding ProcessorThreads}" Style="{StaticResource ValueStyle}"/>
                                     </StackPanel>
                                </Grid>
                                
                                <!-- Clocks Box -->
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,8">
                                    <Grid>
                                         <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                         <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                         
                                         <TextBlock Text="Core Speed" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Column="1" Text="{Binding ProcessorSpeed}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                         
                                         <TextBlock Grid.Row="1" Text="Multiplier" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,4"/>
                                         <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CpuDetails.Multiplier}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,4"/>
                                         
                                         <TextBlock Grid.Row="2" Text="Bus Speed" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CpuDetails.BusSpeed}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    </Grid>
                                </Border>

                                <!-- Cache Box -->
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="3" Padding="8,6">
                                    <Grid>
                                         <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                         <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                         
                                         <TextBlock Text="L1 Cache" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Column="1" Text="{Binding CpuDetails.L1Cache}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                         
                                         <TextBlock Grid.Row="1" Text="L2 Cache" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,4"/>
                                         <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProcessorL2Cache}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,4"/>
                                         
                                         <TextBlock Grid.Row="2" Text="L3 Cache" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProcessorL3Cache}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Instructions -->
                                <TextBlock Text="Instructions" Style="{StaticResource LabelStyle}" Margin="0,12,0,2"/>
                                <TextBlock Text="{Binding CpuDetails.Instructions}" TextWrapping="Wrap" FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}" Opacity="0.75" LineHeight="14"/>

                            </StackPanel>
                        </ContentControl>
                        
                        <!-- 3. Motherboard (CPU-Z Style) -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                     <TextBlock Text="Motherboard" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                     <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                                         <Button Content="🔗 Driver" 
                                                 Style="{StaticResource LinkButtonStyle}"
                                                 Command="{Binding OpenUrlCommand}" 
                                                 CommandParameter="{Binding MotherboardDriverUrl}"
                                                 Visibility="{Binding MotherboardDriverUrl, Converter={StaticResource StringToVisibility}}"
                                                 Margin="0,0,8,0"/>
                                         <Button Content="🔗 Chipset" 
                                                 Style="{StaticResource LinkButtonStyle}"
                                                 Command="{Binding OpenUrlCommand}" 
                                                 CommandParameter="{Binding ChipsetDriverUrl}"
                                                 Visibility="{Binding ChipsetDriverUrl, Converter={StaticResource StringToVisibility}}"/>
                                     </StackPanel>
                                </StackPanel>

                                <!-- Board Model Box -->
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12" Background="#11FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="{Binding BaseboardManufacturer}" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                        <TextBlock Text="{Binding BaseboardProduct}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="0,2,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Chipset" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding MotherboardDetails.Chipset}" Foreground="{DynamicResource ForegroundBrightestBrush}" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                
                                <!-- BIOS Section -->
                                <TextBlock Text="BIOS" Style="{StaticResource LabelStyle}" FontWeight="Bold" Margin="0,0,0,4"/>
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,8">
                                    <Grid>
                                         <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                         <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                         
                                         <TextBlock Text="Version" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Column="1" Text="{Binding BiosVersion}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrightestBrush}" Margin="0,0,12,0"/>
                                         
                                         <TextBlock Grid.Column="2" Text="Date" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                         <TextBlock Grid.Column="3" Text="{Binding BiosDate}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                         
                                         <TextBlock Grid.Row="1" Text="Graphic Interface" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                         <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding MotherboardDetails.GraphicInterface}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,4,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ContentControl>

                        <!-- 4. Memory (CPU-Z Style) -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="💾 Memory" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12"/>
                                
                                <!-- General Box -->
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12" Background="#11FFFFFF">
                                    <Grid>
                                         <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                         <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                         
                                         <StackPanel Margin="0,0,4,8">
                                             <TextBlock Text="Type" Style="{StaticResource LabelStyle}"/>
                                             <TextBlock Text="{Binding MemoryDetails.Type}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                         </StackPanel>
                                         
                                         <StackPanel Grid.Column="1" Margin="4,0,0,8">
                                             <TextBlock Text="Size" Style="{StaticResource LabelStyle}" HorizontalAlignment="Right"/>
                                             <TextBlock Text="{Binding MemoryDetails.Size}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentPurpleBrush}" HorizontalAlignment="Right"/>
                                         </StackPanel>

                                         <StackPanel Grid.Row="1" Margin="0,0,4,0">
                                             <TextBlock Text="Channel #" Style="{StaticResource LabelStyle}"/>
                                             <TextBlock Text="{Binding MemoryDetails.Channels}" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                         </StackPanel>
                                         
                                          <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,0">
                                             <TextBlock Text="NB Frequency" Style="{StaticResource LabelStyle}" HorizontalAlignment="Right"/>
                                             <TextBlock Text="{Binding MemoryDetails.Frequency}" Foreground="{DynamicResource ForegroundLightBrush}" HorizontalAlignment="Right"/>
                                         </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <!-- Timings Box -->
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="3" Padding="8,6">
                                    <Grid>
                                         <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                         <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                         
                                         <TextBlock Text="DRAM Frequency" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Column="1" Text="{Binding MemoryDetails.DRAMFrequency}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                         
                                         <TextBlock Grid.Row="1" Text="CAS# Latency (CL)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,4"/>
                                         <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MemoryDetails.CAS}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrightestBrush}" Margin="0,4"/>
                                         
                                         <TextBlock Grid.Row="2" Text="RAS# to CAS# (tRCD)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MemoryDetails.tRCD}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                         
                                         <TextBlock Grid.Row="3" Text="RAS# Precharge (tRP)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,4"/>
                                         <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MemoryDetails.tRP}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrightestBrush}" Margin="0,4"/>
                                         
                                         <TextBlock Grid.Row="4" Text="Cycle Time (tRAS)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                                         <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MemoryDetails.tRAS}" HorizontalAlignment="Right" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Module List Expander (Improved Click Area) -->
                                <Expander Margin="0,12,0,0" Padding="0">
                                    <Expander.Header>
                                        <Grid HorizontalAlignment="Stretch" Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Expander}}, Path=ActualWidth}">
                                            <Border Background="#1AFFFFFF" CornerRadius="4" Padding="8,6" Margin="0,0,30,0"> <!-- Margin right to avoid arrow overlap -->
                                                <TextBlock Text="SPD (Modules) - Click to View" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding MemoryDetails.Modules}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1" Padding="4,8">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Slot}" FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                                <TextBlock Text="{Binding Manufacturer}" FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding PartNumber}" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Opacity="0.8"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding Size}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right"/>
                                                                <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" HorizontalAlignment="Right"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        
                                                        <!-- Fake SPD Table Table for visual effect (if timings exist) -->
                                                        <ItemsControl ItemsSource="{Binding Timings}" Margin="0,4,0,0">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                     <Border BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="2" Margin="0,0,4,0" Padding="4">
                                                                         <StackPanel>
                                                                             <TextBlock Text="{Binding Frequency, StringFormat='{}{0}MHz'}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                                             <TextBlock Text="{Binding CAS}" FontSize="9" HorizontalAlignment="Center" Foreground="#AAA"/>
                                                                         </StackPanel>
                                                                     </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                            </StackPanel>
                        </ContentControl>
                        


                    </StackPanel>
                    
                    <!-- RIGHT COLUMN (4 Cards) -->
                    <StackPanel Grid.Column="2">
                        <!-- 1. System & BIOS (Moved back to Right Top as requested) -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="🖥️ System &amp; BIOS" Style="{StaticResource SectionHeaderStyle}"/>
                                
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Computer Name" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SystemName}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Manufacturer" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SystemManufacturer}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Model" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SystemModel}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="SKU" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SystemSku}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Type" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SystemType}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                
                                <Border Height="1" Background="{DynamicResource BackgroundLightBrush}" Margin="0,6"/>
                                
                                <TextBlock Text="BIOS / Firmware" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Mode" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding BiosMode}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Version" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding BiosVersion}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="Date" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding BiosDate}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource InfoRowStyle}">
                                    <TextBlock Text="SMBIOS" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="{Binding SmbiosVersion}" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </ContentControl>

                        <!-- 2. Graphics (GPU-Z Style) -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="GPU" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    
                                    <!-- GPU Name Box -->
                                    <Border Grid.Column="1" BorderBrush="#33FFFFFF" BorderThickness="1" Background="#11FFFFFF" CornerRadius="2" Padding="4">
                                        <TextBlock Text="{Binding GpuDetails.Name}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <!-- GPU Details Grid -->
                                <Border BorderBrush="#33FFFFFF" BorderThickness="1" Background="Transparent" Padding="0" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Row 1: SubVendor / CodeName / Tech -->
                                        <Border Grid.Row="0" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Padding="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding GpuDetails.SubVendor}" Foreground="{DynamicResource ForegroundLightBrush}" ToolTip="Subvendor"/>
                                                <TextBlock Grid.Column="1" Text="{Binding GpuDetails.CodeName}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding GpuDetails.Technology}" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Row 2: Bus / ROPs / Shaders -->
                                        <Border Grid.Row="1" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Padding="4">
                                            <Grid>
                                                 <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                 <TextBlock Text="{Binding GpuDetails.BusInterface}" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                 <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                     <TextBlock Text="{Binding GpuDetails.Rops}" ToolTip="ROPs" Margin="0,0,4,0"/>
                                                     <TextBlock Text="/" Foreground="#777" Margin="0,0,4,0"/>
                                                     <TextBlock Text="{Binding GpuDetails.Shaders}" ToolTip="Shaders" FontWeight="SemiBold"/>
                                                 </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Row 3: Memory Info -->
                                        <Border Grid.Row="2" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Padding="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Border Background="#33FFFFFF" CornerRadius="2" Padding="4,0" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding GpuDetails.MemorySize}" FontWeight="Bold" Foreground="{DynamicResource AccentPurpleBrush}"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding GpuDetails.MemoryType}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding GpuDetails.BusWidth}" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Row 4: Clocks Header & Values -->
                                        <TextBlock Grid.Row="3" Text="Current Clocks (MHz)" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="2,4,0,2"/>
                                        
                                        <Grid Grid.Row="4" Margin="4,0,4,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GPU" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <Border Grid.Column="1" Background="#22FFFFFF" CornerRadius="2" Padding="6,2"><TextBlock Text="{Binding GpuDetails.GpuClock}" FontSize="11" HorizontalAlignment="Center"/></Border>
                                            
                                            <TextBlock Grid.Column="2" Text="Memory" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                            <Border Grid.Column="3" Background="#22FFFFFF" CornerRadius="2" Padding="6,2"><TextBlock Text="{Binding GpuDetails.MemoryClock}" FontSize="11" HorizontalAlignment="Center"/></Border>
                                            
                                            <TextBlock Grid.Column="4" Text="Video" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                            <Border Grid.Column="5" Background="#22FFFFFF" CornerRadius="2" Padding="6,2"><TextBlock Text="{Binding GpuDetails.BoostClock}" FontSize="11" HorizontalAlignment="Center"/></Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                                
                                <TextBlock Text="Displays" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,4" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                <ItemsControl ItemsSource="{Binding Monitors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BackgroundMediumBrush}" 
                                                    CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                            <Border CornerRadius="3" Padding="3,1" Margin="6,0,0,0"
                                                                    Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibility}}">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="#4CAF50"/>
                                                                </Border.Background>
                                                                <TextBlock Text="MAIN" FontSize="7" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                        </StackPanel>
                                                        
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock FontSize="10" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold">
                                                                <Run Text="{Binding Resolution, Mode=OneWay}"/>
                                                                <Run Text=" @ "/>
                                                                <Run Text="{Binding RefreshRate, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <TextBlock Text=" • " FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                            <TextBlock Text="{Binding ConnectionType}" FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    
                                                    <Button Grid.Column="1" 
                                                            Content="🔗"
                                                            Style="{StaticResource LinkButtonStyle}"
                                                            Visibility="{Binding SearchUrl, Converter={StaticResource StringToVisibility}}"
                                                            Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding SearchUrl}"
                                                            FontSize="12" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ContentControl>

                        <!-- 2. Storage Drives (Detail List) - Moved from Left -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Drives" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,6"/>
                                
                                <ItemsControl ItemsSource="{Binding DiskDrives}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    
                                                    <!-- Icon -->
                                                    <TextBlock Grid.RowSpan="2" Text="💾" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.8"/>
                                                    
                                                    <!-- Model & Capacity -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                        <TextBlock Text="{Binding Model}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                                        <TextBlock Text="{Binding DisplayCapacity}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Interface, Firmware & Serial -->
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding InterfacePretty}" FontSize="10" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                        <TextBlock Text=" • " FontSize="10" Foreground="#555" Margin="4,0"/>
                                                        <TextBlock Text="{Binding FirmwareRevision}" FontSize="10" Foreground="#AAA" ToolTip="Firmware Revision"/>
                                                        <TextBlock Text=" • " FontSize="10" Foreground="#555" Margin="4,0"/>
                                                        <TextBlock Text="{Binding SerialNumber}" FontSize="10" Foreground="#AAA" ToolTip="Serial Number"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Status / Partitions -->
                                                    <StackPanel Grid.RowSpan="2" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                         <Border Background="#334CAF50" CornerRadius="3" Padding="5,2" HorizontalAlignment="Right" Margin="0,0,0,3">
                                                             <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="Bold" Foreground="#4CAF50"/>
                                                         </Border>
                                                         <TextBlock Text="{Binding Partitions, StringFormat='{}{0} Partitions'}" FontSize="9" Foreground="#777" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ContentControl>
                        

                        
                        <!-- 3. Network Adapters -->
                        <ContentControl Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock Text="🌐 Network Adapters" Style="{StaticResource SectionHeaderStyle}"/>
                                
                                <ItemsControl ItemsSource="{Binding NetworkAdapters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BackgroundMediumBrush}" 
                                                    CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                            <Border CornerRadius="4" Padding="4,1" Margin="8,0,0,0">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Up">
                                                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Status}" FontSize="9"
                                                                           Foreground="{DynamicResource ForegroundOnLightAccentBrush}"/>
                                                            </Border>
                                                        </StackPanel>
                                                    
                                                        <TextBlock Text="{Binding Description}" FontSize="9" 
                                                                   Foreground="{DynamicResource ForegroundLightBrush}" 
                                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                    
                                                        <Grid Margin="0,4,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                        
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding IpAddress}" FontSize="10" 
                                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Speed}" FontSize="10" 
                                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                            
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding MacAddress}" FontSize="9" 
                                                                       Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,2,0,0"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DnsServers}" FontSize="9" 
                                                                       Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding DnsServers}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                    
                                                    <Button Grid.Column="1" 
                                                            Content="📥"
                                                            Style="{StaticResource LinkButtonStyle}"
                                                            Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DriverUrl}"
                                                            FontSize="12" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ContentControl>

                    </StackPanel>
                </Grid>
                
                <!-- Full Width Bottom Section (USB Devices) -->
                <ContentControl Grid.Row="2" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="🔌 USB Devices" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <ItemsControl ItemsSource="{Binding UsbDevices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundMediumBrush}" 
                                            CornerRadius="6" Padding="8" Margin="0,0,8,8" Width="320">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock FontSize="9" Foreground="{DynamicResource ForegroundLightBrush}">
                                                        <Run Text="VID: "/>
                                                        <Run Text="{Binding VendorId, Mode=OneWay}"/>
                                                        <Run Text=" PID: "/>
                                                        <Run Text="{Binding ProductId, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <Button Grid.Column="1" 
                                                    Content="🔗"
                                                    Style="{StaticResource LinkButtonStyle}"
                                                    Visibility="{Binding SearchUrl, Converter={StaticResource StringToVisibility}}"
                                                    Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding SearchUrl}"
                                                    FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
