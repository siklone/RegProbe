<Window x:Class="WindowsOptimizer.App.Views.HardwareDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:WindowsOptimizer.App.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="760"
        Height="700"
        MinWidth="620"
        MinHeight="560"
        MaxWidth="1100"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundDarkestBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
        FontSize="12"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Colors.xaml"/>
                <ResourceDictionary Source="/Resources/Typography.xaml"/>
                <ResourceDictionary Source="/Resources/Spacing.xaml"/>
                <ResourceDictionary Source="/Resources/Icons.xaml"/>
                <ResourceDictionary Source="/Resources/Animations.xaml"/>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
                <ResourceDictionary Source="/Resources/ModernStyles.xaml"/>
                <ResourceDictionary Source="/Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:WindowHeightConverter x:Key="WindowHeightConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootPanel"
            Margin="10"
            CornerRadius="12"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="10"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
                        <DoubleAnimation Storyboard.TargetName="RootTranslate" Storyboard.TargetProperty="Y" From="10" To="0" Duration="0:0:0.18">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Border x:Name="HeaderCard" Grid.Row="0" Margin="10,10,10,8" Style="{DynamicResource ModernCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="42"
                            Height="42"
                            CornerRadius="9"
                            Background="{DynamicResource BackgroundLightBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                        <Image Source="{Binding IconSource}"
                               Width="24"
                               Height="24"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="32"
                            Height="32"
                            Margin="12,0,0,0"
                            Padding="0"
                            VerticalAlignment="Top"
                            Content="X"
                            FontSize="12"
                            FontWeight="Bold"
                            Background="{DynamicResource BackgroundLightBrush}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{DynamicResource ModernButtonStyle}"/>
                </Grid>
            </Border>

            <!-- Row 1: Scrollable Content -->
            <Border Grid.Row="1" Margin="10,0,10,10" Style="{DynamicResource ModernCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="HasDeviceTabsBorder"
                            Grid.Row="0"
                            Margin="0,0,0,10"
                            Background="{DynamicResource BackgroundMediumBrush}"
                            CornerRadius="8"
                            Visibility="{Binding HasDeviceTabs, Converter={StaticResource BoolToVisibility}}">
                        <ListBox ItemsSource="{Binding DeviceTabs}"
                                 SelectedItem="{Binding SelectedDeviceTab, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding IconSource}"
                                               Width="14"
                                               Height="14"
                                               Margin="0,0,6,0"
                                               Stretch="Uniform"
                                               VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Header}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="3"/>
                                    <Setter Property="Padding" Value="10,6"/>
                                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <!-- Loading Skeleton -->
                    <Grid Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Margin="8">
                            <ItemsControl ItemsSource="{Binding SkeletonRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="20"
                                                Margin="0,0,0,6"
                                                CornerRadius="8"
                                                Background="{DynamicResource BackgroundMediumBrush}"
                                                Opacity="0.6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- Scrollable Specs -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="SpecsScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True"
                                  PanningMode="VerticalOnly"
                                  Style="{DynamicResource AutoHidingScrollViewerStyle}"
                                  Margin="0,2,0,0"
                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ScrollViewer.Resources>

                        <ItemsControl ItemsSource="{Binding Specs}" Margin="4,2,4,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Border x:Name="ValueRowBorder"
                                                Padding="10,8"
                                                CornerRadius="10"
                                                Background="#14000000"
                                                BorderBrush="#18FFFFFF"
                                                BorderThickness="1">
                                            <Grid x:Name="ValueRow">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="156"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Label}"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top"
                                                           Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel x:Name="HeaderRow" Visibility="Collapsed" Margin="2,10,2,0">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Border Height="1"
                                                    Margin="0,6,0,0"
                                                    Background="#20FFFFFF"/>
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsGroupHeader}" Value="True">
                                            <Setter TargetName="ValueRowBorder" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="HeaderRow" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
