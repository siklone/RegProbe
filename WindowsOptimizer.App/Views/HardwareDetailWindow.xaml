<Window x:Class="WindowsOptimizer.App.Views.HardwareDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="600" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundDarkestBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
        FontSize="12"
        ResizeMode="CanResize"
        Opacity="0">

    <!-- Entrance Animation: Fade-in + Slide-up -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Fade in -->
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"
                                     EasingFunction="{StaticResource EntranceEase}"/>
                    <!-- Slide up -->
                    <DoubleAnimation Storyboard.TargetName="RootTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="30" To="0" Duration="0:0:0.35"
                                     EasingFunction="{StaticResource EntranceEase}"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.RenderTransform>
        <TranslateTransform x:Name="RootTransform" Y="30"/>
    </Window.RenderTransform>

    <Window.Resources>
        <CubicEase x:Key="EntranceEase" EasingMode="EaseOut"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="DetailValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
            <Setter Property="Margin" Value="0,16,0,12"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundDarkBrush}" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Border Grid.Column="0" Background="{Binding IconBackground}" CornerRadius="12" Padding="16" Margin="0,0,20,0">
                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="32"/>
                </Border>

                <!-- Title & Subtitle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                    <TextBlock Text="{Binding Subtitle}" FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Status & Primary Value -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding PrimaryValue}" FontSize="48" FontWeight="Bold" Foreground="{Binding PrimaryValueColor}"/>
                        <TextBlock Text="{Binding PrimaryUnit}" FontSize="24" Foreground="{DynamicResource ForegroundLightBrush}"
                                   VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Padding="24,12">
            <StackPanel>
                <!-- Quick Stats Row -->
                <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stat1Label}" Style="{StaticResource DetailLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Stat1Value}" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="3,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stat2Label}" Style="{StaticResource DetailLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Stat2Value}" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="3,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stat3Label}" Style="{StaticResource DetailLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Stat3Value}" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource CautionBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stat4Label}" Style="{StaticResource DetailLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Stat4Value}" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Specifications Section -->
                <TextBlock Text="Specifications" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <ItemsControl ItemsSource="{Binding Specifications}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Key}" Style="{StaticResource DetailLabelStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource DetailValueStyle}"
                                               VerticalAlignment="Center" Margin="0" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Additional Details Section -->
                <TextBlock Text="Details" Style="{StaticResource SectionHeaderStyle}"
                           Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibility}}"/>
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding Details}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Key}" Style="{StaticResource DetailLabelStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource DetailValueStyle}"
                                               VerticalAlignment="Center" Margin="0" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Sub-Items (for RAM modules, Disk partitions, etc.) -->
                <TextBlock Text="{Binding SubItemsHeader}" Style="{StaticResource SectionHeaderStyle}"
                           Visibility="{Binding HasSubItems, Converter={StaticResource BoolToVisibility}}"/>
                <ItemsControl ItemsSource="{Binding SubItems}"
                              Visibility="{Binding HasSubItems, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{DynamicResource BackgroundLightBrush}"
                                            CornerRadius="8" Padding="12" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding Properties}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,24,4">
                                                        <TextBlock Text="{Binding Key}" FontSize="11"
                                                                   Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Value}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BackgroundDarkBrush}" Padding="24,16">
            <Grid>
                <TextBlock Text="{Binding FooterText}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Close" HorizontalAlignment="Right" Padding="24,8"
                        Command="{Binding CloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{DynamicResource ModernButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

