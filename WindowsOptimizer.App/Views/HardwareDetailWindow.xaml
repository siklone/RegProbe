<Window x:Class="WindowsOptimizer.App.Views.HardwareDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:WindowsOptimizer.App.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}"
        SizeToContent="Height"
        Width="640"
        MinWidth="520"
        MaxWidth="760"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundDarkestBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
        FontSize="12">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Colors.xaml"/>
                <ResourceDictionary Source="/Resources/Typography.xaml"/>
                <ResourceDictionary Source="/Resources/Spacing.xaml"/>
                <ResourceDictionary Source="/Resources/Icons.xaml"/>
                <ResourceDictionary Source="/Resources/Animations.xaml"/>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
                <ResourceDictionary Source="/Resources/ModernStyles.xaml"/>
                <ResourceDictionary Source="/Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:WindowHeightConverter x:Key="WindowHeightConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootPanel"
            Margin="10"
            CornerRadius="12"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="10"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
                        <DoubleAnimation Storyboard.TargetName="RootTranslate" Storyboard.TargetProperty="Y" From="10" To="0" Duration="0:0:0.18">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Border Grid.Row="0" Margin="12,12,12,8" Style="{DynamicResource ModernCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="48"
                            Height="48"
                            CornerRadius="10"
                            Background="{DynamicResource BackgroundLightBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                        <Image Source="{Binding IconSource}"
                               Width="28"
                               Height="28"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Row 1: Scrollable Content -->
            <Border Grid.Row="1" Margin="12,0,12,0" Style="{DynamicResource ModernCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="8,8,8,0"
                            Background="{DynamicResource BackgroundMediumBrush}"
                            CornerRadius="8"
                            Visibility="{Binding HasDeviceTabs, Converter={StaticResource BoolToVisibility}}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      Style="{DynamicResource AutoHidingScrollViewerStyle}">
                            <ListBox ItemsSource="{Binding DeviceTabs}"
                                     SelectedItem="{Binding SelectedDeviceTab, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding IconSource}"
                                                   Width="14"
                                                   Height="14"
                                                   Margin="0,0,6,0"
                                                   Stretch="Uniform"
                                                   VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Header}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="4"/>
                                        <Setter Property="Padding" Value="12,6"/>
                                        <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <!-- Loading Skeleton -->
                    <Grid Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Margin="8">
                            <TextBlock Text="{Binding LoadingMessage}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding SkeletonRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="24"
                                                Margin="0,0,0,4"
                                                CornerRadius="6"
                                                Background="{DynamicResource BackgroundMediumBrush}"
                                                Opacity="0.6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- Scrollable Specs -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="SpecsScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True"
                                  PanningMode="VerticalOnly"
                                  Style="{DynamicResource AutoHidingScrollViewerStyle}"
                                  MaxHeight="480"
                                  Margin="0,4,0,0"
                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ScrollViewer.Resources>

                        <ItemsControl ItemsSource="{Binding Specs}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                 Text="{Binding Label}" 
                                                 Foreground="{DynamicResource MutedForegroundBrush}" 
                                                 FontSize="13"
                                                 VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1" 
                                                 Text="{Binding Value}" 
                                                 Foreground="{DynamicResource ForegroundBrightestBrush}" 
                                                 FontSize="13" 
                                                 TextWrapping="Wrap"
                                                 VerticalAlignment="Top"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Row 2: Footer -->
            <Border Grid.Row="2" Margin="12,8,12,12" Style="{DynamicResource ModernCardStyle}">
                <Grid>
                    <TextBlock Text="Data loaded from cache"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource MutedForegroundBrush}"/>

                    <Button Content="Close"
                            HorizontalAlignment="Right"
                            Padding="20,6"
                            Click="CloseButton_Click"
                            Style="{DynamicResource ModernButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
