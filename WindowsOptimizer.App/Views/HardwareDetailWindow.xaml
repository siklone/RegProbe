<Window x:Class="WindowsOptimizer.App.Views.HardwareDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:WindowsOptimizer.App.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="760"
        Height="700"
        MinWidth="620"
        MinHeight="560"
        MaxWidth="1100"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundDarkestBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
        FontSize="12"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Colors.xaml"/>
                <ResourceDictionary Source="/Resources/Typography.xaml"/>
                <ResourceDictionary Source="/Resources/Spacing.xaml"/>
                <ResourceDictionary Source="/Resources/Icons.xaml"/>
                <ResourceDictionary Source="/Resources/Animations.xaml"/>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
                <ResourceDictionary Source="/Resources/ModernStyles.xaml"/>
                <ResourceDictionary Source="/Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:WindowHeightConverter x:Key="WindowHeightConverter"/>

            <Style x:Key="HardwareDetailShellCardStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource AppSurfaceCardStyle}">
                <Setter Property="Padding" Value="16"/>
                <Setter Property="CornerRadius" Value="18"/>
            </Style>

            <Style x:Key="InsightCardStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource AppInsetPanelStyle}">
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Margin" Value="0,0,10,10"/>
                <Setter Property="MinHeight" Value="92"/>
            </Style>

            <Style x:Key="HardwareDetailTabHostStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource AppInsetPanelStyle}">
                <Setter Property="Padding" Value="6"/>
                <Setter Property="CornerRadius" Value="14"/>
            </Style>

            <Style x:Key="HardwareDetailTabItemStyle" TargetType="ListBoxItem">
                <Setter Property="Margin" Value="4"/>
                <Setter Property="Padding" Value="11,7"/>
                <Setter Property="Background" Value="#16000000"/>
                <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#1C2A33"/>
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#18252F"/>
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#32FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="HardwareDetailSpecCardStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource AppInsetPanelStyle}">
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="CornerRadius" Value="14"/>
            </Style>

            <Style x:Key="HardwareDetailInsightTitleStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource AppSectionEyebrowTextStyle}">
                <Setter Property="FontSize" Value="10"/>
            </Style>

            <Style x:Key="HardwareDetailInsightBodyStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource AppSectionSubtitleTextStyle}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="HardwareDetailSectionTitleStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource AppSectionTitleTextStyle}">
                <Setter Property="FontSize" Value="19"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootPanel"
            Margin="10"
            Background="{DynamicResource BackgroundDarkestBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="10"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
                        <DoubleAnimation Storyboard.TargetName="RootTranslate" Storyboard.TargetProperty="Y" From="10" To="0" Duration="0:0:0.18">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Border x:Name="HeaderCard" Grid.Row="0" Margin="10,10,10,8" Style="{StaticResource HardwareDetailShellCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="42"
                            Height="42"
                            CornerRadius="11"
                            Style="{StaticResource AppInsetPanelStyle}"
                            Padding="0"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                        <Image Source="{Binding IconSource}"
                               Width="24"
                               Height="24"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Device details"
                                   Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                        <TextBlock Text="{Binding Title}"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource HardwareDetailSectionTitleStyle}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource AppSectionSubtitleTextStyle}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="34"
                            Height="34"
                            Margin="12,0,0,0"
                            Padding="0"
                            VerticalAlignment="Top"
                            Background="#18000000"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource AppQuietActionButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE711;"
                                   FontSize="11"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Row 1: Scrollable Content -->
            <Border Grid.Row="1" Margin="10,0,10,10" Style="{StaticResource HardwareDetailShellCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0"
                                 Columns="2"
                                 Margin="0,0,0,10"
                                 Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Border Style="{StaticResource InsightCardStyle}">
                            <StackPanel>
                                <TextBlock Text="What this is"
                                           Style="{StaticResource HardwareDetailInsightTitleStyle}"/>
                                <TextBlock Text="{Binding WhatThisIs}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource HardwareDetailInsightBodyStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsightCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Why it matters"
                                           Style="{StaticResource HardwareDetailInsightTitleStyle}"/>
                                <TextBlock Text="{Binding WhyItMatters}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource HardwareDetailInsightBodyStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsightCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Driver / runtime"
                                           Style="{StaticResource HardwareDetailInsightTitleStyle}"/>
                                <TextBlock Text="{Binding DriverRuntime}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource HardwareDetailInsightBodyStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsightCardStyle}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Common actions"
                                           Style="{StaticResource HardwareDetailInsightTitleStyle}"/>
                                <TextBlock Text="{Binding CommonActions}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource HardwareDetailInsightBodyStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border x:Name="HasDeviceTabsBorder"
                            Grid.Row="1"
                            Margin="0,0,0,10"
                            Style="{StaticResource HardwareDetailTabHostStyle}"
                            Visibility="{Binding HasDeviceTabs, Converter={StaticResource BoolToVisibility}}">
                        <ListBox ItemsSource="{Binding DeviceTabs}"
                                 SelectedItem="{Binding SelectedDeviceTab, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding IconSource}"
                                               Width="14"
                                               Height="14"
                                               Margin="0,0,6,0"
                                               Stretch="Uniform"
                                               VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Header}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource HardwareDetailTabItemStyle}"/>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <!-- Loading Skeleton -->
                    <Grid Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Margin="8">
                            <ItemsControl ItemsSource="{Binding SkeletonRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="20"
                                                Margin="0,0,0,6"
                                                CornerRadius="8"
                                                Background="{DynamicResource BackgroundMediumBrush}"
                                                Opacity="0.6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- Scrollable Specs -->
                    <ScrollViewer Grid.Row="2"
                                  x:Name="SpecsScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True"
                                  PanningMode="VerticalOnly"
                                  Style="{DynamicResource AutoHidingScrollViewerStyle}"
                                  Margin="0,2,0,0"
                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ScrollViewer.Resources>

                        <ItemsControl ItemsSource="{Binding Specs}" Margin="4,2,4,4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid x:Name="SpecItemRoot"
                                          Width="332"
                                          Margin="0,0,10,10">
                                        <Border x:Name="ValueRowBorder"
                                                Style="{StaticResource HardwareDetailSpecCardStyle}">
                                            <Grid x:Name="ValueRow">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding Label}"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           FontSize="10"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top"/>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Value}"
                                                           Margin="0,4,0,0"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel x:Name="HeaderRow"
                                                    Width="560"
                                                    Visibility="Collapsed"
                                                    Margin="2,8,2,2">
                                            <TextBlock Text="{Binding Label}"
                                                       Style="{StaticResource AppSectionEyebrowTextStyle}"
                                                       TextWrapping="Wrap"/>
                                            <Border Height="1"
                                                    Margin="0,6,0,0"
                                                    Background="#20FFFFFF"/>
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsGroupHeader}" Value="True">
                                            <Setter TargetName="ValueRowBorder" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="HeaderRow" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="SpecItemRoot" Property="Width" Value="560"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
