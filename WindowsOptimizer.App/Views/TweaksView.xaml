                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsChecked" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Rounded ComboBox Style -->
        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <ToggleButton Name="ToggleButton" 
                                              Background="Transparent" 
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter Name="ContentSite" 
                                                  IsHitTestVisible="False" 
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="5,3,23,3"
                                                  VerticalAlignment="Center"/>
                                <Path Name="Arrow" 
                                      Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 Z" 
                                      Fill="{DynamicResource AccentDarkBlueBrush}" 
                                      HorizontalAlignment="Right" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,8,0"/>
                                <Popup Name="Popup" 
                                       Placement="Bottom" 
                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                       AllowsTransparency="True" 
                                       Focusable="False" 
                                       PopupAnimation="Slide">
                                    <Border Name="DropDownBorder" 
                                            Background="{DynamicResource BackgroundDarkBrush}" 
                                            BorderBrush="{DynamicResource GlassBorderBrush}"
                                            BorderThickness="1" 
                                            CornerRadius="4">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Main Tab Button Style (Top-Level Tabs) -->
        <Style x:Key="MainTabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrightCyan10Brush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrightCyan20Brush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMainTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Border Background="Transparent"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="0"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMainTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="{DynamicResource AppQuietButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Margin="{TemplateBinding Margin}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="HeaderContent"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AppQuietButtonHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ShellTopNavHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AppWorkspaceSelectedBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        

        <!-- Recursive Category Template -->

        <!-- Expander Button Style -->
        <Style x:Key="ExpanderButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" Padding="4">
                            <TextBlock x:Name="Icon" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11" RenderTransformOrigin="0.5,0.5">
	                                <TextBlock.RenderTransform>
	                                    <RotateTransform x:Name="IconRotate" Angle="0"/>
	                                </TextBlock.RenderTransform>
	                            </TextBlock>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconRotate" 
                                                           Storyboard.TargetProperty="Angle"
                                                           To="90" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconRotate" 
                                                           Storyboard.TargetProperty="Angle"
                                                           To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tweak Item Template -->
        <DataTemplate x:Key="TweakItemTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
            <Border Background="Transparent"
                    CornerRadius="0"
                    Margin="0"
                    Padding="15,14,14,14"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="0,0,0,1"
                    SnapsToDevicePixels="True"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform x:Name="CardTranslate" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 From="4" To="0" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=IsCompactMode}" Value="True">
                                <Setter Property="Padding" Value="13,12,12,12"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter Property="Background" Value="#121720"/>
                                <Setter Property="BorderBrush" Value="#36FF4C58"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="CornerRadius" Value="10"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Checkbox -->
                            <ColumnDefinition Width="*"/>     <!-- Content -->
                            <ColumnDefinition Width="Auto"/>  <!-- Actions -->
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="0,2,14,0"
                                  ToolTip="Queue this setting for batch actions"
                                  Style="{StaticResource SelectionCheckboxStyle}"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                   FontFamily="{DynamicResource FontFamilyDisplay}"
                                           FontSize="14"/>
                                <Border Background="{Binding StatusBadgeBackground}"
                                        BorderBrush="{Binding StatusColor}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="8,2"
                                        Margin="8,0,0,0"
                                        ToolTip="{Binding StatusTooltip}">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusColor}"
                                                   FontFamily="{DynamicResource FontFamilyMono}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Border Background="{DynamicResource SuccessBrush}" 
                                        CornerRadius="10" 
                                        Padding="8,2" 
                                        Margin="8,0,0,0"
                                        Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibility}}"
                                        ToolTip="{Binding RecommendationReason}">
                                    <TextBlock Text="REC" 
                                               Foreground="{DynamicResource ForegroundOnLightAccentBrush}" 
                                                   FontFamily="{DynamicResource FontFamilyMono}"
                                               FontSize="10" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                   FontFamily="{DynamicResource FontFamilyText}"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"
                                       MaxHeight="34"
                                       Margin="0,4,0,0"
                                       LineHeight="15"/>
                            <TextBlock Margin="0,7,0,0"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                   FontFamily="{DynamicResource FontFamilyMono}"
                                       FontSize="9.5"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding CompactInfoTooltip}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} · {1} · {2}">
                                        <Binding Path="ImpactAreaLabel"/>
                                        <Binding Path="CompactInfoLine"/>
                                        <Binding Path="InventoryFreshnessText"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                             <ComboBox ItemsSource="{Binding ChoiceOptions}"
                                       SelectedItem="{Binding SelectedChoiceOption, Mode=TwoWay}"
                                       DisplayMemberPath="Label"
                                       Width="148"
                                       Margin="0,0,8,0"
                                       Style="{StaticResource RoundedComboBox}"
                                       ToolTip="{Binding SelectedChoiceDescription}"
                                       Visibility="{Binding HasChoiceOptions, Converter={StaticResource BoolToVisibility}}"/>
                             <Button Content="Previous"
                                     Command="{Binding RollbackCommand}"
                                     Style="{StaticResource TweakActionButtonStyle}"
                                     Padding="10,4"
                                     MinWidth="74"
                                     Margin="0,0,6,0"
                                     ToolTip="Restore the previous value captured before Apply."/>
                             <Button Content="{Binding RestoreDefaultButtonText}"
                                     Command="{Binding RestoreDefaultCommand}"
                                     Style="{StaticResource TweakActionButtonStyle}"
                                     Padding="10,4"
                                     MinWidth="82"
                                     Margin="0,0,6,0"
                                     ToolTip="{Binding RestoreDefaultTooltip}"
                                     Visibility="{Binding HasDefaultChoice, Converter={StaticResource BoolToVisibility}}"/>
                             <Button Content="{Binding ActionButtonText}"
                                     Command="{Binding ApplyCommand}"
                                     Style="{StaticResource TweakPrimaryActionButtonStyle}"
                                     Padding="10,4"
                                     MinWidth="68"
                                     Margin="0,0,6,0"
                                     ToolTip="Apply this setting without opening details."/>
                             <Button Command="{Binding ToggleFavoriteCommand}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Cursor="Hand"
                                     Padding="4,2"
                                     ToolTip="Toggle favorite"
                                     Visibility="Collapsed">
                                 <Button.Style>
                                     <Style TargetType="Button">
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                         <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                     </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                     </Style>
                                 </Button.Style>
                                 <TextBlock Text="{Binding FavoriteIcon}" FontSize="12" Opacity="0.72">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock">
                                             <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                     <Setter Property="Foreground" Value="{DynamicResource CautionBrush}"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                 </TextBlock>
                             </Button>
                             <ToggleButton IsChecked="{Binding IsDetailsExpanded}"
                                           Style="{StaticResource ExpanderButtonStyle}"
                                           Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Expanded Details Area -->
                    <Border Margin="0,8,0,0"
                            Background="Transparent"
                            ClipToBounds="True"
                            RenderTransformOrigin="0.5,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="MaxHeight" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                     To="2000" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                     To="0" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ScrollViewer MaxHeight="420"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      PanningMode="VerticalOnly"
                                      utilities:ScrollViewerHelper.EnableMouseWheelScroll="True">
                        <StackPanel>
                         <!-- Detail Tabs -->
                         <UniformGrid Columns="2" Margin="0,0,0,10">
                             <ToggleButton IsChecked="{Binding ShowTerminal, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                                           Content="What Changes"
                                           Style="{StaticResource TabButtonStyle}"/>
                             <ToggleButton IsChecked="{Binding ShowTerminal, Mode=TwoWay}"
                                           Content="Run Details"
                                           Style="{StaticResource TabButtonStyle}"/>
                         </UniformGrid>

                         <!-- Tab View 1: Technical Info -->
                         <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource InverseBoolToVisibility}}">
                             <UniformGrid Columns="2" Margin="0,0,0,10">
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="10" Margin="0,0,6,0">
                                     <StackPanel>
                                         <TextBlock Text="What this setting does" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                         <TextBlock Text="{Binding FriendlyDescription}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="10" Margin="6,0,0,0">
                                     <StackPanel>
                                         <TextBlock Text="What to expect" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                         <TextBlock Text="{Binding EffectSummary}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                             </UniformGrid>

                             <UniformGrid Columns="2"
                                          Margin="0,0,0,10"
                                          Visibility="{Binding HasExtendedGuidance, Converter={StaticResource BoolToVisibility}}">
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}"
                                         CornerRadius="6"
                                         Padding="10"
                                         Margin="0,0,6,0"
                                         Visibility="{Binding HasGuidanceWhenHelpful, Converter={StaticResource BoolToVisibility}}">
                                     <StackPanel>
                                         <TextBlock Text="Good when" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                         <TextBlock Text="{Binding GuidanceWhenHelpful}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}"
                                         CornerRadius="6"
                                         Padding="10"
                                         Margin="6,0,0,0"
                                         Visibility="{Binding HasGuidanceTradeoffs, Converter={StaticResource BoolToVisibility}}">
                                     <StackPanel>
                                         <TextBlock Text="Trade-offs" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                         <TextBlock Text="{Binding GuidanceTradeoffs}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                             </UniformGrid>

                             <UniformGrid Columns="2"
                                          Margin="0,0,0,10"
                                          Visibility="{Binding HasExtendedGuidance, Converter={StaticResource BoolToVisibility}}">
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}"
                                         CornerRadius="6"
                                         Padding="10"
                                         Margin="0,0,6,0"
                                         Visibility="{Binding HasDefaultVsPreviousSummary, Converter={StaticResource BoolToVisibility}}">
                                     <StackPanel>
                                         <TextBlock Text="Previous vs default" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                         <TextBlock Text="{Binding DefaultVsPreviousSummary}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}"
                                         CornerRadius="6"
                                         Padding="10"
                                         Margin="6,0,0,0"
                                         Visibility="{Binding HasProfessionalNotes, Converter={StaticResource BoolToVisibility}}">
                                     <StackPanel>
                                         <TextBlock Text="Professional notes" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                         <TextBlock Text="{Binding ProfessionalNotes}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                             </UniformGrid>

                             <StackPanel Margin="0,0,0,10">
                                 <Grid Margin="0,0,0,4"
                                       Visibility="{Binding HasCompactInfoLine, Converter={StaticResource BoolToVisibility}}"
                                       ToolTip="{Binding CompactInfoTooltip}">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="*"/>
                                     </Grid.ColumnDefinitions>
                                     <Border Background="{DynamicResource BackgroundMediumBrush}"
                                             BorderBrush="{DynamicResource GlassBorderBrush}"
                                             BorderThickness="1"
                                             CornerRadius="3"
                                             Padding="4,0"
                                             Margin="0,0,5,0">
                                         <TextBlock Text="{Binding ImpactAreaLabel}"
                                                    Foreground="{DynamicResource ForegroundLightBrush}"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"/>
                                     </Border>
                                     <TextBlock Grid.Column="1"
                                                Text="{Binding CompactInfoLine}"
                                                Foreground="{DynamicResource ForegroundLightBrush}"
                                                FontSize="11"
                                                Opacity="0.9"
                                                TextWrapping="Wrap"/>
                                 </Grid>
                                 <TextBlock Text="{Binding BatchSummaryLine}"
                                            Visibility="{Binding HasBatchSummaryLine, Converter={StaticResource BoolToVisibility}}"
                                            Foreground="{DynamicResource MutedForegroundBrush}"
                                            FontSize="10"
                                            Margin="0,0,0,4"
                                            TextWrapping="Wrap"/>
                                 <TextBlock Text="{Binding InventoryFreshnessText}"
                                            Foreground="{DynamicResource MutedForegroundBrush}"
                                            FontSize="10"
                                            Margin="0,0,0,4"
                                            TextWrapping="Wrap"/>

                                 <Border Visibility="{Binding HasStateChange, Converter={StaticResource BoolToVisibility}}"
                                         Background="{DynamicResource BackgroundMediumBrush}"
                                         BorderBrush="{DynamicResource GlassBorderBrush}"
                                         BorderThickness="1"
                                         CornerRadius="4"
                                         Padding="8,6">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="*"/>
                                         </Grid.ColumnDefinitions>

                                         <TextBlock Grid.Column="0"
                                                    Text="Before:"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource DangerBrush}"
                                                    Margin="0,0,4,0"/>
                                         <TextBlock Grid.Column="1"
                                                    Text="{Binding BeforeState}"
                                                    FontSize="10"
                                                           FontFamily="{DynamicResource FontFamilyMono}"
                                                    Foreground="{DynamicResource ForegroundLightBrush}"
                                                    TextTrimming="CharacterEllipsis"
                                                    Margin="0,0,12,0"/>

                                         <TextBlock Grid.Column="2"
                                                    Text="After:"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource SuccessBrush}"
                                                    Margin="0,0,4,0"/>
                                         <TextBlock Grid.Column="3"
                                                    Text="{Binding AfterState}"
                                                    FontSize="10"
                                                           FontFamily="{DynamicResource FontFamilyMono}"
                                                    Foreground="{DynamicResource ForegroundLightBrush}"
                                                    TextTrimming="CharacterEllipsis"/>
                                     </Grid>
                                 </Border>
                             </StackPanel>

                             <UniformGrid Columns="2" Margin="0,0,0,10">
                                 <Border Style="{StaticResource TweakInsightCardStyle}">
                                     <StackPanel>
                                         <TextBlock Text="Detected from" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                         <TextBlock Text="{Binding DetectedFromSummary}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                                 <Border Style="{StaticResource TweakInsightCardStyle}">
                                     <StackPanel>
                                         <TextBlock Text="Affects" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                         <TextBlock Text="{Binding AffectsSummary}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                                 <Border Style="{StaticResource TweakInsightCardStyle}">
                                     <StackPanel>
                                         <TextBlock Text="Restart" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                         <TextBlock Text="{Binding RestartAdvice}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                                 <Border Style="{StaticResource TweakInsightCardStyle}">
                                     <StackPanel>
                                         <TextBlock Text="Related settings" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                         <TextBlock Text="{Binding RelatedSettingsSummary}" Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" TextWrapping="Wrap"/>
                                     </StackPanel>
                                 </Border>
                             </UniformGrid>

                             <!-- Registry Info -->
                             <StackPanel Visibility="{Binding HasRegistryPath, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="Registry Location" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Grid>
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8,5">
                                        <TextBlock Text="{Binding RegistryPath}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontFamily="{DynamicResource FontFamilyMono}" TextWrapping="Wrap"/>
                                     </Border>
                                     <Button Grid.Column="1" Command="{Binding CopyRegistryPathCommand}" Content="Copy" Style="{StaticResource CompactButton}" Margin="4,0,0,0"/>
                                 </Grid>
                             </StackPanel>

                             <!-- Registry Diff -->
                             <StackPanel Visibility="{Binding HasDiff, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="Current vs target" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <UniformGrid Columns="2">
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4,0,0,4" Padding="8,6" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1,1,0,1">
                                         <StackPanel>
                                              <TextBlock Text="CURRENT" FontSize="10" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding CurrentValue}" Foreground="{DynamicResource CautionBrush}" FontSize="11" FontFamily="{DynamicResource FontFamilyMono}"/>
                                         </StackPanel>
                                     </Border>
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="0,4,4,0" Padding="8,6" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                                         <StackPanel>
                                              <TextBlock Text="TARGET" FontSize="10" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding TargetValue}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontFamily="{DynamicResource FontFamilyMono}"/>
                                         </StackPanel>
                                     </Border>
                                 </UniformGrid>
                             </StackPanel>

                             <!-- Batch Details -->
                             <StackPanel Visibility="{Binding HasBatchDetails, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="{Binding BatchDetailsTitle, StringFormat={}{0} Breakdown}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8">
                                     <ItemsControl ItemsSource="{Binding BatchDetails}">
                                         <ItemsControl.ItemTemplate>
                                             <DataTemplate>
                                                 <TextBlock Text="{Binding}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                             </DataTemplate>
                                         </ItemsControl.ItemTemplate>
                                     </ItemsControl>
                                 </Border>
                             </StackPanel>

                             <!-- Priority Calculator -->
                             <StackPanel Visibility="{Binding HasPriorityCalculator, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="System Priority Calculator" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,6"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10">
                                     <StackPanel>
                                         <TextBlock Text="{Binding PriorityCalculator.Description}" Foreground="{DynamicResource CautionBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                         <UniformGrid Columns="3">
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalLength}" Style="{StaticResource RoundedComboBox}" FontSize="11" Margin="0,0,4,0">
                                                 <ComboBoxItem Content="Short"/><ComboBoxItem Content="Long"/>
                                             </ComboBox>
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalType}" Style="{StaticResource RoundedComboBox}" FontSize="11" Margin="0,0,4,0">
                                                 <ComboBoxItem Content="Variable"/><ComboBoxItem Content="Fixed"/>
                                             </ComboBox>
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.Boost}" Style="{StaticResource RoundedComboBox}" FontSize="11">
                                                 <ComboBoxItem Content="None"/><ComboBoxItem Content="Middle"/><ComboBoxItem Content="Max"/>
                                             </ComboBox>
                                         </UniformGrid>
                                     </StackPanel>
                                 </Border>
                             </StackPanel>

                             <!-- Code Example -->
                             <StackPanel Visibility="{Binding HasCodeExample, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="Command Preview" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10">
                                        <TextBlock Text="{Binding CodeExample}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontFamily="{DynamicResource FontFamilyMono}" TextWrapping="Wrap"/>
                                 </Border>
                             </StackPanel>

                             <!-- Reference Links -->
	                             <ItemsControl ItemsSource="{Binding UserReferenceLinks}"
                                           Margin="0,0,0,10"
                                           Visibility="{Binding HasUserReferenceLinks, Converter={StaticResource BoolToVisibility}}">
	                                 <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
	                                 <ItemsControl.ItemTemplate>
	                                     <DataTemplate>
	                                         <Button Style="{StaticResource LinkButtonStyle}"
	                                                 Margin="0,0,12,4"
	                                                 ToolTip="{Binding Tooltip}"
	                                                 Command="{Binding DataContext.OpenReferenceLinkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
	                                                 CommandParameter="{Binding Url}">
	                                            <StackPanel Orientation="Horizontal">
	                                                <TextBlock Text="{Binding Icon}" FontSize="11" Margin="0,0,4,0"/>
	                                                <TextBlock Text="{Binding Title}"/>
	                                            </StackPanel>
	                                         </Button>
	                                     </DataTemplate>
	                                 </ItemsControl.ItemTemplate>
	                             </ItemsControl>
                         </StackPanel>

                         <!-- Tab View 2: Execution Log -->
                         <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource BoolToVisibility}}">
                             <Border Background="{DynamicResource TerminalBackgroundBrush}" CornerRadius="4" Padding="10" Height="130">
                                 <ScrollViewer VerticalScrollBarVisibility="Auto"
                                               HorizontalScrollBarVisibility="Disabled"
                                               CanContentScroll="False"
                                               utilities:ScrollViewerHelper.EnableMouseWheelScroll="True">
                                        <TextBlock Text="{Binding TerminalOutput}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" FontFamily="{DynamicResource FontFamilyMono}" TextWrapping="Wrap"/>
                                 </ScrollViewer>
                             </Border>
                         </StackPanel>

                         <!-- Footer Actions -->
                         <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8" Margin="0,2,0,0">
                             <Grid>
                                 <StackPanel Orientation="Horizontal">
	                                     <ComboBox ItemsSource="{Binding ChoiceOptions}"
	                                               SelectedItem="{Binding SelectedChoiceOption, Mode=TwoWay}"
	                                               DisplayMemberPath="Label"
	                                               Width="176"
	                                               Margin="0,0,8,0"
	                                               Style="{StaticResource RoundedComboBox}"
	                                               ToolTip="{Binding SelectedChoiceDescription}"
	                                               Visibility="{Binding HasChoiceOptions, Converter={StaticResource BoolToVisibility}}"/>
	                                     <Button Content="Detect"
	                                             Command="{Binding DetectCommand}"
	                                             Style="{StaticResource TweakActionButtonStyle}"
	                                             Margin="0,0,6,0"
	                                             ToolTip="Detect: reads current state (no changes)."/>
	                                     <Button Content="Restore Previous"
	                                             Command="{Binding RollbackCommand}"
	                                             Style="{StaticResource TweakActionButtonStyle}"
	                                             Margin="0,0,6,0"
	                                             ToolTip="Restore the previous value captured before Apply."/>
	                                     <Button Content="{Binding RestoreDefaultButtonText}"
	                                             Command="{Binding RestoreDefaultCommand}"
	                                             Style="{StaticResource TweakActionButtonStyle}"
	                                             Margin="0,0,6,0"
	                                             ToolTip="{Binding RestoreDefaultTooltip}"
	                                             Visibility="{Binding HasDefaultChoice, Converter={StaticResource BoolToVisibility}}"/>
	                                     <Button Content="{Binding ActionButtonText}"
	                                             Command="{Binding ApplyCommand}"
	                                             Style="{StaticResource TweakPrimaryActionButtonStyle}"
	                                             ToolTip="Apply: Detect -> Apply -> Verify (Rollback on failure)."/>
	                                     <Button Content="?"
	                                             Style="{StaticResource TweakActionButtonStyle}"
	                                             Margin="6,0,0,0"
	                                             ToolTip="{Binding ActionsHelpTooltip}"/>
	                                 </StackPanel>
                                 <TextBlock HorizontalAlignment="Right" Text="{Binding StatusMessage}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="10" VerticalAlignment="Center" FontStyle="Italic"/>
                             </Grid>
                         </Border>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
	                            </StackPanel>
	                        </Border>
                        <!-- ExpanderIconRotate animation removed: rotation is handled inside ExpanderButtonStyle's own ControlTemplate via IsChecked trigger -->
                    </DataTemplate>

        <DataTemplate x:Key="TweakItemCompactTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
            <Border Background="{DynamicResource BackgroundDarkBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,8"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CompactScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="CompactTranslate" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ShadowColorSmall}"
                                      BlurRadius="10"
                                      ShadowDepth="2"
                                      Opacity="0.2"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 From="6"
                                                 To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.01"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.01"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 To="-1"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 To="0"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="26"
                            Height="26"
                            CornerRadius="13"
                            Background="{Binding StatusBadgeBackground}"
                            BorderBrush="{Binding StatusColor}"
                            BorderThickness="1"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding StatusIcon}"
                                   Foreground="{Binding StatusColor}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding Description}"
                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   MaxHeight="30"
                                   ToolTip="{Binding Description}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border Style="{StaticResource RiskBadgeStyle}" Margin="0,0,6,0">
                                <TextBlock Text="{Binding Risk}"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <Border Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    Visibility="{Binding RequiresElevation, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding ElevationBadgeText}"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Detect"
                                Command="{Binding DetectCommand}"
                                Style="{StaticResource TweakActionButtonStyle}"
                                Margin="0,0,4,0"/>
                        <Button Content="{Binding ActionButtonText}"
                                Command="{Binding ApplyCommand}"
                                Style="{StaticResource TweakPrimaryActionButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Recursive Category Template -->
        <DataTemplate x:Key="CategoryTemplate" DataType="{x:Type viewModels:CategoryGroupViewModel}">
            <StackPanel Margin="{Binding IsNested, Converter={StaticResource NestedMarginConverter}}">
                <!-- Category Header -->
                <Border CornerRadius="8" 
                        Margin="0,0,0,6"
                        Padding="10,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNested}" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </DataTrigger>
                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=IsCompactMode}" Value="True">
                                    <Setter Property="Padding" Value="10,5"/>
                                    <Setter Property="Margin" Value="0,0,0,3"/>
                            </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DisplayName, TargetNullValue='Unknown Category', FallbackValue='Category Name'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="10" Padding="6,1" Margin="0,0,10,0">
                                <TextBlock Text="{Binding CountBadge}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <ToggleButton IsChecked="{Binding IsExpanded}" Style="{StaticResource ExpanderButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Nested Content -->
                <Border ClipToBounds="True" RenderTransformOrigin="0.5,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Opacity" Value="0"/>
                            <Setter Property="MaxHeight" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                 To="10000" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                 To="0" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- SubGroups Recursive Call -->
                        <ItemsControl ItemsSource="{Binding SubGroups}" ItemTemplate="{DynamicResource CategoryTemplate}"/>
                        
                        <!-- Tweaks In This Group (uses VisibleTweaks for lazy loading) -->
                        <ItemsControl ItemsSource="{Binding VisibleTweaks}" ItemTemplate="{StaticResource TweakItemTemplate}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel x:Name="TweaksPanel"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDense}" Value="True">
                                            <Setter Property="ItemsPanel">
                                                <Setter.Value>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="3"/>
                                                    </ItemsPanelTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid ClipToBounds="False">
        <Grid Margin="16,8,16,12"
              HorizontalAlignment="Stretch"
              ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="{Binding CurrentMainTabEyebrow}"
                           Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                <TextBlock Text="{Binding CurrentMainTabTitle}"
                           Margin="0,2,0,0"
                           Style="{StaticResource AppHeroTitleTextStyle}"/>
                <TextBlock Text="{Binding CurrentMainTabSubtitle}"
                           Margin="0,3,0,0"
                           Style="{StaticResource AppSectionSubtitleTextStyle}"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource TweakPanelGradientBrush}"
                        BorderBrush="{StaticResource AccentSoftBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="5">
                    <WrapPanel>
                        <ToggleButton IsChecked="{Binding IsConfigurationTabSelected, Mode=OneWay}"
                                      Command="{Binding SetTabCommand}"
                                      CommandParameter="Configuration"
                                      Style="{StaticResource SectionTabToggleStyle}">
                            <TextBlock Text="Configuration"/>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding IsPolicyReferenceTabSelected, Mode=OneWay}"
                                      Command="{Binding SetTabCommand}"
                                      CommandParameter="Policy Reference"
                                      Style="{StaticResource SectionTabToggleStyle}">
                            <TextBlock Text="Policy Reference"/>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding IsServicesTabSelected, Mode=OneWay}"
                                      Command="{Binding SetTabCommand}"
                                      CommandParameter="Services"
                                      Style="{StaticResource SectionTabToggleStyle}">
                            <TextBlock Text="Services"/>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding IsBloatwareTabSelected, Mode=OneWay}"
                                      Command="{Binding SetTabCommand}"
                                      CommandParameter="Bloatware"
                                      Style="{StaticResource SectionTabToggleStyle}">
                            <TextBlock Text="Bloatware"/>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding IsStartupTabSelected, Mode=OneWay}"
                                      Command="{Binding SetTabCommand}"
                                      CommandParameter="Startup"
                                      Style="{StaticResource SectionTabToggleStyle}">
                            <TextBlock Text="Startup"/>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding IsDiskHealthTabSelected, Mode=OneWay}"
                                      Command="{Binding SetTabCommand}"
                                      CommandParameter="Disk Health"
                                      Style="{StaticResource SectionTabToggleStyle}">
                            <TextBlock Text="Disk Health"/>
                        </ToggleButton>
                    </WrapPanel>
                </Border>

                <WrapPanel Grid.Column="1"
                           Margin="12,0,0,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsConfigurationTabSelected, Converter={StaticResource BoolToVisibility}}">
                    <ToggleButton Command="{Binding ShowSettingsWorkspaceCommand}"
                                  IsChecked="{Binding IsSettingsWorkspaceSelected, Mode=OneWay}"
                                  Style="{StaticResource WorkspaceModeButtonStyle}">
                        <TextBlock Text="{Binding SettingsWorkspaceCount, StringFormat={}{0} items}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </ToggleButton>
                    <ToggleButton Command="{Binding ShowMaintenanceWorkspaceCommand}"
                                  IsChecked="{Binding IsMaintenanceWorkspaceSelected, Mode=OneWay}"
                                  Style="{StaticResource WorkspaceModeButtonStyle}">
                        <TextBlock Text="{Binding MaintenanceWorkspaceCount, StringFormat=Cleanup &amp; Repair - {0}}"
                                    FontSize="12"
                                    FontWeight="SemiBold"/>
                    </ToggleButton>
                </WrapPanel>
            </Grid>

            <TabControl Grid.Row="2"
                        Style="{StaticResource ModernMainTabControlStyle}"
                        ItemContainerStyle="{StaticResource ModernMainTabItemStyle}"
                        SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}"
                        Margin="0"
                        Padding="0">
                <TabItem Header="Configuration">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                    <!-- Control Bar -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <Grid Margin="0,0,0,10"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Configuration"
                                           Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                                <TextBlock Text="{Binding CurrentWorkspaceLabel}"
                                           Margin="0,3,0,0"
                                           Style="{StaticResource AppHeroTitleTextStyle}"/>
                                <TextBlock Text="{Binding CurrentWorkspaceDescription}"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource AppSectionSubtitleTextStyle}"/>
                            </StackPanel>

                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Margin="10,0,0,0">
                                <ToggleButton Command="{Binding ShowSettingsWorkspaceCommand}"
                                              IsChecked="{Binding IsSettingsWorkspaceSelected, Mode=OneWay}"
                                              Style="{StaticResource WorkspaceModeButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SettingsWorkspaceCount, StringFormat={}{0} items}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton Command="{Binding ShowMaintenanceWorkspaceCommand}"
                                              IsChecked="{Binding IsMaintenanceWorkspaceSelected, Mode=OneWay}"
                                              Style="{StaticResource WorkspaceModeButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding MaintenanceWorkspaceCount, StringFormat=Cleanup &amp; Repair - {0}}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ToggleButton>
                            </WrapPanel>
                        </Grid>

                        <Border Style="{StaticResource AppSurfaceCardStyle}"
                                Background="{StaticResource TweakPanelGradientBrush}"
                                BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <WrapPanel VerticalAlignment="Center">
                                <Grid Width="300" Margin="0,0,10,6">
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBoxStyle}"
                                             Tag="Search settings and feature switches..."/>
                                </Grid>
                                <CheckBox Tag="Safe" IsChecked="{Binding ShowSafe}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Safe"/>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox Tag="Advanced" IsChecked="{Binding ShowAdvanced}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Advanced"/>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox Tag="Risky" IsChecked="{Binding ShowRisky}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Risky"/>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox Tag="Favorites" IsChecked="{Binding ShowFavoritesOnly}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Favorites"/>
                                        <TextBlock Text="{Binding FavoritesCount, StringFormat={}{0}}"
                                                   Margin="6,0,0,0"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                    </StackPanel>
                                </CheckBox>
                                <Button Content="Reset"
                                        Command="{Binding ResetFiltersCommand}"
                                        Style="{StaticResource CompactButton}"
                                        Margin="0,0,6,6"
                                        Visibility="Collapsed"/>
                                <Button Command="{Binding ExpandAllDetailsCommand}" ToolTip="Expand all details" Style="{StaticResource CompactButton}" Margin="0,0,6,6" Visibility="Collapsed">
                                    <TextBlock Text="Expand"/>
                                </Button>
                                <Button Command="{Binding CollapseAllDetailsCommand}" ToolTip="Collapse all details" Style="{StaticResource CompactButton}" Margin="0,0,6,6" Visibility="Collapsed">
                                    <TextBlock Text="Collapse"/>
                                </Button>
                                <ToggleButton IsChecked="{Binding IsFlatView}" ToolTip="Toggle compact view" Style="{StaticResource CompactToggleButtonStyle}" Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="Compact"/>
                                </ToggleButton>
                            </WrapPanel>
                        </Border>

                            <Grid Margin="2,8,2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding FilterSummary}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       FontSize="10"
                                                            FontFamily="{DynamicResource FontFamilyMono}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding InventoryStatusMessage}"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"
                                                           FontFamily="{DynamicResource FontFamilyMono}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <Border Margin="0,10,0,0"
                                Padding="12,10"
                                Background="{DynamicResource AppInsetSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="{Binding SelectionSummary}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                    <TextBlock Text="Use checkboxes to queue settings, then run one action for all of them."
                                               Margin="0,3,0,0"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding BulkStatusMessage}"
                                               Margin="0,4,0,0"
                                               FontSize="10"
                                               FontFamily="{DynamicResource FontFamilyMono}"
                                               Foreground="{DynamicResource AccentBrightCyanBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <WrapPanel Grid.Column="1"
                                           VerticalAlignment="Center">
                                    <Button Content="Detect selected"
                                            Command="{Binding DetectSelectedCommand}"
                                            Style="{StaticResource TweakActionButtonStyle}"
                                            Margin="0,0,6,0"/>
                                    <Button Content="Apply selected"
                                            Command="{Binding ApplySelectedCommand}"
                                            Style="{StaticResource TweakPrimaryActionButtonStyle}"
                                            Margin="0,0,6,0"/>
                                    <Button Content="Verify"
                                            Command="{Binding VerifySelectedCommand}"
                                            Style="{StaticResource TweakActionButtonStyle}"
                                            Margin="0,0,6,0"/>
                                    <Button Content="Rollback"
                                            Command="{Binding RollbackSelectedCommand}"
                                            Style="{StaticResource TweakActionButtonStyle}"
                                            Margin="0,0,6,0"/>
                                    <Button Content="Clear"
                                            Command="{Binding DeselectAllCommand}"
                                            Style="{StaticResource TweakActionButtonStyle}"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Content -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="204"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                        <!-- Category Sidebar -->
                        <Border Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0,4,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0"
                                        Command="{Binding ClearCategorySelectionCommand}"
                                        Style="{StaticResource CategoryAllButtonStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding AllItemsLabel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource AppChipSurfaceBrush}"
                                                CornerRadius="8"
                                                Padding="8,2">
                                            <TextBlock Text="{Binding CurrentWorkspaceItemCount}"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Button>
                                 <ListBox Grid.Row="1"
                                          ItemsSource="{Binding CategoryGroups}"
                                          SelectedValuePath="CategoryName"
                                          SelectedValue="{Binding SelectedCategoryName, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0,0,0,8"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ScrollViewer.CanContentScroll="True"
                                          ItemContainerStyle="{StaticResource CategoryListItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                     <TextBlock Grid.Column="0"
                                                                 Text="{Binding CategoryName}"
                                                                 FontSize="13"
                                                                 FontWeight="SemiBold"
                                                                 Foreground="{DynamicResource ForegroundBrightBrush}"
                                                                 TextTrimming="CharacterEllipsis"
                                                                 VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1"
                                                            Background="{DynamicResource AppChipSurfaceBrush}"
                                                            CornerRadius="8"
                                                            Padding="8,2">
                                                        <TextBlock Text="{Binding CountBadge}"
                                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>


                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedCategoryLabel}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           Visibility="Collapsed"/>
                                <TextBlock Text="{Binding WorkspaceStatusHint}"
                                           FontSize="11"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           Margin="0,4,0,0"
                                           Visibility="Collapsed"/>
                                <TextBlock Text="{Binding BulkStatusMessage}"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,3,0,0"
                                           Visibility="Collapsed"/>
                                           
                                <!-- DNS Configuration Panel - Compact single-line design -->
                                <Border Background="{DynamicResource BackgroundDarkBrush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        Margin="0,0,0,4"
                                        Visibility="{Binding ShowDnsConfigurationPanel, Converter={StaticResource BoolToVisibility}}">
                                    <Grid DataContext="{Binding DnsConfiguration}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icon + Title -->
                                        <TextBlock Text="{DynamicResource IconNetwork}"
                                                   FontFamily="{DynamicResource IconFontFamily}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <TextBlock Text="DNS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                            <TextBlock Text="{Binding CurrentDnsInfo}" FontSize="10" Foreground="{DynamicResource AccentBrightCyanBrush}" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        
                                        <!-- Provider Selector -->
                                        <ComboBox Grid.Column="2" 
                                                  ItemsSource="{Binding DnsProviders}" 
                                                  SelectedItem="{Binding SelectedDnsProvider, Mode=TwoWay}"
                                                  Style="{StaticResource RoundedComboBox}"
                                                  Height="26"
                                                  MaxWidth="180"
                                                  Margin="0,0,8,0">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon}" FontSize="10" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="11"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        
                                        <!-- Apply Button -->
                                        <Button Grid.Column="3"
                                                Content="Apply"
                                                Command="{Binding ApplyDnsCommand}"
                                                Style="{StaticResource FilterButton}"
                                                Margin="0,0,6,0"
                                                Padding="10,4"
                                                FontSize="11"/>
                                        
                                        <!-- Flush Button -->
                                        <Button Grid.Column="4"
                                                Content="Flush"
                                                Command="{Binding FlushDnsCommand}"
                                                Style="{StaticResource CompactButton}"
                                                Padding="10,4"
                                                FontSize="11"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Border Style="{StaticResource AppSurfaceCardStyle}"
                                        Background="{StaticResource TweakPanelGradientBrush}"
                                        BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="0">
                                    <ListBox ItemsSource="{Binding TweaksView}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0,0,0,8"
                                             HorizontalContentAlignment="Stretch"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Pixel"
                                             VirtualizingPanel.CacheLength="2"
                                             VirtualizingPanel.CacheLengthUnit="Page"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.CanContentScroll="True">
                                        <ListBox.Style>
                                            <Style TargetType="ListBox">
                                                <Setter Property="ItemTemplate" Value="{StaticResource TweakItemTemplate}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFlatView}" Value="True">
                                                        <Setter Property="ItemTemplate" Value="{StaticResource TweakItemCompactTemplate}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Style>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <ContentPresenter />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>

                                <!-- Empty State -->
                                <Border Padding="20"
                                        Background="{DynamicResource BackgroundDarkBrush}"
                                        CornerRadius="10"
                                        Margin="0,20"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding HasVisibleTweaks, Converter={StaticResource InverseBoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EmptyStateTitle}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                   HorizontalAlignment="Center"/>
                                         <TextBlock Text="{Binding EmptyStateDescription}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                </TabItem>

                <TabItem Header="Policy Reference">
                    <Grid DataContext="{Binding PolicyReference}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,8">
                            <Border Background="{StaticResource TweakPanelGradientBrush}"
                                    BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Headline}"
                                                   Style="{StaticResource AppSectionTitleTextStyle}"/>
                                        <TextBlock Text="{Binding Detail}"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Context}"
                                                   Margin="0,4,0,0"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Grid Grid.Column="1"
                                          Width="248"
                                          VerticalAlignment="Top">
                                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SearchBoxStyle}"
                                                 Tag="Search Explorer, Edge, Search, System..."/>
                                    </Grid>

                                    <WrapPanel Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="0,8,0,0">
                                        <Border Style="{StaticResource ConfigInlineStatChipStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding PolicyBackedSettingCount}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                <TextBlock Text="Policy-backed"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource ConfigInlineStatChipStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ComponentCount}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                <TextBlock Text="Components"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource ConfigInlineStatChipStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding MachineScopedSettingCount}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                <TextBlock Text="Machine"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource ConfigInlineStatChipStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding UserScopedSettingCount}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                                <TextBlock Text="User"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,0,8">
                            <Grid>
                                <ItemsControl ItemsSource="{Binding ItemsView}"
                                              HorizontalAlignment="Stretch"
                                              Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource PolicyReferenceCardStyle}">
                                                <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Text="{Binding ComponentName}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                                   TextWrapping="Wrap"/>

                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding Description}"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                                   TextWrapping="Wrap"/>

                                                        <WrapPanel Grid.Row="2"
                                                                   Margin="0,8,0,0">
                                                            <Border Background="{DynamicResource BackgroundMediumBrush}"
                                                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="9"
                                                                    Padding="8,3"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding ScopeLabel}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                            </Border>
                                                            <Border Background="{DynamicResource BackgroundMediumBrush}"
                                                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="9"
                                                                    Padding="8,3"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding SettingCountLabel}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                            </Border>
                                                            <Border Background="{DynamicResource BackgroundMediumBrush}"
                                                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="9"
                                                                    Padding="8,3"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding PrimaryCategory}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                            </Border>
                                                            <Border Background="{DynamicResource BackgroundMediumBrush}"
                                                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="9"
                                                                    Padding="8,3"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding StatusLabel}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                            </Border>
                                                        </WrapPanel>

                                                        <StackPanel Grid.Row="3"
                                                                    Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding RiskLabel}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding ExampleSummary}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                                       TextWrapping="Wrap"/>
                                                            <UniformGrid Columns="2"
                                                                         Margin="0,6,0,0">
                                                                <Border Style="{StaticResource PolicyReferenceInfoCardStyle}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Windows Reads"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                                        <TextBlock Text="{Binding ReadPathLabel}"
                                                                                   Margin="0,4,0,0"
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource PolicyReferenceInfoCardStyle}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Scope"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                                        <TextBlock Text="{Binding ScopeDetail}"
                                                                                   Margin="0,4,0,0"
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource PolicyReferenceInfoCardStyle}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="What To Expect"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                                        <TextBlock Text="{Binding ExpectedBehavior}"
                                                                                   Margin="0,4,0,0"
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource PolicyReferenceInfoCardStyle}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Related Settings"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                                        <TextBlock Text="{Binding RelatedSettingsLabel}"
                                                                                   Margin="0,4,0,0"
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </UniformGrid>
                                                        </StackPanel>

                                                        <WrapPanel Grid.Row="4"
                                                                   Margin="0,8,0,0">
                                                            <Button Content="Show matching settings"
                                                                    Command="{Binding OpenMatchingSettingsCommand}"
                                                                    Style="{StaticResource CompactButton}"/>
                                                        </WrapPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Padding="20"
                                        Background="{DynamicResource BackgroundDarkBrush}"
                                        CornerRadius="10"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="No policy-backed areas match your search"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Try a broader search or run Detect to refresh local setting states."
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="Services">
                    <Grid DataContext="{Binding ServiceManagement}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,8">
                            <Border Background="{StaticResource TweakPanelGradientBrush}"
                                    BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Headline}"
                                                   Style="{StaticResource AppSectionTitleTextStyle}"/>
                                        <TextBlock Text="{Binding Detail}"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Context}"
                                                   Margin="0,4,0,0"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Top">
                                        <Grid Width="250">
                                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SearchBoxStyle}"
                                                     Tag="Search services, descriptions, startup types..."/>
                                        </Grid>
                                        <Button Content="Refresh"
                                                Command="{Binding RefreshCommand}"
                                                Style="{StaticResource CompactButton}"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Grid Grid.Row="1"
                                          Grid.ColumnSpan="2"
                                          Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <WrapPanel>
                                            <Button Command="{Binding SetFilterCommand}"
                                                    CommandParameter="all"
                                                    Margin="0,0,8,8">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                                        <Setter Property="Padding" Value="10,6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAllFilterSelected}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                                <TextBlock Text="{Binding TotalCount, Mode=OneWay, StringFormat=All {0}}"/>
                                            </Button>
                                            <Button Command="{Binding SetFilterCommand}"
                                                    CommandParameter="running"
                                                    Margin="0,0,8,8">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                                        <Setter Property="Padding" Value="10,6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunningFilterSelected}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                                <TextBlock Text="{Binding RunningCount, Mode=OneWay, StringFormat=Running {0}}"/>
                                            </Button>
                                            <Button Command="{Binding SetFilterCommand}"
                                                    CommandParameter="disabled"
                                                    Margin="0,0,8,8">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                                        <Setter Property="Padding" Value="10,6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDisabledFilterSelected}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                                <TextBlock Text="{Binding DisabledCount, Mode=OneWay, StringFormat=Disabled {0}}"/>
                                            </Button>
                                            <Button Command="{Binding SetFilterCommand}"
                                                    CommandParameter="drivers"
                                                    Margin="0,0,8,8">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                                        <Setter Property="Padding" Value="10,6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDriversFilterSelected}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                                <TextBlock Text="{Binding DriverCount, Mode=OneWay, StringFormat=Drivers {0}}"/>
                                            </Button>
                                        </WrapPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FilterStatusText}"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.12*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="0.88*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource AppSurfaceCardStyle}"
                                    Background="{StaticResource TweakPanelGradientBrush}"
                                    BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MutedForegroundBrush}"/>

                                    <ListBox Grid.Row="1"
                                             Margin="0,8,0,0"
                                             ItemsSource="{Binding ItemsView}"
                                             SelectedItem="{Binding SelectedService}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource ServiceManagementListItemStyle}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                                   TextWrapping="Wrap"
                                                                   DockPanel.Dock="Left"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                                   HorizontalAlignment="Right"/>
                                                    </DockPanel>

                                                    <TextBlock Text="{Binding DescriptionOrFallback}"
                                                               Margin="0,5,0,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="46"/>

                                                    <WrapPanel Margin="0,7,0,0">
                                                        <Border Style="{StaticResource AppChipStyle}">
                                                            <TextBlock Text="{Binding Status}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                        </Border>
                                                        <Border Style="{StaticResource AppChipStyle}">
                                                            <TextBlock Text="{Binding StartType}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                        </Border>
                                                        <Border Style="{StaticResource AppChipStyle}">
                                                            <TextBlock Text="{Binding KindText}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource AppSurfaceCardStyle}"
                                    Background="{StaticResource TweakPanelGradientBrush}"
                                    BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Selected service"
                                               Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                                    <TextBlock Text="{Binding SelectedIdentity}"
                                               Margin="0,5,0,0"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedState}"
                                               Margin="0,5,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentBrightCyanBrush}"
                                               TextWrapping="Wrap"/>

                                    <Border Style="{StaticResource ServiceManagementDetailCardStyle}" Margin="0,10,0,8">
                                        <StackPanel>
                                            <TextBlock Text="What it does"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                            <TextBlock Text="{Binding SelectedWhatItDoes}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource ServiceManagementDetailCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Technical details"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                            <TextBlock Text="{Binding SelectedTechnicalDetails}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,4,0,0">
                                        <Button Content="Docs"
                                                Command="{Binding OpenDocsCommand}"
                                                Style="{StaticResource CompactButton}"/>
                                        <Button Content="Set Manual"
                                                Command="{Binding EnableServiceCommand}"
                                                Style="{StaticResource CompactButton}"
                                                Margin="8,0,0,0"
                                                IsEnabled="{Binding CanEnableSelectedService}"/>
                                        <Button Content="Disable"
                                                Command="{Binding DisableServiceCommand}"
                                                Style="{StaticResource CompactButton}"
                                                Margin="8,0,0,0"
                                                IsEnabled="{Binding CanDisableSelectedService}"/>
                                    </WrapPanel>

                                    <TextBlock Margin="0,10,0,0"
                                               Text="Drivers are listed for context. Start-mode changes are only enabled for regular services."
                                               FontSize="10"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Bloatware">
                    <local:BloatwareView DataContext="{Binding Bloatware}"/>
                </TabItem>

                <TabItem Header="Startup">
                    <local:StartupView DataContext="{Binding Startup}"/>
                </TabItem>

                <TabItem Header="Disk Health">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="{StaticResource TweakPanelGradientBrush}"
                                BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Read-only diagnostics"
                                               Style="{StaticResource AppSectionEyebrowTextStyle}"/>
                                    <TextBlock Text="These checks live here so they are treated like tools, not persistent tweaks or optimization settings."
                                               Margin="0,4,0,0"
                                               Style="{StaticResource AppSectionSubtitleTextStyle}"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource AppChipSurfaceBrush}"
                                        CornerRadius="10"
                                        Padding="10,4"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DiskHealthCount, StringFormat={}{0} checks}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,10,0,10"
                                Background="{DynamicResource AppInsetSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding DiskHealthSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SearchBoxStyle}"
                                         Tag="Search disk checks, drives, or report text..."/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding DiskHealthFilterSummary}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           FontFamily="{DynamicResource FontFamilyMono}"
                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Border Style="{StaticResource AppSurfaceCardStyle}"
                                    Background="{StaticResource TweakPanelGradientBrush}"
                                    BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="0">
                                <ListBox ItemsSource="{Binding DiskHealthTweaksView}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0,0,0,8"
                                         HorizontalContentAlignment="Stretch"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True"
                                         ItemTemplate="{StaticResource TweakItemTemplate}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Border>

                            <Border Padding="20"
                                    Background="{DynamicResource BackgroundDarkBrush}"
                                    CornerRadius="10"
                                    Margin="0,20"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding HasVisibleDiskHealthTweaks, Converter={StaticResource InverseBoolToVisibility}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DiskHealthEmptyStateTitle}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DiskHealthEmptyStateDescription}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>


