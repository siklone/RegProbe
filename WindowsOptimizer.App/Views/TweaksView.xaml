                                        HorizontalAlignment="Left"
                                        Margin="0,2,0,2"
                                        Opacity="0"/>
                                <ContentPresenter Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppWorkspaceSurfaceBrush}"/>
