<UserControl x:Class="WindowsOptimizer.App.Views.TweaksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:WindowsOptimizer.Core;assembly=WindowsOptimizer.Core"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        
        <!-- Status Color Converter -->
        <SolidColorBrush x:Key="AppliedBrush" Color="#A3BE8C"/>
        <SolidColorBrush x:Key="NotAppliedBrush" Color="#4C566A"/>
        <SolidColorBrush x:Key="UnknownBrush" Color="#EBCB8B"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#BF616A"/>

        <!-- Risk Badge Styles -->
        <Style x:Key="RiskBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="#434C5E" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Safe}">
                    <Setter Property="Background" Value="#2E4A3E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Advanced}">
                    <Setter Property="Background" Value="#4A3E2E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Risky}">
                    <Setter Property="Background" Value="#4A2E2E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="TweakToggleStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="50" Height="26" Cursor="Hand">
                            <Border x:Name="Track" 
                                    Background="#434C5E" 
                                    CornerRadius="13"
                                    BorderBrush="#4C566A"
                                    BorderThickness="1"/>
                            <Border x:Name="Thumb" 
                                    Width="20" Height="20" 
                                    CornerRadius="10"
                                    Background="#D8DEE9"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#A3BE8C"/>
                                <Setter TargetName="Thumb" Property="Background" Value="#ECEFF4"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="24" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact Button Style with Smooth Animations -->
        <Style x:Key="CompactButton" TargetType="Button">
            <Setter Property="Background" Value="#434C5E"/>
            <Setter Property="Foreground" Value="#D8DEE9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="ButtonShadow"
                                                Color="#000000"
                                                BlurRadius="4"
                                                ShadowDepth="2"
                                                Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Border"
                                                          Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                          To="#4C566A" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1.05" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1.05" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.3" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Border"
                                                          Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                          To="#434C5E" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Bar Button with Smooth Animations -->
        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Background" Value="#5E81AC"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="FilterShadow"
                                                Color="#5E81AC"
                                                BlurRadius="0"
                                                ShadowDepth="0"
                                                Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Border"
                                                          Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                          To="#81A1C1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1.05" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1.05" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="FilterShadow"
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="16" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="FilterShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.5" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Border"
                                                          Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                          To="#5E81AC" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="FilterShadow"
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="FilterShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Box Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Checkbox -->
        <Style x:Key="FilterCheckbox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D8DEE9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- Link Button Style -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#88C0D0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0,1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#81A1C1"/>
                    <Setter Property="BorderBrush" Value="#81A1C1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#2E3440">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E3440" Padding="24,20">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="{Binding Title}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#ECEFF4"/>
                <TextBlock Text="{Binding FilterSummary}"
                           Foreground="#88C0D0"
                           FontSize="12"
                           Margin="0,4,0,16"/>

                <!-- Filter Bar -->
                <Border Background="#3B4252" CornerRadius="10" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Width="260"
                                     Style="{StaticResource SearchBoxStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search tweaks..."/>
                        </StackPanel>

                        <!-- Risk Filters -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                            <CheckBox Content="✓ Safe" 
                                      Style="{StaticResource FilterCheckbox}"
                                      IsChecked="{Binding ShowSafe}" 
                                      Margin="0,0,14,0"/>
                            <CheckBox Content="⚡ Advanced" 
                                      Style="{StaticResource FilterCheckbox}"
                                      IsChecked="{Binding ShowAdvanced}" 
                                      Margin="0,0,14,0"/>
                            <CheckBox Content="⚠ Risky" 
                                      Style="{StaticResource FilterCheckbox}"
                                      IsChecked="{Binding ShowRisky}"/>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Reset" 
                                    Command="{Binding ResetFiltersCommand}"
                                    Style="{StaticResource CompactButton}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Apply All" 
                                    Command="{Binding ApplyAllCommand}" 
                                    Style="{StaticResource FilterButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Category Groups with Virtualization -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,0,24,24">
            <ItemsControl ItemsSource="{Binding CategoryGroups}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12">
                            <StackPanel>
                                <!-- Category Header with Smooth Animations -->
                                <Border x:Name="CategoryHeader"
                                        CornerRadius="8"
                                        Padding="14,10"
                                        Cursor="Hand"
                                        Margin="0,0,0,6">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="HeaderShadow"
                                                        Color="#81A1C1"
                                                        BlurRadius="0"
                                                        ShadowDepth="0"
                                                        Opacity="0"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#3B4252"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                                              To="#434C5E" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="HeaderShadow"
                                                                               Storyboard.TargetProperty="BlurRadius"
                                                                               To="12" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="HeaderShadow"
                                                                               Storyboard.TargetProperty="Opacity"
                                                                               To="0.4" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                                              To="#3B4252" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="HeaderShadow"
                                                                               Storyboard.TargetProperty="BlurRadius"
                                                                               To="0" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="HeaderShadow"
                                                                               Storyboard.TargetProperty="Opacity"
                                                                               To="0" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandCommand}"/>
                                    </Border.InputBindings>
                                    <!-- Use a Grid with Transparent background to catch clicks anywhere on the header -->
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock x:Name="ExpanderIcon"
                                                   Grid.Column="0"
                                                   Text="{Binding ExpanderIcon}"
                                                   FontSize="10"
                                                   Foreground="#88C0D0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="0"/>
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                       To="90" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                       To="0" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding CategoryName}" 
                                                       FontSize="14" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="#ECEFF4"/>
                                        </StackPanel>

                                        <Border Grid.Column="2" 
                                                Background="#5E81AC" 
                                                CornerRadius="8" 
                                                Padding="8,3">
                                            <TextBlock Text="{Binding CountBadge}" 
                                                       FontSize="11" 
                                                       FontWeight="Bold" 
                                                       Foreground="#ECEFF4"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Tweaks List (Simplified, nested virtualization removed to prevent Layout Cycle) -->
                                <ItemsControl ItemsSource="{Binding Tweaks}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                              Margin="16,0,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Tweak Card with Smooth Hover Effects -->
                                            <Border x:Name="TweakCard"
                                                    Background="#3B4252"
                                                    CornerRadius="8"
                                                    Padding="14,12"
                                                    Margin="0,0,0,6"
                                                    BorderThickness="2,0,0,0">
                                                <Border.RenderTransform>
                                                    <TranslateTransform Y="0"/>
                                                </Border.RenderTransform>
                                                <Border.Effect>
                                                    <DropShadowEffect x:Name="CardShadow"
                                                                    Color="#000000"
                                                                    BlurRadius="8"
                                                                    ShadowDepth="2"
                                                                    Opacity="0.2"/>
                                                </Border.Effect>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                           To="-2" Duration="0:0:0.15">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                                                           Storyboard.TargetProperty="BlurRadius"
                                                                                           To="16" Duration="0:0:0.15"/>
                                                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                                                           Storyboard.TargetProperty="ShadowDepth"
                                                                                           To="6" Duration="0:0:0.15"/>
                                                                            <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                                                          To="#434C5E" Duration="0:0:0.15"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                           To="0" Duration="0:0:0.15"/>
                                                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                                                           Storyboard.TargetProperty="BlurRadius"
                                                                                           To="8" Duration="0:0:0.15"/>
                                                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                                                           Storyboard.TargetProperty="ShadowDepth"
                                                                                           To="2" Duration="0:0:0.15"/>
                                                                            <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                                                                          To="#3B4252" Duration="0:0:0.15"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="{Binding StatusColor}"/>
                                                </Border.BorderBrush>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Status Indicator -->
                                                    <Border Grid.Column="0" Grid.RowSpan="2"
                                                            Width="36" Height="36"
                                                            CornerRadius="18"
                                                            Margin="0,0,14,0"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#434C5E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                                                                        <Setter Property="Background" Value="#2E4A3E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                                                                        <Setter Property="Background" Value="#4A2E2E"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding StatusIcon}" 
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#4C566A"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                                                                            <Setter Property="Foreground" Value="#A3BE8C"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                                                                            <Setter Property="Foreground" Value="#BF616A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Unknown}">
                                                                            <Setter Property="Foreground" Value="#EBCB8B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- Tweak Info -->
                                                    <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontSize="13" 
                                                                   FontWeight="SemiBold" 
                                                                   Foreground="#ECEFF4"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Style="{StaticResource RiskBadgeStyle}" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Risk}" 
                                                                       FontSize="9" 
                                                                       Foreground="#D8DEE9"/>
                                                        </Border>
                                                        <Border Visibility="{Binding RequiresElevation, Converter={StaticResource BoolToVisibility}}"
                                                                Background="#4A3E2E" CornerRadius="4" Padding="5,2" Margin="6,0,0,0">
                                                            <TextBlock Text="🔒" FontSize="10"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1" Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               Foreground="#88C0D0"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,4,0,0"/>

                                                    <!-- Toggle and Actions -->
                                                    <StackPanel Grid.Column="2" Grid.RowSpan="2" 
                                                                Orientation="Horizontal" 
                                                                VerticalAlignment="Center">
                                                        <!-- Loading Indicator with Pulse Animation -->
                                                        <Border Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"
                                                                Margin="0,0,12,0">
                                                            <TextBlock Text="⏳" FontSize="14" RenderTransformOrigin="0.5,0.5">
                                                                <TextBlock.RenderTransform>
                                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                </TextBlock.RenderTransform>
                                                                <TextBlock.Triggers>
                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                               From="1.0" To="1.3" Duration="0:0:0.6">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut"/>
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                               From="1.0" To="1.3" Duration="0:0:0.6">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut"/>
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                               From="1.0" To="0.5" Duration="0:0:0.6">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut"/>
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </TextBlock.Triggers>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- Toggle Switch Button with Smooth Animation -->
                                                        <Button Command="{Binding ToggleCommand}"
                                                                ToolTip="{Binding StatusText}"
                                                                Margin="0,0,10,0"
                                                                Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Grid Width="50" Height="26">
                                                                        <Border x:Name="Track"
                                                                                Background="#434C5E"
                                                                                CornerRadius="13"
                                                                                BorderBrush="#4C566A"
                                                                                BorderThickness="1">
                                                                            <Border.Effect>
                                                                                <DropShadowEffect x:Name="TrackGlow"
                                                                                                Color="#A3BE8C"
                                                                                                BlurRadius="0"
                                                                                                ShadowDepth="0"
                                                                                                Opacity="0"/>
                                                                            </Border.Effect>
                                                                        </Border>
                                                                        <Border x:Name="Thumb"
                                                                                Width="20" Height="20"
                                                                                CornerRadius="10"
                                                                                Background="#D8DEE9"
                                                                                HorizontalAlignment="Left"
                                                                                Margin="3,0,0,0">
                                                                            <Border.RenderTransform>
                                                                                <TranslateTransform X="0"/>
                                                                            </Border.RenderTransform>
                                                                            <Border.Effect>
                                                                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                                                                            </Border.Effect>
                                                                        </Border>
                                                                    </Grid>
                                                                    <ControlTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding IsApplied}" Value="True">
                                                                            <Setter TargetName="Track" Property="Background" Value="#A3BE8C"/>
                                                                            <Setter TargetName="Thumb" Property="Background" Value="#ECEFF4"/>
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                                                       To="24" Duration="0:0:0.2">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                        <DoubleAnimation Storyboard.TargetName="TrackGlow"
                                                                                                       Storyboard.TargetProperty="BlurRadius"
                                                                                                       To="15" Duration="0:0:0.2"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TrackGlow"
                                                                                                       Storyboard.TargetProperty="Opacity"
                                                                                                       To="0.6" Duration="0:0:0.2"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.EnterActions>
                                                                            <DataTrigger.ExitActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                                                       To="0" Duration="0:0:0.2">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                        <DoubleAnimation Storyboard.TargetName="TrackGlow"
                                                                                                       Storyboard.TargetProperty="BlurRadius"
                                                                                                       To="0" Duration="0:0:0.2"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TrackGlow"
                                                                                                       Storyboard.TargetProperty="Opacity"
                                                                                                       To="0" Duration="0:0:0.2"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.ExitActions>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter Property="Opacity" Value="0.5"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Track" Property="BorderBrush" Value="#81A1C1"/>
                                                                            <Trigger.EnterActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="Track"
                                                                                                       Storyboard.TargetProperty="(Border.BorderThickness).(Thickness.Left)"
                                                                                                       To="2" Duration="0:0:0.15"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </Trigger.EnterActions>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <!-- Details Expander -->
                                                        <ToggleButton IsChecked="{Binding IsDetailsExpanded}"
                                                                      ToolTip="Show details"
                                                                      Background="Transparent"
                                                                      BorderThickness="0"
                                                                      Cursor="Hand"
                                                                      Padding="6,4">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border x:Name="Border" 
                                                                            Background="#434C5E" 
                                                                            CornerRadius="4"
                                                                            Padding="6,4">
                                                                        <TextBlock x:Name="Icon" 
                                                                                   Text="▼" 
                                                                                   FontSize="10" 
                                                                                   Foreground="#88C0D0"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Icon" Property="Text" Value="▲"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Border" Property="Background" Value="#4C566A"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                    </StackPanel>

                                                    <!-- Expanded Details: Reference tool inspired rich metadata -->
                                                    <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                                                            Visibility="{Binding IsDetailsExpanded, Converter={StaticResource BoolToVisibility}}"
                                                            Margin="0,12,0,0"
                                                            Background="#434C5E"
                                                            CornerRadius="6"
                                                            Padding="16">
                                                        <StackPanel>
                                                            <!-- Row 1: Registry Info -->
                                                            <StackPanel Visibility="{Binding HasRegistryPath, Converter={StaticResource BoolToVisibility}}" 
                                                                        Margin="0,0,0,12">
                                                                <TextBlock Text="Registry Location" FontSize="10" FontWeight="Bold" Foreground="#81A1C1" Margin="0,0,0,4"/>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Background="#2E3440" CornerRadius="4" Padding="8,6">
                                                                        <TextBlock Text="{Binding RegistryPath}" 
                                                                                   Foreground="#88C0D0" 
                                                                                   FontSize="11" 
                                                                                   FontFamily="Consolas"
                                                                                   TextWrapping="Wrap"/>
                                                                    </Border>
                                                                    <Button Grid.Column="1" 
                                                                            Command="{Binding CopyRegistryPathCommand}"
                                                                            Content="📋" 
                                                                            Style="{StaticResource CompactButton}"
                                                                            VerticalAlignment="Stretch"
                                                                            Margin="4,0,0,0"
                                                                            ToolTip="Copy registry path"/>
                                                                </Grid>
                                                            </StackPanel>

                                                            <!-- Row 2: Sub-Options (if any) -->
                                                            <StackPanel Visibility="{Binding HasSubOptions, Converter={StaticResource BoolToVisibility}}" 
                                                                        Margin="0,0,0,12">
                                                                <TextBlock Text="Configuration Overrides" FontSize="10" FontWeight="Bold" Foreground="#81A1C1" Margin="0,0,0,6"/>
                                                                <ItemsControl ItemsSource="{Binding SubOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,0,0,4">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="#D8DEE9" FontSize="11"/>
                                                                                
                                                                                <!-- Handle different sub-option types -->
                                                                                <CheckBox Grid.Column="1" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center">
                                                                                    <CheckBox.Style>
                                                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource FilterCheckbox}">
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Type}" Value="Numeric">
                                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </CheckBox.Style>
                                                                                </CheckBox>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>

                                                            <!-- Row 3: Code Example -->
                                                            <StackPanel Visibility="{Binding HasCodeExample, Converter={StaticResource BoolToVisibility}}" 
                                                                        Margin="0,0,0,12">
                                                                <TextBlock Text="Command Preview" FontSize="10" FontWeight="Bold" Foreground="#81A1C1" Margin="0,0,0,4"/>
                                                                <Border Background="#2E3440" CornerRadius="4" Padding="12" BorderBrush="#3B4252" BorderThickness="1">
                                                                    <TextBlock Text="{Binding CodeExample}" 
                                                                               Foreground="#A3BE8C" 
                                                                               FontSize="11" 
                                                                               FontFamily="Consolas"
                                                                               TextWrapping="Wrap"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <!-- Row 4: Reference Links -->
                                                            <StackPanel Visibility="{Binding HasReferenceLinks, Converter={StaticResource BoolToVisibility}}" 
                                                                        Margin="0,0,0,12">
                                                                <TextBlock Text="Documentation &amp; Sources" FontSize="10" FontWeight="Bold" Foreground="#81A1C1" Margin="0,0,0,4"/>
                                                                <ItemsControl ItemsSource="{Binding ReferenceLinks}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <WrapPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Content="{Binding Title}" 
                                                                                    Style="{StaticResource LinkButtonStyle}"
                                                                                    Margin="0,0,12,4"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>

                                                            <!-- Row 5: Action Pipeline & Status -->
                                                            <Border Background="#2E3440" CornerRadius="4" Padding="10" Margin="0,4,0,0">
                                                                <StackPanel>
                                                                    <Grid Margin="0,0,0,8">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Button Content="Detect" Command="{Binding DetectCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/>
                                                                            <Button Content="Preview" Command="{Binding PreviewCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/>
                                                                            <Button Content="{Binding ActionButtonText}" Command="{Binding ApplyCommand}" Style="{StaticResource CompactButton}" Background="#5E81AC" Margin="0,0,6,0"/>
                                                                            <Button Content="Verify" Command="{Binding VerifyCommand}" Style="{StaticResource CompactButton}" Margin="0,0,6,0"/>
                                                                            <Button Content="Rollback" Command="{Binding RollbackCommand}" Style="{StaticResource CompactButton}"/>
                                                                        </StackPanel>
                                                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#88C0D0" FontSize="10">
                                                                            <Run Text="ID:"/> <Run Text="{Binding Id}"/>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                    <Separator Background="#3B4252" Margin="0,2,0,8"/>
                                                                    <TextBlock Text="{Binding StatusMessage}" Foreground="#D8DEE9" FontSize="11" FontStyle="Italic"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <Border Grid.Row="1"
                Padding="24"
                Background="#3B4252"
                CornerRadius="12"
                Margin="24"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasVisibleTweaks}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="📭" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="No tweaks match your filters"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#ECEFF4"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
