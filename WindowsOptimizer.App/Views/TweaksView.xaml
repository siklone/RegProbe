<UserControl x:Class="WindowsOptimizer.App.Views.TweaksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:WindowsOptimizer.Core;assembly=WindowsOptimizer.Core"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             xmlns:services="clr-namespace:WindowsOptimizer.App.Services"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <viewModels:InverseBooleanConverter x:Key="InverseBool" />
        <viewModels:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <viewModels:NestedMarginConverter x:Key="NestedMarginConverter" />
        <viewModels:SparklinePointsConverter x:Key="SparklinePointsConverter" />
        
        <!-- Status Color Converter -->
        <SolidColorBrush x:Key="AppliedBrush" Color="{DynamicResource Nord14}"/>
        <SolidColorBrush x:Key="NotAppliedBrush" Color="{DynamicResource Nord3}"/>
        <SolidColorBrush x:Key="UnknownBrush" Color="{DynamicResource Nord13}"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource Nord11}"/>

        <!-- Risk Badge Styles -->
        <Style x:Key="RiskBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Safe}">
                    <Setter Property="Background" Value="{DynamicResource SuccessSurfaceBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Advanced}">
                    <Setter Property="Background" Value="{DynamicResource CautionSurfaceBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Risky}">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TweakStatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>

        <Style x:Key="TweakStatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
        </Style>

        <Style x:Key="TweakStatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="TweakToggleStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="50" Height="26" Cursor="Hand">
                            <Border x:Name="Track" 
                                    Background="{DynamicResource BackgroundMediumBrush}" 
                                    CornerRadius="13"
                                    BorderBrush="{DynamicResource BackgroundLightBrush}"
                                    BorderThickness="1"/>
	                            <Border x:Name="Thumb" 
	                                    Width="20" Height="20" 
	                                    CornerRadius="10"
	                                    Background="{DynamicResource ForegroundLightBrush}"
	                                    HorizontalAlignment="Left"
	                                    Margin="3,0,0,0">
	                                <Border.RenderTransform>
	                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
	                                </Border.RenderTransform>
	                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ForegroundOnAccentBrush}"/>
                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
	                                                           Storyboard.TargetProperty="X"
	                                                           To="24" Duration="0:0:0.15">
	                                                <DoubleAnimation.EasingFunction>
	                                                    <QuadraticEase EasingMode="EaseOut"/>
	                                                </DoubleAnimation.EasingFunction>
	                                            </DoubleAnimation>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
	                                                           Storyboard.TargetProperty="X"
	                                                           To="0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
	                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact Button Style with Smooth Animations -->
	        <Style x:Key="CompactButton" TargetType="Button">
	            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
	            <Setter Property="BorderThickness" Value="0"/>
	            <Setter Property="Padding" Value="10,5"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
		                        <Border x:Name="Border"
		                                Background="{TemplateBinding Background}"
		                                CornerRadius="4"
		                                RenderTransformOrigin="0.5,0.5">
			                            <Border.RenderTransform>
			                                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1"/>
			                            </Border.RenderTransform>
		                            <Grid>
		                                <Border x:Name="HoverOverlay"
		                                        Background="{DynamicResource BackgroundLightBrush}"
	                                        CornerRadius="4"
	                                        Opacity="0"
	                                        IsHitTestVisible="False"/>
	                                <ContentPresenter HorizontalAlignment="Center"
	                                                  VerticalAlignment="Center"
	                                                  Margin="{TemplateBinding Padding}"/>
	                            </Grid>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsMouseOver" Value="True">
	                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="1" Duration="0:0:0.15"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.05" Duration="0:0:0.15">
		                                                <DoubleAnimation.EasingFunction>
		                                                    <QuadraticEase EasingMode="EaseOut"/>
		                                                </DoubleAnimation.EasingFunction>
		                                            </DoubleAnimation>
			                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
			                                                           Storyboard.TargetProperty="ScaleY"
			                                                           To="1.05" Duration="0:0:0.15">
			                                                <DoubleAnimation.EasingFunction>
			                                                    <QuadraticEase EasingMode="EaseOut"/>
			                                                </DoubleAnimation.EasingFunction>
			                                            </DoubleAnimation>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="0" Duration="0:0:0.15"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.15"/>
			                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
			                                                           Storyboard.TargetProperty="ScaleY"
			                                                           To="1.0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
                            </Trigger>
		                            <Trigger Property="IsPressed" Value="True">
		                                <Trigger.EnterActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.EnterActions>
		                                <Trigger.ExitActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.ExitActions>
		                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Bar Button with Smooth Animations -->
	        <Style x:Key="FilterButton" TargetType="Button">
	            <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
	            <Setter Property="BorderThickness" Value="0"/>
	            <Setter Property="Padding" Value="14,8"/>
	            <Setter Property="FontWeight" Value="Medium"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
		                        <Border x:Name="Border"
		                                Background="{TemplateBinding Background}"
		                                CornerRadius="6"
		                                RenderTransformOrigin="0.5,0.5">
			                            <Border.RenderTransform>
			                                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1"/>
			                            </Border.RenderTransform>
		                            <Grid>
		                                <Border x:Name="HoverOverlay"
		                                        Background="{DynamicResource AccentBlueBrush}"
	                                        CornerRadius="6"
	                                        Opacity="0"
	                                        IsHitTestVisible="False"/>
	                                <ContentPresenter HorizontalAlignment="Center"
	                                                  VerticalAlignment="Center"
	                                                  Margin="{TemplateBinding Padding}"/>
	                            </Grid>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsMouseOver" Value="True">
	                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="1" Duration="0:0:0.15"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.05" Duration="0:0:0.15">
		                                                <DoubleAnimation.EasingFunction>
		                                                    <QuadraticEase EasingMode="EaseOut"/>
		                                                </DoubleAnimation.EasingFunction>
		                                            </DoubleAnimation>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="1.05" Duration="0:0:0.15">
			                                                <DoubleAnimation.EasingFunction>
			                                                    <QuadraticEase EasingMode="EaseOut"/>
			                                                </DoubleAnimation.EasingFunction>
		                                            </DoubleAnimation>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="0" Duration="0:0:0.15"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.15"/>
			                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
			                                                           Storyboard.TargetProperty="ScaleY"
			                                                           To="1.0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
                            </Trigger>
		                            <Trigger Property="IsPressed" Value="True">
		                                <Trigger.EnterActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.EnterActions>
		                                <Trigger.ExitActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.ExitActions>
		                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Box Style -->
	        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
	            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
	            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
	            <Setter Property="BorderThickness" Value="1"/>
	            <Setter Property="Padding" Value="8,0"/>
	            <Setter Property="FontSize" Value="12"/>
	            <Setter Property="Height" Value="28"/>
	            <Setter Property="VerticalContentAlignment" Value="Center"/>
	            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
	            <Setter Property="Template">
	                <Setter.Value>
	                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

	        <!-- Filter Checkbox -->
	        <Style x:Key="FilterCheckbox" TargetType="CheckBox">
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
	            <Setter Property="FontSize" Value="12"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Style.Triggers>
	                <Trigger Property="IsChecked" Value="True">
	                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
	                    <Setter Property="FontWeight" Value="SemiBold"/>
	                </Trigger>
	            </Style.Triggers>
	        </Style>
        <!-- Link Button Style -->
	        <Style x:Key="LinkButtonStyle" TargetType="Button">
	            <Setter Property="Background" Value="Transparent"/>
	            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
	            <Setter Property="BorderThickness" Value="0,0,0,1"/>
	            <Setter Property="BorderBrush" Value="Transparent"/>
	            <Setter Property="Padding" Value="0,2"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="HorizontalContentAlignment" Value="Left"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
	                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
	                        <Border Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
	                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
	                        </Border>
	                    </ControlTemplate>
	                </Setter.Value>
	            </Setter>
	        <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsChecked" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <!-- Rounded ComboBox Style -->
        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <ToggleButton Name="ToggleButton" 
                                              Background="Transparent" 
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter Name="ContentSite" 
                                                  IsHitTestVisible="False" 
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="5,3,23,3"
                                                  VerticalAlignment="Center"/>
                                <Path Name="Arrow" 
                                      Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 Z" 
                                      Fill="{DynamicResource AccentDarkBlueBrush}" 
                                      HorizontalAlignment="Right" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,8,0"/>
                                <Popup Name="Popup" 
                                       Placement="Bottom" 
                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                       AllowsTransparency="True" 
                                       Focusable="False" 
                                       PopupAnimation="Slide">
                                    <Border Name="DropDownBorder" 
                                            Background="{DynamicResource BackgroundDarkBrush}" 
                                            BorderBrush="{DynamicResource BackgroundLightBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="4">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Recursive Category Template -->
        <DataTemplate x:Key="CategoryTemplate" DataType="{x:Type viewModels:CategoryGroupViewModel}">
            <StackPanel Margin="{Binding IsNested, Converter={StaticResource NestedMarginConverter}}">
                <!-- Category Header -->
                <Border CornerRadius="8" 
                        Margin="0,0,0,8"
                        Padding="12,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNested}" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=IsCompactMode}" Value="True">
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DisplayName, TargetNullValue='Unknown Category', FallbackValue='Category Name'}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="10" Padding="8,2" Margin="0,0,10,0">
                                <TextBlock Text="{Binding CountBadge}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <ToggleButton IsChecked="{Binding IsExpanded}" Style="{StaticResource ExpanderButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Nested Content -->
                <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                    <!-- SubGroups Recursive Call -->
                    <ItemsControl ItemsSource="{Binding SubGroups}" ItemTemplate="{StaticResource CategoryTemplate}"/>
                    
                    <!-- Tweaks In This Group (uses VisibleTweaks for lazy loading) -->
                    <ItemsControl ItemsSource="{Binding VisibleTweaks}" ItemTemplate="{StaticResource TweakItemTemplate}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel x:Name="TweaksPanel"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDense}" Value="True">
                                        <Setter Property="ItemsPanel">
                                            <Setter.Value>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="3"/>
                                                </ItemsPanelTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
        <!-- Expander Button Style -->
        <Style x:Key="ExpanderButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="ToggleButton">
	                        <Border Background="{TemplateBinding Background}" Padding="4">
	                            <TextBlock x:Name="Icon" Text="▶" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="12" RenderTransformOrigin="0.5,0.5">
	                                <TextBlock.RenderTransform>
	                                    <RotateTransform x:Name="IconRotate" Angle="0"/>
	                                </TextBlock.RenderTransform>
	                            </TextBlock>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="IconRotate" 
	                                                           Storyboard.TargetProperty="Angle"
	                                                           To="90" Duration="0:0:0.2"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="IconRotate" 
	                                                           Storyboard.TargetProperty="Angle"
	                                                           To="0" Duration="0:0:0.2"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
	                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tweak Item Template -->
        <DataTemplate x:Key="TweakItemTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
            <Border Background="{DynamicResource BackgroundDarkBrush}" 
                    CornerRadius="10" 
                    Margin="0,0,0,10" 
                    Padding="16"
                    BorderThickness="1">
                <Border.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="{DynamicResource ShadowColorSmall}" BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=EnableCardShadows}" Value="False">
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=IsCompactMode}" Value="True">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource CautionBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <StackPanel>
                    <!-- Main Card content (simplified for brevity here, actual will have full details) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Checkbox -->
                            <ColumnDefinition Width="Auto"/>  <!-- Status -->
                            <ColumnDefinition Width="*"/>     <!-- Content -->
                            <ColumnDefinition Width="Auto"/>  <!-- Actions -->
                        </Grid.ColumnDefinitions>

                        <!-- Selection Checkbox -->
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsSelected}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  ToolTip="Select for batch operations">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>

                        <!-- Status Indicator -->
                        <Border Grid.Column="1"
	                                Width="32"
	                                Height="32"
	                                CornerRadius="16"
	                                Margin="0,0,12,0"
	                                Background="{Binding StatusBadgeBackground}"
                                    BorderBrush="{Binding StatusColor}"
                                    BorderThickness="1"
	                                ToolTip="{Binding StatusTooltip}">
	                             <TextBlock Text="{Binding StatusIcon}"
                                               Foreground="{Binding StatusColor}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
	                        </Border>

	                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" FontSize="12"/>
                                <Border Background="{Binding StatusBadgeBackground}"
                                        BorderBrush="{Binding StatusColor}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        ToolTip="{Binding StatusTooltip}">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusColor}"
                                               FontSize="8"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Border Background="{DynamicResource SuccessBrush}" 
                                        CornerRadius="4" 
                                        Padding="6,2" 
                                        Margin="8,0,0,0"
                                        Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibility}}"
                                        ToolTip="{Binding RecommendationReason}">
                                    <TextBlock Text="★ RECOMMENDED" 
                                               Foreground="{DynamicResource ForegroundOnLightAccentBrush}" 
                                               FontSize="8" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
	                                </Border>
	                            </StackPanel>
	                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/>
	                            <Grid Margin="0,2,0,0"
	                                  Visibility="{Binding HasCompactInfoLine, Converter={StaticResource BoolToVisibility}}"
	                                  ToolTip="{Binding CompactInfoTooltip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource BackgroundMediumBrush}"
                                            BorderBrush="{DynamicResource BackgroundLightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="6,1"
                                            Margin="0,0,6,0">
                                        <TextBlock Text="{Binding ImpactAreaLabel}"
                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                   FontSize="9"
                                                   FontWeight="SemiBold"/>
                                    </Border>
	                                <TextBlock Grid.Column="1"
	                                           Text="{Binding CompactInfoLine}"
	                                           Foreground="{DynamicResource ForegroundLightBrush}"
	                                           FontSize="10"
	                                           FontFamily="Consolas"
	                                           Opacity="0.85"
	                                           TextTrimming="CharacterEllipsis"/>
	                            </Grid>
                                <TextBlock Text="{Binding BatchSummaryLine}"
                                           Visibility="{Binding HasBatchSummaryLine, Converter={StaticResource BoolToVisibility}}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           FontSize="9"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Before/After Snapshot Comparison -->
                                <Border Visibility="{Binding HasStateChange, Converter={StaticResource BoolToVisibility}}"
                                        Background="{DynamicResource BackgroundMediumBrush}"
                                        BorderBrush="{DynamicResource BackgroundLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        Margin="0,6,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Snapshot Comparison"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Before -->
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="Before:"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource DangerBrush}"
                                                       Margin="0,0,8,2"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding BeforeState}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- After -->
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="After:"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding AfterState}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
	                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                             <!-- Favorite Button -->
                             <Button Command="{Binding ToggleFavoriteCommand}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Cursor="Hand"
                                     Padding="6,4"
                                     ToolTip="Toggle favorite">
                                 <Button.Style>
                                     <Style TargetType="Button">
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                         <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                     </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                     </Style>
                                 </Button.Style>
                                 <TextBlock Text="{Binding FavoriteIcon}" FontSize="18">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock">
                                             <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                     <Setter Property="Foreground" Value="{DynamicResource CautionBrush}"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                 </TextBlock>
                             </Button>
                             <ToggleButton IsChecked="{Binding IsDetailsExpanded}" Style="{StaticResource ExpanderButtonStyle}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Expanded Details Area -->
                    <StackPanel Visibility="{Binding IsDetailsExpanded, Converter={StaticResource BoolToVisibility}}" Margin="0,12,0,0">
                         <!-- Detail Tabs -->
                         <UniformGrid Columns="2" Margin="0,0,0,16">
                             <ToggleButton IsChecked="{Binding ShowTerminal, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                                           Content="Technical Info"
                                           Style="{StaticResource TabButtonStyle}"/>
                             <ToggleButton IsChecked="{Binding ShowTerminal, Mode=TwoWay}"
                                           Content="Execution Log"
                                           Style="{StaticResource TabButtonStyle}"/>
                         </UniformGrid>

                         <!-- Tab View 1: Technical Info -->
                         <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource InverseBoolToVisibility}}">
                             <!-- Registry Info -->
                             <StackPanel Visibility="{Binding HasRegistryPath, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                                 <TextBlock Text="Registry Location" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Grid>
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8,6">
                                         <TextBlock Text="{Binding RegistryPath}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                     </Border>
                                     <Button Grid.Column="1" Command="{Binding CopyRegistryPathCommand}" Content="📋" Style="{StaticResource CompactButton}" Margin="4,0,0,0"/>
                                 </Grid>
                             </StackPanel>

                             <!-- Registry Diff -->
                             <StackPanel Visibility="{Binding HasDiff, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                                 <TextBlock Text="Registry Value Comparison" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <UniformGrid Columns="2">
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4,0,0,4" Padding="8,6" BorderBrush="{DynamicResource BackgroundLightBrush}" BorderThickness="1,1,0,1">
                                         <StackPanel>
                                              <TextBlock Text="CURRENT" FontSize="8" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" Margin="0,0,0,2"/>
                                              <TextBlock Text="{Binding CurrentValue}" Foreground="{DynamicResource CautionBrush}" FontSize="11" FontFamily="Consolas"/>
                                         </StackPanel>
                                     </Border>
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="0,4,4,0" Padding="8,6" BorderBrush="{DynamicResource BackgroundLightBrush}" BorderThickness="1">
                                         <StackPanel>
                                              <TextBlock Text="TARGET" FontSize="8" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" Margin="0,0,0,2"/>
                                              <TextBlock Text="{Binding TargetValue}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontFamily="Consolas"/>
                                         </StackPanel>
                                     </Border>
                                 </UniformGrid>
                             </StackPanel>

                             <!-- Batch Details -->
                             <StackPanel Visibility="{Binding HasBatchDetails, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                                 <TextBlock Text="{Binding BatchDetailsTitle, StringFormat={}{0} Breakdown}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10">
                                     <ItemsControl ItemsSource="{Binding BatchDetails}">
                                         <ItemsControl.ItemTemplate>
                                             <DataTemplate>
                                                 <TextBlock Text="{Binding}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                             </DataTemplate>
                                         </ItemsControl.ItemTemplate>
                                     </ItemsControl>
                                 </Border>
                             </StackPanel>

                             <!-- Priority Calculator -->
                             <StackPanel Visibility="{Binding HasPriorityCalculator, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                                 <TextBlock Text="System Priority Calculator" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,8"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="12">
                                     <StackPanel>
                                         <TextBlock Text="{Binding PriorityCalculator.Description}" Foreground="{DynamicResource CautionBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                         <UniformGrid Columns="3">
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalLength}" Style="{StaticResource RoundedComboBox}" FontSize="10" Margin="0,0,4,0">
                                                 <ComboBoxItem Content="Short"/><ComboBoxItem Content="Long"/>
                                             </ComboBox>
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalType}" Style="{StaticResource RoundedComboBox}" FontSize="10" Margin="0,0,4,0">
                                                 <ComboBoxItem Content="Variable"/><ComboBoxItem Content="Fixed"/>
                                             </ComboBox>
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.Boost}" Style="{StaticResource RoundedComboBox}" FontSize="10">
                                                 <ComboBoxItem Content="None"/><ComboBoxItem Content="Middle"/><ComboBoxItem Content="Max"/>
                                             </ComboBox>
                                         </UniformGrid>
                                     </StackPanel>
                                 </Border>
                             </StackPanel>

                             <!-- System Impact Sparkline -->
                             <StackPanel Margin="0,0,0,12">
                                 <TextBlock Text="System Impact Estimator" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,8"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="12,8">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                              <ColumnDefinition Width="Auto"/>
                                              <ColumnDefinition Width="*"/>
                                         </Grid.ColumnDefinitions>
                                         <TextBlock Text="📈" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                         <Polyline Grid.Column="1" Points="{Binding SparklinePoints, Converter={StaticResource SparklinePointsConverter}}" 
                                                   Stroke="{DynamicResource AccentBrightCyanBrush}" StrokeThickness="1.5" Opacity="0.7" 
                                                   VerticalAlignment="Center" Height="40" Stretch="Fill"/>
                                     </Grid>
                                 </Border>
                             </StackPanel>

                             <!-- Code Example -->
                             <StackPanel Visibility="{Binding HasCodeExample, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                                 <TextBlock Text="Command Preview" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="12">
                                     <TextBlock Text="{Binding CodeExample}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                 </Border>
                             </StackPanel>

                             <!-- Reference Links -->
	                             <ItemsControl ItemsSource="{Binding ReferenceLinks}" Margin="0,0,0,12">
	                                 <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
	                                 <ItemsControl.ItemTemplate>
	                                     <DataTemplate>
	                                         <Button Style="{StaticResource LinkButtonStyle}"
	                                                 Margin="0,0,12,4"
	                                                 ToolTip="{Binding Tooltip}"
	                                                 Command="{Binding DataContext.OpenReferenceLinkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
	                                                 CommandParameter="{Binding Url}">
	                                            <StackPanel Orientation="Horizontal">
	                                                <TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,4,0"/>
	                                                <TextBlock Text="{Binding Title}"/>
	                                            </StackPanel>
	                                         </Button>
	                                     </DataTemplate>
	                                 </ItemsControl.ItemTemplate>
	                             </ItemsControl>
                         </StackPanel>

                         <!-- Tab View 2: Execution Log -->
                         <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource BoolToVisibility}}">
                             <Border Background="{DynamicResource TerminalBackgroundBrush}" CornerRadius="4" Padding="12" Height="150">
                                 <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                               HorizontalScrollBarVisibility="Disabled">
                                     <TextBlock Text="{Binding TerminalOutput}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                 </ScrollViewer>
                             </Border>
                         </StackPanel>

                         <!-- Footer Actions -->
                         <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10" Margin="0,4,0,0">
                             <Grid>
                                 <StackPanel Orientation="Horizontal">
	                                     <Button Content="Detect"
	                                             Command="{Binding DetectCommand}"
	                                             Style="{StaticResource CompactButton}"
	                                             Margin="0,0,6,0"
	                                             ToolTip="Detect: reads current state (no changes)."/>
	                                     <Button Content="{Binding ActionButtonText}"
	                                             Command="{Binding ApplyCommand}"
	                                             Style="{StaticResource CompactButton}"
	                                             Background="{DynamicResource AccentDarkBlueBrush}"
                                                 Foreground="{DynamicResource ForegroundOnAccentBrush}"
	                                             ToolTip="Apply: Detect -> Apply -> Verify (Rollback on failure)."/>
	                                     <Button Content="?"
	                                             Style="{StaticResource CompactButton}"
	                                             Margin="6,0,0,0"
	                                             ToolTip="{Binding ActionsHelpTooltip}"/>
	                                 </StackPanel>
                                 <TextBlock HorizontalAlignment="Right" Text="{Binding StatusMessage}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="10" VerticalAlignment="Center" FontStyle="Italic"/>
                             </Grid>
                         </Border>
                    </StackPanel>
	                            </StackPanel>
	                        </Border>
	                        <DataTemplate.Triggers>
	                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
	                                <DataTrigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ExpanderIconRotate"
	                                                             Storyboard.TargetProperty="Angle"
	                                                             To="90"
	                                                             Duration="0:0:0.2">
	                                                <DoubleAnimation.EasingFunction>
	                                                    <CubicEase EasingMode="EaseOut"/>
	                                                </DoubleAnimation.EasingFunction>
	                                            </DoubleAnimation>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </DataTrigger.EnterActions>
	                                <DataTrigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ExpanderIconRotate"
	                                                             Storyboard.TargetProperty="Angle"
	                                                             To="0"
	                                                             Duration="0:0:0.2">
	                                                <DoubleAnimation.EasingFunction>
	                                                    <CubicEase EasingMode="EaseOut"/>
	                                                </DoubleAnimation.EasingFunction>
	                                            </DoubleAnimation>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </DataTrigger.ExitActions>
	                            </DataTrigger>
	                        </DataTemplate.Triggers>
	                    </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundDarkestBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundDarkestBrush}" Padding="24,20">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="{Binding Title}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                <TextBlock Text="{Binding FilterSummary}"
                           Foreground="{DynamicResource AccentBrightCyanBrush}"
                           FontSize="12"
                           Margin="0,4,0,8"/>

                <UniformGrid Columns="5" Margin="0,0,-12,4">
                    <Button Command="{Binding ResetFiltersCommand}" Cursor="Hand" ToolTip="Show all tweaks">
                        <Button.Template>
                            <ControlTemplate>
                                <Border Style="{StaticResource TweakStatCardStyle}">
                                    <StackPanel>
                                        <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="10" Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Text="📦" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding TotalTweaksAvailable}" Style="{StaticResource TweakStatValueStyle}"/>
                                        <TextBlock Text="Total Tweaks" Style="{StaticResource TweakStatLabelStyle}"/>
                                        <TextBlock Text="Show all" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding FilterAppliedCommand}" Cursor="Hand" ToolTip="Filter applied tweaks">
                        <Button.Template>
                            <ControlTemplate>
                                <Border Style="{StaticResource TweakStatCardStyle}">
                                    <StackPanel>
                                        <Border Background="{DynamicResource SuccessBrush}" CornerRadius="10" Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Text="✅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding TweaksApplied}" Style="{StaticResource TweakStatValueStyle}" Foreground="{DynamicResource SuccessBrush}"/>
                                        <TextBlock Text="Applied" Style="{StaticResource TweakStatLabelStyle}"/>
                                        <TextBlock Text="Click to filter" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding FilterRolledBackCommand}" Cursor="Hand" ToolTip="Filter rolled-back tweaks">
                        <Button.Template>
                            <ControlTemplate>
                                <Border Style="{StaticResource TweakStatCardStyle}">
                                    <StackPanel>
                                        <Border Background="{DynamicResource CautionBrush}" CornerRadius="10" Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Text="↩️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding TweaksRolledBack}" Style="{StaticResource TweakStatValueStyle}" Foreground="{DynamicResource CautionBrush}"/>
                                        <TextBlock Text="Rolled Back" Style="{StaticResource TweakStatLabelStyle}"/>
                                        <TextBlock Text="Click to filter" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding OpenCsvLogCommand}" Cursor="Hand" ToolTip="Open tweak log (CSV)">
                        <Button.Template>
                            <ControlTemplate>
                                <Border Style="{StaticResource TweakStatCardStyle}">
                                    <StackPanel>
                                        <Border Background="{DynamicResource InfoBrush}" CornerRadius="10" Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Text="📄" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding LogFileSizeFormatted}" Style="{StaticResource TweakStatValueStyle}" FontSize="22"/>
                                        <TextBlock Text="Log File Size" Style="{StaticResource TweakStatLabelStyle}"/>
                                        <TextBlock Text="Click to open" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding OpenDocsCoverageReportCommand}" Cursor="Hand" ToolTip="{Binding DocsCoverageSummary}">
                        <Button.Template>
                            <ControlTemplate>
                                <Border Style="{StaticResource TweakStatCardStyle}">
                                    <StackPanel>
                                        <Border CornerRadius="10" Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DocsCoverageOk}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DocsCoverageWarn}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource CautionBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DocsCoverageCritical}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="📚" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding DocsMissingCount}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TweakStatValueStyle}">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DocsCoverageOk}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DocsCoverageWarn}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource CautionBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DocsCoverageCritical}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Docs Missing" Style="{StaticResource TweakStatLabelStyle}"/>
                                        <TextBlock Text="{Binding DocsCoverageSummary}" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </UniformGrid>

                <!-- Status Filter Badge (shown when filtering by applied/rolled back) -->
                <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="6" Padding="12,6" Margin="0,0,0,12"
                        HorizontalAlignment="Left" Cursor="Hand"
                        Visibility="{Binding HasStatusFilter, Converter={StaticResource BoolToVisibility}}">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding ResetFiltersCommand}"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusFilterLabel}" Foreground="{DynamicResource ForegroundOnAccentBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="  ✕ Clear" Foreground="{DynamicResource ForegroundOnAccentBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Filter Bar -->
                <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="10" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

	                        <!-- Search -->
	                        <StackPanel Grid.Column="0" Orientation="Horizontal">
	                            <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
	                            <TextBox Width="160"
	                                     Style="{StaticResource SearchBoxStyle}"
	                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
	                                     ToolTip="Search tweaks..."/>
	                        </StackPanel>

	                        <!-- Risk Filters -->
	                        <WrapPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
	                            <CheckBox Content="Safe" 
	                                      Style="{StaticResource FilterCheckbox}"
	                                      IsChecked="{Binding ShowSafe}" 
	                                      Margin="0,0,12,0"
	                                      ToolTip="Show Safe tweaks"/>
	                            <CheckBox Content="Advanced" 
	                                      Style="{StaticResource FilterCheckbox}"
	                                      IsChecked="{Binding ShowAdvanced}" 
	                                      Margin="0,0,12,0"
	                                      ToolTip="Show Advanced tweaks"/>
	                            <CheckBox Content="Risky"
	                                      Style="{StaticResource FilterCheckbox}"
	                                      IsChecked="{Binding ShowRisky}"
	                                      Margin="0,0,12,0"
	                                      ToolTip="Show Risky tweaks"/>
	                            <Border Width="1" Background="{DynamicResource BackgroundLightBrush}" Margin="4,2,12,2"/>
	                            <CheckBox Style="{StaticResource FilterCheckbox}"
	                                      IsChecked="{Binding ShowFavoritesOnly}"
	                                      Margin="0,0,12,0"
	                                      ToolTip="Show only favorite tweaks">
	                                <StackPanel Orientation="Horizontal">
	                                    <TextBlock Text="★" Foreground="{DynamicResource CautionBrush}" Margin="0,0,4,0"/>
	                                    <TextBlock Text="Favorites"/>
	                                    <TextBlock Text="{Binding FavoritesCount, StringFormat=' ({0})'}" Foreground="{DynamicResource AccentBrightCyanBrush}"/>
	                                </StackPanel>
	                            </CheckBox>
	                            <CheckBox Content="Flat"
	                                      Style="{StaticResource FilterCheckbox}"
	                                      IsChecked="{Binding IsFlatView}"
	                                      ToolTip="Flatten category hierarchy for maximum performance"/>
	                        </WrapPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <!-- Quick Preset Buttons -->
                            <Button Content="Gaming"
                                    Command="{Binding LoadPresetCommand}"
                                    CommandParameter="Gaming"
                                    Style="{StaticResource CompactButton}"
                                    Margin="0,0,4,0"
                                    ToolTip="Load Gaming preset"/>
                            <Button Content="Privacy"
                                    Command="{Binding LoadPresetCommand}"
                                    CommandParameter="Privacy"
                                    Style="{StaticResource CompactButton}"
                                    Margin="0,0,4,0"
                                    ToolTip="Load Privacy preset"/>
                            <Button Content="Performance"
                                    Command="{Binding LoadPresetCommand}"
                                    CommandParameter="Performance"
                                    Style="{StaticResource CompactButton}"
                                    Margin="0,0,4,0"
                                    ToolTip="Load Performance preset"/>
                            <Button Content="Minimal"
                                    Command="{Binding LoadPresetCommand}"
                                    CommandParameter="Minimal"
                                    Style="{StaticResource CompactButton}"
                                    Margin="0,0,8,0"
                                    ToolTip="Load Minimal preset"/>

	                            <Button Content="Reset"
	                                    Command="{Binding ResetFiltersCommand}"
	                                    Style="{StaticResource CompactButton}"
	                                    Margin="0,0,8,0"
	                                    ToolTip="Reset filters (search + risk + view)."/>
	                            <Button Content="Export" 
	                                    Command="{Binding ExportPresetCommand}"
	                                    Style="{StaticResource CompactButton}"
	                                    Margin="0,0,4,0"
	                                    ToolTip="Export presets and snapshots."/>
	                            <Button Content="Import" 
	                                    Command="{Binding ImportPresetCommand}"
	                                    Style="{StaticResource CompactButton}"
	                                    Margin="0,0,4,0"
	                                    ToolTip="Import presets."/>
	                            <Button Content="Snapshot" 
	                                    Command="{Binding CreateSnapshotCommand}"
	                                    Style="{StaticResource CompactButton}"
	                                    ToolTip="Create a snapshot of current states."/>
	                            <Button Content="Apply All" 
	                                    Command="{Binding ApplyAllCommand}" 
	                                    Style="{StaticResource FilterButton}"
	                                    ToolTip="Apply all visible tweaks (Detect → Apply → Verify)."/>
                        </StackPanel>
                    </Grid>
	                </Border>

	                <!-- Elevated Host Missing Warning -->
	                <Border Background="{DynamicResource CautionSurfaceBrush}"
	                        CornerRadius="10"
	                        Padding="12,10"
	                        Margin="0,10,0,0"
	                        Visibility="{Binding IsElevatedHostAvailable, Converter={StaticResource InverseBoolToVisibility}}">
	                    <StackPanel Orientation="Horizontal">
	                        <TextBlock FontFamily="Segoe MDL2 Assets"
	                                   Text="&#xE7BA;"
	                                   FontSize="14"
	                                   Foreground="{DynamicResource CautionBrush}"
	                                   Margin="0,0,8,0"
	                                   VerticalAlignment="Center"/>
	                        <TextBlock Text="{Binding ElevatedHostStatusMessage}"
	                                   Foreground="{DynamicResource CautionBrush}"
	                                   FontSize="11"
	                                   TextWrapping="Wrap"/>
	                    </StackPanel>
	                </Border>

	                <!-- Selection Toolbar -->
	                <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="10" Padding="16,12" Margin="0,12,0,0"
	                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Selection Info -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="✓" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text="{Binding SelectionSummary}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Selection Controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
	                            <Button Content="Select All Visible"
	                                    Command="{Binding SelectAllCommand}"
	                                    Style="{StaticResource CompactButton}"
	                                    Margin="0,0,8,0"
	                                    ToolTip="Selects all currently visible tweaks."/>
	                            <Button Content="Deselect All"
	                                    Command="{Binding DeselectAllCommand}"
	                                    Style="{StaticResource CompactButton}"
	                                    ToolTip="Clears the current selection."/>
                        </StackPanel>

                        <!-- Batch Actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
	                            <Button Content="Detect Selected"
	                                    Command="{Binding DetectSelectedCommand}"
	                                    Style="{StaticResource FilterButton}"
	                                    Background="{DynamicResource AccentDarkBlueBrush}"
                                        Foreground="{DynamicResource ForegroundOnAccentBrush}"
	                                    Margin="0,0,6,0"
	                                    ToolTip="Detect selected tweaks (no changes)."/>
	                            <Button Content="Apply Selected"
	                                    Command="{Binding ApplySelectedCommand}"
	                                    Style="{StaticResource FilterButton}"
	                                    Background="{DynamicResource SuccessBrush}"
                                        Foreground="{DynamicResource ForegroundOnLightAccentBrush}"
	                                    Margin="0,0,6,0"
	                                    ToolTip="Apply selected tweaks (Detect → Apply → Verify)."/>
	                            <Button Content="Verify Selected"
	                                    Command="{Binding VerifySelectedCommand}"
	                                    Style="{StaticResource FilterButton}"
	                                    Background="{DynamicResource AccentBrightCyanBrush}"
                                        Foreground="{DynamicResource ForegroundOnLightAccentBrush}"
	                                    Margin="0,0,6,0"
	                                    ToolTip="Verify selected tweaks are in the desired state."/>
	                            <Button Content="Rollback Selected"
	                                    Command="{Binding RollbackSelectedCommand}"
	                                    Style="{StaticResource FilterButton}"
	                                    Background="{DynamicResource DangerBrush}"
                                        Foreground="{DynamicResource ForegroundOnAccentBrush}"
	                                    ToolTip="Rollback selected tweaks using the last Detect snapshot (this session)."/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main Content Area: Conditional between Hierarchical and Flat View -->
        <Grid Grid.Row="1">
            <!-- Hierarchical Category View -->
            <ListBox ItemsSource="{Binding CategoryGroups}"
                     Visibility="{Binding IsFlatView, Converter={StaticResource InverseBoolToVisibility}}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="24,0,24,24"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.IsDeferredScrollingEnabled="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="2,2"
                     VirtualizingPanel.CacheLengthUnit="Page">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12">
                            <StackPanel>
                                <!-- Category Header with Smooth Animations -->
		                                    <Border x:Name="CategoryHeader"
		                                            CornerRadius="8"
		                                            Cursor="Hand"
		                                            Margin="0,0,0,6"
		                                            Background="{DynamicResource BackgroundDarkBrush}">
		                                        <Border.Triggers>
		                                            <EventTrigger RoutedEvent="MouseEnter">
		                                                <BeginStoryboard>
		                                                    <Storyboard>
		                                                        <DoubleAnimation Storyboard.TargetName="CategoryHeaderHoverOverlay"
		                                                                       Storyboard.TargetProperty="Opacity"
		                                                                       To="0.35" Duration="0:0:0.15"/>
		                                                    </Storyboard>
		                                                </BeginStoryboard>
		                                            </EventTrigger>
		                                            <EventTrigger RoutedEvent="MouseLeave">
		                                                <BeginStoryboard>
		                                                    <Storyboard>
		                                                        <DoubleAnimation Storyboard.TargetName="CategoryHeaderHoverOverlay"
		                                                                       Storyboard.TargetProperty="Opacity"
		                                                                       To="0" Duration="0:0:0.15"/>
		                                                    </Storyboard>
		                                                </BeginStoryboard>
		                                            </EventTrigger>
		                                        </Border.Triggers>
		                                    <Border.InputBindings>
		                                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandCommand}"/>
		                                    </Border.InputBindings>
		                                    <Grid>
		                                        <Border x:Name="CategoryHeaderHoverOverlay"
		                                                Background="{DynamicResource BackgroundMediumBrush}"
		                                                CornerRadius="8"
		                                                Opacity="0"
		                                                IsHitTestVisible="False"/>
		                                        <!-- Use a Grid with Transparent background to catch clicks anywhere on the header -->
		                                        <Grid Background="Transparent" Margin="14,10">
		                                        <Grid.ColumnDefinitions>
		                                            <ColumnDefinition Width="Auto"/>
		                                            <ColumnDefinition Width="*"/>
		                                            <ColumnDefinition Width="Auto"/>
		                                        </Grid.ColumnDefinitions>

	                                        <TextBlock x:Name="ExpanderIcon"
	                                                   Grid.Column="0"
	                                                   Text="{Binding ExpanderIcon}"
	                                                   FontSize="10"
	                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"
	                                                   VerticalAlignment="Center"
	                                                   Margin="0,0,10,0"
	                                                   RenderTransformOrigin="0.5,0.5">
	                                            <TextBlock.RenderTransform>
	                                                <RotateTransform x:Name="ExpanderIconRotate" Angle="0"/>
	                                            </TextBlock.RenderTransform>
	                                        </TextBlock>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CategoryIcon}" FontFamily="Segoe UI Emoji" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding CategoryName}" 
                                                       FontSize="15" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                       Margin="0,0,6,0"
                                                       ToolTip="{Binding HelpTooltip}"/>
                                        </StackPanel>

                                        <Border Grid.Column="2" 
                                                Background="{DynamicResource AccentDarkBlueBrush}" 
                                                CornerRadius="8" 
                                                Padding="8,3">
                                            <TextBlock Text="{Binding CountBadge}" 
                                                       FontSize="11" 
                                                       FontWeight="Bold" 
                                                       Foreground="{DynamicResource ForegroundOnAccentBrush}"/>
		                                        </Border>
		                                        </Grid>
		                                    </Grid>
		                                </Border>

                                <!-- Tweaks List (uses VisibleTweaks for lazy loading - empty when collapsed) -->
                                <ItemsControl ItemsSource="{Binding VisibleTweaks}"
                                              Margin="16,0,0,0"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Tweak Card with Smooth Hover Effects -->
		                                            <Border x:Name="TweakCard"
		                                                    CornerRadius="8"
		                                                    Padding="14,12"
		                                                    Margin="0,0,0,6"
		                                                    BorderThickness="2,0,0,0"
                                                    BorderBrush="{Binding StatusColor}"
                                                    Background="{DynamicResource BackgroundDarkBrush}"
                                                    CacheMode="BitmapCache">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="TweakCardTranslate" Y="0"/>
                                                </Border.RenderTransform>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="{DynamicResource ShadowColorSmall}"
                                                                                  BlurRadius="8"
                                                                                  ShadowDepth="2"
                                                                                  Opacity="0.2"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=EnableCardShadows}" Value="False">
                                                                <Setter Property="Effect" Value="{x:Null}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                        <BeginStoryboard>
	                                                            <Storyboard>
			                                                                <DoubleAnimation Storyboard.TargetName="TweakCardTranslate"
			                                                                               Storyboard.TargetProperty="Y"
			                                                                               To="-2" Duration="0:0:0.15">
	                                                                    <DoubleAnimation.EasingFunction>
	                                                                        <QuadraticEase EasingMode="EaseOut"/>
	                                                                    </DoubleAnimation.EasingFunction>
	                                                                </DoubleAnimation>
	                                                                <DoubleAnimation Storyboard.TargetName="TweakCardHoverOverlay"
	                                                                               Storyboard.TargetProperty="Opacity"
	                                                                               To="0.35" Duration="0:0:0.15"/>
		                                                            </Storyboard>
		                                                        </BeginStoryboard>
		                                                    </EventTrigger>
		                                                    <EventTrigger RoutedEvent="MouseLeave">
	                                                        <BeginStoryboard>
	                                                            <Storyboard>
			                                                                <DoubleAnimation Storyboard.TargetName="TweakCardTranslate"
			                                                                               Storyboard.TargetProperty="Y"
			                                                                               To="0" Duration="0:0:0.15"/>
	                                                                <DoubleAnimation Storyboard.TargetName="TweakCardHoverOverlay"
	                                                                               Storyboard.TargetProperty="Opacity"
	                                                                               To="0" Duration="0:0:0.15"/>
		                                                            </Storyboard>
		                                                        </BeginStoryboard>
		                                                    </EventTrigger>
		                                                </Border.Triggers>
		                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>  <!-- Checkbox -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- Status -->
                                                        <ColumnDefinition Width="*"/>     <!-- Content -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- Actions -->
                                                    </Grid.ColumnDefinitions>
	                                                    <Grid.RowDefinitions>
	                                                        <RowDefinition Height="Auto"/>
	                                                        <RowDefinition Height="Auto"/>
	                                                        <RowDefinition Height="Auto"/>
	                                                    </Grid.RowDefinitions>

	                                                    <Border x:Name="TweakCardHoverOverlay"
	                                                            Grid.ColumnSpan="4"
	                                                            Grid.RowSpan="3"
	                                                            Background="{DynamicResource BackgroundMediumBrush}"
	                                                            CornerRadius="6"
	                                                            Opacity="0"
	                                                            IsHitTestVisible="False"/>

	                                                    <!-- Selection Checkbox -->
	                                                    <CheckBox Grid.Column="0"
	                                                              IsChecked="{Binding IsSelected}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,10,0"
                                                              ToolTip="Select for batch operations">
                                                        <CheckBox.Style>
                                                            <Style TargetType="CheckBox">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                            </Style>
                                                        </CheckBox.Style>
                                                    </CheckBox>

                                                    <!-- Status Indicator -->
	                                                    <Border Grid.Column="1" Grid.RowSpan="2"
	                                                            Width="36" Height="36"
	                                                            CornerRadius="18"
	                                                            Margin="0,0,14,0"
	                                                            VerticalAlignment="Center"
                                                                Background="{Binding StatusBadgeBackground}"
                                                                BorderBrush="{Binding StatusColor}"
                                                                BorderThickness="1"
	                                                            ToolTip="{Binding StatusTooltip}">
                                                        <TextBlock Text="{Binding StatusIcon}" 
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Foreground>
                                                                <Binding Path="StatusColor"/>
                                                            </TextBlock.Foreground>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- Tweak Info -->
                                                    <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Background="{Binding StatusBadgeBackground}"
                                                                BorderBrush="{Binding StatusColor}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                Margin="8,0,0,0"
                                                                ToolTip="{Binding StatusTooltip}">
                                                            <TextBlock Text="{Binding StatusText}"
                                                                       FontSize="9"
                                                                       Foreground="{Binding StatusColor}"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Style="{StaticResource RiskBadgeStyle}" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Risk}"
                                                                       FontSize="9"
                                                                       Foreground="{DynamicResource ForegroundLightBrush}"/>
                                                        </Border>
	                                                        <Border Visibility="{Binding RequiresElevation, Converter={StaticResource BoolToVisibility}}"
	                                                                Background="{DynamicResource CautionSurfaceBrush}"
	                                                                CornerRadius="4"
	                                                                Padding="6,2"
	                                                                Margin="6,0,0,0"
	                                                                ToolTip="{Binding ElevationTooltip}">
	                                                            <StackPanel Orientation="Horizontal">
	                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" FontSize="10" Foreground="{DynamicResource CautionBrush}" Margin="0,0,4,0"/>
	                                                                <TextBlock Text="{Binding ElevationBadgeText}" FontSize="9" Foreground="{DynamicResource CautionBrush}" FontWeight="SemiBold"/>
	                                                            </StackPanel>
	                                                        </Border>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2" Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               Foreground="{DynamicResource AccentBrightCyanBrush}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,4,0,0"/>

                                                    <!-- Toggle and Actions -->
                                                    <StackPanel Grid.Column="3" Grid.RowSpan="2"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <!-- Loading Indicator with Pulse Animation -->
                                                        <Border Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"
                                                                Margin="0,0,12,0">
                                                            <TextBlock Text="⏳" FontSize="14" RenderTransformOrigin="0.5,0.5">
	                                                                <TextBlock.RenderTransform>
	                                                                    <ScaleTransform x:Name="LoadingScale" ScaleX="1" ScaleY="1"/>
	                                                                </TextBlock.RenderTransform>
                                                                <TextBlock.Triggers>
                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
	                                                                                <DoubleAnimation Storyboard.TargetName="LoadingScale" Storyboard.TargetProperty="ScaleX"
	                                                                                               From="1.0" To="1.3" Duration="0:0:0.6">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut"/>
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
	                                                                                <DoubleAnimation Storyboard.TargetName="LoadingScale" Storyboard.TargetProperty="ScaleY"
	                                                                                               From="1.0" To="1.3" Duration="0:0:0.6">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut"/>
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                               From="1.0" To="0.5" Duration="0:0:0.6">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut"/>
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </TextBlock.Triggers>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- Toggle Switch Button with Smooth Animation -->
	                                                        <Button Command="{Binding ToggleCommand}"
	                                                                ToolTip="{Binding StatusTooltip}"
	                                                                Margin="0,0,10,0"
	                                                                Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
	                                                                    <Grid Width="50" Height="26">
	                                                                        <Border x:Name="Track"
	                                                                                Background="{DynamicResource BackgroundMediumBrush}"
	                                                                                CornerRadius="13"
	                                                                                BorderBrush="{DynamicResource BackgroundLightBrush}"
	                                                                                BorderThickness="1"/>
	                                                                        <Border x:Name="Thumb"
	                                                                                Width="20" Height="20"
	                                                                                CornerRadius="10"
                                                                                Background="{DynamicResource ForegroundLightBrush}"
                                                                                HorizontalAlignment="Left"
                                                                                Margin="3,0,0,0">
                                                                            <Border.RenderTransform>
                                                                                <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                                                            </Border.RenderTransform>
                                                                            <Border.Effect>
                                                                                <DropShadowEffect Color="{DynamicResource ShadowColorSmall}" BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                                                                            </Border.Effect>
                                                                        </Border>
                                                                    </Grid>
                                                                    <ControlTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=EnableCardShadows}" Value="False">
                                                                            <Setter TargetName="Thumb" Property="Effect" Value="{x:Null}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsApplied}" Value="True">
                                                                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ForegroundOnAccentBrush}"/>
	                                                                            <DataTrigger.EnterActions>
	                                                                                <BeginStoryboard>
	                                                                                    <Storyboard>
		                                                                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
		                                                                                                       Storyboard.TargetProperty="X"
	                                                                                                       To="24" Duration="0:0:0.2">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
	                                                                                            </DoubleAnimation.EasingFunction>
	                                                                                        </DoubleAnimation>
	                                                                                    </Storyboard>
	                                                                                </BeginStoryboard>
	                                                                            </DataTrigger.EnterActions>
	                                                                            <DataTrigger.ExitActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
	                                                                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
	                                                                                                       Storyboard.TargetProperty="X"
	                                                                                                       To="0" Duration="0:0:0.2">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
	                                                                                            </DoubleAnimation.EasingFunction>
	                                                                                        </DoubleAnimation>
	                                                                                    </Storyboard>
	                                                                                </BeginStoryboard>
	                                                                            </DataTrigger.ExitActions>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter Property="Opacity" Value="0.5"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                                                                            <!-- Thickness components can't be animated directly; animate the whole Thickness. -->
                                                                            <Setter TargetName="Track" Property="BorderThickness" Value="2"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <!-- Details Expander -->
                                                        <ToggleButton IsChecked="{Binding IsDetailsExpanded}"
                                                                      ToolTip="Show details"
                                                                      Background="Transparent"
                                                                      BorderThickness="0"
                                                                      Cursor="Hand"
                                                                      Padding="6,4">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border x:Name="Border" 
                                                                            Background="{DynamicResource BackgroundMediumBrush}" 
                                                                            CornerRadius="4"
                                                                            Padding="6,4">
                                                                        <TextBlock x:Name="Icon" 
                                                                                   Text="▼" 
                                                                                   FontSize="10" 
                                                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Icon" Property="Text" Value="▲"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                    </StackPanel>

                                                    <!-- Expanded Details: Reference tool inspired rich metadata -->
                                                    <Border Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="2"
                                                            Visibility="{Binding IsDetailsExpanded, Converter={StaticResource BoolToVisibility}}"
                                                            Margin="0,12,0,0"
                                                            Background="{DynamicResource BackgroundMediumBrush}"
                                                            CornerRadius="6"
                                                            Padding="16">
                                                        <StackPanel>
                                                            <!-- Detail Tabs -->
                                                            <UniformGrid Columns="2" Margin="0,0,0,16">
                                                                <ToggleButton IsChecked="{Binding ShowTerminal, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                                                                              Content="Technical Info"
                                                                              Style="{StaticResource TabButtonStyle}"/>
                                                                <ToggleButton IsChecked="{Binding ShowTerminal, Mode=TwoWay}"
                                                                              Content="Execution Log"
                                                                              Style="{StaticResource TabButtonStyle}"/>
                                                            </UniformGrid>

                                                            <!-- Tab View 1: Technical Info -->
                                                            <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource InverseBoolToVisibility}}">
                                                                <!-- Registry Info -->
                                                                <StackPanel Visibility="{Binding HasRegistryPath, Converter={StaticResource BoolToVisibility}}" 
                                                                            Margin="0,0,0,12">
                                                                    <TextBlock Text="Registry Location" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8,6">
                                                                            <TextBlock Text="{Binding RegistryPath}" 
                                                                                       Foreground="{DynamicResource AccentBrightCyanBrush}" 
                                                                                       FontSize="11" 
                                                                                       FontFamily="Consolas"
                                                                                       TextWrapping="Wrap"/>
                                                                        </Border>
                                                                        <Button Grid.Column="1" 
                                                                                Command="{Binding CopyRegistryPathCommand}"
                                                                                Content="📋" 
                                                                                Style="{StaticResource CompactButton}"
                                                                                VerticalAlignment="Stretch"
                                                                                Margin="4,0,0,0"
                                                                                ToolTip="Copy registry path"/>
                                                                    </Grid>
                                                                </StackPanel>

                                                                <!-- Priority Calculator Specialized UI -->
                                                                <StackPanel Visibility="{Binding HasPriorityCalculator, Converter={StaticResource BoolToVisibility}}" 
                                                                            Margin="0,0,0,12">
                                                                    <TextBlock Text="System Priority Calculator" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,8"/>
                                                                    <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="12">
                                                                        <StackPanel>
                                                                            <Grid Margin="0,0,0,10">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Text="{Binding PriorityCalculator.Description}" Foreground="{DynamicResource CautionBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                                                <TextBlock Grid.Column="1" Text="{Binding PriorityCalculator.Bitmask, StringFormat='Value: 0x{0:X2}'}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontFamily="Consolas"/>
                                                                            </Grid>
                                                                            
                                                                            <UniformGrid Columns="3" Margin="0,5">
                                                                                <StackPanel Margin="0,0,10,0">
                                                                                    <TextBlock Text="Length" FontSize="9" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,0,4"/>
                                                                                    <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalLength}" Style="{StaticResource RoundedComboBox}" FontSize="10">
                                                                                        <ComboBoxItem Content="Short (01)" ToolTip="Best for responsiveness"/>
                                                                                        <ComboBoxItem Content="Long (10)" ToolTip="Best for servers"/>
                                                                                    </ComboBox>
                                                                                </StackPanel>
                                                                                <StackPanel Margin="0,0,10,0">
                                                                                    <TextBlock Text="Type" FontSize="9" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,0,4"/>
                                                                                    <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalType}" Style="{StaticResource RoundedComboBox}" FontSize="10">
                                                                                        <ComboBoxItem Content="Variable (01)" ToolTip="Dynamic scheduling"/>
                                                                                        <ComboBoxItem Content="Fixed (10)" ToolTip="Equal priority"/>
                                                                                    </ComboBox>
                                                                                </StackPanel>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="Boost" FontSize="9" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,0,4"/>
                                                                                    <ComboBox SelectedIndex="{Binding PriorityCalculator.Boost}" Style="{StaticResource RoundedComboBox}" FontSize="10">
                                                                                        <ComboBoxItem Content="None (01)"/>
                                                                                        <ComboBoxItem Content="Middle (10)"/>
                                                                                        <ComboBoxItem Content="Maximum (11)"/>
                                                                                    </ComboBox>
                                                                                </StackPanel>
                                                                            </UniformGrid>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Sub-Options -->
                                                                <StackPanel Visibility="{Binding HasSubOptions, Converter={StaticResource BoolToVisibility}}" 
                                                                            Margin="0,0,0,12">
                                                                    <TextBlock Text="Configuration Overrides" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,6"/>
                                                                    <ItemsControl ItemsSource="{Binding SubOptions}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Margin="0,0,0,4">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
                                                                                    <CheckBox Grid.Column="1" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center">
                                                                                        <CheckBox.Style>
                                                                                            <Style TargetType="CheckBox" BasedOn="{StaticResource FilterCheckbox}">
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding Type}" Value="Numeric">
                                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </CheckBox.Style>
                                                                                    </CheckBox>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>

                                                                <!-- Code Example -->
                                                                <StackPanel Visibility="{Binding HasCodeExample, Converter={StaticResource BoolToVisibility}}" 
                                                                            Margin="0,0,0,12">
                                                                    <TextBlock Text="Command Preview" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                                                    <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="12" BorderBrush="{DynamicResource BackgroundDarkBrush}" BorderThickness="1">
                                                                        <TextBlock Text="{Binding CodeExample}" 
                                                                                   Foreground="{DynamicResource SuccessBrush}" 
                                                                                   FontSize="11" 
                                                                                   FontFamily="Consolas"
                                                                                   TextWrapping="Wrap"/>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Batch Details -->
                                                                <StackPanel Visibility="{Binding HasBatchDetails, Converter={StaticResource BoolToVisibility}}" 
                                                                            Margin="0,0,0,12">
                                                                    <TextBlock Text="{Binding BatchDetailsTitle, StringFormat={}{0} Breakdown}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                                                    <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10" BorderBrush="{DynamicResource BackgroundDarkBrush}" BorderThickness="1">
                                                                        <ItemsControl ItemsSource="{Binding BatchDetails}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Reference Links -->
                                                                <StackPanel Visibility="{Binding HasReferenceLinks, Converter={StaticResource BoolToVisibility}}" 
                                                                            Margin="0,0,0,12">
                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                        <TextBlock Text="Documentation &amp; Sources" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                                        <TextBlock Text="?" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource MutedForegroundBrush}" Margin="6,0,0,0"
                                                                                   ToolTip="📚 Catalog • 🧩 Details • 📘 Category • 📄 Source • 🔗 External"/>
                                                                    </StackPanel>
	                                                                    <ItemsControl ItemsSource="{Binding ReferenceLinks}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel Orientation="Horizontal"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
	                                                                        <ItemsControl.ItemTemplate>
	                                                                            <DataTemplate>
	                                                                                    <Button Style="{StaticResource LinkButtonStyle}"
	                                                                                        Margin="0,0,12,4"
	                                                                                        ToolTip="{Binding Tooltip}"
	                                                                                        Command="{Binding DataContext.OpenReferenceLinkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
	                                                                                        CommandParameter="{Binding Url}">
	                                                                                        <StackPanel Orientation="Horizontal">
	                                                                                            <TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,4,0"/>
	                                                                                            <TextBlock Text="{Binding Title}"/>
	                                                                                        </StackPanel>
	                                                                                    </Button>
	                                                                            </DataTemplate>
	                                                                        </ItemsControl.ItemTemplate>
	                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- Tab View 2: Execution Log (Terminal) -->
                                                            <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource BoolToVisibility}}">
                                                                <Border Background="{DynamicResource TerminalBackgroundBrush}" CornerRadius="4" Padding="12" Height="180">
                                                                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                                                                  HorizontalScrollBarVisibility="Disabled">
                                                                        <TextBlock Text="{Binding TerminalOutput, FallbackValue='Execution logs will appear here...'}" 
                                                                                   Foreground="{DynamicResource ForegroundLightBrush}" 
                                                                                   FontSize="11" 
                                                                                   FontFamily="Consolas"
                                                                                   TextWrapping="Wrap"/>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </StackPanel>

                                                            <!-- Shared Actions Footer -->
                                                            <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10" Margin="0,4,0,0">
                                                                <StackPanel>
                                                                    <Grid Margin="0,0,0,8">
                                                                        <StackPanel Orientation="Horizontal">
	                                                                            <Button Content="Detect"
	                                                                                    Command="{Binding DetectCommand}"
	                                                                                    Style="{StaticResource CompactButton}"
	                                                                                    Margin="0,0,6,0"
	                                                                                    ToolTip="Detect: reads current state (no changes)."/>
	                                                                            <Button Content="Preview"
	                                                                                    Command="{Binding PreviewCommand}"
	                                                                                    Style="{StaticResource CompactButton}"
	                                                                                    Margin="0,0,6,0"
	                                                                                    ToolTip="Preview: dry run (no changes)."/>
	                                                                            <Button Content="{Binding ActionButtonText}"
	                                                                                    Command="{Binding ApplyCommand}"
	                                                                                    Style="{StaticResource CompactButton}"
	                                                                                    Background="{DynamicResource AccentDarkBlueBrush}"
                                                                                        Foreground="{DynamicResource ForegroundOnAccentBrush}"
	                                                                                    Margin="0,0,6,0"
	                                                                                    ToolTip="Apply: Detect -> Apply -> Verify (Rollback on failure)."/>
	                                                                            <Button Content="Verify"
	                                                                                    Command="{Binding VerifyCommand}"
	                                                                                    Style="{StaticResource CompactButton}"
	                                                                                    Margin="0,0,6,0"
	                                                                                    ToolTip="Verify: confirms the change took effect (checks current state matches desired)."/>
	                                                                            <Button Content="Rollback"
	                                                                                    Command="{Binding RollbackCommand}"
	                                                                                    Style="{StaticResource CompactButton}"
	                                                                                    Margin="0,0,6,0"
	                                                                                    ToolTip="Rollback: restores value captured by Detect (same app session)."/>
	                                                                            <Button Content="?"
	                                                                                    Style="{StaticResource CompactButton}"
	                                                                                    ToolTip="{Binding ActionsHelpTooltip}"/>
	                                                                        </StackPanel>
                                                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="10">
                                                                            <Run Text="ID:"/> <Run Text="{Binding Id, Mode=OneWay}"/>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                    <Separator Background="{DynamicResource BackgroundDarkBrush}" Margin="0,2,0,8"/>
                                                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" FontStyle="Italic"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Flat High-Performance List View -->
            <ListBox ItemsSource="{Binding TweaksView}"
                     ItemTemplate="{StaticResource TweakItemTemplate}"
                     Visibility="{Binding IsFlatView, Converter={StaticResource BoolToVisibility}}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="24,0,24,24"
                     HorizontalContentAlignment="Stretch"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <!-- Empty State -->
        <Border Grid.Row="1"
                Padding="24"
                Background="{DynamicResource BackgroundDarkBrush}"
                CornerRadius="12"
                Margin="24"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasVisibleTweaks}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="📭" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="No tweaks match your filters"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
