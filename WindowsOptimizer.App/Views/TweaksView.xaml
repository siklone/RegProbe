<UserControl x:Class="WindowsOptimizer.App.Views.TweaksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:WindowsOptimizer.Core;assembly=WindowsOptimizer.Core"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
              xmlns:services="clr-namespace:WindowsOptimizer.App.Services"
              xmlns:converters="clr-namespace:WindowsOptimizer.App.Converters"
              xmlns:utilities="clr-namespace:WindowsOptimizer.App.Utilities"
              xmlns:local="clr-namespace:WindowsOptimizer.App.Views"
              x:Name="TweaksRoot"
              mc:Ignorable="d"
             FontFamily="{DynamicResource FontFamilyText}"
             FontSize="12"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanConverter x:Key="InverseBool" />
        <converters:FirstCharConverter x:Key="FirstCharConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:NestedMarginConverter x:Key="NestedMarginConverter" />
        <converters:StringEmptyToVisibilityConverter x:Key="StringToVisibility" />
        
        <!-- Status Color Converter -->
        <SolidColorBrush x:Key="AppliedBrush" Color="{DynamicResource Nord14}"/>
        <SolidColorBrush x:Key="NotAppliedBrush" Color="{DynamicResource Nord3}"/>
        <SolidColorBrush x:Key="UnknownBrush" Color="{DynamicResource Nord13}"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource Nord11}"/>

        <!-- Risk Badge Styles -->
        <Style x:Key="RiskBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Safe}">
                    <Setter Property="Background" Value="{DynamicResource SuccessSurfaceBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Advanced}">
                    <Setter Property="Background" Value="{DynamicResource CautionSurfaceBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Risky}">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="{DynamicResource AccentBrightCyan10}"/>
        <SolidColorBrush x:Key="AccentBrightCyan10Brush" Color="{DynamicResource AccentBrightCyan10}"/>
        <SolidColorBrush x:Key="AccentBrightCyan20Brush" Color="{DynamicResource AccentBrightCyan20}"/>

        <LinearGradientBrush x:Key="TweakPanelGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{DynamicResource Nord1}" Offset="0"/>
            <GradientStop Color="{DynamicResource Nord0}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TweakStatCardGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{DynamicResource Nord2}" Offset="0"/>
            <GradientStop Color="{DynamicResource Nord3}" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="TweakStatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource TweakStatCardGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <!-- Preset Card Style (Merged from PresetsView) -->
        <Style x:Key="PresetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ShadowColorSmall}"
                                    BlurRadius="12"
                                    ShadowDepth="4"
                                    Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TweakStatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
        </Style>

        <Style x:Key="TweakStatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <Style x:Key="CatalogCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Width" Value="300"/>
            <Setter Property="MinHeight" Value="170"/>
        </Style>

        <Style x:Key="PolicyReferenceCardStyle" TargetType="Border" BasedOn="{StaticResource CatalogCardStyle}">
            <Setter Property="MinHeight" Value="254"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>

        <Style x:Key="PolicyReferenceInfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkestBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
        </Style>

        <Style x:Key="ConfigInlineStatChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppChipSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>

        <Style x:Key="TweakInsightCardStyle" TargetType="Border" BasedOn="{StaticResource PolicyReferenceInfoCardStyle}">
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="ServiceManagementListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{DynamicResource AppInsetSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="10,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppWorkspaceHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ShellTopNavHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ServiceManagementDetailCardStyle" TargetType="Border" BasedOn="{StaticResource PolicyReferenceInfoCardStyle}">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <converters:EnumToBooleanConverter x:Key="EnumToBool" />
        <converters:TabToVisibilityConverter x:Key="TabToVis" />

        <!-- Toggle Switch Style -->
        <Style x:Key="TweakToggleStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="50" Height="26" Cursor="Hand">
                            <Border x:Name="Track" 
                                    Background="{DynamicResource BackgroundMediumBrush}" 
                                    CornerRadius="13"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"/>
	                            <Border x:Name="Thumb" 
	                                    Width="20" Height="20" 
	                                    CornerRadius="10"
	                                    Background="{DynamicResource ForegroundLightBrush}"
	                                    HorizontalAlignment="Left"
	                                    Margin="3,0,0,0">
	                                <Border.RenderTransform>
	                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
	                                </Border.RenderTransform>
	                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ForegroundOnAccentBrush}"/>
                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
	                                                           Storyboard.TargetProperty="X"
	                                                           To="24" Duration="0:0:0.15">
	                                                <DoubleAnimation.EasingFunction>
	                                                    <QuadraticEase EasingMode="EaseOut"/>
	                                                </DoubleAnimation.EasingFunction>
	                                            </DoubleAnimation>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
	                                                           Storyboard.TargetProperty="X"
	                                                           To="0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
	                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- Compact Button Style with Smooth Animations -->
	        <Style x:Key="CompactButton" TargetType="Button">
	            <Setter Property="Background" Value="{DynamicResource AppQuietButtonBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
	            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
	            <Setter Property="BorderThickness" Value="1"/>
	            <Setter Property="Padding" Value="10,5"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="MinHeight" Value="28"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
		                        <Border x:Name="Border"
		                                Background="{TemplateBinding Background}"
		                                BorderBrush="{TemplateBinding BorderBrush}"
		                                BorderThickness="{TemplateBinding BorderThickness}"
		                                CornerRadius="8"
		                                RenderTransformOrigin="0.5,0.5">
			                            <Border.RenderTransform>
			                                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1"/>
			                            </Border.RenderTransform>
		                            <Grid>
		                                <Border x:Name="HoverOverlay"
		                                        Background="{DynamicResource AppQuietButtonHoverBrush}"
	                                        CornerRadius="8"
	                                        Opacity="0"
	                                        IsHitTestVisible="False"/>
	                                <ContentPresenter HorizontalAlignment="Center"
	                                                  VerticalAlignment="Center"
	                                                  Margin="{TemplateBinding Padding}"/>
	                            </Grid>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsMouseOver" Value="True">
	                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="1" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
                            </Trigger>
		                            <Trigger Property="IsPressed" Value="True">
		                                <Trigger.EnterActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.EnterActions>
		                                <Trigger.ExitActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TweakActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButton}">
            <Setter Property="MinWidth" Value="72"/>
        </Style>

        <Style x:Key="TweakPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TweakActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                    <Setter Property="Background" Value="{DynamicResource SuccessSurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WorkspaceModeButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource AppWorkspaceSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppWorkspaceHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ShellTopNavHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppWorkspaceSelectedBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTabToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource WorkspaceModeButtonStyle}">
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
        </Style>

        <!-- Filter Bar Button with Smooth Animations -->
	        <Style x:Key="FilterButton" TargetType="Button">
	            <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
	            <Setter Property="BorderThickness" Value="0"/>
	            <Setter Property="Padding" Value="11,6"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="FontWeight" Value="Medium"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
		                        <Border x:Name="Border"
		                                Background="{TemplateBinding Background}"
		                                CornerRadius="8"
		                                RenderTransformOrigin="0.5,0.5">
			                            <Border.RenderTransform>
			                                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1"/>
			                            </Border.RenderTransform>
		                            <Grid>
		                                <Border x:Name="HoverOverlay"
		                                        Background="{DynamicResource AccentBlueBrush}"
	                                        CornerRadius="8"
	                                        Opacity="0"
	                                        IsHitTestVisible="False"/>
	                                <ContentPresenter HorizontalAlignment="Center"
	                                                  VerticalAlignment="Center"
	                                                  Margin="{TemplateBinding Padding}"/>
	                            </Grid>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsMouseOver" Value="True">
	                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="1" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
                            </Trigger>
		                            <Trigger Property="IsPressed" Value="True">
		                                <Trigger.EnterActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.EnterActions>
		                                <Trigger.ExitActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.ExitActions>
		                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Box Style -->
	        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
	            <Setter Property="Background" Value="{DynamicResource AppSearchSurfaceBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
	            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
	            <Setter Property="BorderThickness" Value="1"/>
	            <Setter Property="Padding" Value="12,0"/>
	            <Setter Property="FontSize" Value="12"/>
	            <Setter Property="Height" Value="34"/>
	            <Setter Property="VerticalContentAlignment" Value="Center"/>
	            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
	            <Setter Property="Template">
	                <Setter.Value>
	                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="{TemplateBinding Padding}"/>
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="10,0,10,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SearchRoot" Property="BorderBrush" Value="{DynamicResource ShellTopNavSelectedBorderBrush}"/>
                                <Setter TargetName="SearchRoot" Property="Background" Value="{DynamicResource AppQuietButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

	        <!-- Filter Checkbox -->
        <Style x:Key="FilterCheckbox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                                <Border x:Name="Pill"
                                Background="{DynamicResource AppWorkspaceSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="11,6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource AppWorkspaceHoverBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource ShellTopNavHoverBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource AppWorkspaceSelectedBorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Safe"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource SuccessSurfaceBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Advanced"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource CautionSurfaceBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Risky"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource DangerSurfaceBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Favorites"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource AppWorkspaceSelectedBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource AppWorkspaceSelectedBorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
	        </Style>

        <Style x:Key="SelectionCheckboxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="18" Height="18">
                            <Border x:Name="Box"
                                    Background="{DynamicResource AppSelectionBoxBrush}"
                                    BorderBrush="{DynamicResource AppSelectionBoxBorderBrush}"
                                    BorderThickness="1.2"
                                    CornerRadius="5"/>
                            <Path x:Name="Tick"
                                  Data="M 4 9 L 7.1 12.2 L 14 5.2"
                                  Stroke="{DynamicResource AppSelectionCheckBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AppSelectionBoxHoverBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AppSelectionBoxHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AppSelectionBoxCheckedBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AppSelectionBoxCheckedBorderBrush}"/>
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="Tick" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category Sidebar Styles -->
