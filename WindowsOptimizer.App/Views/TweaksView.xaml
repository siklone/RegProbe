<UserControl x:Class="WindowsOptimizer.App.Views.TweaksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:WindowsOptimizer.Core;assembly=WindowsOptimizer.Core"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="TweakCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E3E5E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="BorderBrush" Value="#F0B429" />
                    <Setter Property="Background" Value="#FFFCF2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RiskBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="#E8EEF6" />
            <Setter Property="BorderBrush" Value="#C9D5E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Safe}">
                    <Setter Property="Background" Value="#E8F5E9" />
                    <Setter Property="BorderBrush" Value="#B6E2C2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Advanced}">
                    <Setter Property="Background" Value="#FFF5E5" />
                    <Setter Property="BorderBrush" Value="#F6D6A8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Risky}">
                    <Setter Property="Background" Value="#FDECEC" />
                    <Setter Property="BorderBrush" Value="#F1B9B9" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StepIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#B9BDC6" />
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.InProgress}">
                    <Setter Property="Fill" Value="#F0B429" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Success}">
                    <Setter Property="Fill" Value="#4CAF50" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Failed}">
                    <Setter Property="Fill" Value="#D64545" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Skipped}">
                    <Setter Property="Fill" Value="#7A7F87" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.NotApplicable}">
                    <Setter Property="Fill" Value="#7A7F87" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OutcomeBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="#EEF1F4" />
            <Setter Property="BorderBrush" Value="#D3D8DE" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding LastOutcome}" Value="{x:Static viewModels:TweakRunOutcome.InProgress}">
                    <Setter Property="Background" Value="#FFF5E5" />
                    <Setter Property="BorderBrush" Value="#F6D6A8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastOutcome}" Value="{x:Static viewModels:TweakRunOutcome.Success}">
                    <Setter Property="Background" Value="#E8F5E9" />
                    <Setter Property="BorderBrush" Value="#B6E2C2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastOutcome}" Value="{x:Static viewModels:TweakRunOutcome.Failed}">
                    <Setter Property="Background" Value="#FDECEC" />
                    <Setter Property="BorderBrush" Value="#F1B9B9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastOutcome}" Value="{x:Static viewModels:TweakRunOutcome.Cancelled}">
                    <Setter Property="Background" Value="#EFE7FF" />
                    <Setter Property="BorderBrush" Value="#D6C7F4" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastOutcome}" Value="{x:Static viewModels:TweakRunOutcome.Skipped}">
                    <Setter Property="Background" Value="#EEF1F4" />
                    <Setter Property="BorderBrush" Value="#C7CCD4" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,0"
                           Text="Preview runs are DryRun by default. Use Apply to execute a tweak and Verify/Rollback for follow-up actions."
                           Foreground="#4B4B4B"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding ExportStatusMessage}"
                           Foreground="#8A8D93"
                           FontSize="11" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding BulkStatusMessage}"
                           Foreground="#8A8D93"
                           FontSize="11" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding BulkProgressText}"
                           Foreground="#8A8D93"
                           FontSize="11" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding BulkTargetSummary}"
                           Foreground="#8A8D93"
                           FontSize="11" />
                <ProgressBar Height="6"
                             Margin="0,4,0,0"
                             Minimum="0"
                             Maximum="{Binding BulkProgressTotal}"
                             Value="{Binding BulkProgressCurrent}"
                             Visibility="{Binding HasBulkProgress, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding FilterSummary}"
                           Foreground="#8A8D93"
                           FontSize="11" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding RiskSummary}"
                           Foreground="#8A8D93"
                           FontSize="11" />
                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                    <CheckBox Content="Safe"
                              IsChecked="{Binding ShowSafe}"
                              ToolTip="Show safe tweaks."
                              Margin="0,0,12,0" />
                    <CheckBox Content="Advanced"
                              IsChecked="{Binding ShowAdvanced}"
                              ToolTip="Show advanced tweaks."
                              Margin="0,0,12,0" />
                    <CheckBox Content="Risky"
                              IsChecked="{Binding ShowRisky}"
                              ToolTip="Show risky tweaks."
                              Margin="0,0,12,0" />
                    <CheckBox Content="Only Failed"
                              IsChecked="{Binding ShowOnlyFailed}"
                              ToolTip="Show only failed tweaks."
                              Margin="0,0,12,0" />
                    <CheckBox Content="Only Running"
                              IsChecked="{Binding ShowOnlyRunning}"
                              ToolTip="Show only running tweaks."
                              Margin="0,0,12,0" />
                    <CheckBox Content="Only Succeeded"
                              IsChecked="{Binding ShowOnlySucceeded}"
                              ToolTip="Show only successful tweaks."
                              Margin="0,0,12,0" />
                    <CheckBox Content="Failed First"
                              IsChecked="{Binding SortFailedFirst}"
                              ToolTip="Sort failed tweaks to the top."
                              Margin="0,0,12,0" />
                    <Button Content="Reset Filters"
                            Command="{Binding ResetFiltersCommand}"
                            Padding="10,2" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="12,6,0,0">
                <Button Content="Detect All"
                        Command="{Binding DetectAllCommand}"
                        ToolTip="Run detection for all visible tweaks."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Preview All"
                        Command="{Binding PreviewAllCommand}"
                        ToolTip="Preview (DryRun) all visible tweaks."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Apply All"
                        Command="{Binding ApplyAllCommand}"
                        ToolTip="Apply all visible tweaks."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Verify All"
                        Command="{Binding VerifyAllCommand}"
                        ToolTip="Verify all visible tweaks."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Rollback All"
                        Command="{Binding RollbackAllCommand}"
                        ToolTip="Rollback all visible tweaks."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Cancel All"
                        Command="{Binding CancelAllCommand}"
                        ToolTip="Cancel the current bulk run."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Clear Results"
                        Command="{Binding ResetAllCommand}"
                        ToolTip="Clear all tweak status cards."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Expand Details"
                        Command="{Binding ExpandAllDetailsCommand}"
                        ToolTip="Expand details for all tweaks."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Collapse Details"
                        Command="{Binding CollapseAllDetailsCommand}"
                        ToolTip="Collapse details for all tweaks."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Open Log Folder"
                        Command="{Binding OpenLogFolderCommand}"
                        ToolTip="Open the log folder."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Open App Log"
                        Command="{Binding OpenAppLogCommand}"
                        ToolTip="Open the app log file."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Copy App Log Path"
                        Command="{Binding CopyAppLogPathCommand}"
                        ToolTip="Copy the app log path."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Open CSV Log"
                        Command="{Binding OpenCsvLogCommand}"
                        ToolTip="Open the tweak log CSV file."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Copy CSV Path"
                        Command="{Binding CopyCsvPathCommand}"
                        ToolTip="Copy the tweak log CSV path."
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Export Logs"
                        Command="{Binding ExportLogsCommand}"
                        ToolTip="Export tweak logs to CSV."
                        Padding="12,6" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
            <Grid>
                <ItemsControl ItemsSource="{Binding TweaksView}"
                              Visibility="{Binding HasVisibleTweaks, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource TweakCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                        <Border Style="{StaticResource RiskBadgeStyle}" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Risk}" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Style="{StaticResource OutcomeBadgeStyle}"
                                                Margin="10,0,0,0"
                                                Visibility="{Binding HasOutcome, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding OutcomeSummary}" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Detect"
                                            Command="{Binding DetectCommand}"
                                            ToolTip="Detect current configuration."
                                            Padding="12,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Preview"
                                            Command="{Binding PreviewCommand}"
                                            ToolTip="Preview the tweak (DryRun)."
                                            Padding="12,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Apply"
                                            Command="{Binding ApplyCommand}"
                                            ToolTip="Apply the tweak."
                                            Padding="12,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Verify"
                                            Command="{Binding VerifyCommand}"
                                            ToolTip="Verify the tweak."
                                            Padding="12,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Rollback"
                                            Command="{Binding RollbackCommand}"
                                            ToolTip="Rollback the tweak."
                                            Padding="12,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Cancel"
                                            Command="{Binding CancelCommand}"
                                            ToolTip="Cancel the current run."
                                            Padding="12,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Reset"
                                            Command="{Binding ResetCommand}"
                                            ToolTip="Clear this tweak's status."
                                            Padding="12,4" />
                                </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                        <ProgressBar Height="4"
                                                     Margin="0,0,0,8"
                                                     IsIndeterminate="True"
                                                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}" />
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#4B4B4B"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Id}"
                                                       Foreground="#8A8D93"
                                                       FontSize="10"
                                                       VerticalAlignment="Center" />
                                            <Button Content="Copy ID"
                                                    Command="{Binding CopyIdCommand}"
                                                    Padding="6,1"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Expander Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              Margin="0,12,0,0"
                                              IsExpanded="{Binding IsDetailsExpanded}"
                                              Header="Details">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding Steps}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="4" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,12,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Style="{StaticResource StepIndicatorStyle}" Margin="0,3,6,0" />
                                                                <TextBlock Text="{Binding ActionLabel}" FontSize="12" FontWeight="SemiBold" />
                                                            </StackPanel>
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="{Binding StatusText}"
                                                                       Foreground="#5B606A"
                                                                       FontSize="11" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="{Binding Message}"
                                                                       Foreground="#8A8D93"
                                                                       FontSize="10"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="{Binding TimestampText}"
                                                                       Foreground="#A6A8AF"
                                                                       FontSize="10" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding StatusMessage}" Foreground="#4B4B4B" />
                                            <TextBlock Text=" - " Foreground="#A6A8AF" Margin="6,0" />
                                            <TextBlock Text="{Binding LastUpdatedText}" Foreground="#8A8D93" />
                                            <TextBlock Text=" - " Foreground="#A6A8AF" Margin="6,0" />
                                            <TextBlock Text="{Binding LastDurationText}" Foreground="#8A8D93" />
                                            <TextBlock Text=" - " Foreground="#A6A8AF" Margin="6,0" />
                                            <TextBlock Text="{Binding StepProgressText}" Foreground="#8A8D93" />
                                            <TextBlock Text=" - " Foreground="#A6A8AF" Margin="6,0" />
                                            <TextBlock Text="{Binding RunCount, StringFormat=Runs: {0}}" Foreground="#8A8D93" />
                                        </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Padding="24"
                        Background="#FAFAFB"
                        BorderBrush="#E3E5E8"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleTweaks}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="No tweaks match your filters."
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Clear the search or enable more risk levels to see results."
                                   Foreground="#6B6F76"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
