<UserControl x:Class="WindowsOptimizer.App.Views.TweaksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:WindowsOptimizer.Core;assembly=WindowsOptimizer.Core"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
              xmlns:services="clr-namespace:WindowsOptimizer.App.Services"
              xmlns:converters="clr-namespace:WindowsOptimizer.App.Converters"
              xmlns:local="clr-namespace:WindowsOptimizer.App.Views"
              x:Name="TweaksRoot"
              mc:Ignorable="d"
             FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
             FontSize="12"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanConverter x:Key="InverseBool" />
        <converters:FirstCharConverter x:Key="FirstCharConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:NestedMarginConverter x:Key="NestedMarginConverter" />
        <converters:StringEmptyToVisibilityConverter x:Key="StringToVisibility" />
        
        <!-- Status Color Converter -->
        <SolidColorBrush x:Key="AppliedBrush" Color="{DynamicResource Nord14}"/>
        <SolidColorBrush x:Key="NotAppliedBrush" Color="{DynamicResource Nord3}"/>
        <SolidColorBrush x:Key="UnknownBrush" Color="{DynamicResource Nord13}"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource Nord11}"/>

        <!-- Risk Badge Styles -->
        <Style x:Key="RiskBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Safe}">
                    <Setter Property="Background" Value="{DynamicResource SuccessSurfaceBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Advanced}">
                    <Setter Property="Background" Value="{DynamicResource CautionSurfaceBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="{x:Static core:TweakRiskLevel.Risky}">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="{DynamicResource AccentBrightCyan10}"/>
        <SolidColorBrush x:Key="AccentBrightCyan10Brush" Color="{DynamicResource AccentBrightCyan10}"/>
        <SolidColorBrush x:Key="AccentBrightCyan20Brush" Color="{DynamicResource AccentBrightCyan20}"/>

        <LinearGradientBrush x:Key="TweakPanelGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{DynamicResource Nord1}" Offset="0"/>
            <GradientStop Color="{DynamicResource Nord2}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TweakStatCardGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{DynamicResource Nord2}" Offset="0"/>
            <GradientStop Color="{DynamicResource Nord3}" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="TweakStatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource TweakStatCardGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>

        <!-- Preset Card Style (Merged from PresetsView) -->
        <Style x:Key="PresetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ShadowColorSmall}"
                                    BlurRadius="12"
                                    ShadowDepth="4"
                                    Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TweakStatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
        </Style>

        <Style x:Key="TweakStatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <converters:EnumToBooleanConverter x:Key="EnumToBool" />
        <converters:TabToVisibilityConverter x:Key="TabToVis" />

        <!-- Toggle Switch Style -->
        <Style x:Key="TweakToggleStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="50" Height="26" Cursor="Hand">
                            <Border x:Name="Track" 
                                    Background="{DynamicResource BackgroundMediumBrush}" 
                                    CornerRadius="13"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"/>
	                            <Border x:Name="Thumb" 
	                                    Width="20" Height="20" 
	                                    CornerRadius="10"
	                                    Background="{DynamicResource ForegroundLightBrush}"
	                                    HorizontalAlignment="Left"
	                                    Margin="3,0,0,0">
	                                <Border.RenderTransform>
	                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
	                                </Border.RenderTransform>
	                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ForegroundOnAccentBrush}"/>
                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
	                                                           Storyboard.TargetProperty="X"
	                                                           To="24" Duration="0:0:0.15">
	                                                <DoubleAnimation.EasingFunction>
	                                                    <QuadraticEase EasingMode="EaseOut"/>
	                                                </DoubleAnimation.EasingFunction>
	                                            </DoubleAnimation>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
	                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
	                                                           Storyboard.TargetProperty="X"
	                                                           To="0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
	                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- Compact Button Style with Smooth Animations -->
	        <Style x:Key="CompactButton" TargetType="Button">
	            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
	            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
	            <Setter Property="BorderThickness" Value="1"/>
	            <Setter Property="Padding" Value="10,5"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="MinHeight" Value="30"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
		                        <Border x:Name="Border"
		                                Background="{TemplateBinding Background}"
		                                BorderBrush="{TemplateBinding BorderBrush}"
		                                BorderThickness="{TemplateBinding BorderThickness}"
		                                CornerRadius="7"
		                                RenderTransformOrigin="0.5,0.5">
			                            <Border.RenderTransform>
			                                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1"/>
			                            </Border.RenderTransform>
		                            <Grid>
		                                <Border x:Name="HoverOverlay"
		                                        Background="{DynamicResource BackgroundLightBrush}"
                                        CornerRadius="7"
	                                        Opacity="0"
	                                        IsHitTestVisible="False"/>
	                                <ContentPresenter HorizontalAlignment="Center"
	                                                  VerticalAlignment="Center"
	                                                  Margin="{TemplateBinding Padding}"/>
	                            </Grid>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsMouseOver" Value="True">
	                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="1" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
                            </Trigger>
		                            <Trigger Property="IsPressed" Value="True">
		                                <Trigger.EnterActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.EnterActions>
		                                <Trigger.ExitActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TweakActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButton}">
            <Setter Property="MinWidth" Value="72"/>
        </Style>

        <Style x:Key="TweakPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TweakActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Applied}">
                    <Setter Property="Background" Value="{DynamicResource SuccessSurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding AppliedStatus}" Value="{x:Static viewModels:TweakAppliedStatus.Error}">
                    <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Filter Bar Button with Smooth Animations -->
	        <Style x:Key="FilterButton" TargetType="Button">
	            <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
	            <Setter Property="BorderThickness" Value="0"/>
	            <Setter Property="Padding" Value="11,6"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="FontWeight" Value="Medium"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
		                        <Border x:Name="Border"
		                                Background="{TemplateBinding Background}"
		                                CornerRadius="6"
		                                RenderTransformOrigin="0.5,0.5">
			                            <Border.RenderTransform>
			                                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1"/>
			                            </Border.RenderTransform>
		                            <Grid>
		                                <Border x:Name="HoverOverlay"
		                                        Background="{DynamicResource AccentBlueBrush}"
	                                        CornerRadius="6"
	                                        Opacity="0"
	                                        IsHitTestVisible="False"/>
	                                <ContentPresenter HorizontalAlignment="Center"
	                                                  VerticalAlignment="Center"
	                                                  Margin="{TemplateBinding Padding}"/>
	                            </Grid>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsMouseOver" Value="True">
	                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="1" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.EnterActions>
	                                <Trigger.ExitActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
		                                                           Storyboard.TargetProperty="Opacity"
		                                                           To="0" Duration="0:0:0.15"/>
	                                        </Storyboard>
	                                    </BeginStoryboard>
	                                </Trigger.ExitActions>
                            </Trigger>
		                            <Trigger Property="IsPressed" Value="True">
		                                <Trigger.EnterActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="0.95" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.EnterActions>
		                                <Trigger.ExitActions>
		                                    <BeginStoryboard>
		                                        <Storyboard>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleX"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
		                                                           Storyboard.TargetProperty="ScaleY"
		                                                           To="1.0" Duration="0:0:0.05"/>
		                                        </Storyboard>
		                                    </BeginStoryboard>
		                                </Trigger.ExitActions>
		                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Box Style -->
	        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
	            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
	            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
	            <Setter Property="BorderThickness" Value="1"/>
	            <Setter Property="Padding" Value="10,0"/>
	            <Setter Property="FontSize" Value="12"/>
	            <Setter Property="Height" Value="32"/>
	            <Setter Property="VerticalContentAlignment" Value="Center"/>
	            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
	            <Setter Property="Template">
	                <Setter.Value>
	                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="{TemplateBinding Padding}"/>
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="12,0,12,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SearchRoot" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

	        <!-- Filter Checkbox -->
	        <Style x:Key="FilterCheckbox" TargetType="CheckBox">
	            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="Pill"
                                    Background="{DynamicResource BackgroundDarkBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="9,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource SuccessSurfaceBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Safe"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource SuccessSurfaceBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Advanced"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource CautionSurfaceBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource CautionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource CautionBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Risky"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource DangerSurfaceBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="Favorites"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </MultiDataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
	        </Style>

        <!-- Category Sidebar Styles -->
        <Style x:Key="CategoryAllButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAllCategoriesSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="AccentBar"
                                        Width="4"
                                        Background="{DynamicResource AccentBrightCyanBrush}"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        Margin="0,2,0,2"
                                        Opacity="0"/>
                                <ContentPresenter Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="0.35"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Link Button Style -->
	        <Style x:Key="LinkButtonStyle" TargetType="Button">
	            <Setter Property="Background" Value="Transparent"/>
	            <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
	            <Setter Property="BorderThickness" Value="0,0,0,1"/>
	            <Setter Property="BorderBrush" Value="Transparent"/>
	            <Setter Property="Padding" Value="0,1"/>
	            <Setter Property="FontSize" Value="11"/>
	            <Setter Property="Cursor" Value="Hand"/>
	            <Setter Property="HorizontalContentAlignment" Value="Left"/>
	            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
	            <Setter Property="Template">
	                <Setter.Value>
	                    <ControlTemplate TargetType="Button">
	                        <Border Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
	                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
	                        </Border>
	                    </ControlTemplate>
	                </Setter.Value>
	            </Setter>
	        <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsChecked" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Rounded ComboBox Style -->
        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <ToggleButton Name="ToggleButton" 
                                              Background="Transparent" 
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter Name="ContentSite" 
                                                  IsHitTestVisible="False" 
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="5,3,23,3"
                                                  VerticalAlignment="Center"/>
                                <Path Name="Arrow" 
                                      Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 Z" 
                                      Fill="{DynamicResource AccentDarkBlueBrush}" 
                                      HorizontalAlignment="Right" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,8,0"/>
                                <Popup Name="Popup" 
                                       Placement="Bottom" 
                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                       AllowsTransparency="True" 
                                       Focusable="False" 
                                       PopupAnimation="Slide">
                                    <Border Name="DropDownBorder" 
                                            Background="{DynamicResource BackgroundDarkBrush}" 
                                            BorderBrush="{DynamicResource GlassBorderBrush}"
                                            BorderThickness="1" 
                                            CornerRadius="4">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Main Tab Button Style (Top-Level Tabs) -->
        <Style x:Key="MainTabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrightCyan10Brush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrightCyan20Brush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMainTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid ClipToBounds="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TabPanel x:Name="HeaderPanel"
                                      Grid.Row="0"
                                      IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="0,0,0,6"
                                      ClipToBounds="False"
                                      Panel.ZIndex="1"/>

                            <Border Grid.Row="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMainTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Margin="{TemplateBinding Margin}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="HeaderContent"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentBrightCyan10Brush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentBrightCyan20Brush}"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        

        <!-- Recursive Category Template -->

        <!-- Expander Button Style -->
        <Style x:Key="ExpanderButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
	                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" Padding="4">
                            <TextBlock x:Name="Icon" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" RenderTransformOrigin="0.5,0.5">
	                                <TextBlock.RenderTransform>
	                                    <RotateTransform x:Name="IconRotate" Angle="0"/>
	                                </TextBlock.RenderTransform>
	                            </TextBlock>
	                        </Border>
	                        <ControlTemplate.Triggers>
	                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
	                                    <BeginStoryboard>
	                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconRotate" 
                                                           Storyboard.TargetProperty="Angle"
                                                           To="90" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconRotate" 
                                                           Storyboard.TargetProperty="Angle"
                                                           To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tweak Item Template -->
        <DataTemplate x:Key="TweakItemTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
            <Border Background="{DynamicResource BackgroundDarkBrush}" 
                    CornerRadius="8" 
                    Margin="0,0,0,5" 
                    Padding="10,6"
                    BorderThickness="1"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="CardTranslate" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 From="4" To="0" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="{DynamicResource ShadowColorSmall}" BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=EnableCardShadows}" Value="False">
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=IsCompactMode}" Value="True">
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="Margin" Value="0,0,0,5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource CautionBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <StackPanel>
                    <!-- Main Card content (simplified for brevity here, actual will have full details) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Checkbox -->
                            <ColumnDefinition Width="Auto"/>  <!-- Status -->
                            <ColumnDefinition Width="*"/>     <!-- Content -->
                            <ColumnDefinition Width="Auto"/>  <!-- Actions -->
                        </Grid.ColumnDefinitions>

                        <!-- Selection Checkbox -->
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsSelected}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  ToolTip="Select for batch operations">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>

                        <!-- Status Indicator - Compact -->
                        <Border Grid.Column="1"
	                                Width="18"
	                                Height="18"
	                                CornerRadius="9"
	                                Margin="0,0,6,0"
	                                Background="Transparent"
                                    BorderBrush="{Binding StatusColor}"
                                    BorderThickness="1"
	                                ToolTip="{Binding StatusTooltip}">
	                             <TextBlock Text="{Binding StatusIcon}"
                                               Foreground="{Binding StatusColor}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
	                        </Border>

	                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" FontSize="13"/>
                                <Border Background="{Binding StatusBadgeBackground}"
                                        BorderBrush="{Binding StatusColor}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="5,1"
                                        Margin="6,0,0,0"
                                        ToolTip="{Binding StatusTooltip}">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusColor}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Border Background="{DynamicResource SuccessBrush}" 
                                        CornerRadius="3" 
                                        Padding="5,1" 
                                        Margin="6,0,0,0"
                                        Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibility}}"
                                        ToolTip="{Binding RecommendationReason}">
                                    <TextBlock Text="REC" 
                                               Foreground="{DynamicResource ForegroundOnLightAccentBrush}" 
                                               FontSize="10" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
	                                </Border>
	                            </StackPanel>
	                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,0,0,1" ToolTip="{Binding Description}" LineHeight="14"/>
	                            <Grid Margin="0,1,0,0"
	                                  Visibility="{Binding HasCompactInfoLine, Converter={StaticResource BoolToVisibility}}"
	                                  ToolTip="{Binding CompactInfoTooltip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource BackgroundMediumBrush}"
                                            BorderBrush="{DynamicResource GlassBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="4,0"
                                            Margin="0,0,5,0">
                                        <TextBlock Text="{Binding ImpactAreaLabel}"
                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"/>
                                    </Border>
	                                <TextBlock Grid.Column="1"
	                                           Text="{Binding CompactInfoLine}"
	                                           Foreground="{DynamicResource ForegroundLightBrush}"
	                                           FontSize="11"
	                                           FontFamily="Consolas"
	                                           Opacity="0.85"
	                                           TextTrimming="CharacterEllipsis"/>
	                            </Grid>
                                <TextBlock Text="{Binding BatchSummaryLine}"
                                           Visibility="{Binding HasBatchSummaryLine, Converter={StaticResource BoolToVisibility}}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           FontSize="10"
                                           Margin="0,1,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding InventoryFreshnessText}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           FontSize="10"
                                           Margin="0,1,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Before/After Snapshot Comparison - Compact -->
                                <Border Visibility="{Binding HasStateChange, Converter={StaticResource BoolToVisibility}}"
                                        Background="{DynamicResource BackgroundMediumBrush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="0,3,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Before -->
                                        <TextBlock Grid.Column="0"
                                                   Text="Before:"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   Margin="0,0,4,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BeforeState}"
                                                   FontSize="10"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,12,0"/>

                                        <!-- After -->
                                        <TextBlock Grid.Column="2"
                                                   Text="After:"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   Margin="0,0,4,0"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding AfterState}"
                                                   FontSize="10"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
	                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                             <!-- Favorite Button -->
                             <Button Command="{Binding ToggleFavoriteCommand}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Cursor="Hand"
                                     Padding="4,2"
                                     ToolTip="Toggle favorite">
                                 <Button.Style>
                                     <Style TargetType="Button">
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                         <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                     </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                     </Style>
                                 </Button.Style>
                                 <TextBlock Text="{Binding FavoriteIcon}" FontSize="14">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock">
                                             <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                     <Setter Property="Foreground" Value="{DynamicResource CautionBrush}"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                 </TextBlock>
                             </Button>
                             <ToggleButton IsChecked="{Binding IsDetailsExpanded}" Style="{StaticResource ExpanderButtonStyle}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Expanded Details Area -->
                    <Border Margin="0,8,0,0"
                            Background="Transparent"
                            ClipToBounds="True"
                            RenderTransformOrigin="0.5,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="MaxHeight" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                     To="2000" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                     To="0" Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                         <!-- Detail Tabs -->
                         <UniformGrid Columns="2" Margin="0,0,0,10">
                             <ToggleButton IsChecked="{Binding ShowTerminal, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                                           Content="Technical Info"
                                           Style="{StaticResource TabButtonStyle}"/>
                             <ToggleButton IsChecked="{Binding ShowTerminal, Mode=TwoWay}"
                                           Content="Execution Log"
                                           Style="{StaticResource TabButtonStyle}"/>
                         </UniformGrid>

                         <!-- Tab View 1: Technical Info -->
                         <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource InverseBoolToVisibility}}">
                             <!-- Registry Info -->
                             <StackPanel Visibility="{Binding HasRegistryPath, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="Registry Location" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Grid>
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8,5">
                                         <TextBlock Text="{Binding RegistryPath}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                     </Border>
                                     <Button Grid.Column="1" Command="{Binding CopyRegistryPathCommand}" Content="Copy" Style="{StaticResource CompactButton}" Margin="4,0,0,0"/>
                                 </Grid>
                             </StackPanel>

                             <!-- Registry Diff -->
                             <StackPanel Visibility="{Binding HasDiff, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="Registry Value Comparison" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <UniformGrid Columns="2">
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4,0,0,4" Padding="8,6" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1,1,0,1">
                                         <StackPanel>
                                              <TextBlock Text="CURRENT" FontSize="10" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" Margin="0,0,0,2"/>
                                              <TextBlock Text="{Binding CurrentValue}" Foreground="{DynamicResource CautionBrush}" FontSize="11" FontFamily="Consolas"/>
                                         </StackPanel>
                                     </Border>
                                     <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="0,4,4,0" Padding="8,6" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                                         <StackPanel>
                                              <TextBlock Text="TARGET" FontSize="10" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" Margin="0,0,0,2"/>
                                              <TextBlock Text="{Binding TargetValue}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontFamily="Consolas"/>
                                         </StackPanel>
                                     </Border>
                                 </UniformGrid>
                             </StackPanel>

                             <!-- Batch Details -->
                             <StackPanel Visibility="{Binding HasBatchDetails, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="{Binding BatchDetailsTitle, StringFormat={}{0} Breakdown}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8">
                                     <ItemsControl ItemsSource="{Binding BatchDetails}">
                                         <ItemsControl.ItemTemplate>
                                             <DataTemplate>
                                                 <TextBlock Text="{Binding}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" TextWrapping="Wrap"/>
                                             </DataTemplate>
                                         </ItemsControl.ItemTemplate>
                                     </ItemsControl>
                                 </Border>
                             </StackPanel>

                             <!-- Priority Calculator -->
                             <StackPanel Visibility="{Binding HasPriorityCalculator, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="System Priority Calculator" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,6"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10">
                                     <StackPanel>
                                         <TextBlock Text="{Binding PriorityCalculator.Description}" Foreground="{DynamicResource CautionBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                         <UniformGrid Columns="3">
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalLength}" Style="{StaticResource RoundedComboBox}" FontSize="11" Margin="0,0,4,0">
                                                 <ComboBoxItem Content="Short"/><ComboBoxItem Content="Long"/>
                                             </ComboBox>
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.IntervalType}" Style="{StaticResource RoundedComboBox}" FontSize="11" Margin="0,0,4,0">
                                                 <ComboBoxItem Content="Variable"/><ComboBoxItem Content="Fixed"/>
                                             </ComboBox>
                                             <ComboBox SelectedIndex="{Binding PriorityCalculator.Boost}" Style="{StaticResource RoundedComboBox}" FontSize="11">
                                                 <ComboBoxItem Content="None"/><ComboBoxItem Content="Middle"/><ComboBoxItem Content="Max"/>
                                             </ComboBox>
                                         </UniformGrid>
                                     </StackPanel>
                                 </Border>
                             </StackPanel>

                             <!-- Code Example -->
                             <StackPanel Visibility="{Binding HasCodeExample, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,10">
                                 <TextBlock Text="Command Preview" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                 <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="10">
                                     <TextBlock Text="{Binding CodeExample}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                 </Border>
                             </StackPanel>

                             <!-- Reference Links -->
	                             <ItemsControl ItemsSource="{Binding ReferenceLinks}" Margin="0,0,0,10">
	                                 <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
	                                 <ItemsControl.ItemTemplate>
	                                     <DataTemplate>
	                                         <Button Style="{StaticResource LinkButtonStyle}"
	                                                 Margin="0,0,12,4"
	                                                 ToolTip="{Binding Tooltip}"
	                                                 Command="{Binding DataContext.OpenReferenceLinkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
	                                                 CommandParameter="{Binding Url}">
	                                            <StackPanel Orientation="Horizontal">
	                                                <TextBlock Text="{Binding Icon}" FontSize="11" Margin="0,0,4,0"/>
	                                                <TextBlock Text="{Binding Title}"/>
	                                            </StackPanel>
	                                         </Button>
	                                     </DataTemplate>
	                                 </ItemsControl.ItemTemplate>
	                             </ItemsControl>
                         </StackPanel>

                         <!-- Tab View 2: Execution Log -->
                         <StackPanel Visibility="{Binding ShowTerminal, Converter={StaticResource BoolToVisibility}}">
                             <Border Background="{DynamicResource TerminalBackgroundBrush}" CornerRadius="4" Padding="10" Height="130">
                                 <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                               HorizontalScrollBarVisibility="Disabled">
                                     <TextBlock Text="{Binding TerminalOutput}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                 </ScrollViewer>
                             </Border>
                         </StackPanel>

                         <!-- Footer Actions -->
                         <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="4" Padding="8" Margin="0,2,0,0">
                             <Grid>
                                 <StackPanel Orientation="Horizontal">
	                                     <Button Content="Detect"
	                                             Command="{Binding DetectCommand}"
	                                             Style="{StaticResource TweakActionButtonStyle}"
	                                             Margin="0,0,6,0"
	                                             ToolTip="Detect: reads current state (no changes)."/>
	                                     <Button Content="{Binding ActionButtonText}"
	                                             Command="{Binding ApplyCommand}"
	                                             Style="{StaticResource TweakPrimaryActionButtonStyle}"
	                                             ToolTip="Apply: Detect -> Apply -> Verify (Rollback on failure)."/>
	                                     <Button Content="?"
	                                             Style="{StaticResource TweakActionButtonStyle}"
	                                             Margin="6,0,0,0"
	                                             ToolTip="{Binding ActionsHelpTooltip}"/>
	                                 </StackPanel>
                                 <TextBlock HorizontalAlignment="Right" Text="{Binding StatusMessage}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="10" VerticalAlignment="Center" FontStyle="Italic"/>
                             </Grid>
                         </Border>
                        </StackPanel>
                    </Border>
	                            </StackPanel>
	                        </Border>
                        <!-- ExpanderIconRotate animation removed: rotation is handled inside ExpanderButtonStyle's own ControlTemplate via IsChecked trigger -->
                    </DataTemplate>

        <DataTemplate x:Key="TweakItemCompactTemplate" DataType="{x:Type viewModels:TweakItemViewModel}">
            <Border Background="{DynamicResource BackgroundDarkBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,8"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CompactScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="CompactTranslate" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ShadowColorSmall}"
                                      BlurRadius="10"
                                      ShadowDepth="2"
                                      Opacity="0.2"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 From="6"
                                                 To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.01"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.01"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 To="-1"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CompactTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 To="0"
                                                 Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="26"
                            Height="26"
                            CornerRadius="13"
                            Background="{Binding StatusBadgeBackground}"
                            BorderBrush="{Binding StatusColor}"
                            BorderThickness="1"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding StatusIcon}"
                                   Foreground="{Binding StatusColor}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding Description}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Description}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border Style="{StaticResource RiskBadgeStyle}" Margin="0,0,6,0">
                                <TextBlock Text="{Binding Risk}"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <Border Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    Visibility="{Binding RequiresElevation, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding ElevationBadgeText}"
                                           Foreground="{DynamicResource ForegroundLightBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Detect"
                                Command="{Binding DetectCommand}"
                                Style="{StaticResource TweakActionButtonStyle}"
                                Margin="0,0,4,0"/>
                        <Button Content="{Binding ActionButtonText}"
                                Command="{Binding ApplyCommand}"
                                Style="{StaticResource TweakPrimaryActionButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Recursive Category Template -->
        <DataTemplate x:Key="CategoryTemplate" DataType="{x:Type viewModels:CategoryGroupViewModel}">
            <StackPanel Margin="{Binding IsNested, Converter={StaticResource NestedMarginConverter}}">
                <!-- Category Header -->
                <Border CornerRadius="8" 
                        Margin="0,0,0,6"
                        Padding="10,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNested}" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </DataTrigger>
                            <DataTrigger Binding="{Binding Source={x:Static services:UiPreferences.Current}, Path=IsCompactMode}" Value="True">
                                    <Setter Property="Padding" Value="10,5"/>
                                    <Setter Property="Margin" Value="0,0,0,3"/>
                            </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DisplayName, TargetNullValue='Unknown Category', FallbackValue='Category Name'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="10" Padding="6,1" Margin="0,0,10,0">
                                <TextBlock Text="{Binding CountBadge}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <ToggleButton IsChecked="{Binding IsExpanded}" Style="{StaticResource ExpanderButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Nested Content -->
                <Border ClipToBounds="True" RenderTransformOrigin="0.5,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Opacity" Value="0"/>
                            <Setter Property="MaxHeight" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                 To="10000" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                 To="0" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.2">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- SubGroups Recursive Call -->
                        <ItemsControl ItemsSource="{Binding SubGroups}" ItemTemplate="{DynamicResource CategoryTemplate}"/>
                        
                        <!-- Tweaks In This Group (uses VisibleTweaks for lazy loading) -->
                        <ItemsControl ItemsSource="{Binding VisibleTweaks}" ItemTemplate="{StaticResource TweakItemTemplate}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel x:Name="TweaksPanel"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDense}" Value="True">
                                            <Setter Property="ItemsPanel">
                                                <Setter.Value>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="3"/>
                                                    </ItemsPanelTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid ClipToBounds="False">
        <Grid Margin="16,8,16,16" ClipToBounds="False">
            <TabControl Style="{StaticResource ModernMainTabControlStyle}"
                        ItemContainerStyle="{StaticResource ModernMainTabItemStyle}"
                        Margin="0"
                        Padding="0">
                <TabItem Header="Policies">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                    <!-- Control Bar -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <Border Background="{StaticResource TweakPanelGradientBrush}"
                                BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <WrapPanel Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,6">
                                        <Grid Width="280" Margin="0,0,10,6">
                                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SearchBoxStyle}"
                                                     Tag="Search policies, IDs, or descriptions..."/>
                                        </Grid>
                                        <CheckBox Tag="Safe" IsChecked="{Binding ShowSafe}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                                                <TextBlock Text="Safe"/>
                                            </StackPanel>
                                        </CheckBox>
                                        <CheckBox Tag="Advanced" IsChecked="{Binding ShowAdvanced}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                                                <TextBlock Text="Advanced"/>
                                            </StackPanel>
                                        </CheckBox>
                                        <CheckBox Tag="Risky" IsChecked="{Binding ShowRisky}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                                                <TextBlock Text="Risky"/>
                                            </StackPanel>
                                        </CheckBox>
                                        <CheckBox Tag="Favorites" IsChecked="{Binding ShowFavoritesOnly}" Style="{StaticResource FilterCheckbox}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                                                <TextBlock Text="Favorites"/>
                                                <Border Background="{DynamicResource BackgroundMediumBrush}"
                                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="6,1"
                                                        Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding FavoritesCount}"
                                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </CheckBox>
                                        <Button Content="Reset Filters"
                                                Command="{Binding ResetFiltersCommand}"
                                                Style="{StaticResource CompactButton}"
                                                Margin="0,0,0,6"/>
                                    </WrapPanel>

                                    <WrapPanel Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,0,6">
                                        <Button Command="{Binding OpenLogFolderCommand}" ToolTip="Open logs folder" Style="{StaticResource CompactButton}" Margin="0,0,6,6">
                                            <TextBlock Text="Logs"/>
                                        </Button>
                                        <Button Command="{Binding OpenDocsCoverageReportCommand}" ToolTip="Docs Coverage Report" Style="{StaticResource CompactButton}" Margin="0,0,8,6">
                                            <TextBlock Text="Docs"/>
                                        </Button>
                                        <Button Command="{Binding ExpandAllDetailsCommand}" ToolTip="Expand all details" Style="{StaticResource CompactButton}" Margin="0,0,4,6">
                                            <TextBlock Text="Expand"/>
                                        </Button>
                                        <Button Command="{Binding CollapseAllDetailsCommand}" ToolTip="Collapse all details" Style="{StaticResource CompactButton}" Margin="0,0,8,6">
                                            <TextBlock Text="Collapse"/>
                                        </Button>
                                        <ToggleButton IsChecked="{Binding IsFlatView}" ToolTip="Toggle compact view" Style="{StaticResource CompactToggleButtonStyle}" Margin="0,0,0,6">
                                            <TextBlock Text="Compact"/>
                                        </ToggleButton>
                                    </WrapPanel>
                                </Grid>

                                <Grid Grid.Row="1" Margin="4,0,4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FilterSummary}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="{Binding InventoryStatusMessage}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Content -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Category Sidebar -->
                        <Border Grid.Column="0"
                                Background="{StaticResource TweakPanelGradientBrush}"
                                BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Policy Domains"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding TotalTweaksAvailable, StringFormat={}{0} policies cataloged}"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,3,0,10"/>
                                <Button Grid.Row="2"
                                        Command="{Binding ClearCategorySelectionCommand}"
                                        Style="{StaticResource CategoryAllButtonStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="All Policies"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BackgroundMediumBrush}"
                                                CornerRadius="10"
                                                Padding="8,2">
                                            <TextBlock Text="{Binding TotalTweaksAvailable}"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Button>
                                <Border Grid.Row="3"
                                        Height="1"
                                        Background="{DynamicResource BackgroundLightBrush}"
                                        Opacity="0.5"
                                        Margin="0,10,0,10"/>
                                 <ListBox Grid.Row="4"
                                          ItemsSource="{Binding CategoryGroups}"
                                          SelectedValuePath="CategoryName"
                                          SelectedValue="{Binding SelectedCategoryName, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0,0,0,8"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                         ScrollViewer.CanContentScroll="True">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Padding" Value="10,9"/>
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemRoot"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="10"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding CategoryIcon}"
                                                                FontSize="13"
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center"/>
                                                     <TextBlock Grid.Column="1"
                                                                 Text="{Binding CategoryName}"
                                                                 FontSize="14"
                                                                 FontWeight="SemiBold"
                                                                 Foreground="{DynamicResource ForegroundLightBrush}"
                                                                 TextTrimming="CharacterEllipsis"
                                                                 VerticalAlignment="Center"/>
                                                    <Border Grid.Column="2"
                                                            Background="{DynamicResource BackgroundMediumBrush}"
                                                            CornerRadius="10"
                                                            Padding="8,2">
                                                        <TextBlock Text="{Binding CountBadge}"
                                                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>


                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SelectedCategoryLabel}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="{Binding BulkStatusMessage}"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,3,0,0"/>
                                           
                                <!-- DNS Configuration Panel - Compact single-line design -->
                                <Border Background="{DynamicResource BackgroundDarkBrush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        Margin="0,10,20,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCategoryName}" Value="Network">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid DataContext="{Binding DnsConfiguration}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icon + Title -->
                                        <TextBlock Text="{DynamicResource IconNetwork}"
                                                   FontFamily="{DynamicResource IconFontFamily}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AccentBrightCyanBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <TextBlock Text="DNS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                            <TextBlock Text="{Binding CurrentDnsInfo}" FontSize="10" Foreground="{DynamicResource AccentBrightCyanBrush}" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        
                                        <!-- Provider Selector -->
                                        <ComboBox Grid.Column="2" 
                                                  ItemsSource="{Binding DnsProviders}" 
                                                  SelectedItem="{Binding SelectedDnsProvider, Mode=TwoWay}"
                                                  Style="{StaticResource RoundedComboBox}"
                                                  Height="26"
                                                  MaxWidth="180"
                                                  Margin="0,0,8,0">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon}" FontSize="10" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="11"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        
                                        <!-- Apply Button -->
                                        <Button Grid.Column="3"
                                                Content="Apply"
                                                Command="{Binding ApplyDnsCommand}"
                                                Style="{StaticResource FilterButton}"
                                                Margin="0,0,6,0"
                                                Padding="10,4"
                                                FontSize="11"/>
                                        
                                        <!-- Flush Button -->
                                        <Button Grid.Column="4"
                                                Content="Flush"
                                                Command="{Binding FlushDnsCommand}"
                                                Style="{StaticResource CompactButton}"
                                                Padding="10,4"
                                                FontSize="11"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <ListBox ItemsSource="{Binding TweaksView}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0,0,20,20"
                                         HorizontalContentAlignment="Stretch"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox">
                                            <Setter Property="ItemTemplate" Value="{StaticResource TweakItemTemplate}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFlatView}" Value="True">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource TweakItemCompactTemplate}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- Empty State -->
                                <Border Padding="20"
                                        Background="{DynamicResource BackgroundDarkBrush}"
                                        CornerRadius="10"
                                        Margin="0,20"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding HasVisibleTweaks, Converter={StaticResource InverseBoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="No policies match your filters"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                   HorizontalAlignment="Center"/>
                                         <TextBlock Text="Try clearing search or category filters."
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                </TabItem>

                <TabItem Header="Bloatware">
                    <local:BloatwareView DataContext="{Binding Bloatware}"/>
                </TabItem>

                <TabItem Header="Startup">
                    <local:StartupView DataContext="{Binding Startup}"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>


