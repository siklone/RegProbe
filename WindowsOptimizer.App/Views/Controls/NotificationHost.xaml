<UserControl x:Class="WindowsOptimizer.App.Views.Controls.NotificationHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400"
             IsHitTestVisible="True">
    
    <UserControl.Resources>
        <!-- Toast notification colors -->
        <SolidColorBrush x:Key="ToastSuccessBg" Color="#22C55E"/>
        <SolidColorBrush x:Key="ToastSuccessBorder" Color="#16A34A"/>
        <SolidColorBrush x:Key="ToastWarningBg" Color="#F59E0B"/>
        <SolidColorBrush x:Key="ToastWarningBorder" Color="#D97706"/>
        <SolidColorBrush x:Key="ToastErrorBg" Color="#EF4444"/>
        <SolidColorBrush x:Key="ToastErrorBorder" Color="#DC2626"/>
        <SolidColorBrush x:Key="ToastInfoBg" Color="#3B82F6"/>
        <SolidColorBrush x:Key="ToastInfoBorder" Color="#2563EB"/>
        
        <!-- Slide-in animation -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation 
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                From="400" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation 
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>
    
    <!-- Notifications container - bottom right -->
    <ItemsControl x:Name="NotificationItems"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Right"
                  Margin="0,0,20,20"
                  IsHitTestVisible="True">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border x:Name="ToastBorder"
                        Margin="0,8,0,0"
                        Padding="16,12"
                        CornerRadius="10"
                        MinWidth="320"
                        MaxWidth="400"
                        Cursor="Hand"
                        Background="#1E293B"
                        BorderThickness="1,1,1,3"
                        RenderTransformOrigin="1,0.5">
                    
                    <Border.RenderTransform>
                        <TranslateTransform X="0"/>
                    </Border.RenderTransform>
                    
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.4" Color="Black"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Icon -->
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="18"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="Success">
                                            <Setter Property="Background" Value="{StaticResource ToastSuccessBg}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="Warning">
                                            <Setter Property="Background" Value="{StaticResource ToastWarningBg}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="Error">
                                            <Setter Property="Background" Value="{StaticResource ToastErrorBg}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="Info">
                                            <Setter Property="Background" Value="{StaticResource ToastInfoBg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding Icon}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Content -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="White"
                                       Visibility="{Binding Title, Converter={StaticResource NullToCollapsedConverter}}"/>
                            <TextBlock Text="{Binding Message}"
                                       FontSize="13"
                                       Foreground="#CBD5E1"
                                       TextWrapping="Wrap"
                                       MaxWidth="280"/>
                        </StackPanel>
                        
                        <!-- Dismiss button -->
                        <Button Grid.Column="2"
                                Content="✕"
                                Width="24" Height="24"
                                FontSize="12"
                                Foreground="#94A3B8"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Top"
                                Margin="8,0,0,0"
                                Click="DismissButton_Click"
                                Tag="{Binding Id}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12"
                                            x:Name="border">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#334155"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
                
                <DataTemplate.Triggers>
                    <!-- Border color based on type -->
                    <DataTrigger Binding="{Binding Type}" Value="Success">
                        <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource ToastSuccessBorder}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Type}" Value="Warning">
                        <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource ToastWarningBorder}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Type}" Value="Error">
                        <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource ToastErrorBorder}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Type}" Value="Info">
                        <Setter TargetName="ToastBorder" Property="BorderBrush" Value="{StaticResource ToastInfoBorder}"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
