<UserControl x:Class="WindowsOptimizer.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
             FontSize="12">
    <UserControl.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" Background="{DynamicResource BackgroundDarkestBrush}">
        <Grid Margin="32">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                <!-- Header with Logo -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="16" Padding="16" Margin="0,0,20,0">
                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="Modern, safe, and reversible Windows optimization tool"
                                   Foreground="{DynamicResource AccentBrightCyanBrush}"
                                   FontSize="14"/>
                    </StackPanel>
                </StackPanel>

                <!-- Version Info Cards -->
                <UniformGrid Columns="5" Margin="0,0,0,20">
                    <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Version" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                            <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Build" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                            <TextBlock Text="{Binding BuildConfiguration}" Foreground="{DynamicResource SuccessBrush}" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Framework" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                            <TextBlock Text="{Binding Framework}" Foreground="{DynamicResource InfoBrush}" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Architecture" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                            <TextBlock Text="{Binding Architecture}" Foreground="{DynamicResource CautionBrush}" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <!-- Log File Size -->
                    <Button Command="{Binding OpenLogFileCommand}" Cursor="Hand" ToolTip="Click to open log file">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="10" Padding="16">
                                     <StackPanel>
                                        <TextBlock Text="Log Size" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                        <TextBlock Text="{Binding LogFileSizeFormatted}" Foreground="{DynamicResource InfoBrush}" FontSize="20" FontWeight="Bold"/>
                                     </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </UniformGrid>

                <!-- Features Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource AccentBrightCyanBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource BackgroundDarkestBrush}"/>
                            </Border>
                            <TextBlock Text="Core Features" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <UniformGrid Columns="4">
                            <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="14" Margin="0,0,8,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Registry Tweaks" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="Modify Windows registry safely" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="14" Margin="8,0,8,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Service Management" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="Review services with descriptions and safe start-mode changes" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="14" Margin="8,0,8,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Command Execution" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="Secure command allowlist" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="14" Margin="8,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Drivers &amp; Runtime Guidance" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="Official vendor links and common Windows runtime recommendations" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Safety Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="{DynamicResource SuccessBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource BackgroundDarkestBrush}"/>
                            </Border>
                            <TextBlock Text="Safety &amp; Reliability" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="All tweaks support Preview, Apply, Verify, and Rollback" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="Changes logged to CSV for audit trails" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="Elevated operations isolated in separate host process" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Research Credits -->
                <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource ForegroundBrightestBrush}" Margin="0,0,12,0"/>
                            <TextBlock Text="Research Credits" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                        </StackPanel>
                        
                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Windows Registry Research" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="Reverse engineering and documentation by nohuto" 
                                           Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="0,4,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="win-config" 
                                            Command="{Binding OpenUrlCommand}"
                                            CommandParameter="https://github.com/nohuto/win-config"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource AccentBrightCyanBrush}"
                                            Padding="0" Margin="0,0,16,0" Cursor="Hand"/>
                                    <Button Content="win-registry" 
                                            Command="{Binding OpenUrlCommand}"
                                            CommandParameter="https://github.com/nohuto/win-registry"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource AccentBrightCyanBrush}"
                                            Padding="0" Cursor="Hand"/>
                                </StackPanel>
                                <TextBlock Text="Methods: IDA Pro, WinDbg, WPR, Procmon" 
                                           FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Project Info -->
                <Border Background="{DynamicResource BackgroundMediumBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource ForegroundBrightestBrush}" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Repository" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                            <Button Content="{Binding RepositoryUrl}"
                                    Command="{Binding OpenUrlCommand}"
                                    CommandParameter="{Binding RepositoryUrl}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource AccentBrightCyanBrush}"
                                    FontSize="13"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Warning -->
                <Border Background="{DynamicResource BackgroundDarkBrush}" 
                        BorderBrush="{DynamicResource CautionBrush}" 
                        BorderThickness="1"
                        CornerRadius="8" 
                        Padding="16"
                        Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource CautionBrush}" Margin="0,0,12,0"/>
                        <TextBlock Foreground="{DynamicResource CautionBrush}" FontSize="12">
                            <Run FontWeight="SemiBold">Warning:</Run>
                            <Run>Always create a system restore point before applying system tweaks.</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
