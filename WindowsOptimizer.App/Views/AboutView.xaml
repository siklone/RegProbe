<UserControl x:Class="WindowsOptimizer.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#2E3440">
        <Grid Margin="32">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                <!-- Header with Logo -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Border Background="#5E81AC" CornerRadius="16" Padding="16" Margin="0,0,20,0">
                        <TextBlock Text="⚡" FontSize="32"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="#ECEFF4"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="Modern, safe, and reversible Windows optimization tool"
                                   Foreground="#88C0D0"
                                   FontSize="14"/>
                    </StackPanel>
                </StackPanel>

                <!-- Version Info Cards -->
                <UniformGrid Columns="4" Margin="0,0,0,20">
                    <Border Background="#434C5E" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Version" Foreground="#4C566A" FontSize="11"/>
                            <TextBlock Text="1.0.0" Foreground="#88C0D0" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#434C5E" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Build" Foreground="#4C566A" FontSize="11"/>
                            <TextBlock Text="Release" Foreground="#A3BE8C" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#434C5E" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Framework" Foreground="#4C566A" FontSize="11"/>
                            <TextBlock Text=".NET 8" Foreground="#B48EAD" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#434C5E" CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Architecture" Foreground="#4C566A" FontSize="11"/>
                            <TextBlock Text="x64" Foreground="#EBCB8B" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Features Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#88C0D0" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="🎯" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Core Features" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="#ECEFF4"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Background="#434C5E" CornerRadius="8" Padding="14" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="⚙️ Registry Tweaks" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="13"/>
                                    <TextBlock Text="Modify Windows registry safely" Foreground="#88C0D0" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Row="0" Grid.Column="1" Background="#434C5E" CornerRadius="8" Padding="14" Margin="8,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="🔧 Service Management" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="13"/>
                                    <TextBlock Text="Control Windows services" Foreground="#88C0D0" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Row="1" Grid.Column="0" Background="#434C5E" CornerRadius="8" Padding="14" Margin="0,8,8,0">
                                <StackPanel>
                                    <TextBlock Text="💻 Command Execution" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="13"/>
                                    <TextBlock Text="Secure command allowlist" Foreground="#88C0D0" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Row="1" Grid.Column="1" Background="#434C5E" CornerRadius="8" Padding="14" Margin="8,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="💬 Discord Integration" FontWeight="SemiBold" Foreground="#ECEFF4" FontSize="13"/>
                                    <TextBlock Text="Webhook notifications" Foreground="#88C0D0" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Safety Section -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#A3BE8C" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="🛡️" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Safety &amp; Reliability" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="#ECEFF4"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Background="#2E4A3E" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="✓" Foreground="#A3BE8C" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="All tweaks support Preview, Apply, Verify, and Rollback" Foreground="#D8DEE9"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="✓" Foreground="#A3BE8C" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="Changes logged to CSV for audit trails" Foreground="#D8DEE9"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓" Foreground="#A3BE8C" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="Elevated operations isolated in separate host process" Foreground="#D8DEE9"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Project Info -->
                <Border Background="#434C5E" CornerRadius="8" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔗" FontSize="16" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Repository" Foreground="#4C566A" FontSize="11"/>
                            <TextBlock Text="github.com/siklone/WPF-Windows-optimizer-with-safe-reversible-tweaks" 
                                       Foreground="#88C0D0" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Warning -->
                <Border Background="#4A3E2E" 
                        BorderBrush="#EBCB8B" 
                        BorderThickness="1"
                        CornerRadius="8" 
                        Padding="16"
                        Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Foreground="#EBCB8B" FontSize="12">
                            <Run FontWeight="SemiBold">Warning:</Run>
                            <Run>Always create a system restore point before applying system tweaks.</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
