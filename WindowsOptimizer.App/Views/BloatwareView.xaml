<UserControl x:Class="WindowsOptimizer.App.Views.BloatwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <DockPanel>
                <TextBlock Text="{Binding Title}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                           DockPanel.Dock="Left"/>
                
                <Button Content="🔄 Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource ModernButtonStyle}"
                        Padding="12,6"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"/>
            </DockPanel>
            
            <TextBlock Text="Remove pre-installed bloatware and unnecessary UWP apps"
                       FontSize="14"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Warning Banner -->
        <Border Grid.Row="1"
                Background="#33FF9800"
                BorderBrush="#FF9800"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,16">
            <DockPanel>
                <TextBlock Text="⚠️"
                           FontSize="20"
                           Margin="0,0,12,0"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="Safety Notice"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                    <TextBlock Text="Critical system apps are protected. Only apps marked as 'Safe' or 'Caution' can be removed. Apps can be reinstalled from Microsoft Store."
                               FontSize="12"
                               Foreground="{DynamicResource ForegroundLightBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Apps List -->
        <Border Grid.Row="2"
                Background="{DynamicResource BackgroundDarkBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="0">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14"
                             Background="Transparent"
                             Foreground="{DynamicResource ForegroundBrightestBrush}"
                             BorderThickness="0"
                             Padding="8,4">
                        <TextBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <!-- Apps List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Apps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:AppxPackageViewModel}">
                                <Border BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="20,16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- App Info -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                       Margin="0,0,0,6"/>
                                            
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Publisher}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           Margin="0,0,16,0"/>
                                                <TextBlock Text="{Binding Version}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           Margin="0,0,16,0"/>
                                                <TextBlock Text="{Binding SizeFormatted}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                                            </StackPanel>

                                            <!-- Safety Badge -->
                                            <Border Background="{Binding SafetyColor}"
                                                    CornerRadius="4"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding SafetyText}"
                                                           FontSize="10"
                                                           FontWeight="Medium"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Uninstall Button -->
                                        <Button Grid.Column="1"
                                                Command="{Binding UninstallCommand}"
                                                Content="🗑️ Uninstall"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Background="#F44336"
                                                Padding="16,8"
                                                VerticalAlignment="Center"
                                                Margin="16,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource BackgroundMediumBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status Icon -->
                <Ellipse Grid.Column="0"
                         Width="12" Height="12"
                         Fill="{DynamicResource AccentBrightCyanBrush}"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center"/>

                <!-- Status Message -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           FontSize="13"
                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
