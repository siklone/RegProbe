                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding Type}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="12" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="Download" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
                                            <TextBlock Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="14">
                                                <Run Text="{Binding ReceiveMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="16,0,0,0">
                                            <TextBlock Text="Upload" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
                                            <TextBlock Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" FontSize="14">
                                                <Run Text="{Binding SendMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="16,0,0,0">
                                            <TextBlock Text="Total Received" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
                                            <TextBlock Foreground="{DynamicResource CautionBrush}" FontWeight="Medium" FontSize="12">
                                                <Run Text="{Binding TotalBytesReceived, StringFormat={}{0:N0}, Mode=OneWay}"/><Run Text=" bytes"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MonitorDiskActivityTemplate">
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Disk Activity" Style="{StaticResource SectionHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Drive Letter -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DriveLetter}"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                        <!-- Disk Space Info -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <TextBlock FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}">
                                                <Run Text="{Binding UsedSpaceGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB used of "/><Run Text="{Binding TotalSizeGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,2,0,0">
                                                <Run Text="{Binding FreeSpaceGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB free"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,2,0,0"
                                                       Text="{Binding DescriptorText}"/>
                                        </StackPanel>

                                        <!-- Read Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0">
                                            <TextBlock Text="Read" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
                                            <TextBlock Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="14">
                                                <Run Text="{Binding ReadMBps, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" MB/s"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Write Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="8,0">
                                            <TextBlock Text="Write" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
                                            <TextBlock Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" FontSize="14">
                                                <Run Text="{Binding WriteMBps, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" MB/s"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Usage Percent -->
                                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="8,0,0,0">
                                            <TextBlock Text="Usage" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
                                            <TextBlock Foreground="{DynamicResource CautionBrush}" FontWeight="Bold" FontSize="14">
                                                <Run Text="{Binding UsedPercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MonitorPerformanceTabTemplate">
            <ItemsControl ItemsSource="{Binding MonitorSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:MonitorSectionLayout}">
                        <ContentControl Content="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate" Value="{StaticResource MonitorStatCardsTemplate}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Key}" Value="stat-cards">
                                            <Setter Property="ContentTemplate" Value="{StaticResource MonitorStatCardsTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Key}" Value="cpu-ram-history">
                                            <Setter Property="ContentTemplate" Value="{StaticResource MonitorHistoryChartsTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Key}" Value="network-disk-io">
                                            <Setter Property="ContentTemplate" Value="{StaticResource MonitorIoChartsTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Key}" Value="performance-panel">
                                            <Setter Property="ContentTemplate" Value="{StaticResource MonitorPerformanceTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Key}" Value="network-adapters">
                                            <Setter Property="ContentTemplate" Value="{StaticResource MonitorNetworkAdaptersTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Key}" Value="disk-activity">
                                            <Setter Property="ContentTemplate" Value="{StaticResource MonitorDiskActivityTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

        <DataTemplate x:Key="MonitorProcessesTabTemplate">
            <StackPanel>
                <TextBlock Text="Processes"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Live top processes by CPU, RAM, network, and disk activity."
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Margin="0,0,0,12"/>
                <ListBox ItemsSource="{Binding ProcessCategories}"
                         SelectedItem="{Binding SelectedProcessCategory}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,0,0,12"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ProcessCategoryTabStyle}"/>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate" Value="{StaticResource MonitorTopCpuTemplate}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProcessCategory.Category}" Value="{x:Static viewModels:MonitorViewModel+ProcessCategory.Memory}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource MonitorTopRamTemplate}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedProcessCategory.Category}" Value="{x:Static viewModels:MonitorViewModel+ProcessCategory.Network}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource MonitorTopNetworkTemplate}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedProcessCategory.Category}" Value="{x:Static viewModels:MonitorViewModel+ProcessCategory.Disk}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource MonitorTopDiskTemplate}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="MonitorStartupAppsTemplate">
            <Border Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Startup Apps"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Registry and Startup folder entries that launch with Windows."
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding StartupAppsSummary}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AccentBrightCyanBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text=" • "
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                                <TextBlock Text="{Binding StartupAppsUpdatedText}"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshStartupAppsCommand}"
                                Style="{StaticResource HeaderActionButtonStyle}"
                                Padding="10,6"
                                ToolTip="Refresh startup entries">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding StartupApps}"
                              SelectedItem="{Binding SelectedStartupApp}"
                              Background="Transparent"
                              BorderThickness="0"
                              utils:ScrollViewerHelper.EnableMouseWheelScroll="True"
                              MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportHeight}"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                                <GridViewColumn Header="Status" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                       FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Scope" DisplayMemberBinding="{Binding Scope}" Width="110"/>
                                <GridViewColumn Header="Source" DisplayMemberBinding="{Binding Source}" Width="130"/>
                                <GridViewColumn Header="Action" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ToggleStartupAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,4"
                                                    IsEnabled="{Binding CanToggle}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                                        <Setter Property="Content" Value="Disable"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Content" Value="Enable"/>
                                                                <Setter Property="Background" Value="{DynamicResource AccentDarkBlueBrush}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource ForegroundOnAccentBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CanToggle}" Value="False">
                                                                <Setter Property="Content" Value="Managed"/>
                                                                <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Command" Width="360">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Command}"
                                                       Foreground="{DynamicResource ForegroundLightBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Command}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MonitorServicesTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Services &amp; Drivers"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="Full registry-backed list including drivers and system components."
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding ServicesSummary}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentBrightCyanBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text=" • "
                                               FontSize="11"
                                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                                    <TextBlock Text="{Binding ServicesUpdatedText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding RefreshServicesCommand}"
                                    Style="{StaticResource HeaderActionButtonStyle}"
                                    Padding="10,6"
                                    ToolTip="Refresh services list">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Refresh"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding Services}"
                                  SelectedItem="{Binding SelectedService}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  utils:ScrollViewerHelper.EnableMouseWheelScroll="True"
                                  MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportHeight}"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                  ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                  ScrollViewer.IsDeferredScrollingEnabled="True"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <ListView.Resources>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                                </Style>
                            </ListView.Resources>
                            <ListView.View>
                                <GridView>
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="160"/>
                                        <GridViewColumn Header="Display" DisplayMemberBinding="{Binding DisplayName}" Width="220"/>
                                        <GridViewColumn Header="Kind" DisplayMemberBinding="{Binding KindText}" Width="80"/>
                                        <GridViewColumn Header="Start" DisplayMemberBinding="{Binding StartType}" Width="90"/>
                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="90"/>
                                        <GridViewColumn Header="Binary Path" Width="300">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BinaryPath}"
                                                               Foreground="{DynamicResource ForegroundLightBrush}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding BinaryPath}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Details" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SelectedService.DisplayName, TargetNullValue=Select a service}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SelectedService.Description}"
                                   FontSize="11"
                                   Foreground="{DynamicResource ForegroundLightBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding ServiceDetailItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Value}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Command="{Binding OpenServiceDocsCommand}"
                                CommandParameter="{Binding SelectedService}"
                                Style="{StaticResource HeaderActionButtonStyle}"
                                Margin="0,12,0,0"
                                Padding="10,6"
                                ToolTip="Open Microsoft Learn search for this service.">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71B;" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="Docs"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Command="{Binding EnableServiceCommand}"
                                    IsEnabled="{Binding CanEnableSelectedService}"
                                    Style="{StaticResource HeaderActionButtonStyle}"
                                    Padding="10,6"
                                    ToolTip="Set startup type to Manual.">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D4;" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Enable"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DisableServiceCommand}"
                                    IsEnabled="{Binding CanDisableSelectedService}"
                                    Style="{StaticResource HeaderActionButtonStyle}"
                                    Padding="10,6"
                                    Margin="8,0,0,0"
                                    ToolTip="Set startup type to Disabled.">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7E8;" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Disable"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="Changes are applied via ElevatedHost and may affect system stability."
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.IsDeferredScrollingEnabled="True"
                      ScrollViewer.PanningMode="VerticalOnly">
            <StackPanel Margin="20">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                    <TextBlock Text="Real-time system hardware monitoring" FontSize="14" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrightCyanBrush}"
                               Margin="0,6,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    <ListBox ItemsSource="{Binding MonitorTabs}"
                             SelectedItem="{Binding SelectedTab}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,12,0,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MonitorTabItemStyle}"/>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,8,0,0">
                    <Border Style="{StaticResource HeaderPillStyle}" ToolTip="Auto refresh every 1 second."
                            Visibility="{Binding IsPerformanceTab, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="Live (1s)" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Button Command="{Binding ExportMetricsCommand}"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            VerticalAlignment="Center"
                            ToolTip="Save snapshot (CSV) to your Desktop."
                            Visibility="{Binding IsPerformanceTab, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE105;" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportSensorDiagnosticsCommand}"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            ToolTip="Export a sensor diagnostics report for troubleshooting."
                            Visibility="{Binding IsPerformanceTab, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Sensors"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleLayoutEditorCommand}"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            ToolTip="Customize which sections are visible and their order."
                            Visibility="{Binding IsPerformanceTab, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Customize"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource MonitorPerformanceTabTemplate}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab.Tab}" Value="{x:Static viewModels:MonitorViewModel+MonitorTab.Processes}">
                                <Setter Property="ContentTemplate" Value="{StaticResource MonitorProcessesTabTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedTab.Tab}" Value="{x:Static viewModels:MonitorViewModel+MonitorTab.StartupApps}">
                                <Setter Property="ContentTemplate" Value="{StaticResource MonitorStartupAppsTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedTab.Tab}" Value="{x:Static viewModels:MonitorViewModel+MonitorTab.Services}">
                                <Setter Property="ContentTemplate" Value="{StaticResource MonitorServicesTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            </StackPanel>
        </ScrollViewer>

        <Grid IsHitTestVisible="{Binding IsLayoutEditorVisible}"
              Visibility="{Binding IsPerformanceTab, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="10">
            <Button x:Name="LayoutEditorScrim"
                    Style="{StaticResource LayoutScrimButtonStyle}"
                    Command="{Binding ToggleLayoutEditorCommand}"/>

            <Border x:Name="LayoutEditorDialog"
                    Style="{StaticResource LayoutDialogStyle}"
                    Width="640"
                    MaxWidth="720"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Customize Layout"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Drag sections to reorder or toggle them. Changes are saved automatically."
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding ResetLayoutCommand}"
                                    Style="{StaticResource HeaderActionButtonStyle}"
                                    Padding="10,6"
                                    ToolTip="Restore the default monitor layout."
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE777;" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Reset"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ToggleLayoutEditorCommand}"
                                    Style="{StaticResource HeaderActionButtonStyle}"
                                    Padding="8,6"
                                    ToolTip="Close">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  Margin="0,16,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding MonitorSections}"
                                 AllowDrop="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 PreviewMouseLeftButtonDown="OnLayoutItemPreviewMouseLeftButtonDown"
                                 PreviewMouseMove="OnLayoutItemPreviewMouseMove"
                                 DragOver="OnLayoutItemDragOver"
                                 Drop="OnLayoutItemDrop">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="IsHitTestVisible" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:MonitorSectionLayout}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <CheckBox Content="{Binding Title}"
                                                      IsChecked="{Binding IsVisible}"
                                                      Style="{StaticResource LayoutCheckBoxStyle}"
                                                      ToolTip="{Binding Description}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                       FontSize="10"
                                                       Margin="24,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding DataContext.MoveSectionUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Move up"
                                                    Style="{StaticResource LayoutMoveButtonStyle}">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70E;"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.MoveSectionDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Move down"
                                                    Style="{StaticResource LayoutMoveButtonStyle}"
                                                    Margin="6,0,0,0">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
