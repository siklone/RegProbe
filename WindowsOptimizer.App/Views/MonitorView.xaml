<UserControl x:Class="WindowsOptimizer.App.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             xmlns:converters="clr-namespace:WindowsOptimizer.App.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundDarkestBrush}">

    <UserControl.Resources>
        <converters:SparklinePointsConverter x:Key="SparklinePointsConverter"/>
        <converters:SparklineAreaConverter x:Key="SparklineAreaConverter"/>
        <converters:LastValueToYConverter x:Key="LastValueToYConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Chart gradient brushes -->
        <LinearGradientBrush x:Key="CpuAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource AccentBrightCyan40}" Offset="0"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan10}" Offset="0.5"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="RamAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Success40}" Offset="0"/>
            <GradientStop Color="{DynamicResource Success10}" Offset="0.5"/>
            <GradientStop Color="{DynamicResource Success00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DownloadAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Success30}" Offset="0"/>
            <GradientStop Color="{DynamicResource Success08}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource Success00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="UploadAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource AccentBrightCyan30}" Offset="0"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan08}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DiskReadAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Success30}" Offset="0"/>
            <GradientStop Color="{DynamicResource Success08}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource Success00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DiskWriteAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Danger30}" Offset="0"/>
            <GradientStop Color="{DynamicResource Danger08}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource Danger00}" Offset="1"/>
        </LinearGradientBrush>

        <!-- Glow effect for chart lines -->
        <DropShadowEffect x:Key="ChartGlowCpu" Color="{DynamicResource Nord8}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="ChartGlowRam" Color="{DynamicResource Nord14}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="ChartGlowUpload" Color="{DynamicResource Nord8}" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
        <DropShadowEffect x:Key="ChartGlowDownload" Color="{DynamicResource Nord14}" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
        <DropShadowEffect x:Key="ChartGlowRead" Color="{DynamicResource Nord14}" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
        <DropShadowEffect x:Key="ChartGlowWrite" Color="{DynamicResource Nord11}" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>

        <TransformGroup x:Key="MonitorCardTransform" x:Shared="False">
            <ScaleTransform ScaleX="1" ScaleY="1"/>
            <TranslateTransform X="0" Y="12"/>
        </TransformGroup>

        <Style x:Key="MonitorCardRevealStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="{StaticResource MonitorCardTransform}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1"
                                             Duration="0:0:0.35"
                                             EasingFunction="{StaticResource CubicEaseOut}"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             From="12" To="0"
                                             Duration="0:0:0.35"
                                             EasingFunction="{StaticResource CubicEaseOut}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.015" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.015" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource MonitorCardRevealStyle}">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource MonitorCardRevealStyle}">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                    <TextBlock Text="Real-time system hardware monitoring" FontSize="14" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Save"
                        ToolTip="Saves a CSV snapshot to your Desktop."
                        Command="{Binding ExportMetricsCommand}"
                        Style="{StaticResource HeaderActionButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- System Information Section -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="System Information" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- OS Name -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Operating System" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.OsName}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- OS Version -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="OS Version" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.OsVersion}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- CPU Name -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Processor" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.CpuName}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
	                            <TextBlock FontSize="12" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,2,0,0">
	                                <Run Text="{Binding SystemInfo.CpuCores, Mode=OneWay}"/><Run Text=" Cores, "/><Run Text="{Binding SystemInfo.CpuThreads, Mode=OneWay}"/><Run Text=" Threads"/>
	                            </TextBlock>
                        </StackPanel>

                        <!-- GPU Name -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="Graphics Card" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.GpuName}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- Total RAM -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Total Memory" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
	                            <TextBlock FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium">
	                                <Run Text="{Binding SystemInfo.TotalRamGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB"/>
	                            </TextBlock>
                        </StackPanel>

                        <!-- Uptime -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="System Uptime" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.UptimeFormatted}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Stats Cards Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU Usage Card -->
                <Border Grid.Column="0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCpuAlertActive}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU Usage" FontSize="12" Foreground="{DynamicResource ForegroundLightBrush}"/>
                            <TextBlock Text="⚠ HIGH" FontSize="11" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Right" Visibility="{Binding IsCpuAlertActive, Converter={StaticResource BoolToVisibility}}"/>
                        </Grid>
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrightCyanBrush}" Margin="0,8,0,4">
                            <Run Text="{Binding CpuUsage, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%" FontSize="20"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- RAM Usage Card -->
                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRamAlertActive}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="RAM Usage" FontSize="12" Foreground="{DynamicResource ForegroundLightBrush}"/>
                            <TextBlock Text="⚠ HIGH" FontSize="11" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Right" Visibility="{Binding IsRamAlertActive, Converter={StaticResource BoolToVisibility}}"/>
                        </Grid>
                        <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,4">
                            <Run Text="{Binding RamUsedGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" / " FontSize="16" Foreground="{DynamicResource ForegroundLightBrush}"/><Run Text="{Binding RamTotalGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB" FontSize="16"/>
                        </TextBlock>
                        <TextBlock FontSize="14" Foreground="{DynamicResource ForegroundLightBrush}">
                            <Run Text="{Binding RamUsagePercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- CPU Temperature Card -->
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}"
                        ToolTip="CPU temperature sensor via LibreHardwareMonitor. Shows N/A if sensor data is unavailable (requires admin rights or hardware support).">
                    <StackPanel>
                        <TextBlock Text="CPU Temp" FontSize="12" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CpuTempText}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource CautionBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Sensor: LibreHardwareMonitor"
                                   FontSize="9"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Visibility="{Binding IsCpuTempAvailable, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- GPU Usage Card -->
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="GPU Usage" FontSize="12" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,8"/>
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,0,0,4">
                            <Run Text="{Binding GpuUsage, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%" FontSize="20"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- GPU Temperature Card -->
                <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="GPU Temp" FontSize="12" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding GpuTempText}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource InfoBrush}"
                                   Margin="0,0,0,4"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU History Chart -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU History (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding CpuHistoryMax, StringFormat={}{0:F0}%}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding CpuHistoryMin, StringFormat={}{0:F0}%}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Now: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}%}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <!-- Y-Axis Labels -->
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="30" Margin="0,0,5,0">
                                    <TextBlock Text="100%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="75%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Top" Margin="0,18,0,0"/>
                                    <TextBlock Text="50%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="25%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Center" Margin="0,16,0,0"/>
                                    <TextBlock Text="0%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Bottom" Margin="0,8,0,0"/>
                                </StackPanel>
                                <!-- Chart Area with Gridlines -->
                                <Border Margin="30,0,0,0" ClipToBounds="True">
                                    <Grid>
                                        <!-- Horizontal Gridlines -->
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Top"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Bottom" Margin="0,0,0,25"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Bottom"/>
                                        <!-- Area Fill -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Polygon Points="{Binding CpuHistory, Converter={StaticResource SparklineAreaConverter}, ConverterParameter=auto}"
                                                         Fill="{StaticResource CpuAreaGradient}"/>
                                            </Canvas>
                                        </Viewbox>
                                        <!-- Sparkline with glow -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Polyline Points="{Binding CpuHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                          Stroke="{DynamicResource AccentBrightCyanBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          Effect="{StaticResource ChartGlowCpu}"/>
                                            </Canvas>
                                        </Viewbox>
                                        <!-- Current value indicator dot -->
                                        <Canvas ClipToBounds="False">
                                            <Ellipse Width="10" Height="10" Fill="{DynamicResource AccentBrightCyanBrush}"
                                                     Canvas.Right="0"
                                                     Canvas.Top="{Binding CpuHistory, Converter={StaticResource LastValueToYConverter}, ConverterParameter=auto}">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="{DynamicResource Nord8}" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- RAM History Chart -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="RAM History (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding RamHistoryMax, StringFormat={}{0:F0}%}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding RamHistoryMin, StringFormat={}{0:F0}%}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Now: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding RamUsagePercent, StringFormat={}{0:F0}%}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <!-- Y-Axis Labels -->
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="30" Margin="0,0,5,0">
                                    <TextBlock Text="100%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="75%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Top" Margin="0,18,0,0"/>
                                    <TextBlock Text="50%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="25%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Center" Margin="0,16,0,0"/>
                                    <TextBlock Text="0%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Bottom" Margin="0,8,0,0"/>
                                </StackPanel>
                                <!-- Chart Area with Gridlines -->
                                <Border Margin="30,0,0,0" ClipToBounds="True">
                                    <Grid>
                                        <!-- Horizontal Gridlines -->
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Top"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Bottom" Margin="0,0,0,25"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Bottom"/>
                                        <!-- Area Fill -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Polygon Points="{Binding RamHistory, Converter={StaticResource SparklineAreaConverter}, ConverterParameter=auto}"
                                                         Fill="{StaticResource RamAreaGradient}"/>
                                            </Canvas>
                                        </Viewbox>
                                        <!-- Sparkline with glow -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Polyline Points="{Binding RamHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                          Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          Effect="{StaticResource ChartGlowRam}"/>
                                            </Canvas>
                                        </Viewbox>
                                        <!-- Current value indicator dot -->
                                        <Canvas ClipToBounds="False">
                                            <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}"
                                                     Canvas.Right="0"
                                                     Canvas.Top="{Binding RamHistory, Converter={StaticResource LastValueToYConverter}, ConverterParameter=auto}">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="{DynamicResource Nord14}" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Network and Disk I/O Charts Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Network I/O Chart -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Network I/O (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Down: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkDownloadNow, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkDownloadMax, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkDownloadMin, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Up: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkUploadNow, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkUploadMax, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkUploadMin, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <!-- Horizontal Gridlines -->
                                <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Top"/>
                                <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Bottom" Margin="0,0,0,25"/>
                                <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Bottom"/>
                                <!-- Download Area Fill -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polygon Points="{Binding NetworkDownloadHistory, Converter={StaticResource SparklineAreaConverter}, ConverterParameter=auto}"
                                                 Fill="{StaticResource DownloadAreaGradient}"/>
                                    </Canvas>
                                </Viewbox>
                                <!-- Upload Area Fill -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polygon Points="{Binding NetworkUploadHistory, Converter={StaticResource SparklineAreaConverter}, ConverterParameter=auto}"
                                                 Fill="{StaticResource UploadAreaGradient}"/>
                                    </Canvas>
                                </Viewbox>
                                <!-- Download Line with glow -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polyline Points="{Binding NetworkDownloadHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                  Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Effect="{StaticResource ChartGlowDownload}"/>
                                    </Canvas>
                                </Viewbox>
                                <!-- Upload Line with glow -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polyline Points="{Binding NetworkUploadHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                  Stroke="{DynamicResource AccentBrightCyanBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Effect="{StaticResource ChartGlowUpload}"/>
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Border>
                        <Grid Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Width="12" Height="12" Background="{DynamicResource SuccessBrush}" CornerRadius="2" Margin="0,0,6,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource Nord14}" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="Download" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Width="12" Height="12" Background="{DynamicResource AccentBrightCyanBrush}" CornerRadius="2" Margin="0,0,6,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource Nord8}" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="Upload" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Disk I/O Chart -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Disk I/O (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Read: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskReadNow, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskReadMax, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskReadMin, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Write: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskWriteNow, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource DangerBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskWriteMax, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource DangerBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskWriteMin, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource DangerBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <!-- Horizontal Gridlines -->
                                <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Top"/>
                                <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                <Rectangle Height="1" Fill="{DynamicResource BackgroundDarkBrush}" VerticalAlignment="Bottom" Margin="0,0,0,25"/>
                                <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundDarkBrush}" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Bottom"/>
                                <!-- Read Area Fill -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polygon Points="{Binding DiskReadHistory, Converter={StaticResource SparklineAreaConverter}, ConverterParameter=auto}"
                                                 Fill="{StaticResource DiskReadAreaGradient}"/>
                                    </Canvas>
                                </Viewbox>
                                <!-- Write Area Fill -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polygon Points="{Binding DiskWriteHistory, Converter={StaticResource SparklineAreaConverter}, ConverterParameter=auto}"
                                                 Fill="{StaticResource DiskWriteAreaGradient}"/>
                                    </Canvas>
                                </Viewbox>
                                <!-- Read Line with glow -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polyline Points="{Binding DiskReadHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                  Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Effect="{StaticResource ChartGlowRead}"/>
                                    </Canvas>
                                </Viewbox>
                                <!-- Write Line with glow -->
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="600" Height="100">
                                        <Polyline Points="{Binding DiskWriteHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                  Stroke="{DynamicResource DangerBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Effect="{StaticResource ChartGlowWrite}"/>
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Border>
                        <Grid Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Width="12" Height="12" Background="{DynamicResource SuccessBrush}" CornerRadius="2" Margin="0,0,6,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource Nord14}" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="Read" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Width="12" Height="12" Background="{DynamicResource DangerBrush}" CornerRadius="2" Margin="0,0,6,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource Nord11}" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="Write" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top Processes Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top CPU Processes -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="Top 10 Processes by CPU" Style="{StaticResource SectionHeaderStyle}"/>
                        <ItemsControl ItemsSource="{Binding TopProcessesByCpu}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                                                <TextBlock Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" Margin="0,2,0,0">
	                                                    <Run Text="PID: "/><Run Text="{Binding Pid, Mode=OneWay}"/>
	                                                    <Run Text=" | Threads: "/><Run Text="{Binding Threads, Mode=OneWay}"/>
	                                                    <Run Text=" | Handles: "/><Run Text="{Binding Handles, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0">
	                                                <Run Text="{Binding CpuPercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
                                            </TextBlock>
                                            <Button Grid.Column="2" Content="Kill"
                                                    Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource ForegroundOnAccentBrush}" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="3" Content="Suspend"
                                                    Command="{Binding DataContext.SuspendProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource CautionBrush}" Foreground="{DynamicResource ForegroundOnLightAccentBrush}" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="4" Content="Resume"
                                                    Command="{Binding DataContext.ResumeProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource ForegroundOnLightAccentBrush}" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Top RAM Processes -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Top 10 Processes by RAM" Style="{StaticResource SectionHeaderStyle}"/>
                        <ItemsControl ItemsSource="{Binding TopProcessesByRam}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                                                <TextBlock Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" Margin="0,2,0,0">
	                                                    <Run Text="PID: "/><Run Text="{Binding Pid, Mode=OneWay}"/>
	                                                    <Run Text=" | Threads: "/><Run Text="{Binding Threads, Mode=OneWay}"/>
	                                                    <Run Text=" | Handles: "/><Run Text="{Binding Handles, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0">
	                                                <Run Text="{Binding RamMb, StringFormat={}{0:F0}, Mode=OneWay}"/><Run Text=" MB"/>
                                            </TextBlock>
                                            <Button Grid.Column="2" Content="Kill"
                                                    Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource ForegroundOnAccentBrush}" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="3" Content="Suspend"
                                                    Command="{Binding DataContext.SuspendProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource CautionBrush}" Foreground="{DynamicResource ForegroundOnLightAccentBrush}" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="4" Content="Resume"
                                                    Command="{Binding DataContext.ResumeProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource ForegroundOnLightAccentBrush}" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top Network Processes -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Top 10 Processes by Network (Approx.)" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="Based on total process I/O bytes. May include disk activity."
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               FontSize="11"
                               Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding TopProcessesByNetwork}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                                            <TextBlock Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" Margin="0,2,0,0">
                                                <Run Text="PID: "/><Run Text="{Binding Pid, Mode=OneWay}"/>
                                                <Run Text=" | Threads: "/><Run Text="{Binding Threads, Mode=OneWay}"/>
                                                <Run Text=" | Handles: "/><Run Text="{Binding Handles, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0">
                                            <Run Text="{Binding IoMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
                                        </TextBlock>
                                        <Button Grid.Column="2" Content="Kill"
                                                Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource ForegroundOnAccentBrush}" BorderThickness="0"
                                                Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        <Button Grid.Column="3" Content="Suspend"
                                                Command="{Binding DataContext.SuspendProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource CautionBrush}" Foreground="{DynamicResource ForegroundOnLightAccentBrush}" BorderThickness="0"
                                                Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        <Button Grid.Column="4" Content="Resume"
                                                Command="{Binding DataContext.ResumeProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource ForegroundOnLightAccentBrush}" BorderThickness="0"
                                                Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Network Adapters Section -->
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Network Adapters" Style="{StaticResource SectionHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding NetworkAdapters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding Type}" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="Download" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
	                                            <TextBlock Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding ReceiveMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
	                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="16,0,0,0">
                                            <TextBlock Text="Upload" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
	                                            <TextBlock Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding SendMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
	                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="16,0,0,0">
                                            <TextBlock Text="Total Received" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
	                                            <TextBlock Foreground="{DynamicResource CautionBrush}" FontWeight="Medium" FontSize="12">
	                                                <Run Text="{Binding TotalBytesReceived, StringFormat={}{0:N0}, Mode=OneWay}"/><Run Text=" bytes"/>
	                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Disks Section -->
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Disk Activity" Style="{StaticResource SectionHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Drive Letter -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DriveLetter}"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                        <!-- Disk Space Info -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
	                                            <TextBlock FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}">
	                                                <Run Text="{Binding UsedSpaceGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB used of "/><Run Text="{Binding TotalSizeGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB"/>
	                                            </TextBlock>
	                                            <TextBlock FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,2,0,0">
	                                                <Run Text="{Binding FreeSpaceGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB free"/>
	                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Read Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0">
                                            <TextBlock Text="Read" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
	                                            <TextBlock Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding ReadMBps, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" MB/s"/>
	                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Write Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="8,0">
                                            <TextBlock Text="Write" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
	                                            <TextBlock Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding WriteMBps, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" MB/s"/>
	                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Usage Percent -->
                                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="8,0,0,0">
                                            <TextBlock Text="Usage" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11"/>
	                                            <TextBlock Foreground="{DynamicResource CautionBrush}" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding UsedPercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
	                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
