        <DataTemplate x:Key="MonitorTopCpuTemplate">
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Top 10 Processes by CPU" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Process" Style="{StaticResource ProcessHeaderCellStyle}"/>
                        <TextBlock Grid.Column="1" Text="CPU" Style="{StaticResource ProcessHeaderCellStyle}" Margin="12,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="RAM" Style="{StaticResource ProcessHeaderCellStyle}" Margin="12,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="PID" Style="{StaticResource ProcessHeaderCellStyle}" Margin="12,0,0,0"/>
                        <TextBlock Grid.Column="4" Text="Actions" Style="{StaticResource ProcessHeaderCellStyle}" Margin="12,0,0,0"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding TopProcessesByCpu}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource ProcessCellStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="{DynamicResource ForegroundLightBrush}" FontSize="10" Margin="0,2,0,0">
                                                <Run Text="Threads: "/><Run Text="{Binding Threads, Mode=OneWay}"/>
                                                <Run Text="  Handles: "/><Run Text="{Binding Handles, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Foreground="{DynamicResource AccentBrightCyanBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Run Text="{Binding CpuPercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Run Text="{Binding RamMb, StringFormat={}{0:F0}, Mode=OneWay}"/><Run Text=" MB"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="3" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Run Text="{Binding Pid, Mode=OneWay}"/>
                                        </TextBlock>
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0,0,0">
                                            <Button Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
