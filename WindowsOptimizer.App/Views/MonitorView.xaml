                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- RAM History Chart -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="RAM History (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding RamHistoryMax, StringFormat={}{0:F0}%}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding RamHistoryMin, StringFormat={}{0:F0}%}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Now: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding RamUsagePercent, StringFormat={}{0:F0}%}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <!-- Y-Axis Labels -->
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="30" Margin="0,0,5,0">
                                    <TextBlock Text="{Binding RamHistoryScaleMax, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding RamHistoryScaleThreeQuarter, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Top" Margin="0,18,0,0"/>
                                    <TextBlock Text="{Binding RamHistoryScaleMid, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding RamHistoryScaleQuarter, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Center" Margin="0,16,0,0"/>
                                    <TextBlock Text="0%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Bottom" Margin="0,8,0,0"/>
                                </StackPanel>
                                <!-- Chart Area with Gridlines -->
                                <Border Margin="30,0,0,0" ClipToBounds="True">
                                    <Grid>
                                        <!-- Horizontal Gridlines -->
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Top"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundLightBrush}" Opacity="0.35" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundLightBrush}" Opacity="0.35" VerticalAlignment="Bottom" Margin="0,0,0,25"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Bottom"/>
                                        <!-- Area Fill -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Polygon Points="{Binding RamHistory, Converter={StaticResource SparklineAreaConverter}}"
                                                         Fill="{StaticResource RamAreaGradient}"/>
                                            </Canvas>
                                        </Viewbox>
                                        <!-- Sparkline with glow (GPU-accelerated) -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Canvas.CacheMode>
                                                    <BitmapCache EnableClearType="True" RenderAtScale="1"/>
                                                </Canvas.CacheMode>
                                                <Polyline Points="{Binding RamHistory, Converter={StaticResource SparklinePointsConverter}}"
                                                          Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                        <!-- Current value indicator dot -->
                                        <Canvas ClipToBounds="False">
                                            <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}"
                                                     Canvas.Right="0"
                                                     Canvas.Top="{Binding RamHistory, Converter={StaticResource LastValueToYConverter}}"/>
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MonitorIoChartsTemplate">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Network I/O Chart -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Network I/O (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Down: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkDownloadNow, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkDownloadMax, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkDownloadMin, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Up: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkUploadNow, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkUploadMax, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding NetworkUploadMin, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding NetworkIoScaleMax, StringFormat=Scale: {0:F1} Mbps peak}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       FontSize="11"
                                       Margin="0,-4,0,0"/>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                    <TextBlock Text="{Binding NetworkIoScaleMax, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding NetworkIoScaleMid, StringFormat={}{0:F1} Mbps}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Center" Margin="0,12,0,0"/>
                                    <TextBlock Text="0 Mbps" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Bottom" Margin="0,12,0,0"/>
                                </StackPanel>
                                <Grid Grid.Column="1" Margin="6,0,0,0">
                                    <!-- Horizontal Gridlines -->
                                    <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Top"/>
                                    <Rectangle Height="1" Fill="{DynamicResource BackgroundLightBrush}" Opacity="0.35" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                    <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                    <Rectangle Height="1" Fill="{DynamicResource BackgroundLightBrush}" Opacity="0.35" VerticalAlignment="Bottom" Margin="0,0,0,25"/>
                                    <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Bottom"/>
                                    <!-- Download Area Fill -->
                                    <Viewbox Stretch="Fill">
                                        <Canvas Width="600" Height="100">
                                            <Polygon Fill="{StaticResource DownloadAreaGradient}">
                                                <Polygon.Points>
                                                    <MultiBinding Converter="{StaticResource SparklineAreaWithMaxConverter}">
                                                        <Binding Path="NetworkDownloadHistory"/>
                                                        <Binding Path="NetworkIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polygon.Points>
                                            </Polygon>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Upload Area Fill -->
                                    <Viewbox Stretch="Fill">
                                        <Canvas Width="600" Height="100">
                                            <Polygon Fill="{StaticResource UploadAreaGradient}">
                                                <Polygon.Points>
                                                    <MultiBinding Converter="{StaticResource SparklineAreaWithMaxConverter}">
                                                        <Binding Path="NetworkUploadHistory"/>
                                                        <Binding Path="NetworkIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polygon.Points>
                                            </Polygon>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Download Line with glow -->
                                    <Viewbox Stretch="Fill">
                                        <Canvas Width="600" Height="100">
                                            <Polyline Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                <Polyline.Points>
                                                    <MultiBinding Converter="{StaticResource SparklinePointsWithMaxConverter}">
                                                        <Binding Path="NetworkDownloadHistory"/>
                                                        <Binding Path="NetworkIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polyline.Points>
                                            </Polyline>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Upload Line with glow -->
                                    <Viewbox Stretch="Fill">
                                        <Canvas Width="600" Height="100">
                                            <Polyline Stroke="{DynamicResource AccentBrightCyanBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                <Polyline.Points>
                                                    <MultiBinding Converter="{StaticResource SparklinePointsWithMaxConverter}">
                                                        <Binding Path="NetworkUploadHistory"/>
                                                        <Binding Path="NetworkIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polyline.Points>
                                            </Polyline>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Current value indicators -->
                                    <Canvas ClipToBounds="False">
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}" Canvas.Right="0">
                                            <Canvas.Top>
                                                <MultiBinding Converter="{StaticResource LastValueToYWithMaxConverter}">
                                                    <Binding Path="NetworkDownloadHistory"/>
                                                    <Binding Path="NetworkIoScaleMax"/>
                                                </MultiBinding>
                                            </Canvas.Top>
                                        </Ellipse>
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource AccentBrightCyanBrush}" Canvas.Right="0">
                                            <Canvas.Top>
                                                <MultiBinding Converter="{StaticResource LastValueToYWithMaxConverter}">
                                                    <Binding Path="NetworkUploadHistory"/>
                                                    <Binding Path="NetworkIoScaleMax"/>
                                                </MultiBinding>
                                            </Canvas.Top>
                                        </Ellipse>
                                    </Canvas>
                                </Grid>
                            </Grid>
                        </Border>
                        <Grid Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Width="12" Height="12" Background="{DynamicResource SuccessBrush}" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Download" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Width="12" Height="12" Background="{DynamicResource AccentBrightCyanBrush}" CornerRadius="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Upload" Foreground="{DynamicResource ForegroundLightBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Disk I/O Chart -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Disk I/O (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Read: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskReadNow, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskReadMax, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskReadMin, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Write: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskWriteNow, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource DangerBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskWriteMax, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource DangerBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding DiskWriteMin, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource DangerBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding DiskIoScaleMax, StringFormat=Scale: {0:F1} MB/s peak}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       FontSize="11"
                                       Margin="0,-4,0,0"/>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                    <TextBlock Text="{Binding DiskIoScaleMax, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding DiskIoScaleMid, StringFormat={}{0:F1} MB/s}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Center" Margin="0,12,0,0"/>
                                    <TextBlock Text="0 MB/s" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Bottom" Margin="0,12,0,0"/>
                                </StackPanel>
                                <Grid Grid.Column="1" Margin="6,0,0,0">
