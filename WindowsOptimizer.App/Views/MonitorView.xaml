                                                        <Binding Path="DiskReadHistory"/>
                                                        <Binding Path="DiskIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polygon.Points>
                                            </Polygon>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Write Area Fill -->
                                    <Viewbox Stretch="Fill">
                                        <Canvas Width="600" Height="100">
                                            <Polygon Fill="{StaticResource DiskWriteAreaGradient}">
                                                <Polygon.Points>
                                                    <MultiBinding Converter="{StaticResource SparklineAreaWithMaxConverter}">
                                                        <Binding Path="DiskWriteHistory"/>
                                                        <Binding Path="DiskIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polygon.Points>
                                            </Polygon>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Read Line with glow -->
                                    <Viewbox Stretch="Fill">
                                        <Canvas Width="600" Height="100">
                                            <Polyline Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                <Polyline.Points>
                                                    <MultiBinding Converter="{StaticResource SparklinePointsWithMaxConverter}">
                                                        <Binding Path="DiskReadHistory"/>
                                                        <Binding Path="DiskIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polyline.Points>
                                            </Polyline>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Write Line with glow -->
                                    <Viewbox Stretch="Fill">
                                        <Canvas Width="600" Height="100">
                                            <Polyline Stroke="{DynamicResource DangerBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                <Polyline.Points>
                                                    <MultiBinding Converter="{StaticResource SparklinePointsWithMaxConverter}">
                                                        <Binding Path="DiskWriteHistory"/>
                                                        <Binding Path="DiskIoScaleMax"/>
                                                    </MultiBinding>
                                                </Polyline.Points>
                                            </Polyline>
                                        </Canvas>
                                    </Viewbox>
                                    <!-- Current value indicators -->
                                    <Canvas ClipToBounds="False">
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}" Canvas.Right="0">
                                            <Canvas.Top>
                                                <MultiBinding Converter="{StaticResource LastValueToYWithMaxConverter}">
                                                    <Binding Path="DiskReadHistory"/>
                                                    <Binding Path="DiskIoScaleMax"/>
