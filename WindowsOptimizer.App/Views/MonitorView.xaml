<UserControl x:Class="WindowsOptimizer.App.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="StepIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#4C566A"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.InProgress}">
                    <Setter Property="Fill" Value="#EBCB8B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Success}">
                    <Setter Property="Fill" Value="#A3BE8C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Failed}">
                    <Setter Property="Fill" Value="#BF616A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Skipped}">
                    <Setter Property="Fill" Value="#4C566A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.NotApplicable}">
                    <Setter Property="Fill" Value="#4C566A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="StepCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.InProgress}">
                    <Setter Property="BorderBrush" Value="#EBCB8B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Success}">
                    <Setter Property="BorderBrush" Value="#A3BE8C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static viewModels:TweakStepState.Failed}">
                    <Setter Property="BorderBrush" Value="#BF616A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonitorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5E81AC"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#81A1C1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource MonitorButtonStyle}">
            <Setter Property="Background" Value="#434C5E"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource MonitorButtonStyle}">
            <Setter Property="Background" Value="#BF616A"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#2E3440" Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding Title}" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#ECEFF4"/>
            <TextBlock Margin="0,6,0,0"
                       Text="Live status for the tweak execution pipeline."
                       Foreground="#88C0D0"
                       FontSize="14"/>
        </StackPanel>

        <!-- Current Tweak Status Card -->
        <Border Grid.Row="1"
                Background="#3B4252"
                BorderBrush="#4C566A"
                BorderThickness="1"
                CornerRadius="12"
                Margin="0,0,0,24"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#5E81AC" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                            <TextBlock Text="🔄" FontSize="16"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentTweakName}" 
                                       FontSize="16"
                                       FontWeight="SemiBold" 
                                       Foreground="#ECEFF4"/>
                            <TextBlock Text="{Binding StatusMessage}" 
                                       Foreground="#88C0D0"
                                       FontSize="13"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Background="#434C5E" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding LastUpdatedText}" Foreground="#4C566A" FontSize="10"/>
                        </Border>
                        <Border Background="#434C5E" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="{Binding RunModeLabel}" Foreground="#4C566A" FontSize="10"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶ Preview"
                            Command="{Binding RunPreviewCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="⚡ Apply"
                            Command="{Binding RunApplyCommand}"
                            Style="{StaticResource MonitorButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="✕ Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Step Cards -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Steps}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource StepCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Style="{StaticResource StepIndicatorStyle}" Margin="0,2,8,0"/>
                                <TextBlock Text="{Binding ActionLabel}" 
                                           FontSize="14" 
                                           FontWeight="SemiBold"
                                           Foreground="#ECEFF4"/>
                            </StackPanel>
                            <TextBlock Text="{Binding StatusText}" 
                                       Foreground="#88C0D0"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding Message}"
                                       Foreground="#D8DEE9"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding TimestampText}"
                                       Foreground="#4C566A"
                                       FontSize="10"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
