<UserControl x:Class="WindowsOptimizer.App.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             xmlns:converters="clr-namespace:WindowsOptimizer.App.ViewModels"
             mc:Ignorable="d"
             Background="#2E3440">

    <UserControl.Resources>
        <converters:SparklinePointsConverter x:Key="SparklinePointsConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#434C5E"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderBrush" Value="#4C566A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="#ECEFF4"/>
                    <TextBlock Text="Real-time system hardware monitoring" FontSize="14" Foreground="#D8DEE9" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Save"
                        ToolTip="Saves a CSV snapshot to your Desktop."
                        Command="{Binding ExportMetricsCommand}"
                        Style="{StaticResource HeaderActionButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- System Information Section -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="System Information" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- OS Name -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Operating System" FontSize="11" Foreground="#D8DEE9" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.OsName}" FontSize="14" Foreground="#ECEFF4" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- OS Version -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="OS Version" FontSize="11" Foreground="#D8DEE9" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.OsVersion}" FontSize="14" Foreground="#ECEFF4" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- CPU Name -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Processor" FontSize="11" Foreground="#D8DEE9" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.CpuName}" FontSize="14" Foreground="#ECEFF4" FontWeight="Medium"/>
	                            <TextBlock FontSize="12" Foreground="#D8DEE9" Margin="0,2,0,0">
	                                <Run Text="{Binding SystemInfo.CpuCores, Mode=OneWay}"/><Run Text=" Cores, "/><Run Text="{Binding SystemInfo.CpuThreads, Mode=OneWay}"/><Run Text=" Threads"/>
	                            </TextBlock>
                        </StackPanel>

                        <!-- GPU Name -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="Graphics Card" FontSize="11" Foreground="#D8DEE9" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.GpuName}" FontSize="14" Foreground="#ECEFF4" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- Total RAM -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Total Memory" FontSize="11" Foreground="#D8DEE9" Margin="0,0,0,4"/>
	                            <TextBlock FontSize="14" Foreground="#ECEFF4" FontWeight="Medium">
	                                <Run Text="{Binding SystemInfo.TotalRamGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB"/>
	                            </TextBlock>
                        </StackPanel>

                        <!-- Uptime -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="System Uptime" FontSize="11" Foreground="#D8DEE9" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.UptimeFormatted}" FontSize="14" Foreground="#ECEFF4" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Stats Cards Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU Usage Card -->
                <Border Grid.Column="0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCpuAlertActive}" Value="True">
                                    <Setter Property="BorderBrush" Value="#BF616A"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU Usage" FontSize="12" Foreground="#D8DEE9"/>
                            <TextBlock Text="⚠ HIGH" FontSize="11" Foreground="#BF616A" FontWeight="Bold"
                                       HorizontalAlignment="Right" Visibility="{Binding IsCpuAlertActive, Converter={StaticResource BoolToVisibility}}"/>
                        </Grid>
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="#88C0D0" Margin="0,8,0,4">
                            <Run Text="{Binding CpuUsage, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%" FontSize="20"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- RAM Usage Card -->
                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRamAlertActive}" Value="True">
                                    <Setter Property="BorderBrush" Value="#BF616A"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="RAM Usage" FontSize="12" Foreground="#D8DEE9"/>
                            <TextBlock Text="⚠ HIGH" FontSize="11" Foreground="#BF616A" FontWeight="Bold"
                                       HorizontalAlignment="Right" Visibility="{Binding IsRamAlertActive, Converter={StaticResource BoolToVisibility}}"/>
                        </Grid>
                        <TextBlock FontSize="24" FontWeight="Bold" Foreground="#A3BE8C" Margin="0,8,0,4">
                            <Run Text="{Binding RamUsedGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" / " FontSize="16" Foreground="#D8DEE9"/><Run Text="{Binding RamTotalGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB" FontSize="16"/>
                        </TextBlock>
                        <TextBlock FontSize="14" Foreground="#D8DEE9">
                            <Run Text="{Binding RamUsagePercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- CPU Temperature Card -->
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}"
                        ToolTip="CPU temperature sensor via LibreHardwareMonitor. Shows N/A if sensor data is unavailable (requires admin rights or hardware support).">
                    <StackPanel>
                        <TextBlock Text="CPU Temp" FontSize="12" Foreground="#D8DEE9" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CpuTempText}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#EBCB8B"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Sensor: LibreHardwareMonitor"
                                   FontSize="9"
                                   Foreground="#4C566A"
                                   Visibility="{Binding IsCpuTempAvailable, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- GPU Usage Card -->
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="GPU Usage" FontSize="12" Foreground="#D8DEE9" Margin="0,0,0,8"/>
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="#81A1C1" Margin="0,0,0,4">
                            <Run Text="{Binding GpuUsage, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%" FontSize="20"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- GPU Temperature Card -->
                <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="GPU Temp" FontSize="12" Foreground="#D8DEE9" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding GpuTempText}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#B48EAD"
                                   Margin="0,0,0,4"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU History Chart -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU History (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="Max: " Foreground="#4C566A" FontSize="11"/>
                                <TextBlock Text="{Binding CpuHistoryMax, StringFormat={}{0:F0}%}" Foreground="#88C0D0" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Min: " Foreground="#4C566A" FontSize="11"/>
                                <TextBlock Text="{Binding CpuHistoryMin, StringFormat={}{0:F0}%}" Foreground="#88C0D0" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="#2E3440" CornerRadius="8" Padding="10">
                            <Grid>
                                <!-- Y-Axis Labels -->
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="30" Margin="0,0,5,0">
                                    <TextBlock Text="100%" Foreground="#4C566A" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="50%" Foreground="#4C566A" FontSize="9" VerticalAlignment="Center" Margin="0,35,0,0"/>
                                    <TextBlock Text="0%" Foreground="#4C566A" FontSize="9" VerticalAlignment="Bottom" Margin="0,35,0,0"/>
                                </StackPanel>
                                <!-- Chart Area with Gridlines -->
                                <Border Margin="30,0,0,0">
                                    <Grid>
                                        <!-- Horizontal Gridlines -->
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#3B4252" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Top"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#3B4252" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#3B4252" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Bottom"/>
                                        <!-- Sparkline -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Polyline Points="{Binding CpuHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                          Stroke="#88C0D0" StrokeThickness="2"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- RAM History Chart -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="RAM History (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="Max: " Foreground="#4C566A" FontSize="11"/>
                                <TextBlock Text="{Binding RamHistoryMax, StringFormat={}{0:F0}%}" Foreground="#A3BE8C" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Min: " Foreground="#4C566A" FontSize="11"/>
                                <TextBlock Text="{Binding RamHistoryMin, StringFormat={}{0:F0}%}" Foreground="#A3BE8C" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="#2E3440" CornerRadius="8" Padding="10">
                            <Grid>
                                <!-- Y-Axis Labels -->
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="30" Margin="0,0,5,0">
                                    <TextBlock Text="100%" Foreground="#4C566A" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="50%" Foreground="#4C566A" FontSize="9" VerticalAlignment="Center" Margin="0,35,0,0"/>
                                    <TextBlock Text="0%" Foreground="#4C566A" FontSize="9" VerticalAlignment="Bottom" Margin="0,35,0,0"/>
                                </StackPanel>
                                <!-- Chart Area with Gridlines -->
                                <Border Margin="30,0,0,0">
                                    <Grid>
                                        <!-- Horizontal Gridlines -->
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#3B4252" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Top"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#3B4252" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="#3B4252" StrokeThickness="1" Stretch="Fill" VerticalAlignment="Bottom"/>
                                        <!-- Sparkline -->
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="600" Height="100">
                                                <Polyline Points="{Binding RamHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                                          Stroke="#A3BE8C" StrokeThickness="2"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Network and Disk I/O Charts Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Network I/O Chart -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="Network I/O (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Height="120" Background="#2E3440" CornerRadius="8" Padding="10">
                            <Viewbox Stretch="Fill">
                                <Canvas Width="600" Height="100">
                                    <Polyline Points="{Binding NetworkDownloadHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                              Stroke="#A3BE8C" StrokeThickness="2"/>
                                    <Polyline Points="{Binding NetworkUploadHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                              Stroke="#88C0D0" StrokeThickness="2"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <Grid Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Width="12" Height="12" Background="#A3BE8C" Margin="0,0,4,0"/>
                                <TextBlock Text="Download" Foreground="#D8DEE9" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Width="12" Height="12" Background="#88C0D0" Margin="0,0,4,0"/>
                                <TextBlock Text="Upload" Foreground="#D8DEE9" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Disk I/O Chart -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Disk I/O (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Height="120" Background="#2E3440" CornerRadius="8" Padding="10">
                            <Viewbox Stretch="Fill">
                                <Canvas Width="600" Height="100">
                                    <Polyline Points="{Binding DiskReadHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                              Stroke="#A3BE8C" StrokeThickness="2"/>
                                    <Polyline Points="{Binding DiskWriteHistory, Converter={StaticResource SparklinePointsConverter}, ConverterParameter=auto}"
                                              Stroke="#BF616A" StrokeThickness="2"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <Grid Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Width="12" Height="12" Background="#A3BE8C" Margin="0,0,4,0"/>
                                <TextBlock Text="Read" Foreground="#D8DEE9" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Width="12" Height="12" Background="#BF616A" Margin="0,0,4,0"/>
                                <TextBlock Text="Write" Foreground="#D8DEE9" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top Processes Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top CPU Processes -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="Top 10 Processes by CPU" Style="{StaticResource SectionHeaderStyle}"/>
                        <ItemsControl ItemsSource="{Binding TopProcessesByCpu}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2E3440" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="#ECEFF4" FontWeight="Medium"/>
                                                <TextBlock Foreground="#D8DEE9" FontSize="11" Margin="0,2,0,0">
	                                                    <Run Text="PID: "/><Run Text="{Binding Pid, Mode=OneWay}"/>
	                                                    <Run Text=" | Threads: "/><Run Text="{Binding Threads, Mode=OneWay}"/>
	                                                    <Run Text=" | Handles: "/><Run Text="{Binding Handles, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Foreground="#88C0D0" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0">
	                                                <Run Text="{Binding CpuPercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
                                            </TextBlock>
                                            <Button Grid.Column="2" Content="Kill"
                                                    Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#BF616A" Foreground="White" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="3" Content="Suspend"
                                                    Command="{Binding DataContext.SuspendProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#EBCB8B" Foreground="#2E3440" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="4" Content="Resume"
                                                    Command="{Binding DataContext.ResumeProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#A3BE8C" Foreground="White" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Top RAM Processes -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Top 10 Processes by RAM" Style="{StaticResource SectionHeaderStyle}"/>
                        <ItemsControl ItemsSource="{Binding TopProcessesByRam}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2E3440" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="#ECEFF4" FontWeight="Medium"/>
                                                <TextBlock Foreground="#D8DEE9" FontSize="11" Margin="0,2,0,0">
	                                                    <Run Text="PID: "/><Run Text="{Binding Pid, Mode=OneWay}"/>
	                                                    <Run Text=" | Threads: "/><Run Text="{Binding Threads, Mode=OneWay}"/>
	                                                    <Run Text=" | Handles: "/><Run Text="{Binding Handles, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Foreground="#A3BE8C" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0">
	                                                <Run Text="{Binding RamMb, StringFormat={}{0:F0}, Mode=OneWay}"/><Run Text=" MB"/>
                                            </TextBlock>
                                            <Button Grid.Column="2" Content="Kill"
                                                    Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#BF616A" Foreground="White" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="3" Content="Suspend"
                                                    Command="{Binding DataContext.SuspendProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#EBCB8B" Foreground="#2E3440" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                            <Button Grid.Column="4" Content="Resume"
                                                    Command="{Binding DataContext.ResumeProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#A3BE8C" Foreground="White" BorderThickness="0"
                                                    Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top Network Processes -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Top 10 Processes by Network (Approx.)" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="Based on total process I/O bytes. May include disk activity."
                               Foreground="#4C566A"
                               FontSize="11"
                               Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding TopProcessesByNetwork}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2E3440" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="#ECEFF4" FontWeight="Medium"/>
                                            <TextBlock Foreground="#D8DEE9" FontSize="11" Margin="0,2,0,0">
                                                <Run Text="PID: "/><Run Text="{Binding Pid, Mode=OneWay}"/>
                                                <Run Text=" | Threads: "/><Run Text="{Binding Threads, Mode=OneWay}"/>
                                                <Run Text=" | Handles: "/><Run Text="{Binding Handles, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Foreground="#88C0D0" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0">
                                            <Run Text="{Binding IoMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
                                        </TextBlock>
                                        <Button Grid.Column="2" Content="Kill"
                                                Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#BF616A" Foreground="White" BorderThickness="0"
                                                Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        <Button Grid.Column="3" Content="Suspend"
                                                Command="{Binding DataContext.SuspendProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#EBCB8B" Foreground="#2E3440" BorderThickness="0"
                                                Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                        <Button Grid.Column="4" Content="Resume"
                                                Command="{Binding DataContext.ResumeProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#A3BE8C" Foreground="White" BorderThickness="0"
                                                Padding="8,4" Margin="4,0" FontSize="11" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Network Adapters Section -->
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Network Adapters" Style="{StaticResource SectionHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding NetworkAdapters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2E3440" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Foreground="#ECEFF4" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding Type}" Foreground="#D8DEE9" FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="Download" Foreground="#D8DEE9" FontSize="11"/>
	                                            <TextBlock Foreground="#A3BE8C" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding ReceiveMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
	                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="16,0,0,0">
                                            <TextBlock Text="Upload" Foreground="#D8DEE9" FontSize="11"/>
	                                            <TextBlock Foreground="#88C0D0" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding SendMbps, StringFormat={}{0:F2}, Mode=OneWay}"/><Run Text=" Mbps"/>
	                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="16,0,0,0">
                                            <TextBlock Text="Total Received" Foreground="#D8DEE9" FontSize="11"/>
	                                            <TextBlock Foreground="#EBCB8B" FontWeight="Medium" FontSize="12">
	                                                <Run Text="{Binding TotalBytesReceived, StringFormat={}{0:N0}, Mode=OneWay}"/><Run Text=" bytes"/>
	                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Disks Section -->
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Disk Activity" Style="{StaticResource SectionHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2E3440" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Drive Letter -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DriveLetter}"
                                                   Foreground="#ECEFF4" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                        <!-- Disk Space Info -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
	                                            <TextBlock FontSize="11" Foreground="#D8DEE9">
	                                                <Run Text="{Binding UsedSpaceGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB used of "/><Run Text="{Binding TotalSizeGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB"/>
	                                            </TextBlock>
	                                            <TextBlock FontSize="11" Foreground="#D8DEE9" Margin="0,2,0,0">
	                                                <Run Text="{Binding FreeSpaceGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB free"/>
	                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Read Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0">
                                            <TextBlock Text="Read" Foreground="#D8DEE9" FontSize="11"/>
	                                            <TextBlock Foreground="#A3BE8C" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding ReadMBps, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" MB/s"/>
	                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Write Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="8,0">
                                            <TextBlock Text="Write" Foreground="#D8DEE9" FontSize="11"/>
	                                            <TextBlock Foreground="#BF616A" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding WriteMBps, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" MB/s"/>
	                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Usage Percent -->
                                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="8,0,0,0">
                                            <TextBlock Text="Usage" Foreground="#D8DEE9" FontSize="11"/>
	                                            <TextBlock Foreground="#EBCB8B" FontWeight="Bold" FontSize="14">
	                                                <Run Text="{Binding UsedPercent, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text="%"/>
	                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
