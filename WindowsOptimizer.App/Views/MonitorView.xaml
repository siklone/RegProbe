<UserControl x:Class="WindowsOptimizer.App.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels"
             xmlns:converters="clr-namespace:WindowsOptimizer.App.ViewModels"
             xmlns:hardware="clr-namespace:WindowsOptimizer.App.ViewModels.Hardware"
             xmlns:utils="clr-namespace:WindowsOptimizer.App.Utilities"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundDarkestBrush}">

    <UserControl.Resources>
        <converters:SparklinePointsConverter x:Key="SparklinePointsConverter"/>
        <converters:SparklineAreaConverter x:Key="SparklineAreaConverter"/>
        <converters:LastValueToYConverter x:Key="LastValueToYConverter"/>
        <converters:SparklinePointsWithMaxConverter x:Key="SparklinePointsWithMaxConverter"/>
        <converters:SparklineAreaWithMaxConverter x:Key="SparklineAreaWithMaxConverter"/>
        <converters:LastValueToYWithMaxConverter x:Key="LastValueToYWithMaxConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <!-- Chart gradient brushes -->
        <LinearGradientBrush x:Key="CpuAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource AccentBrightCyan40}" Offset="0"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan20}" Offset="0.5"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="RamAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Success40}" Offset="0"/>
            <GradientStop Color="{DynamicResource Success20}" Offset="0.5"/>
            <GradientStop Color="{DynamicResource Success00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DownloadAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Success40}" Offset="0"/>
            <GradientStop Color="{DynamicResource Success20}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource Success00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="UploadAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource AccentBrightCyan40}" Offset="0"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan20}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource AccentBrightCyan00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DiskReadAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Success40}" Offset="0"/>
            <GradientStop Color="{DynamicResource Success20}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource Success00}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DiskWriteAreaGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource Danger40}" Offset="0"/>
            <GradientStop Color="{DynamicResource Danger20}" Offset="0.7"/>
            <GradientStop Color="{DynamicResource Danger00}" Offset="1"/>
        </LinearGradientBrush>

        <!-- Glow effect for chart lines -->
        <DropShadowEffect x:Key="ChartGlowCpu" Color="{DynamicResource Nord8}" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
        <DropShadowEffect x:Key="ChartGlowRam" Color="{DynamicResource Nord14}" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
        <DropShadowEffect x:Key="ChartGlowUpload" Color="{DynamicResource Nord8}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="ChartGlowDownload" Color="{DynamicResource Nord14}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="ChartGlowRead" Color="{DynamicResource Nord14}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="ChartGlowWrite" Color="{DynamicResource Nord11}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>

        <TransformGroup x:Key="MonitorCardTransform" x:Shared="False">
            <ScaleTransform ScaleX="1" ScaleY="1"/>
            <TranslateTransform X="0" Y="12"/>
        </TransformGroup>

        <Style x:Key="MonitorCardRevealStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="{StaticResource MonitorCardTransform}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1"
                                             Duration="0:0:0.35"
                                             EasingFunction="{StaticResource CubicEaseOut}"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             From="12" To="0"
                                             Duration="0:0:0.35"
                                             EasingFunction="{StaticResource CubicEaseOut}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.015" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.015" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource MonitorCardRevealStyle}">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinHeight" Value="85"/>
            <!-- GPU Cache for smoother rendering -->
            <Setter Property="CacheMode">
                <Setter.Value>
                    <BitmapCache EnableClearType="True" RenderAtScale="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <!-- Animated hover effect -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.02" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.02" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Expandable card style with detail section -->
        <Style x:Key="ExpandableStatCardStyle" TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
            <Setter Property="Tag" Value="Collapsed"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Tag" Value="Expanded"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource MonitorCardRevealStyle}">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <!-- GPU Cache for smoother rendering -->
            <Setter Property="CacheMode">
                <Setter.Value>
                    <BitmapCache EnableClearType="True" RenderAtScale="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundDarkestBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="MonitorTabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="{Binding Subtitle}"
                                           FontSize="10"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProcessCategoryTabStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="{Binding Subtitle}"
                                           FontSize="9"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProcessHeaderCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ProcessCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ProcessActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Border x:Name="HoverOverlay"
                                        Background="{DynamicResource BackgroundLightBrush}"
                                        CornerRadius="4"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.05" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.05" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.95" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.95" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.0" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="BorderScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LayoutCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LayoutMoveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundDarkestBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LayoutScrimButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ScrimOverlayBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Opacity="{TemplateBinding Opacity}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLayoutEditorVisible}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1"
                                                 Duration="0:0:0.14"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.1"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LayoutDialogStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ShadowColorLarge}"
                                      BlurRadius="26"
                                      ShadowDepth="8"
                                      Direction="270"
                                      Opacity="0.35"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLayoutEditorVisible}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1"
                                                 Duration="0:0:0.16"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 From="0.96" To="1"
                                                 Duration="0:0:0.16"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 From="0.96" To="1"
                                                 Duration="0:0:0.16"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.1"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="0.98"
                                                 Duration="0:0:0.1"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="0.98"
                                                 Duration="0:0:0.1"
                                                 EasingFunction="{StaticResource EaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="MonitorSystemInfoTemplate">
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="System Information" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- OS Name -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Operating System" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.OsName}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- OS Version -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="OS Version" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.OsVersion}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- CPU Name -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Processor" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.CpuName}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,2,0,0">
                                <Run Text="{Binding SystemInfo.CpuCores, Mode=OneWay}"/><Run Text=" Cores, "/><Run Text="{Binding SystemInfo.CpuThreads, Mode=OneWay}"/><Run Text=" Threads"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- GPU Name -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="Graphics Card" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.GpuName}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- Total RAM -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Total Memory" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium">
                                <Run Text="{Binding SystemInfo.TotalRamGb, StringFormat={}{0:F1}, Mode=OneWay}"/><Run Text=" GB"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Uptime -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="16,0,0,12">
                            <TextBlock Text="System Uptime" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SystemInfo.UptimeFormatted}" FontSize="14" Foreground="{DynamicResource ForegroundBrightestBrush}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MonitorPerformanceTemplate">
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Performance Insights"
                                       Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="Live breakdown across CPU, memory, disks, network, and GPU."
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <ListBox ItemsSource="{Binding PerformanceItems}"
                             SelectedItem="{Binding SelectedPerformanceItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,12,0,16"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,10,10"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10"
                                        Padding="12"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource BackgroundLightBrush}"
                                        MinWidth="150">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrightCyanBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Opacity" Value="0.55"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding PerformanceChartTitle}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                            <TextBlock Text="{Binding SelectedPerformanceItem.Subtitle}"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,4,0,12"/>

                            <Grid Height="190" Margin="0,0,0,12">
                                <Border Background="{DynamicResource BackgroundDarkestBrush}"
                                        BorderBrush="{DynamicResource BackgroundLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"/>
                                <Canvas Margin="12">
                                    <Polyline Stroke="{DynamicResource AccentBrightCyanBrush}"
                                              StrokeThickness="2">
                                        <Polyline.Points>
                                            <MultiBinding Converter="{StaticResource SparklinePointsWithMaxConverter}">
                                                <Binding Path="PerformancePrimaryHistory"/>
                                                <Binding Path="PerformanceHistoryScaleMax"/>
                                            </MultiBinding>
                                        </Polyline.Points>
                                    </Polyline>

                                    <Polyline Stroke="{DynamicResource SuccessBrush}"
                                              StrokeThickness="2"
                                              Visibility="{Binding HasPerformanceSecondary, Converter={StaticResource BoolToVisibility}}">
                                        <Polyline.Points>
                                            <MultiBinding Converter="{StaticResource SparklinePointsWithMaxConverter}">
                                                <Binding Path="PerformanceSecondaryHistory"/>
                                                <Binding Path="PerformanceHistoryScaleMax"/>
                                            </MultiBinding>
                                        </Polyline.Points>
                                    </Polyline>
                                </Canvas>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding PerformancePrimaryLabel}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                                <TextBlock Text="{Binding PerformanceSecondaryLabel}"
                                           FontSize="11"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Margin="12,0,0,0"
                                           Visibility="{Binding HasPerformanceSecondary, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Details"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       Margin="0,0,0,10"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="300">
                                <ItemsControl ItemsSource="{Binding PerformanceDetailItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Hardware Cards Template - Only CPU, GPU, RAM, Disk -->
        <DataTemplate x:Key="MonitorStatCardsTemplate">
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                <!-- CPU Card -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,6,0" Cursor="Hand"
                        ToolTip="Click for detailed CPU information">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.OpenHardwareDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="cpu"/>
                    </Border.InputBindings>
                    <Grid DataContext="{Binding CpuCard}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Icon -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{Binding IconBackground}" CornerRadius="8" Padding="8" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji" FontSize="18"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            </StackPanel>
                            <Ellipse Grid.Column="2" Width="10" Height="10" Fill="{Binding StatusColor}" VerticalAlignment="Top"/>
                        </Grid>

                        <!-- Primary Value (Large) -->
                        <StackPanel Grid.Row="1" Margin="0,12,0,8" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PrimaryValue}" FontSize="42" FontWeight="Bold" Foreground="{Binding PrimaryValueColor}"/>
                                <TextBlock Text="{Binding PrimaryUnit}" FontSize="20" Foreground="{DynamicResource ForegroundLightBrush}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LiveSummary}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                       Visibility="{Binding LiveSummary, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Grid.Row="2" Height="1" Background="{DynamicResource BackgroundLightBrush}" Margin="0,4,0,8"/>

                        <!-- Secondary Metrics Grid -->
                        <ItemsControl Grid.Row="3" ItemsSource="{Binding SecondaryMetrics}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}">
                                            <Run Text="{Binding Value}"/><Run Text="{Binding Unit}" FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- GPU Card -->
                <Border Style="{StaticResource StatCardStyle}" Margin="3,0,3,0" Cursor="Hand"
                        ToolTip="Click for detailed GPU information">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.OpenHardwareDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="gpu"/>
                    </Border.InputBindings>
                    <Grid DataContext="{Binding GpuCard}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{Binding IconBackground}" CornerRadius="8" Padding="8" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji" FontSize="18"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            </StackPanel>
                            <Ellipse Grid.Column="2" Width="10" Height="10" Fill="{Binding StatusColor}" VerticalAlignment="Top"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,12,0,8" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PrimaryValue}" FontSize="42" FontWeight="Bold" Foreground="{Binding PrimaryValueColor}"/>
                                <TextBlock Text="{Binding PrimaryUnit}" FontSize="20" Foreground="{DynamicResource ForegroundLightBrush}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LiveSummary}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                       Visibility="{Binding LiveSummary, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        </StackPanel>

                        <Border Grid.Row="2" Height="1" Background="{DynamicResource BackgroundLightBrush}" Margin="0,4,0,8"/>

                        <ItemsControl Grid.Row="3" ItemsSource="{Binding SecondaryMetrics}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}">
                                            <Run Text="{Binding Value}"/><Run Text="{Binding Unit}" FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- RAM Card -->
                <Border Style="{StaticResource StatCardStyle}" Margin="3,0,3,0" Cursor="Hand"
                        ToolTip="Click for detailed RAM information">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.OpenHardwareDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="ram"/>
                    </Border.InputBindings>
                    <Grid DataContext="{Binding RamCard}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{Binding IconBackground}" CornerRadius="8" Padding="8" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji" FontSize="18"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            </StackPanel>
                            <Ellipse Grid.Column="2" Width="10" Height="10" Fill="{Binding StatusColor}" VerticalAlignment="Top"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,12,0,8" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PrimaryValue}" FontSize="42" FontWeight="Bold" Foreground="{Binding PrimaryValueColor}"/>
                                <TextBlock Text="{Binding PrimaryUnit}" FontSize="20" Foreground="{DynamicResource ForegroundLightBrush}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LiveSummary}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                       Visibility="{Binding LiveSummary, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        </StackPanel>

                        <Border Grid.Row="2" Height="1" Background="{DynamicResource BackgroundLightBrush}" Margin="0,4,0,8"/>

                        <ItemsControl Grid.Row="3" ItemsSource="{Binding SecondaryMetrics}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}">
                                            <Run Text="{Binding Value}"/><Run Text="{Binding Unit}" FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Disk Card -->
                <Border Style="{StaticResource StatCardStyle}" Margin="6,0,0,0" Cursor="Hand"
                        ToolTip="Click for detailed Storage information">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.OpenHardwareDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="disk"/>
                    </Border.InputBindings>
                    <Grid DataContext="{Binding DiskCard}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{Binding IconBackground}" CornerRadius="8" Padding="8" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji" FontSize="18"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrightestBrush}"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            </StackPanel>
                            <Ellipse Grid.Column="2" Width="10" Height="10" Fill="{Binding StatusColor}" VerticalAlignment="Top"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,12,0,8" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PrimaryValue}" FontSize="42" FontWeight="Bold" Foreground="{Binding PrimaryValueColor}"/>
                                <TextBlock Text="{Binding PrimaryUnit}" FontSize="20" Foreground="{DynamicResource ForegroundLightBrush}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LiveSummary}" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                       Visibility="{Binding LiveSummary, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        </StackPanel>

                        <Border Grid.Row="2" Height="1" Background="{DynamicResource BackgroundLightBrush}" Margin="0,4,0,8"/>

                        <ItemsControl Grid.Row="3" ItemsSource="{Binding SecondaryMetrics}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}">
                                            <Run Text="{Binding Value}"/><Run Text="{Binding Unit}" FontSize="10" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </UniformGrid>
        </DataTemplate>

        <DataTemplate x:Key="MonitorHistoryChartsTemplate">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU History Chart -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU History (60s)" Style="{StaticResource SectionHeaderStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="Peak: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding CpuHistoryMax, StringFormat={}{0:F0}%}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Low: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding CpuHistoryMin, StringFormat={}{0:F0}%}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="  Now: " Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}%}" Foreground="{DynamicResource AccentBrightCyanBrush}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        <Border Height="120" Background="{DynamicResource BackgroundDarkestBrush}" CornerRadius="8" Padding="10" ClipToBounds="True">
                            <Grid>
                                <!-- Y-Axis Labels -->
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="30" Margin="0,0,5,0">
                                    <TextBlock Text="{Binding CpuHistoryScaleMax, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding CpuHistoryScaleThreeQuarter, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Top" Margin="0,18,0,0"/>
                                    <TextBlock Text="{Binding CpuHistoryScaleMid, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding CpuHistoryScaleQuarter, StringFormat={}{0:F0}%}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="8" VerticalAlignment="Center" Margin="0,16,0,0"/>
                                    <TextBlock Text="0%" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9" VerticalAlignment="Bottom" Margin="0,8,0,0"/>
                                </StackPanel>
                                <!-- Chart Area with Gridlines -->
                                <Border Margin="30,0,0,0" ClipToBounds="True">
                                    <Grid>
                                        <!-- Horizontal Gridlines -->
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Top"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundLightBrush}" Opacity="0.35" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Center" StrokeDashArray="4,2"/>
                                        <Rectangle Height="1" Fill="{DynamicResource BackgroundLightBrush}" Opacity="0.35" VerticalAlignment="Bottom" Margin="0,0,0,25"/>
                                        <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="{DynamicResource BackgroundLightBrush}" StrokeThickness="1" Opacity="0.45" Stretch="Fill" VerticalAlignment="Bottom"/>
