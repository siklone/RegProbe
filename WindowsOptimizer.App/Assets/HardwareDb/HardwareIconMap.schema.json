{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HardwareIconMap",
  "description": "Schema for hardware icon mapping database",
  "type": "object",
  "required": ["version", "fallbacks", "mappings"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d{4}\\.\\d{2}\\.\\d{2}" },
    "description": { "type": "string" },
    "fallbacks": {
      "type": "object",
      "description": "Default icon for each hardware type when no match found",
      "additionalProperties": { "type": "string" }
    },
    "mappings": {
      "type": "object",
      "description": "Icon mapping rules per hardware type",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["match", "icon", "priority"],
          "properties": {
            "match": {
              "type": "string",
              "description": "Case-insensitive substring to match in hardware name"
            },
            "icon": {
              "type": "string",
              "description": "Icon key (filename without extension or path)"
            },
            "priority": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Higher priority checked first"
            }
          }
        }
      }
    }
  }
}
