<Window x:Class="WindowsOptimizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:WindowsOptimizer.App.Behaviors"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="Windows Optimizer Suite"
        Width="1280"
        Height="800"
        MinWidth="1000"
        MinHeight="600"
        Background="{DynamicResource BackgroundDarkestBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">

    <!-- Keyboard Shortcuts -->
    <Window.InputBindings>
        <!-- Navigation: Ctrl+1 to Ctrl+5 -->
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding NavigateToDashboardCommand}"/>
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding NavigateToTweaksCommand}"/>
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding NavigateToMonitorCommand}"/>
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding NavigateToSettingsCommand}"/>
        <KeyBinding Key="D5" Modifiers="Control" Command="{Binding NavigateToAboutCommand}"/>
        <!-- Search: Ctrl+F -->
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}"/>
        <!-- Clear filters: Escape -->
        <KeyBinding Key="Escape" Command="{Binding ClearFiltersCommand}"/>
    </Window.InputBindings>
    
    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Sidebar ListBox Style -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        </Style>
        
        <!-- Navigation Item Style with Icons and Glow -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <!-- Selection Indicator -->
                            <Border x:Name="SelectionIndicator"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="0,2,2,0"
                                    Background="Transparent"
                                    Margin="-8,4,0,4"/>
                            <!-- Main Border -->
                            <Border x:Name="Border"
                                    Background="Transparent"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundDarkBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundMediumBrush}" />
                                <Setter TargetName="SelectionIndicator" Property="Background" Value="{DynamicResource AccentBrightCyanBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}" />
                                <Setter Property="FontWeight" Value="Medium" />
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Main Layout Grid -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Enhanced Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource BackgroundDarkestBrush}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.3" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo/Header -->
                <Border Grid.Row="0" Padding="20,24,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="10" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="⚡" FontFamily="Segoe UI Emoji" FontSize="18"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimizer"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Suite"
                                           Foreground="{DynamicResource AccentBrightCyanBrush}"
                                           FontSize="12"
                                           Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Subtitle -->
                        <TextBlock Text="Windows Optimization Tool"
                                   Foreground="{DynamicResource BackgroundLightBrush}"
                                   FontSize="10"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Margin="0,8,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" 
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="16" 
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BackgroundDarkBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding AppVersionLabel}"
                                   Foreground="{DynamicResource BackgroundLightBrush}"
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AppCopyrightLabel}"
                                   Foreground="{DynamicResource BackgroundLightBrush}"
                                   FontSize="9"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundDarkestBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Crash Recovery Banner -->
                <Border Grid.Row="0"
                        Background="#BF616A"
                        Padding="16,12"
                        Visibility="{Binding HasPendingRollbacks, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Warning Icon -->
                        <TextBlock Grid.Column="0"
                                   Text="⚠️"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <!-- Message -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Crash Recovery Required"
                                       Foreground="#ECEFF4"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding PendingRollbackMessage}"
                                       Foreground="#FFE5E5"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Recover Button -->
                            <Button Command="{Binding RecoverPendingRollbacksCommand}"
                                    Background="#A3BE8C"
                                    Foreground="#2E3440"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"
                                    ToolTip="Roll back all pending tweaks to restore previous state">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#8FAE7B"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Recover" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <!-- Dismiss Button -->
                            <Button Command="{Binding DismissPendingRollbacksCommand}"
                                    Background="Transparent"
                                    Foreground="#ECEFF4"
                                    Padding="12,6"
                                    Cursor="Hand"
                                    ToolTip="Dismiss this warning without rolling back (tweaks will remain applied)">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="#ECEFF4"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#FFFFFF"/>
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.1"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Dismiss" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Recovery Progress Indicator -->
                <Border Grid.Row="0"
                        Background="#5E81AC"
                        Padding="16,12"
                        Visibility="{Binding IsRecovering, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🔄"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="Recovering pending rollbacks..."
                                   Foreground="#ECEFF4"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Content with Page Transitions -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}">
                    <i:Interaction.Behaviors>
                        <behaviors:NavigationTransitionBehavior Transition="FadeAndSlide" />
                    </i:Interaction.Behaviors>
                </ContentControl>
            </Grid>
        </Border>
        </Grid>

        <!-- System Tray Icon (outside layout Grid to avoid rendering in window) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Windows Optimizer Suite"
                        Visibility="Visible"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">

            <tb:TaskbarIcon.TrayToolTip>
                <Border Background="#2E3440"
                        BorderBrush="#4C566A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⚡" FontFamily="Segoe UI Emoji" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Windows Optimizer Suite"
                                       Foreground="#ECEFF4"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                        </StackPanel>
                        <Border Background="#3B4252" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="Health Score" Foreground="#88C0D0" FontSize="10" Margin="0,0,0,2"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding OptimizationScore, StringFormat={}{0}%}"
                                               Foreground="#A3BE8C"
                                               FontSize="20"
                                               FontWeight="Bold"/>
                                    <TextBlock Text=" optimized"
                                               Foreground="#D8DEE9"
                                               FontSize="11"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,3"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontFamily="Segoe UI Emoji" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Foreground="#D8DEE9" FontSize="11">
                                <Run Text="{Binding TweaksApplied, Mode=OneWay}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding TotalTweaksAvailable, Mode=OneWay}"/>
                                <Run Text=" tweaks applied"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </tb:TaskbarIcon.TrayToolTip>

            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu HasDropShadow="True">
                    <ContextMenu.Template>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="#2E3440"
                                    BorderBrush="#4C566A"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="4">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True"/>
                            </Border>
                        </ControlTemplate>
                    </ContextMenu.Template>
                    <ContextMenu.Resources>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#D8DEE9"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="12,8"
                                                Margin="0,1"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter ContentSource="Header"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center"
                                                              RecognizesAccessKey="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3B4252"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3B4252"/>
                                                <Setter Property="Foreground" Value="#ECEFF4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="Separator">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Separator">
                                        <Border Background="#4C566A"
                                                Height="1"
                                                Margin="8,4"
                                                SnapsToDevicePixels="True"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ContextMenu.Resources>
                    <MenuItem Header="📊  Dashboard" Click="MenuItem_Dashboard_Click"/>
                    <MenuItem Header="⚙️  Tweaks" Click="MenuItem_Tweaks_Click"/>
                    <MenuItem Header="📈  Monitor" Click="MenuItem_Monitor_Click"/>
                    <Separator/>
                    <MenuItem Header="🔍  Scan Now" Click="MenuItem_ScanNow_Click"/>
                    <Separator/>
                    <MenuItem Header="👁️  Show Window" Click="MenuItem_Show_Click" FontWeight="SemiBold"/>
                    <MenuItem Header="❌  Exit" Click="MenuItem_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
