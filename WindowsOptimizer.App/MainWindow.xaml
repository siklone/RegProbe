<Window x:Class="WindowsOptimizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:WindowsOptimizer.App.Behaviors"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:controls="clr-namespace:WindowsOptimizer.App.Views.Controls"
        xmlns:views="clr-namespace:WindowsOptimizer.App.Views"
        mc:Ignorable="d"
        Title="Windows Optimizer Suite"
        Width="1280"
        Height="800"
        MinWidth="1000"
        MinHeight="600"
        Background="{DynamicResource BackgroundDarkestBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, sans-serif"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- WindowChrome for resize borders -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>


    <!-- Keyboard Shortcuts -->
    <Window.InputBindings>
        <!-- Navigation: Ctrl+1 to Ctrl+7 -->
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding NavigateToDashboardCommand}"/>
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding NavigateToTweaksCommand}"/>
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding NavigateToBloatwareCommand}"/>
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding NavigateToStartupCommand}"/>
        <KeyBinding Key="D5" Modifiers="Control" Command="{Binding NavigateToMonitorCommand}"/>
        <KeyBinding Key="D6" Modifiers="Control" Command="{Binding NavigateToSettingsCommand}"/>
        <KeyBinding Key="D7" Modifiers="Control" Command="{Binding NavigateToAboutCommand}"/>
        <!-- Search: Ctrl+F -->
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}"/>
        <!-- Clear filters: Escape -->
        <KeyBinding Key="Escape" Command="{Binding ClearFiltersCommand}"/>
    </Window.InputBindings>
    
    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Sidebar ListBox Style -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        </Style>
        
        <!-- Navigation Item Style with MDL2 Icons -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Grid>
                                <!-- Selection Indicator Bar -->
                                <Border x:Name="SelectionIndicator"
                                        Width="3"
                                        HorizontalAlignment="Left"
                                        CornerRadius="0,2,2,0"
                                        Background="Transparent"
                                        Margin="-8,6,0,6"/>
                                <!-- Main Border -->
                                <Border x:Name="Border"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        BorderBrush="Transparent"
                                        Padding="12,9">
                                    <ContentPresenter />
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundDarkBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundMediumBrush}" />
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource GlowCyanBorderBrush}" />
                                    <Setter TargetName="SelectionIndicator" Property="Background" Value="{DynamicResource AccentBrightCyanBrush}" />
                                    <Setter TargetName="SelectionIndicator" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="{StaticResource Nord8}" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" 
                Panel.ZIndex="100"
                Background="{DynamicResource BackgroundDarkBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Title and Icon (Draggable area) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                            MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                               Foreground="{DynamicResource AccentBrightCyanBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Windows Optimizer Suite" 
                               Foreground="{DynamicResource ForegroundLightBrush}"
                               FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Window Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Minimize -->
                    <Button x:Name="MinimizeButton" Click="MinimizeButton_Click"
                            Width="46" Height="48" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Minimize"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}">
                                                <Path Data="M 0,5 H 10" 
                                                      Stroke="{DynamicResource ForegroundLightBrush}" 
                                                      StrokeThickness="1"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- Maximize/Restore -->
                    <Button x:Name="MaximizeButton" Click="MaximizeButton_Click"
                            Width="46" Height="48"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Maximize"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}">
                                                <Path x:Name="MaxIcon" 
                                                      Data="M 0,0 H 10 V 10 H 0 Z" 
                                                      Stroke="{DynamicResource ForegroundLightBrush}" 
                                                      StrokeThickness="1" Fill="Transparent"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- Close -->
                    <Button x:Name="CloseButton" Click="CloseButton_Click"
                            Width="46" Height="48"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Close"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}">
                                                <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" 
                                                      Stroke="{DynamicResource ForegroundLightBrush}" 
                                                      StrokeThickness="1"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Layout Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Enhanced Sidebar (Glass Effect) -->
             <Border Grid.Column="0" 
                 Background="{DynamicResource BackgroundDarkBrush}"
                 BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo/Header -->
                <Border Grid.Row="0" Padding="20,24,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource AccentDarkBlueBrush}" CornerRadius="10" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimizer"
                                           Foreground="{DynamicResource ForegroundBrightestBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Suite"
                                           Foreground="{DynamicResource AccentBrightCyanBrush}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Subtitle -->
                        <TextBlock Text="Windows Optimization Tool"
                                   Foreground="{DynamicResource BackgroundLightBrush}"
                                   FontSize="10"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Margin="0,8,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" 
                                           Text="{Binding IconGlyph}" 
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" 
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0.85"/>
                                           
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding Title}" 
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Margin="10,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BackgroundDarkBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding AppVersionLabel}"
                                   Foreground="{DynamicResource BackgroundLightBrush}"
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AppCopyrightLabel}"
                                   Foreground="{DynamicResource BackgroundLightBrush}"
                                   FontSize="9"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundDarkestBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Crash Recovery Banner -->
                <Border Grid.Row="0"
                        Background="{DynamicResource DangerBrush}"
                        Padding="16,12"
                        Visibility="{Binding HasPendingRollbacks, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Warning Icon -->
                        <TextBlock Grid.Column="0"
                                   Text="&#xE7BA;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                   Margin="0,0,12,0"/>

                        <!-- Message -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Crash Recovery Required"
                                       Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding PendingRollbackMessage}"
                                       Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Recover Button -->
                            <Button Command="{Binding RecoverPendingRollbacksCommand}"
                                    Background="{DynamicResource SuccessBrush}"
                                    Foreground="{DynamicResource ForegroundOnLightAccentBrush}"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"
                                    ToolTip="Roll back all pending tweaks to restore previous state">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Recover" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <!-- Dismiss Button -->
                            <Button Command="{Binding DismissPendingRollbacksCommand}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                    Padding="12,6"
                                    Cursor="Hand"
                                    ToolTip="Dismiss this warning without rolling back (tweaks will remain applied)">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{DynamicResource ForegroundOnAccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Dismiss" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Recovery Progress Indicator -->
                <Border Grid.Row="0"
                        Background="{DynamicResource AccentDarkBlueBrush}"
                        Padding="16,12"
                        Visibility="{Binding IsRecovering, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="Recovering pending rollbacks..."
                                   Foreground="{DynamicResource ForegroundOnAccentBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Content with Page Transitions -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}">
                    <i:Interaction.Behaviors>
                        <behaviors:NavigationTransitionBehavior Transition="FadeAndSlide" />
                    </i:Interaction.Behaviors>
                </ContentControl>
            </Grid>
        </Border>
        </Grid>

        <!-- Startup Scan Overlay -->
        <Grid Panel.ZIndex="100"
              IsHitTestVisible="False"
              Visibility="{Binding IsStartupScanActive, Converter={StaticResource BoolToVisibility}}">
            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="240"
                    Margin="0,0,24,24"
                    Padding="16,14"
                    Background="{DynamicResource BackgroundDarkestBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Opacity="0.96">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ShadowColorMedium}"
                                      BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.28"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Background scan"
                               Foreground="{DynamicResource ForegroundBrightestBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <ProgressBar Height="4"
                                 Margin="0,10,0,0"
                                 IsIndeterminate="True"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- System Tray Icon (outside layout Grid to avoid rendering in window) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Windows Optimizer Suite"
                        Visibility="Visible"
                        PopupActivation="LeftClick"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">

            <tb:TaskbarIcon.TrayPopup>
                <views:TrayPopupView DataContext="{Binding TrayViewModel, Mode=OneWay}"/>
            </tb:TaskbarIcon.TrayPopup>

            <tb:TaskbarIcon.TrayToolTip>
                <Border Background="{DynamicResource BackgroundDarkestBrush}"
                        BorderBrush="{DynamicResource BackgroundLightBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColorMedium}" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel DataContext="{Binding TrayViewModel}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrightCyanBrush}"/>
                            <TextBlock Text="Windows Optimizer Suite"
                                       Foreground="{DynamicResource ForegroundBrightestBrush}"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                        </StackPanel>
                        
                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="4" Padding="8">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right">
                                        <Run Text="{Binding CpuUsage, StringFormat={}{0:F0}%}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding CpuTemp}" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    </TextBlock>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="RAM" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentPurpleBrush}" HorizontalAlignment="Right">
                                        <Run Text="{Binding RamUsagePercent, StringFormat={}{0:F0}%}"/>
                                    </TextBlock>
                                </Grid>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="GPU" FontSize="11" Foreground="{DynamicResource ForegroundLightBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GpuTemp}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrightestBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </tb:TaskbarIcon.TrayToolTip>

            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu HasDropShadow="True">
                    <ContextMenu.Template>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{DynamicResource BackgroundDarkestBrush}"
                                    BorderBrush="{DynamicResource BackgroundLightBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="4">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource ShadowColorMedium}" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True"/>
                            </Border>
                        </ControlTemplate>
                    </ContextMenu.Template>
                    <ContextMenu.Resources>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource ForegroundLightBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="12,8"
                                                Margin="0,1"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter ContentSource="Header"
                                                              HorizontalAlignment="Left"
                                                              VerticalAlignment="Center"
                                                              RecognizesAccessKey="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrightestBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="Separator">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Separator">
                                        <Border Background="{DynamicResource BackgroundLightBrush}"
                                                Height="1"
                                                Margin="8,4"
                                                SnapsToDevicePixels="True"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ContextMenu.Resources>
                    <MenuItem Header="Dashboard" Click="MenuItem_Dashboard_Click"/>
                    <MenuItem Header="Configuration" Click="MenuItem_Tweaks_Click"/>
                    <MenuItem Header="Monitor" Click="MenuItem_Monitor_Click"/>
                    <Separator/>
                    <MenuItem Header="Show Window" Click="MenuItem_Show_Click" FontWeight="SemiBold"/>
                    <MenuItem Header="Exit" Click="MenuItem_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Toast Notifications Overlay -->
        <controls:NotificationHost x:Name="NotificationHost"
                                   Panel.ZIndex="200"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   IsHitTestVisible="True"/>

        <!-- Busy Indicator Overlay -->
        <controls:LoadingOverlay DataContext="{Binding BusyService}" 
                                Panel.ZIndex="300"
                                d:IsHidden="True"/>
    </Grid>
</Window>
