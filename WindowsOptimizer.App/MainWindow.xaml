<Window x:Class="WindowsOptimizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:WindowsOptimizer.App.Behaviors"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="Windows Optimizer Suite"
        Width="1280"
        Height="800"
        MinWidth="1000"
        MinHeight="600"
        Background="#2E3440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">
    
    <Window.Resources>
        <!-- Sidebar ListBox Style -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        </Style>
        
        <!-- Navigation Item Style with Icons and Glow -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#D8DEE9" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <!-- Selection Indicator -->
                            <Border x:Name="SelectionIndicator"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="0,2,2,0"
                                    Background="Transparent"
                                    Margin="-8,4,0,4"/>
                            <!-- Main Border -->
                            <Border x:Name="Border" 
                                    Background="Transparent" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3B4252" />
                                <Setter Property="Foreground" Value="#ECEFF4" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#434C5E" />
                                <Setter TargetName="SelectionIndicator" Property="Background" Value="#88C0D0" />
                                <Setter Property="Foreground" Value="#ECEFF4" />
                                <Setter Property="FontWeight" Value="Medium" />
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.02" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                       To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Enhanced Sidebar -->
        <Border Grid.Column="0" Background="#2E3440">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.3" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo/Header -->
                <Border Grid.Row="0" Padding="20,24,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#5E81AC" CornerRadius="10" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="⚡" FontFamily="Segoe UI Emoji" FontSize="18"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Optimizer" 
                                           Foreground="#ECEFF4" 
                                           FontSize="18" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="Suite" 
                                           Foreground="#88C0D0" 
                                           FontSize="12" 
                                           Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Subtitle -->
                        <TextBlock Text="Windows Optimization Tool" 
                                   Foreground="#4C566A" 
                                   FontSize="10" 
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Margin="0,8,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" 
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="16" 
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="20,16" BorderThickness="0,1,0,0" BorderBrush="#3B4252">
                    <StackPanel>
                        <TextBlock Text="{Binding AppVersionLabel}" 
                                   Foreground="#4C566A" 
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AppCopyrightLabel}" 
                                   Foreground="#4C566A" 
                                   FontSize="9"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="#2E3440">
            <!-- Content with Page Transitions -->
            <ContentControl Content="{Binding CurrentViewModel}">
                <i:Interaction.Behaviors>
                    <behaviors:NavigationTransitionBehavior Transition="FadeAndSlide" />
                </i:Interaction.Behaviors>
            </ContentControl>
        </Border>

        <!-- System Tray Icon (placed here to avoid property element ordering issues) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Windows Optimizer Suite"
                        Visibility="Visible"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">

            <tb:TaskbarIcon.TrayToolTip>
                <Border Background="#2E3440"
                        BorderBrush="#4C566A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⚡" FontFamily="Segoe UI Emoji" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Windows Optimizer Suite"
                                       Foreground="#ECEFF4"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                        </StackPanel>
                        <Border Background="#3B4252" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="Health Score" Foreground="#88C0D0" FontSize="10" Margin="0,0,0,2"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding OptimizationScore, StringFormat={}{0}%}"
                                               Foreground="#A3BE8C"
                                               FontSize="20"
                                               FontWeight="Bold"/>
                                    <TextBlock Text=" optimized"
                                               Foreground="#D8DEE9"
                                               FontSize="11"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,3"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontFamily="Segoe UI Emoji" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Foreground="#D8DEE9" FontSize="11">
                                <Run Text="{Binding TweaksApplied, Mode=OneWay}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding TotalTweaksAvailable, Mode=OneWay}"/>
                                <Run Text=" tweaks applied"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </tb:TaskbarIcon.TrayToolTip>

            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Background="#2E3440" BorderBrush="#4C566A" Foreground="#ECEFF4">
                    <ContextMenu.Resources>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#D8DEE9"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3B4252"/>
                                    <Setter Property="Foreground" Value="#ECEFF4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="Separator">
                            <Setter Property="Background" Value="#4C566A"/>
                            <Setter Property="Margin" Value="4,2"/>
                        </Style>
                    </ContextMenu.Resources>
                    <MenuItem Header="📊  Dashboard" Click="MenuItem_Dashboard_Click"/>
                    <MenuItem Header="⚙️  Tweaks" Click="MenuItem_Tweaks_Click"/>
                    <MenuItem Header="📈  Monitor" Click="MenuItem_Monitor_Click"/>
                    <Separator/>
                    <MenuItem Header="🔍  Scan Now" Click="MenuItem_ScanNow_Click"/>
                    <Separator/>
                    <MenuItem Header="👁️  Show Window" Click="MenuItem_Show_Click" FontWeight="SemiBold"/>
                    <MenuItem Header="❌  Exit" Click="MenuItem_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
