<Application x:Class="WindowsOptimizer.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:WindowsOptimizer.App.Views"
             xmlns:viewModels="clr-namespace:WindowsOptimizer.App.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Core Design System -->
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Typography.xaml"/>
                <ResourceDictionary Source="Resources/Spacing.xaml"/>
                <ResourceDictionary Source="Resources/Icons.xaml"/>
                
                <!-- Theme Resources -->
                <ResourceDictionary Source="Resources/Animations.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
                <ResourceDictionary Source="Resources/ModernStyles.xaml"/>
                <ResourceDictionary Source="Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type Window}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamilyText}" />
            </Style>

            <Style TargetType="{x:Type UserControl}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamilyText}" />
            </Style>

            <!-- View-ViewModel Mapping -->
            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:TweaksViewModel}">
                <views:TweaksView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:AboutViewModel}">
                <views:AboutView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:StartupViewModel}">
                <views:StartupView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModels:BloatwareViewModel}">
                <views:BloatwareView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
