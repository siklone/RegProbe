{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regprobe.local/registry-research-framework/schemas/static-evidence.schema.json",
  "title": "v3.2 Static Evidence",
  "type": "object",
  "required": ["static"],
  "properties": {
    "$schema": { "type": "string" },
    "static": {
      "type": "object",
