        "bingrep": { "type": "object" },
        "floss": { "type": "object" },
        "capa": { "type": "object" },
        "ghidra": { "type": "object" },
        "ida": { "type": "object" },
        "cross_verification": { "type": "object" },
        "doc_source": { "type": "object" }
      }
    },
    "source_evidence_ids": { "type": "array", "items": { "type": "string" } }
  }
}
