<Window x:Class="OpenTraceProject.App.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Open Trace Project"
        Width="420"
        Height="180"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Background="#FF111418"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FF111418">
        <Border Width="360"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FF171C22"
                BorderBrush="#FF2C343D"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Text="Open Trace Project"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="{DynamicResource FontFamilyDisplay}"
                           Foreground="#FFF2F4F7"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <TextBlock x:Name="VersionText"
                           Margin="0,6,0,0"
                           FontSize="11"
                           FontFamily="{DynamicResource FontFamilyMono}"
                           Foreground="#FF9CA6B3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="v0.1.0"/>

                <TextBlock Margin="0,18,0,0"
                           Text="Starting up"
                           FontSize="12"
                           Foreground="#FF9CA6B3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <ProgressBar x:Name="LoadProgress"
                             Margin="0,14,0,0"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>

                <TextBlock x:Name="LoadLabel"
                           Margin="0,12,0,0"
                           FontSize="11"
                           FontFamily="{DynamicResource FontFamilyMono}"
                           Foreground="#FFB9C1CA"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="Initializing..."/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
