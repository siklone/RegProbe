<Window x:Class="OpenTraceProject.App.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Open Trace Project"
        Width="460"
        Height="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Background="#FF101317"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FF101317">
        <Border Width="392"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FF171B20"
                BorderBrush="#FF2B3138"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Text="Open Trace Project"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="{DynamicResource FontFamilyDisplay}"
                           Foreground="#FFF2F4F7"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <TextBlock x:Name="VersionText"
                           Margin="0,8,0,0"
                           FontSize="10"
                           FontFamily="{DynamicResource FontFamilyMono}"
                           Foreground="#FFD0D6DD"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="0.1.0"/>

                <TextBlock x:Name="LoadLabel"
                           Margin="0,18,0,0"
                           FontSize="12"
                           Foreground="#FF9CA6B3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="Loading research data and services"/>

                <ProgressBar x:Name="LoadProgress"
                             Margin="0,18,0,0"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
