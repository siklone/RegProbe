    "file_system": {
      "name": "File System",
      "description": "NTFS and file system behavior settings",
      "risk_level": "low",
      "requires_reboot": true,
      "entries": [
        {
          "id": "ntfs_disable_8dot3",
          "name": "Disable 8.3 Name Creation",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\FileSystem",
          "value_name": "NtfsDisable8dot3NameCreation",
          "type": "REG_DWORD",
          "default_value": 0,
          "options": {
            "0": "Enable 8.3 for all volumes",
            "1": "Disable 8.3 for all volumes",
            "2": "Per volume setting",
            "3": "Disable except system volume"
          },
          "description": "Controls creation of short 8.3 filenames. Disabling improves performance.",
          "documentation": "https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/fsutil-8dot3name",
          "verified": true,
          "safe": true
        },
        {
          "id": "ntfs_disable_last_access_update",
          "name": "Disable Last Access Update",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\FileSystem",
          "value_name": "NtfsDisableLastAccessUpdate",
          "type": "REG_DWORD",
          "default_value": 1,
          "description": "Controls last access time updates on NTFS files. Disabling reduces disk I/O.",
          "documentation": "https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/fsutil-behavior",
          "verified": true,
          "safe": true
        },
        {
          "id": "long_paths_enabled",
          "name": "Long Paths Enabled",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\FileSystem",
          "value_name": "LongPathsEnabled",
          "type": "REG_DWORD",
          "default_value": 0,
          "description": "Enables Win32 long paths (up to 32k characters) for apps that opt in.",
          "verified": true,
          "safe": true
        },
        {
          "id": "ntfs_memory_usage",
          "name": "NTFS Memory Usage",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\FileSystem",
          "value_name": "NtfsMemoryUsage",
          "type": "REG_DWORD",
          "default_value": 0,
          "description": "Configures internal cache levels of NTFS paged-pool and nonpaged-pool memory.",
          "verified": true,
          "safe": true
        },
        {
          "id": "ntfs_mft_zone_reservation",
          "name": "NTFS MFT Zone Reservation",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\FileSystem",
          "value_name": "NtfsMftZoneReservation",
          "type": "REG_DWORD",
          "default_value": 1,
          "valid_range": "1-4",
          "description": "Reserved MFT zone size as 200MB x value. Larger values reduce MFT fragmentation.",
          "verified": true,
          "safe": true
        }
      ]
    },
