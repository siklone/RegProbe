  "categories": {
    "service_splitting": {
      "name": "Service Host Splitting",
      "description": "Controls how services running under svchost.exe are grouped or split into separate processes",
      "risk_level": "low",
      "requires_reboot": true,
      "entries": [
        {
          "id": "svchost_split_threshold",
          "name": "SvcHost Split Threshold",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control",
          "value_name": "SvcHostSplitThresholdInKB",
          "type": "REG_DWORD",
          "default_value": 380000,
          "recommended_value": 4294967295,
          "description": "Controls the RAM threshold above which services are split into separate svchost.exe processes. Setting to max DWORD (4294967295) disables splitting.",
          "documentation": "https://learn.microsoft.com/en-us/windows/application-management/svchost-service-refactoring",
          "verified": true,
          "safe": true
        }
      ]
    },
    "kernel_scheduler": {
      "name": "Kernel Scheduler Settings",
      "description": "Controls CPU scheduling, DPC handling, and thread priority settings",
      "risk_level": "medium",
      "requires_reboot": true,
      "entries": [
        {
          "id": "adjust_dpc_threshold",
          "name": "Adjust DPC Threshold",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "AdjustDpcThreshold",
          "type": "REG_DWORD",
          "default_value": 20,
          "description": "Kernel variable KiAdjustDpcThreshold - controls DPC threshold adjustment",
          "verified": true,
          "safe": true
        },
        {
          "id": "ideal_dpc_rate",
          "name": "Ideal DPC Rate",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "IdealDpcRate",
          "type": "REG_DWORD",
          "default_value": 20,
          "description": "Kernel variable KiIdealDpcRate - target DPC rate per second",
          "verified": true,
          "safe": true
        },
        {
          "id": "minimum_dpc_rate",
          "name": "Minimum DPC Rate",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "MinimumDpcRate",
          "type": "REG_DWORD",
          "default_value": 3,
          "description": "Kernel variable KiMinimumDpcRate - minimum DPC rate threshold",
          "verified": true,
          "safe": true
        },
        {
          "id": "dpc_queue_depth",
          "name": "DPC Queue Depth",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "DpcQueueDepth",
          "type": "REG_DWORD",
          "default_value": 4,
          "description": "Kernel variable KiMaximumDpcQueueDepth - maximum depth of DPC queue",
          "verified": true,
          "safe": true
        },
        {
          "id": "dpc_watchdog_period",
          "name": "DPC Watchdog Period",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "DpcWatchdogPeriod",
          "type": "REG_DWORD",
          "default_value": 120000,
          "description": "Kernel variable KeDpcWatchdogPeriodMs - DPC watchdog timeout in milliseconds",
          "verified": true,
          "safe": true
        },
        {
          "id": "serialize_timer_expiration",
          "name": "Serialize Timer Expiration",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "SerializeTimerExpiration",
          "type": "REG_DWORD",
          "default_value": 1,
          "description": "Controls timer serialization. 0=kernel decides based on Modern Standby, 1=enabled, 2+=disabled for timer distribution among processors",
          "verified": true,
          "safe": true
        },
        {
          "id": "thread_dpc_enable",
          "name": "Thread DPC Enable",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "ThreadDpcEnable",
          "type": "REG_DWORD",
          "default_value": 1,
          "description": "Kernel variable KeThreadDpcEnable - enables/disables threaded DPCs",
          "verified": true,
          "safe": true
        },
        {
          "id": "disable_low_qos_timer_resolution",
          "name": "Disable Low QoS Timer Resolution",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Kernel",
          "value_name": "DisableLowQosTimerResolution",
          "type": "REG_DWORD",
          "default_value": 1,
          "description": "Kernel variable KeDisableLowQosTimerResolution",
          "verified": true,
          "safe": true
        }
      ]
    },
    "priority_control": {
      "name": "Priority Control",
      "description": "Controls CPU scheduling priorities between foreground and background processes",
      "risk_level": "medium",
      "requires_reboot": false,
      "entries": [
        {
          "id": "win32_priority_separation",
          "name": "Win32 Priority Separation",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\PriorityControl",
          "value_name": "Win32PrioritySeparation",
          "type": "REG_DWORD",
          "default_value": 38,
          "options": {
            "24": "Long, Fixed, no boost (0x18)",
            "36": "Short, Variable, no boost (0x24)",
            "38": "Short, Variable, 3:1 foreground boost (0x26) - Windows default",
            "40": "Short, Fixed, no boost (0x28)"
          },
          "description": "Controls quantum length, variability, and foreground priority boost. 6-bit bitmask controlling CPU scheduling behavior.",
          "documentation": "Windows Internals 7th Edition",
          "verified": true,
          "safe": true
        }
      ]
    },
    "mmcss": {
      "name": "Multimedia Class Scheduler Service",
      "description": "Controls CPU resource allocation for multimedia applications",
      "risk_level": "low",
      "requires_reboot": false,
      "entries": [
        {
          "id": "system_responsiveness",
          "name": "System Responsiveness",
          "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Multimedia\\SystemProfile",
          "value_name": "SystemResponsiveness",
          "type": "REG_DWORD",
          "default_value": 20,
          "valid_range": "10-100 (rounded to nearest 10, 100 disables MMCSS)",
          "description": "Percentage of CPU guaranteed to low-priority tasks. Lower values = more CPU for multimedia. 100 disables MMCSS entirely.",
          "documentation": "https://learn.microsoft.com/en-us/windows/win32/procthread/multimedia-class-scheduler-service",
          "verified": true,
          "safe": true
        },
        {
          "id": "network_throttling_index",
          "name": "Network Throttling Index",
          "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Multimedia\\SystemProfile",
          "value_name": "NetworkThrottlingIndex",
          "type": "REG_DWORD",
          "default_value": 10,
          "valid_range": "1-70, 0xFFFFFFFF disables",
          "description": "Limits network packet processing. Values 1-70 valid, 0xFFFFFFFF disables throttling completely.",
          "verified": true,
          "safe": true
        },
        {
          "id": "no_lazy_mode",
          "name": "No Lazy Mode",
          "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Multimedia\\SystemProfile",
          "value_name": "NoLazyMode",
          "type": "REG_DWORD",
          "default_value": 0,
          "description": "Disables idle detection for MMCSS. May be more resource intensive but operates in more realtime mode.",
          "verified": true,
          "safe": true
        },
        {
          "id": "lazy_mode_timeout",
          "name": "Lazy Mode Timeout",
          "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Multimedia\\SystemProfile",
          "value_name": "LazyModeTimeout",
          "type": "REG_DWORD",
          "default_value": 1000000,
          "description": "100 nanosecond interval for lazy mode timeout. Default 1000000 = 100ms.",
          "verified": true,
          "safe": true
        },
        {
          "id": "scheduler_timer_resolution",
          "name": "Scheduler Timer Resolution",
          "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Multimedia\\SystemProfile",
          "value_name": "SchedulerTimerResolution",
          "type": "REG_DWORD",
          "default_value": 10000,
          "description": "Timer resolution in 100ns units. Values >10000 clamped to 10000.",
          "verified": true,
          "safe": true
        },
        {
          "id": "scheduler_period",
          "name": "Scheduler Period",
          "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Multimedia\\SystemProfile",
          "value_name": "SchedulerPeriod",
          "type": "REG_DWORD",
          "default_value": 100000,
          "valid_range": "50000-1000000",
          "description": "Scheduler period in 100ns units. Valid range 50000-1000000, defaults to 100000 if invalid.",
          "verified": true,
          "safe": true
        }
      ]
    },
    "graphics_drivers": {
      "name": "Graphics Drivers (DXG Kernel)",
      "description": "DirectX/WDDM graphics kernel driver settings",
      "risk_level": "medium",
      "requires_reboot": true,
      "entries": [
        {
          "id": "hw_sch_mode",
          "name": "Hardware Accelerated GPU Scheduling",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers",
          "value_name": "HwSchMode",
          "type": "REG_DWORD",
          "default_value": 1,
          "options": {
            "1": "Disabled",
            "2": "Enabled"
          },
          "description": "Enables Hardware Accelerated GPU Scheduling (HAGS). GPU handles its own scheduling instead of CPU.",
          "verified": true,
          "safe": true
        },
        {
          "id": "tdr_delay",
          "name": "TDR Delay",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers",
          "value_name": "TdrDelay",
          "type": "REG_DWORD",
          "default_value": 2,
          "description": "Timeout Detection and Recovery delay in seconds before GPU reset.",
          "verified": true,
          "safe": true
        },
        {
          "id": "tdr_ddi_delay",
          "name": "TDR DDI Delay",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers",
          "value_name": "TdrDdiDelay",
          "type": "REG_DWORD",
          "default_value": 5,
          "description": "TDR delay for DDI operations in seconds.",
          "verified": true,
          "safe": true
        },
        {
          "id": "tdr_level",
          "name": "TDR Level",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers",
          "value_name": "TdrLevel",
          "type": "REG_DWORD",
          "default_value": 3,
          "description": "TDR behavior level.",
          "verified": true,
          "safe": true
        },
        {
          "id": "tdr_limit_count",
          "name": "TDR Limit Count",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers",
          "value_name": "TdrLimitCount",
          "type": "REG_DWORD",
          "default_value": 5,
          "description": "Number of TDR events before system action.",
          "verified": true,
          "safe": true
        },
        {
          "id": "tdr_limit_time",
          "name": "TDR Limit Time",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers",
          "value_name": "TdrLimitTime",
          "type": "REG_DWORD",
          "default_value": 60,
          "description": "Time window in seconds for TDR limit count.",
          "verified": true,
          "safe": true
        },
        {
          "id": "disable_overlays",
          "name": "Disable Overlays",
          "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\GraphicsDrivers",
          "value_name": "DisableOverlays",
          "type": "REG_DWORD",
          "default_value": 0,
          "description": "Disables overlay planes.",
          "verified": true,
          "safe": true
        }
      ]
    },
